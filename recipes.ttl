<http://example.org/recipes/bebida/13> a schema1:Recipe ;
    schema1:description "El canelazo es una bebida ecuatoriana tradicional de la Sierra, se prepara mezclando agua con canela, azúcar y aguardiente. Es ideal para las noches frías o cuando llueve."@es ;
    schema1:name "Canelazo"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 taza de azúcar o panela rallada"@es,
        "6 tazas de agua"@es,
        "8 palitos de canela"@es,
        "¼ taza de aguardiente"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/13/step/5247919197b34b1fbd57d4675b587e42>,
        <http://example.org/recipes/bebida/13/step/974b9c4ccb3c403bad32b7e4a4009e21>,
        <http://example.org/recipes/bebida/13/step/e93d45e9f7874e2aa0c806b29be7fe3b> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/14> a schema1:Recipe ;
    schema1:description "El capuchino es muy consumido en el Ecuador principalmente por personas que trabajan en oficinas."@es ;
    schema1:name "Capuchino"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "2 tazas de leche"@es,
        "Azúcar al gusto"@es,
        "Canela en polvo o cacao en polvo para decorar"@es,
        "½ taza de café expreso negro o café descafeinado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/14/step/1fed9f084b5742dcba1483ef51ddb1fa>,
        <http://example.org/recipes/bebida/14/step/3756fa7c692e4fa293a0738bed1f7de3>,
