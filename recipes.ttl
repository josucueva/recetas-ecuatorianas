    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/108> a schema1:Recipe ;
    schema1:description "Exquisitos tallarines preparados con una jugosa carne y salsa a base de tomate y vegetales."@es ;
