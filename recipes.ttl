    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/23> a schema1:Recipe ;
    schema1:description "El dulce de zapallo, también conocido como zapallo con miel de panela, es un postre tradicional ecuatoriano preparado con zapallo (calabaza o auyama), panela o piloncillo y especias. Este delicioso postre usa ingredientes sencillos y es muy fácil de preparar. Se sirve acompañado con un trozo de quesillo o queso."@es ;
    schema1:name "Dulce de Zapallo"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 zapallo de casi 1 kilo"@es,
        "3 granos de pimienta dulce"@es,
        "3 tazas de agua"@es,
        "5 clavos de olor"@es,
        "5 rajas de canela"@es,
        "½ kilo de panela o piloncillo cortado en trozos"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/23/step/085043e7f78d405e97ff7357364dd36b>,
        <http://example.org/recipes/postre/23/step/16c5306c8b744951bc75f0503ebb9116>,
        <http://example.org/recipes/postre/23/step/8a4f58b190e84148ba55bc33a2ae1ec4>,
        <http://example.org/recipes/postre/23/step/df31529d0cd94e1baa96664613265156> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/24> a schema1:Recipe ;
    schema1:description "Los famosos Dulces de los Reyes, son un exquisito postre que consiste de un biscocho esponjoso cubierto con mermelada y manjar de leche. Es una de los dulces típicos y que forma parte de las tradiciones gastronómicas del Ecuador."@es ;
    schema1:name "Dulces de los reyes"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de esencia de vainilla"@es,
        "1 cucharada de polvo de hornear"@es,
        "1 piña mediana pelada"@es,
        "2 ½ litros de leche"@es,
        "200 gr de mantequilla"@es,
        "3 ½ tazas de azúcar"@es,
        "4 huevos"@es,
        "900 gr de harina"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/24/step/5b8dfc58a98346cabe630a352c288790>,
        <http://example.org/recipes/postre/24/step/67cba265edd74f4cb7ba651ba1d32e6d>,
