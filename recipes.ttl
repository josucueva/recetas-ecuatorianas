<http://example.org/recipes/entrada/26> a schema1:Recipe ;
    schema1:description "El ceviche volquetero se originó en la región del Oriente o Amazonia del Ecuador, específicamente en Puyo. A diferencia del ceviche tradicional de pescado, esta receta se prepara con atún enlatado, convirtiéndolo en un plato rápido y fácil de preparar."@es ;
    schema1:name "Ceviche Volquetero"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 ají picante, desvenado y sin semillas, finamente cortado"@es,
        "1 cebolla colorada cortada en rodajas finas"@es,
        "2 cucharadas de cilantro finamente cortado"@es,
        "2 latas de atún"@es,
        "4 tomates cortados en cubos"@es,
        "Aceite de oliva"@es,
        "Jugo de 2 limones"@es,
        "Sal al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/26/step/0c28e534bed24439b601573277b3cbe1>,
