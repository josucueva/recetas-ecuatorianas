    schema1:recipeYield 8 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/5> a schema1:Recipe ;
    schema1:description "El arroz con pollo es un plato lleno de sabores caseros y que se prepara de distintas formas y con distintos ingredientes según el país donde se realice. La receta ecuatoriana utiliza verduras, pechuga de pollo y el arroz se cocina con el caldo del pollo y suele acompañarse con plátano maduro frito. El arroz con pollo ecuatoriano es un plato delicioso y fácil de preparar."@es ;
    schema1:name "Arroz con Pollo Ecuatoriano"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla blanca cortada en cubos"@es,
        "1 cucharada de achiote en polvo"@es,
        "1 cucharada de comino molido"@es,
        "1 pimiento verde cortado en cubos"@es,
        "1 taza de cerveza o vino blanco"@es,
        "1 taza de guisantes"@es,
        "10 dientes de ajo machacados"@es,
        "1½ taza de agua o caldo de pollo"@es,
        "2 kilos de pechugas de pollo cortadas en trozos"@es,
        "2 tallos de cebolletas finamente cortadas"@es,
        "2 tazas de arroz sin cocer"@es,
        "2 zanahorias medianas, peladas y cortadas en cubos"@es,
        "3 cucharadas de aceite"@es,
        "3 cucharadas de cilantro finamente cortado"@es,
        "4 tomates pelados y cortados en cubos"@es,
        "sal y pimienta al gusto"@es,
        "½ cucharada de pepas de cilantro molidas o en polvo"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/5/step/3ab0a315084648a4b706c018f5147cba>,
        <http://example.org/recipes/plato-principal/5/step/65333ee6d3794d819be7f671a7cea88f>,
        <http://example.org/recipes/plato-principal/5/step/c75a5002ed6943f3a0427c00a4145b86>,
        <http://example.org/recipes/plato-principal/5/step/c89f66d3fe2d466fa96965af5c9188d1>,
        <http://example.org/recipes/plato-principal/5/step/d05ea0bccce7488a8f0f204db49abfa4>,
        <http://example.org/recipes/plato-principal/5/step/e28971531d56462fa2f347ea82f25ae9> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/50> a schema1:Recipe ;
    schema1:description "Ricas pechugas crocantes al estilo Ecuatoriano. Se pueden servir con ensalada, papas fritas o arroz blanco."@es ;
