<http://example.org/recipes/plato-principal/20> a schema1:Recipe ;
    schema1:description "Rica carne colorada al estilo Ecuatoriano. Preparada como un guiso. Se acompaña con arroz, maduro y aguacate."@es ;
    schema1:name "Carne colorada ecuatoriana"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada picadita"@es,
        "1 cerveza"@es,
        "1 cucharada de comino en polvo"@es,
