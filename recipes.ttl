<http://example.org/recipes/bebida/36> a schema1:Recipe ;
    schema1:description "Bebida nutritiva y refrescante. Tradicional de Ecuador. A base de avena, leche y canela."@es ;
    schema1:name "Horchata de avena"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 raja de canela"@es,
        "1 taza de avena"@es,
        "2 cucharaditas de extracto de vainilla"@es,
        "2 lata de leche evaporada"@es,
        "2 tazas de agua"@es,
        "¾ de taza de azúcar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/36/step/0c7a3236f4194eeaaec24db08a3129c6>,
