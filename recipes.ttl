<http://example.org/recipes/postre/43> a schema1:Recipe ;
    schema1:description "Delicioso dulce tradicional de Ecuador. Compuesto por morocho dulce y esencias que le dan ese toque caracteristico."@es ;
    schema1:name "Morocho dulce ecuatoriano"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 taza de morocho (remojado)"@es,
        "4 clavos de olor"@es,
        "4 tazas de agua"@es,
        "4 tazas de leche entera"@es,
        "6 bolitas de pimienta dulce"@es,
        "½ taza de azúcar o de leche condensada"@es,
        "½ taza de pasas o al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/43/step/30b5c54f82384b3697797b059df6f888>,
