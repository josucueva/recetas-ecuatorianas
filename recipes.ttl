    schema1:recipeYield 1 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/50> a schema1:Recipe ;
    schema1:description "El jugo de naranjilla, es una bebida tradicional y muy popular en los hogares ecuatorianos. Es refrescante y fácil de preparar. El sabor agridulce de la fruta le aporta a este jugo muchas propiedades y es una opción estupenda para calmar la sed."@es ;
    schema1:name "Jugo de naranjilla"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de agua"@es,
        "1 taza de azúcar"@es,
        "6 naranjillas medianas"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/50/step/04c32b15135c41f9b953f5c2d1130115>,
        <http://example.org/recipes/bebida/50/step/1bd81100feea4f0b9d0dcff0e6e5760d>,
