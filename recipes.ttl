        <http://example.org/recipes/postre/44/step/b2ecef5bf15e45b9893313c935491504> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/postre/45> a schema1:Recipe ;
    schema1:description "Este rico y delicado postre se elabora a base del Taxo, una fruta deliciosa y con múltiples propiedades. Es típica del Ecuador y tiene gran sabor, muy nutritiva y saludable. Sencillamente una alternativa deliciosa de aprovechar las bondades de este fruto. Anímate."@es ;
    schema1:name "Mousse de taxo"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 lata de leche evaporada"@es,
        "1 sobre de gelatina sin sabor"@es,
        "1 taza de pulpa de taxo"@es,
        "2 claras de huevo"@es,
        "¼ taza de agua"@es,
        "½ taza de leche condensada"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/45/step/0b72bdaa2301449e9fae1a218181464f>,
        <http://example.org/recipes/postre/45/step/0d9f45ff4b334387958b4550536a40bd>,
