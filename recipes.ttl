    schema1:recipeYield 8 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/postre/8> a schema1:Recipe ;
    schema1:description "Los buñuelos de mandioca son dulce clásicos ecuatorianos que utilizan la mandioca y la miel para formar un postre tradicional exquisito."@es ;
    schema1:name "Buñuelos de mandioca"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharadita de polvo para hornear"@es,
        "1 naranja para jugo"@es,
        "1 pizca de sal"@es,
        "1 taza de agua"@es,
        "100 gr de queso cremoso cortado en cubos"@es,
        "2 huevos"@es,
        "2 tazas de panela rayada"@es,
        "20 gr de manteca"@es,
        "4 tazas de aceite para freír"@es,
        "500 gr de mandioca cocida"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/8/step/10f64b136215485e96ba796f3bf5f3fa>,
        <http://example.org/recipes/postre/8/step/38b754e16fcd4c95897bbd3ce0c064ff>,
