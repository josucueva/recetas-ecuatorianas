<http://example.org/recipes/postre/12> a schema1:Recipe ;
    schema1:description "Las cocadas son uno de los clásicos dulces de coco de la ciudad ecuatoriana de Esmeraldas. Es un manjar de panela seca con textura comprometedora del coco que se mete hasta el infinito del gusto."@es ;
    schema1:name "Cocadas Esmeraldeñas"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 coco rallado"@es,
        "1 cucharada de jugo de limón"@es,
        "2 onzas de mantequilla"@es,
        "2 tazas de leche"@es,
        "4 yemas de huevo"@es,
        "¼ kilo de azúcar"@es,
        "½ kilo de panela rallada"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/12/step/4945ed41b8184f6698d7111bc3f0fbcb>,
