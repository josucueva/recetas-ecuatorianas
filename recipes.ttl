<http://example.org/recipes/plato-principal/13> a schema1:Recipe ;
    schema1:description "El sabor del ajo puro combinado con condimentos naturales resaltan el sabor de los camarones o langostinos haciendo de éste un popular plato en la costa ecuatoriana."@es ;
    schema1:name "Camarones o langostinos al ajillo"@es ;
