<http://example.org/recipes/entrada/16> a schema1:Recipe ;
    schema1:description "El ceviche en sus diferentes versiones es un indispensable en todo Ecuador, en este caso se prepara con pescado canchalagua."@es ;
    schema1:name "Ceviche de canchalaguas"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla morada"@es,
        "1 cucharadita de cilantro picado"@es,
        "1 pimiento verde"@es,
        "1 tomate"@es,
        "2 canchalaguas"@es,
        "2 limones"@es,
        "2 naranjas"@es,
        "Aceite, sal y pimienta a gusto"@es,
        "Canguil"@es ;
