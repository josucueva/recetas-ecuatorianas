        <http://example.org/recipes/entrada/21/step/a9846df949d84ccc8d4ee748ea722f25> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/22> a schema1:Recipe ;
    schema1:description "En Ecuador hay diferentes recetas del ceviche, ya sea de pescado o de mariscos, y cada región considera que su ceviche es el mejor. Sin embargo, el encanto de este plato está en la cocción o encurtido del pescado en limón, los ácidos le dan un sabor y una textura exquisita."@es ;
    schema1:name "Ceviche de Pescado"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 kilo de pescado bien fresco (corvina, halibut, dorado, pargo, tilapia, etc.)"@es,
        "1 manojo de cilantro"@es,
        "2 cebollas coloradas"@es,
        "2 pimientos verdes o rojos"@es,
        "4 tomates"@es,
        "Jugo de 20 limones"@es,
        "Sal y aceite al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/22/step/055ad1f827414c60ad971d80af5830af>,
        <http://example.org/recipes/entrada/22/step/7a8db75363264f7a9a3ef09d916b9d8f>,
        <http://example.org/recipes/entrada/22/step/b62fb01f0ec9491da5d2a01f7ca50303>,
        <http://example.org/recipes/entrada/22/step/bec05437d16244e6a936cc221823df7d>,
        <http://example.org/recipes/entrada/22/step/dd3347fa79664ca19bedc567f4a02291>,
        <http://example.org/recipes/entrada/22/step/e381fd57d595438eac66b605a66191b9> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/entrada/23> a schema1:Recipe ;
    schema1:description "El ceviche de pollo es una variante muy interesante del tradicional ceviche de pescado y tiene gran aceptación en la población de la sierra ecuatoriana."@es ;
    schema1:name "Ceviche de pollo"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cucharada de aceite vegetal"@es,
        "1 cucharada de ají colorado molido"@es,
        "1 hoja de lechuga"@es,
        "1 pechuga de pollo"@es,
        "1 ramita de cilantro"@es,
        "2 cebollas coloradas"@es,
        "2 cucharadas de ajos picados"@es,
        "5 cucharadas de ají amarillo molido"@es,
        "Sal y pimienta al gusto"@es,
        "Zumo de 5 limones."@es,
        "½ ají amarillo"@es,
        "½ taza de caldo de pollo"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/23/step/0f360ef18d7146b3913f072fd10a8b89>,
        <http://example.org/recipes/entrada/23/step/0f5e594df7774961be59bf52ae303dfc>,
        <http://example.org/recipes/entrada/23/step/13a85bd0a7db4699ba3aecea86a87aa4>,
