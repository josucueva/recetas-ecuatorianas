<http://example.org/recipes/entrada/63> a schema1:Recipe ;
    schema1:description "Rico, fresco y simple, el batido de guayaba es un indispensable en todas las playas y zona costera del Ecuador."@es ;
    schema1:name "Jugo de guayabas"@es ;
    schema1:recipeCategory "Entrada"@es ;
