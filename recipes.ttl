<http://example.org/recipes/bebida/48> a schema1:Recipe ;
    schema1:description "En el Ecuador se está incentivando el cultivo de la jamaica y la planta se emplea en la fabricación de jugos, refrescos, gelatinas, vinos y en pastelería."@es ;
    schema1:name "Jugo de jamaica"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "2 litros de agua"@es,
        "Hielo"@es,
        "Rodajas delgadas de limón para decorar (opcional)"@es,
        "½ taza de azúcar o al gusto"@es,
        "½ taza de flor de Jamaica"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/48/step/0d4045edd95149529ce7bb435302a27f>,
        <http://example.org/recipes/bebida/48/step/232e12148d51440dbbda3e7f592f339d>,
