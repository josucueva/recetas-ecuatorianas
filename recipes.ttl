<http://example.org/recipes/entrada/31> a schema1:Recipe ;
    schema1:description "Los chifles son frituras de plátano verde. También se conocen como platanitos o chips. Los chifles son un excelente acompañante para sopas, ceviches y cervezas, o son ideales como entrada acompañados con salsas como ají criollo, curtido de tomate y cebolla, o salsa rosada."@es ;
    schema1:name "Chifles Ecuatorianos"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "Aceite para freír"@es,
        "Ají o dientes de ajo para darle sabor al aceite"@es,
        "Plátanos verdes"@es,
        "Sal al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/31/step/2ca71df36ad940edb344ac60282370ea>,
        <http://example.org/recipes/entrada/31/step/a361ee9dcaf84238bfcf83e0162951cf>,
