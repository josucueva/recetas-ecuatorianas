<http://example.org/recipes/plato-principal/22> a schema1:Recipe ;
    schema1:description "La cazuela de pescado es un plato típico de la costa ecuatoriana también se la puede hacer de otros mariscos y siempre lleva plátano que es el ingrediente universal de la cocina ecuatoriana"@es ;
    schema1:name "Cazuela de pescado"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de cilantro picado finamente"@es,
        "1 lb de pescado fileteado (preferiblemente corvina o dorado)"@es,
        "2 cebollas coloradas"@es,
        "2 cucharada de aceite o achiote"@es,
        "2 cucharadas de ajo"@es,
        "2 litros de consomé de pescado o agua"@es,
        "2 pimientos verdes picados"@es,
        "2 tomates picados"@es,
        "3 plátanos verdes"@es,
        "Sal, pimienta y comino al gusto"@es,
        "½ lb de pasta de maní"@es ;
