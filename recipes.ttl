<http://example.org/recipes/entrada/44> a schema1:Recipe ;
    schema1:description "Las empanadas de maíz son un delicioso bocadillo que se puede comer todos los días, en Ecuador se consumen en todas las regiones y estas empanadas pueden ser rellenadas con una gran variedad de ingredientes"@es ;
    schema1:name "Empanadas de maíz"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 diente de ajo machacado y picado muy fino"@es,
