    schema1:recipeYield 4 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/postre/66> a schema1:Recipe ;
    schema1:description "Uno de los postres frios preferidos es la tres leches. Esa mezcla de bizcocho mojado de leche con la crema por encima tiene un sabor único."@es ;
    schema1:name "Tres leches ecuatoriana"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 crema de leche 500 gramos"@es,
        "1 lata leche condensada"@es,
        "1 lata leche evaporada"@es,
        "1 sobre de crema chantilly"@es,
        "1 taza de leche fría"@es,
        "140 gr de azúcar"@es,
        "140 gr de harina"@es,
        "4 huevos"@es,
        "Para crema chantilly"@es,
        "Para el liquido"@es,
        "½ cucharada de esencia de vainilla"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/66/step/04ff442fba524910a7fad3c481cd227c>,
        <http://example.org/recipes/postre/66/step/21aadfed2a874f8bb1d76a37deeb56f1>,
