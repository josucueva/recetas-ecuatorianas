<http://example.org/recipes/plato-principal/9> a schema1:Recipe ;
    schema1:description "El bistec de carne al horno es una receta muy fácil y rápida de preparar que tiene ingredientes muy fáciles de conseguir como la carne y algunas verduras."@es ;
