<http://example.org/recipes/plato-principal/40> a schema1:Recipe ;
    schema1:description "Este locro es una de las comidas más famosas de toda la gastronomía de Ecuador, significa Yahuar (sangre) y locro (sopa)."@es ;
    schema1:name "El yahuarlocro"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 diente de ajo"@es,
        "1 kg de menudencias de borrego o cordero"@es,
        "1 litro de sangre fresca de borrego"@es,
        "1 taza de maní licuado con leche"@es,
        "2 cebollas picadas"@es,
        "2 cucharadas de perejil fresco"@es,
        "2 kg de papas cubeteadas"@es,
        "2 limones"@es,
        "4 cucharadas de aceite"@es,
        "Sal y pimienta al gusto"@es,
        "Una pizca de achiote"@es,
        "Una pizca de comino"@es,
