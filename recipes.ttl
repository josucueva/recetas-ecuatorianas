    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/plato-principal/12> a schema1:Recipe ;
    schema1:description "El bollo de pescado es uno de los platos principales característicos de la costa ecuatoriana, entre sus ingredientes estrella se encuentra el plátano verde."@es ;
