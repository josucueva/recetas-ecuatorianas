<http://example.org/recipes/plato-principal/98> a schema1:Recipe ;
    schema1:description "El seco es un guiso típico de la gastronomía de Ecuador puede elaborarse con cualquier tipo de carne, el seco de carne de guanta es típico de la selva amazónica del ecuador."@es ;
    schema1:name "Seco de carne de guanta"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 ají picado"@es,
        "1 cebolla morada"@es,
        "1 diente de ajo"@es,
        "1 litro de chicha"@es,
        "2 cebollas blanca"@es,
        "2 cucharadas de chillangua"@es,
        "2 kg de carne de guanta"@es,
        "2 pimientos verdes"@es,
        "Aceite de freir"@es,
        "Sal, comino, cilantro y pimienta"@es,
        "¼ taza de maní tostado"@es ;
