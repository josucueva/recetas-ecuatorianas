<http://example.org/recipes/entrada/72> a schema1:Recipe ;
    schema1:description "El pan de yuca es un aperitivo originario de la costa ecuatoriana y uno de los platos más representativos de Ecuador. Su receta es muy sencilla y se suele consumir en el desayuno o merienda, aunque también está presente en la mesa a la hora del almuerzo como guarnición de otras comidas más fuertes."@es ;
    schema1:name "Pan de Yuca"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cucharadita de polvo de hornear"@es,
        "1 pizca de sal"@es,
        "2 huevos"@es,
        "2 ½ tazas de almidón de yuca"@es,
        "3 cucharadas de agua o leche (si la masa está seca)"@es,
        "4 onzas de mantequilla"@es,
        "4 tazas de queso rallado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/72/step/4928e106f66240c0b8a10adeabfbe64f>,
        <http://example.org/recipes/entrada/72/step/8b33c00cc727418491c9a8d05b7db17b>,
