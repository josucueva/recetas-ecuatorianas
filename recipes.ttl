<http://example.org/recipes/bebida/34> a schema1:Recipe ;
    schema1:description "La Horchata de ajonjoli es bebida rica y refrescante. Se sirve con hielo picadito y un toque de vainilla."@es ;
    schema1:name "Horchata de ajonjolí"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 taza de agua"@es,
        "2 cucharadas de azúcar"@es,
