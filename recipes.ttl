<http://example.org/recipes/plato-principal/28> a schema1:Recipe ;
    schema1:description "El chaulafán de pollo es la versión ecuatoriana del arroz frito chino preparado con pollo, tocino, cebolla, ajo, pimientos, arvejas, zanahorias, huevos, pasas, especias y hierbas."@es ;
    schema1:name "Chaulafán"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
