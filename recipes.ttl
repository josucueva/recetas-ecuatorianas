<http://example.org/recipes/sopa/21> a schema1:Recipe ;
    schema1:description "El chupé de camarones es muy popular en la cocina ecuatoriana y se lo puede encontrar en las playas de las provincias de Manabi y Esmeraldas principalmente."@es ;
    schema1:name "Chupé de camarones"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla colorada (paiteña)"@es,
        "1 cucharada de salsa de tomate"@es,
        "1 kg de camarones limpios"@es,
        "1 lb de papas blancas o amarillas"@es,
        "1 lb de pescado"@es,
        "1 litro de agua"@es,
        "1 tarro de leche evaporada"@es,
        "1 taza de arvejas"@es,
        "2 cucharadas de queso parmesano"@es,
        "2 dientes de ajo machacado"@es,
        "2 huevos"@es,
        "Ají y cilantro al gusto"@es,
