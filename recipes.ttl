<http://example.org/recipes/entrada/15> a schema1:Recipe ;
    schema1:description "El ceviche de canchalagua es un plato que ha ganado muchos seguidores en las islas galápagos (principalmente en San Cristóbal)"@es ;
    schema1:name "Ceviche de canchalagua"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla colorada (paiteña)"@es,
        "1 cucharada de aceite vegetal"@es,
        "1 cucharadita de cilantro picado"@es,
        "1 tomate"@es,
        "2 canchalaguas"@es,
        "2 limones pequeños"@es,
        "2 naranjas"@es,
        "Canguil"@es,
        "Chifles"@es,
        "Sal y pimienta al gusto"@es,
        "¼ pimiento verde"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/15/step/049c9c740202431ea3a3cd45b270c4b4>,
