        <http://example.org/recipes/plato-principal/43/step/e001acd1ff9944b38290fb80f03b8fac> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/44> a schema1:Recipe ;
    schema1:description "El encocado de pescado es un plato típico de la costa ecuatoriana que consiste de pescado corvina cocinado en una deliciosa salsa de coco. Existen otras variaciones del encocado con camarones, conchas, cangrejo, calamar u otros mariscos."@es ;
    schema1:name "Encocado de Pescado"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla blanca cortada en cubitos"@es,
        "1 coco fresco licuado (el agua y la pulpa de coco)"@es,
        "1 cucharadita de achiote molido"@es,
        "1 cucharadita de comino molido"@es,
        "1 cucharadita de pepitas de cilantro molido"@es,
        "2 cucharadas de aceite"@es,
        "2 kilos de filetes de corvina cortados en trozos medianos"@es,
        "2 pimientos cortados en cubitos"@es,
        "3 cucharadas de cilantro finamente cortado"@es,
        "4 dientes de ajo machacados"@es,
        "4 tomates pelados y cortados en cubitos"@es,
        "Coco rallado fresco"@es,
        "Jugo de 2 limones"@es,
        "Jugo de 2 naranjas"@es,
        "Sal al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/44/step/47b95cff4d884fb1bc79075f0b10783e>,
        <http://example.org/recipes/plato-principal/44/step/ce49dd371e744258a9c7ce3076eb2fcf>,
        <http://example.org/recipes/plato-principal/44/step/dcdbf4bc25e14b47862937eb1479e9bb> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/45> a schema1:Recipe ;
    schema1:description "El Ensumacao es un delicioso caldo de mariscos con leche de coco y maní, muy típico de la provincia de Esmeraldas. Sus orígenes vienen de la cultura afrodescendiente. Se elabora a base de diversos frutos del mar y aromatizados con la chillangua, una hierba oriunda de esta región."@es ;
    schema1:name "Ensumacao"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 vaso de leche de coco"@es,
        "100 gr de maní tostado"@es,
        "2 cebollas paiteñas"@es,
        "2 cucharadas de mantequilla"@es,
        "2 pimientos verdes"@es,
        "2 ramitas de chillangua"@es,
        "2 tazas de caldo de camarones"@es,
        "200 gr de almejas"@es,
        "200 gr de cangrejo azul"@es,
        "300 gr de calamar"@es,
        "300 gr de langostinos"@es,
        "300 gr de pateburro"@es,
        "300 gr de pulpo"@es,
        "5 dientes de ajo"@es,
        "500 gr de camarón"@es,
        "500 gr de pescado"@es,
        "Aceite con achiote"@es,
        "Sal c/n"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/45/step/23db71b1d9654a1c92072e60e2364dd6>,
        <http://example.org/recipes/plato-principal/45/step/ab0301d2ca574ac78e8153c8f02caaf4>,
        <http://example.org/recipes/plato-principal/45/step/d037d84672704b6896e659a5636705b5>,
        <http://example.org/recipes/plato-principal/45/step/dce31090db2d4011bdb17ec755793712>,
        <http://example.org/recipes/plato-principal/45/step/dfa6bd266ee44ae9add47840c1d3a0e0>,
        <http://example.org/recipes/plato-principal/45/step/e29d37c737a44147ba0a1c8d66454578> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/46> a schema1:Recipe ;
    schema1:description "El estofado de pescado es un almuerzo tradicional del pueblo ecuatoriano, puede realizarse con variedades de pescados en este caso se usara corvina de mar."@es ;
    schema1:name "Estofado de corvina"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada"@es,
        "1 cucharada de ajo molido"@es,
        "1 kg de corvina de mar"@es,
        "1 papa"@es,
        "1 pimiento verde"@es,
        "1 tomate"@es,
        "Sal, pimienta y comino a gusto"@es,
        "Una pizca de achiote"@es,
        "Una pizca de cilantro"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/46/step/068f42653fba455095184f31d36c8af4>,
