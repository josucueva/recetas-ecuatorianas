<http://example.org/recipes/plato-principal/79> a schema1:Recipe ;
    schema1:description "El pastel de carne es un plato cuyo principal ingrediente es la carne(carne molida de vaca, jamón, tocino) y pan molido con algunas especias. Es fácil de preparar y se puede comer a cualquier hora del día."@es ;
