    schema1:recipeYield 6 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/32> a schema1:Recipe ;
    schema1:description "Una de las razones por las que es conocido Ecuador en todo el mundo es su exquisito café, este cóctel granizado es ideal para beberlo en una tarde de calor."@es ;
    schema1:name "Granizado de café"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 cucharadita de café en polvo"@es,
        "1 medida de coñac"@es,
        "100 gr de crema batida o chantilly"@es,
        "150 gr azúcar"@es,
        "3 tazas de agua"@es,
        "3 tazas de café ecuatoriano"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/32/step/52f718241e3844349f7bb0c8e43262f8>,
        <http://example.org/recipes/bebida/32/step/61a09c0876e74e02a1948281a009c6f3>,
