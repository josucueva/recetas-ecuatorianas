<http://example.org/recipes/plato-principal/16> a schema1:Recipe ;
    schema1:description "La clásica cangrejada ecuatoriana es un plato imperdible de la marisqueria de Ecuador que se prepara con pangoras y jaibas, especies autóctonas de la zona costera del país ."@es ;
    schema1:name "Cangrejadas"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1litro de cerveza"@es,
        "2 cucharadas soperas de comino"@es,
        "2 cucharadas soperas de pimienta negra en grano"@es,
        "2 cucharadas soperas de sal"@es,
        "2 cucharadas soperas orégano"@es,
        "2 plátanos maduros"@es,
        "3 kg de cangrejos"@es,
        "3 plátanos verdes"@es,
        "4 cebollas"@es,
        "4 dientes de ajo"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/16/step/1d9a5a0c13d546d58b7642aa5cbfe860>,
        <http://example.org/recipes/plato-principal/16/step/24f8a037ae1e4325b3e38970a2cbbd7b>,
