<http://example.org/recipes/plato-principal/114> a schema1:Recipe ;
    schema1:description "El tapao de pescado es un plato típico de la cocina esmeraldeña, y se basa en un preparado de pescado fresco o salado, plátano verde y aromatizado con hierbas como la chillangua, orégano o chirarán. En la receta tradicional, se cocina tapado con hojas de plátano."@es ;
    schema1:name "Tapao de pescado"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada picada en julianas"@es,
        "1 cucharada de ajo triturado"@es,
        "1 cucharadita de achiote en polvo"@es,
        "1 pimiento verde cortado en cubos"@es,
        "1 tomate picado en cubos"@es,
        "2 pescados frescos (bagre)"@es,
        "3 limón"@es,
        "3 verdes sin corteza"@es,
        "Hierbas (chillangua, orégano o chirarán)"@es,
        "Sal y comino c/n"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/114/step/4df502722ae6412f8da14d5ee22746bb>,
        <http://example.org/recipes/plato-principal/114/step/60d2448977be47e4b607093a76018553>,
