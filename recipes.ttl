<http://example.org/recipes/plato-principal/19> a schema1:Recipe ;
    schema1:description "La carne colorada es típico de las provincias de Carchi e Imbabura en el norte del Ecuador. La carne colorada es un plato de carne de res (o de cerdo) marinada en un adobo de achiote."@es ;
    schema1:name "Carne Colorada"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada cortada"@es,
        "1 cucharada de comino molido"@es,
        "1 cucharada de semillas de achiote"@es,
        "1 kilo de carne de res (o de cerdo) cortado en cubos o tiras de tamaño mediano"@es,
        "2 cucharadas de jugo de limón"@es,
        "3 cucharadas de aceite"@es,
        "3 cucharadas de achiote molido"@es,
        "6 dientes de ajo"@es,
        "sal al gusto"@es,
        "½ cucharada de orégano"@es,
        "½ taza de cerveza"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/19/step/015be075c5e14389a3f0d177e53bd4c1>,
        <http://example.org/recipes/plato-principal/19/step/6dcc3450f77848d596d648076e707c9d>,
