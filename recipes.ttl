<http://example.org/recipes/plato-principal/75> a schema1:Recipe ;
    schema1:description "La menestra de fréjol es muy consumida en la costa ecuatoriana y principalmente en el puerto de Guayaquil es una variante de la menestra de lentejas."@es ;
