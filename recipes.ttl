<http://example.org/recipes/plato-principal/51> a schema1:Recipe ;
    schema1:description "Jugoso pollo preparado con una deliciosa salsa de champiñones. Puede acompañarse con arroz o ensalada."@es ;
    schema1:name "Filete de pollo al champiñon"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
