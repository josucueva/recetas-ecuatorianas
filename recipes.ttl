<http://example.org/recipes/sopa/4> a schema1:Recipe ;
    schema1:description "El biche de pescado, también conocido como viche, es una deliciosa sopa típica de Manabí, Ecuador. Este plato tradicional de la gastronomía ecuatoriana tiene mucha consistencia y el contraste de los sabores es exquisito."@es ;
    schema1:name "Biche de Pescado"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cucharada de orégano seco"@es,
        "1 cucharadita de achiote molido"@es,
        "1 kilo de filetes de pescado blanco (corvina, merluza, halibut, bacalao, etc.), cortados en trozos medianos"@es,
        "1 kilo de yuca pelada y cortada en trozos pequeños"@es,
        "1 pimiento rojo o verde cortado en cubos"@es,
        "1 taza de leche"@es,
        "1 taza de maní ligeramente tostado"@es,
        "10 dientes de ajo machacados"@es,
        "10 tazas de agua"@es,
        "2 choclos cortados en rodajas"@es,
        "2 cucharadas de cilantro o perejil cortado"@es,
        "2 cucharaditas de comino molido"@es,
        "2 plátanos maduros pelados y cortados en rodajas"@es,
        "3 tazas de cebolla colorada cortada"@es,
        "4 cucharadas de aceite o mantequilla"@es,
        "Sal y pimienta al gusto"@es,
        "½ kilo de cabezas y huesos de pescado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/4/step/139697d0a3af4971a466882d3918b33d>,
        <http://example.org/recipes/sopa/4/step/8f57c37f76f141468adb455d92ac01cd>,
