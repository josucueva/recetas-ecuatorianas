<http://example.org/recipes/sopa/54> a schema1:Recipe ;
    schema1:description "La deliciosa sopa de aguacate es una receta tradicional de la cocina lojana, puede disfrutarse ligeramente tibia o preferiblemente fría. Se elabora con frutos en su punto ideal de maduración y un buen y delicado. No dudes en disfrutarla."@es ;
    schema1:name "Sopa de aguacate"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 aguacate no muy maduro"@es,
        "1 rama de culantro"@es,
        "2 dientes de ajo picados finamente"@es,
        "400 gr de carne de res con huesos"@es,
        "Pimienta"@es,
        "Sal"@es,
        "½ rama de cebolla blanca picada finamente"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/54/step/9cc59e80946842b981300e828ddab788>,
