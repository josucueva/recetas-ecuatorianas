<http://example.org/recipes/bebida/49> a schema1:Recipe ;
    schema1:description "La maracuyá es una fruta típica del territorio ecuatoriano y en los hogares no puede faltar el refrescante jugo de maracuyá especialmente a la hora del almuerzo."@es ;
    schema1:name "Jugo de maracuyá"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 kg de maracuyá (No incluir frutas con pulpa mohosa)"@es,
        "1 litro de agua"@es,
        "Azúcar al gusto"@es,
        "Hielo"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/49/step/af0907196f4b4a8aae7ba8c7f1ab157b>,
