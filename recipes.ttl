<http://example.org/recipes/plato-principal/105> a schema1:Recipe ;
    schema1:description "El seco de pollo o gallina es uno de esos platos que se suelen encontrar en cualquier hogar ecuatoriano. El seco de pollo, también conocido como seco de gallina criolla, se cocina a fuego lento en una salsa de cerveza, cebolla, pimiento, tomate, hierbas y condimentos. Tradicionalmente se usaba chicha para preparar el seco, pero hoy en día es más común con cerveza."@es ;
    schema1:name "Seco de Pollo o Gallina"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla cortada en trozos"@es,
        "1 manojo de cilantro"@es,
        "1 manojo de perejil"@es,
        "1 taza de jugo de naranjilla (lulo)"@es,
        "2 cucharaditas de achiote molido"@es,
        "2 cucharaditas de comino molido"@es,
        "2 cucharaditas de orégano seco"@es,
        "2 kilos de presas de pollo o gallina"@es,
        "2 pimientos (rojo o verde) cortados en trozos"@es,
        "2 tazas de cerveza (no muy oscura)"@es,
        "3 cucharadas de aceite"@es,
        "6 tomates cortados en cuartos"@es,
        "8 dientes de ajo"@es,
        "Sal y pimienta al gusto"@es,
        "½ taza de jugo de una naranja (opcional)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/105/step/37d1c8e7f85c4ac28aa962af54fc7c16>,
        <http://example.org/recipes/plato-principal/105/step/7549c8bc7d494bc0a10c543f594c9c71>,
        <http://example.org/recipes/plato-principal/105/step/b2791c27bed84b30bdeeca797cbcd02d>,
        <http://example.org/recipes/plato-principal/105/step/d29cfbf4f79d4b1db06576aec604f497> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/106> a schema1:Recipe ;
    schema1:description "El spaghetti con albondigas es un plato italo-estadounidense que usualmente consiste de espagueti, salsa de tomates, y albóndigas que es muy delicioso y tiene gran aceptación en la población ecuatoriana"@es ;
    schema1:name "Spaghetti con albondigas"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 huevo"@es,
        "1 lb de carne molida"@es,
        "1 litro de agua"@es,
        "1 paquete de spaghetti 350 gramos"@es,
        "1 taza de aceite"@es,
        "2 cebollas perla"@es,
        "2 cucharadas de perejil picado"@es,
        "4 cucharadas de pasta de tomate"@es,
        "4 hojas de albahaca"@es,
        "6 tomates"@es,
        "Queso parmesano para decorar"@es,
        "Sal y pimienta al gusto"@es,
