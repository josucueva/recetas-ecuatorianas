<http://example.org/recipes/postre/7> a schema1:Recipe ;
    schema1:description "El budín de pan es uno de los postres más fáciles de elaborar, pero lo sencillo no le quita lo exquisito"@es ;
    schema1:name "Budín de pan"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 copa de ron o aguardiente"@es,
        "1 lb de azúcar (o a tu gusto)"@es,
        "1 litro de leche"@es,
        "10 panes de sal (no importa si es pan viejo)"@es,
        "3 cucharadas de esencia de vainilla"@es,
        "3 huevos"@es,
        "½ lb de mantequilla derretida"@es,
        "½ taza de pasas (opcional)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/7/step/0248e452bde84276a869ee53bab3eb6b>,
        <http://example.org/recipes/postre/7/step/328276e730b24523bdfab0d27e6857ce>,
