<http://example.org/recipes/plato-principal/36> a schema1:Recipe ;
    schema1:description "Las costillas a la BBQ es un plato preferido por muchos en Ecuador. La salsa que cubre las costillas es sumamente una delicia. Se puede acompañar con ensalada."@es ;
