<http://example.org/recipes/plato-principal/52> a schema1:Recipe ;
    schema1:description "Los filetes de pescado apanados son ricos y deliciosos por combinar en un mismo plato la suavidad y sabor del pescado con la textura crujiente que lo envuelve. En la cocina ecuatoriana se les encuentra a menudo en variadas recetas, que sin lugar a dudas encantarán a todos."@es ;
    schema1:name "Filetes de pescado apanado"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 kg de filetes de corvina"@es,
        "2 tazas de miga de pan"@es,
        "300 gr de harina de trigo"@es,
        "4 huevos"@es,
        "Aceite para freír"@es,
        "Sal y pimienta c/n"@es,
        "½ taza de jugo de limón"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/52/step/378ff796fb624c3f856bf87e8a115563>,
        <http://example.org/recipes/plato-principal/52/step/3b931c303051489abddf013e1ee04bbc>,
