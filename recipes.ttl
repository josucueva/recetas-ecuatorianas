    schema1:recipeYield 4 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/11> a schema1:Recipe ;
    schema1:description "Incorporar espinaca a nuestra dieta es siempre una opción nutritiva y saludable, este batido se lo encuentra en puestos de mercados populares principalmente."@es ;
    schema1:name "Bebida de Espinaca"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 zanahoria grande"@es,
        "10 hojas de espinaca"@es,
        "2 ramitas de apio"@es,
        "3 hojas de lechuga romana"@es,
        "Jugo de un limón o naranja"@es,
        "¼ taza de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/11/step/32253a2a63b6479b8b487667ef9a67de>,
        <http://example.org/recipes/bebida/11/step/3ed980a9ddf249cb90e4f7153313163b>,
