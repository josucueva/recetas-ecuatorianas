<http://example.org/recipes/entrada/52> a schema1:Recipe ;
    schema1:description "La ensalada de atún es una receta saludable y de fácil de preparación. En la gastronomía ecuatoriana, es una de las delicias que usualmente encontramos, con el atún como protagonista y acompañado de muchas variantes. Te invitamos a que no dejes de probarla. Disfrútala."@es ;
    schema1:name "Ensalada de atún con tomate y cebolla"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cucharada de culantro"@es,
        "1 limón"@es,
        "2 latas de atún"@es,
        "2 tomates picados en cubos"@es,
        "Aceite de oliva"@es,
        "Sal c/n"@es,
        "½ cebolla paiteña picada en cubos"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/52/step/612ef2f503b744e9af9b36b2ddf23eac>,
        <http://example.org/recipes/entrada/52/step/956b472bf1eb421e87f6fff65189cc03>,
