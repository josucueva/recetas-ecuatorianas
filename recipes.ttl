<http://example.org/recipes/sopa/71> a schema1:Recipe ;
    schema1:description "Es una sopa de maíz de tipo morocho, elaborada con coles, papas y, a veces, carne. Según la contundencia del plato puede tratarse como plato fuerte."@es ;
