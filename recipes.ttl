<http://example.org/recipes/sopa/5> a schema1:Recipe ;
    schema1:description "El caldo blanco es un plato típico ecuatoriano con un delicioso sabor y que se degusta bien caliente. Este caldo es bastante ligero que debe tener una consistencia cristalina, lo cual es característico del plato. No pierdas la oportunidad de aprender a elaborarlo."@es ;
    schema1:name "Caldo blanco ecuatoriano"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla"@es,
        "1 cebolla en rama finamente picada"@es,
