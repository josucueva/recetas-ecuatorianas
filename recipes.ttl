<http://example.org/recipes/entrada/28> a schema1:Recipe ;
    schema1:description "La chicha de chonta y maduro es una bebida ancestral y muy tradicional de Ecuador. Se elabora a base de los frutos de una palmera conocida como chonta, cuyo sabor es fuerte y un poco ácido. Se acompaña de maduros que le aportan cremosidad y dulzor. No puedes perdértela."@es ;
    schema1:name "Chicha de chonta y maduro"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "2 litros de agua"@es,
        "3 plátanos muy maduros"@es,
        "3 ramas de canela"@es,
        "30 pepas de chonta licuada"@es,
        "Azúcar al gusto (opcional)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/28/step/0accf9d899054669aaa27f0a5bcf29ee>,
        <http://example.org/recipes/entrada/28/step/71737405c03747f1a32f7436d6e26ae5>,
