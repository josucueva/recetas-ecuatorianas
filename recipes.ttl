<http://example.org/recipes/sopa/16> a schema1:Recipe ;
    schema1:description "El caldo de patas de res, es una sopa tradicional y muy típica en varios países latinoamericanos. Se sirve caliente y es muy rica, ya que encuentras lo gelatinoso de la carne con el sabor de las hierbas aromáticas. Puede acompañarse con mote, arroz u otro vegetal que te apetezca."@es ;
    schema1:name "Caldo de patas"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 kg de mote"@es,
        "1 manojo de cilantro"@es,
        "1 rama de cebolla"@es,
        "1 taza de leche"@es,
        "1 taza de maní tostado"@es,
        "1 ½ litro de agua"@es,
        "2 cebollas blancas"@es,
        "2 cucharadas de aceite"@es,
        "2 cucharadas de culantro"@es,
        "2 kg de papas"@es,
        "2 patas	de res"@es,
        "4 dientes de ajo"@es,
        "Sal al gusto"@es ;
