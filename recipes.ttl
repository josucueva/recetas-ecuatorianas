        <http://example.org/recipes/postre/8/step/d6d1c03879c34e69b502fba55a38f39a> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/9> a schema1:Recipe ;
    schema1:description "Los buñuelos de yuca son postres tradicionales y que se pueden servir en cualquier momento, con el sabor del queso, la yuca y la miel forman una mezcla exquisita para degustar."@es ;
    schema1:name "Buñuelos de yuca"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de mantequilla"@es,
        "1 cucharadita de polvo para hornear"@es,
        "1 lb de yuca cocida"@es,
        "1 naranjilla (jugo)"@es,
        "1 pizca de sal"@es,
        "1 taza de queso cortado de trozos (no muy salado)"@es,
        "2 huevos"@es,
        "2 tazas de panela rayada"@es,
        "4 tazas de aceite para freír"@es,
        "½ taza de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/9/step/2434dec6bce5490ab2968ed553014559>,
        <http://example.org/recipes/postre/9/step/71f1879682704aa0a673d3de69c00f15>,
