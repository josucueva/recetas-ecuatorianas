<http://example.org/recipes/postre/10> a schema1:Recipe ;
    schema1:description "Exquisito postre de chocolate caliente. Con un toque único y tradicional de Ecuador al acompañarlo con queso."@es ;
    schema1:name "Chocolate caliente con queso"@es ;
    schema1:recipeCategory "Postre"@es ;
