    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/55> a schema1:Recipe ;
    schema1:description "En Ecuador, especialmente en la costa, es muy común encontrar deliciosos flanes preparados con coco, piña u otras frutas. El queso de piña es una receta sencilla para preparar un delicioso flan con jugo de piña, azúcar, leche, huevos, vainilla y ron."@es ;
    schema1:name "Queso de Piña"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de maicena"@es,
        "1 cucharadita de esencia o extracto de vainilla"@es,
        "1 taza de leche"@es,
        "10 huevos"@es,
        "10 moldes de flan pequeños engrasados ligeramente con mantequilla"@es,
        "10 rodajas de piña"@es,
        "2 cucharadas de ron"@es,
        "2 tazas de azúcar"@es,
        "2½ tazas de jugo de piña fresca, colado y sin la espuma"@es,
        "Azúcar morena"@es,
        "½ taza de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/55/step/1b373d29ee1e44b1a1e9908491860681>,
