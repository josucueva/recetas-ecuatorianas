    schema1:recipeYield 6 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/47> a schema1:Recipe ;
    schema1:description "La natilla o mazmorra de choclo es un platillo muy popular en la provincia de Manabi y se hace con el choclo cuando está endureciendo,"@es ;
    schema1:name "Natilla o mazamorra de choclo"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharadita de esencia de vainilla"@es,
        "1 litro de leche"@es,
        "3 o 4 astillas de canela"@es,
        "4 mazorcas de choclo duro"@es,
        "Azúcar al gusto"@es,
        "Canela en polvo para decorar"@es,
        "Clavo de olor"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/47/step/13bb1f6760b8473399baefb236e31461>,
        <http://example.org/recipes/postre/47/step/2f155c8d9afa45559b8a1133e026d8a6>,
