<http://example.org/recipes/plato-principal/33> a schema1:Recipe ;
    schema1:description "El churrasco es uno de los platos más populares en Ecuador. Consiste en una chuleta de carne de vacuno cocinada a la plancha o a la brasa. El secreto para la preparación de un buen churrasco ecuatoriano es que la carne esté bien sazonada."@es ;
    schema1:name "Churrasco"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
