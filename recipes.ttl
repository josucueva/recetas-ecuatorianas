    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/68> a schema1:Recipe ;
    schema1:description "El turrón es considerado en todo el mundo un clásico de la Navidad, en Ecuador el ingrediente sorpresa son las obleas, el toque mágico de la costa ecuatoriana."@es ;
    schema1:name "Turrón dulce ecuatoriano"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharadita de canela"@es,
        "1 taza de almendras tostadas"@es,
        "100 gr de azúcar"@es,
        "2 claras de huevo"@es,
        "2 obleas"@es,
        "300 gr de azúcar glass"@es,
        "½ taza de miel"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/68/step/1b0d0f841e0042b583f8d072cb5242f1>,
        <http://example.org/recipes/postre/68/step/23018213f7eb420792e63193e2d7eb15>,
