<http://example.org/recipes/plato-principal/88> a schema1:Recipe ;
    schema1:description "Suculento pollo asado al horno con especies al estilo Ecuatoriano. Se puede comer con papas, arroz o ensalada."@es ;
    schema1:name "Pollo asado al horno"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
