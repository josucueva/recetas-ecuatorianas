<http://example.org/recipes/plato-principal/6> a schema1:Recipe ;
    schema1:description "El arroz marinero es uno de los preferidos por su variedad en ingredientes. Puede acompañarse con maduros."@es ;
    schema1:name "Arroz marinero"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de achiote"@es,
        "1 cucharadita de sal"@es,
        "1 pizca pimienta negra"@es,
        "2 cucharadas de aceite"@es,
        "2 dientes de ajo picaditos"@es,
        "2 ramas de cebolla"@es,
        "2 tomates cortados en cuadritos:"@es,
        "3 cucharadas de cebolla roja picadita"@es,
        "6 tazas de aguas"@es,
        "6 tazas de arroz"@es,
        "Cangrejo de ecuador"@es,
        "Maduros fritos"@es,
        "Mariscos:"@es,
        "¼ cucharadita de comino"@es,
        "½kg de camaron"@es,
        "½kg de langostinos"@es,
        "½kg de pulpo"@es,
        "½kgde calamares"@es ;
