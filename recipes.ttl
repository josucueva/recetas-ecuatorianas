<http://example.org/recipes/bebida/28> a schema1:Recipe ;
    schema1:description "Los jugos, batidos y coladas son parte integral de la cultura de Ecuador. La colada de avena, también conocida como colada quaker, es una bebida tradicional ecuatoriana que generalmente se sirve en las comidas y se puede tomar caliente o frío."@es ;
    schema1:name "Colada de Avena"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "10 granos de pimienta dulce"@es,
        "10 oz de panela"@es,
        "10 palitos de canela"@es,
        "2 litros de agua"@es,
        "3 tazas de avena entera remojada en 1 taza de agua"@es,
        "3 tazas de pulpa de naranjilla"@es,
        "5 clavos de olor"@es,
        "La cáscara de 1 limón"@es,
        "Las cortezas y el centro de 1 piña"@es,
        "½ cucharadita hierba luisa seca"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/28/step/1da9ae093cbb4559bb606087f58fb7ee>,
        <http://example.org/recipes/bebida/28/step/3ffaf3f570824b21b6419b72542ce8d1>,
        <http://example.org/recipes/bebida/28/step/a095403db3a54c838cc5a89e590637d7>,
        <http://example.org/recipes/bebida/28/step/e25d1806a5c244dd9c62563a03648466> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/bebida/29> a schema1:Recipe ;
    schema1:description "La colada morada es la bebida tradicional del pueblo ecuatoriano el día que se celebra la fiesta de los difuntos, las frutas autóctonas del país son protagonistas de esta celebración."@es ;
    schema1:name "Colada de moras"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 taza de frutillas"@es,
        "1 taza de piña"@es,
        "1 taza de pulpa de naranja"@es,
        "2 litros de agua"@es,
        "2 ramas de canela"@es,
        "250 gr de arándanos"@es,
        "250 gr de moras"@es,
        "Clavos de olor"@es,
        "Cáscara de 1 limón"@es,
        "Cáscara de 1 naranja"@es,
        "½ cucharadita de hierba luisa seca"@es,
        "½ taza azúcar morena"@es,
        "½ taza de panela"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/29/step/24ac37e8da89460e8d102fc95e5cbc06>,
        <http://example.org/recipes/bebida/29/step/295a9a3ee3a842a5a5cb000b22c1caa1>,
