<http://example.org/recipes/postre/51> a schema1:Recipe ;
    schema1:description "El maduro es un plátano indispensable en la cocina ecuatoriana. Esta receta de pie de maduro contrasta el sabor dulce del plátano con el salado del queso, haciendo de este postre una fabulosa combinación propia del Ecuador."@es ;
    schema1:name "Pie de Maduro"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "2 cucharaditas de sal"@es,
        "2 tazas de azúcar panela"@es,
