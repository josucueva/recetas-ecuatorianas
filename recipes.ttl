    schema1:recipeYield 8 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/17> a schema1:Recipe ;
    schema1:description "Los carapachos de cangrejo rellenos son un plato tradicional de la marisquería ecuatoriana, para realizarlos se utilizan las caparazones de los cangrejos que se recolectan de las costas del país."@es ;
    schema1:name "Carapachos de cangrejo"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharadita de esencia de vainilla"@es,
        "2 plátanos maduros"@es,
        "20 gr de mantequilla"@es,
        "4 carapachos de cangrejo"@es,
        "500 gr de carne de cangrejo"@es,
        "Aceitunas"@es,
        "Azúcar a gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/17/step/1804a9e5d0564be19126d3acbcb8479a>,
        <http://example.org/recipes/plato-principal/17/step/1c44353a0e2746a3bafa5238b3c64532>,
