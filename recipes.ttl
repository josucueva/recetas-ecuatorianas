<http://example.org/recipes/bebida/5> a schema1:Recipe ;
    schema1:description "El batido de galletas oreo es uno de los solicitados en los puestos de ventas de batidos en todos los pueblos de la costa ecuatoriana."@es ;
    schema1:name "Batido de oreo"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 cucharada de esencia de vainilla"@es,
        "125 ml o ½ taza de leche fría"@es,
        "6 galletas oreo"@es,
        "Nata montada"@es,
        "½ taza de helado de vainilla o de chocolate blanco"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/5/step/077c43fb88954c95b0e1602f98c653d6>,
        <http://example.org/recipes/bebida/5/step/1fcd786d56664c8a8bc4178e23e70cbd>,
