<http://example.org/recipes/sopa/47> a schema1:Recipe ;
    schema1:description """El repe lojano es una sopa hecha a base de plátanos, queso lojano(de ahí su nombre) y leche.
Es la sopa mas tradicional de la región de Loja."""@es ;
    schema1:name "Repe de loja"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla cortada en cubos"@es,
        "1500 cc de agua"@es,
        "2 cucharadas de aceite"@es,
        "2 dientes de ajo machacados"@es,
        "200 gr de queso lojano"@es,
        "6 plátanos verdes"@es,
        "75 cc de crema de leche"@es,
        "Cilantro fresco"@es,
        "Sal"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/47/step/874f8520b6834825907b13d20ae2e143>,
        <http://example.org/recipes/sopa/47/step/b69fef2c9d484fe59a9c12cef231baf3>,
