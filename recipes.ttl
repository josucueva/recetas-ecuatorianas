    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/21> a schema1:Recipe ;
    schema1:description "La Cauca es un potaje estofado hecho en base a maíz morocho y carne, el origen proviene de la provincia de Tungurahua."@es ;
    schema1:name "Cauca de choclo"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla"@es,
        "1 rama de perejil"@es,
        "1 taza de choclo"@es,
        "1 taza de leche"@es,
        "1 tomate"@es,
        "2 dientes de ajo"@es,
        "50 gr de mantequilla"@es,
        "500 gr de carne de cerdo"@es,
        "500 gr de papas"@es,
        "6 tazas de agua"@es,
        "Cilantro fresco"@es,
        "Sal, pimienta y comino al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/21/step/2607eadc995e4257a1edd3ee021a18a0>,
