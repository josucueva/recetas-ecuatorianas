        <http://example.org/recipes/sopa/48/step/ec396f3ab58448c69552b20335f4f201> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/sopa/49> a schema1:Recipe ;
    schema1:description "El chocho es una legumbre ecuatoriana que se ha hecho famosa por sus beneficios nutritivos, esta receta de salsa de chochos es ideal para acompañar carnes blancas."@es ;
    schema1:name "Salsa de chocho"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla blanca"@es,
        "2 dientes de ajo"@es,
        "200 gr de queso rallado"@es,
        "25 gr de mantequilla"@es,
        "250 gr de chochos"@es,
        "400 cc de leche"@es,
        "Cilantro picado"@es,
        "Jugo de medio limón"@es,
        "Sal y pimienta"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/49/step/22d8d8c68f24465b9beb3e5edaa7edad>,
