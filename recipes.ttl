<http://example.org/recipes/postre/69> a schema1:Recipe ;
    schema1:description "Es un postre clásico y muy rico que se prepara de una forma bastante fácil. Consiste de un biscocho bastante húmedo y jugoso que se baña en un caramelo con sabor a piña. Es muy común encontrarla en los hogares y en pastelerías, y puedes disfrutarla en cualquier ocasión."@es ;
    schema1:name "Volteado de piña"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de ron añejo"@es,
        "1 lata de rebanadas de piña en almíbar"@es,
        "1 ½ tazas de harina de trigo"@es,
        "1¼ tazas de azúcar"@es,
        "2 huevos"@es,
        "¼ de cucharadita de sal"@es,
        "½ taza de mantequilla sin sal"@es,
        "¾ de taza de yogur"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/69/step/0a19c07cf1aa4f478acae074cc425b42>,
        <http://example.org/recipes/postre/69/step/0d2102b6a3344940876216a4bce28a54>,
