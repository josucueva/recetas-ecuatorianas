<http://example.org/recipes/postre/19> a schema1:Recipe ;
    schema1:description "El dulce de higos es uno de esos postres que representan la esencia de Ecuador, son deliciosos y sencillos. El proceso para preparar los higos es un poco largo, tarda casi tres días, pero vale la pena la espera, es el toque ideal para el final a una buena comida."@es ;
    schema1:name "Dulce de higos"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 kilo de panela o piloncillo"@es,
        "1 pizca de bicarbonato"@es,
        "20 higos lavados maduros pero firmes"@es,
        "Agua"@es,
        "Canela, clavo de olor y otras especias"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/19/step/1237ae81278f41549333832d5a3d930f>,
        <http://example.org/recipes/postre/19/step/219eec1ddb414f5889e6d9665bb793fd>,
