        <http://example.org/recipes/postre/40/step/ef5a9d5bfb2849fe91f55779b282706e> ;
    schema1:recipeYield 10 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/41> a schema1:Recipe ;
    schema1:description "La mermelada de tomate de árbol o tamarillo, es un exquisito postre muy fácil de preparar. Esta fruta está llena de vitaminas y propiedades muy saludables, por lo que disfrutarla de esta forma deleitará su paladar. Es común acompañarla con galletas o pan."@es ;
    schema1:name "Mermelada de tomate de Árbol"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 limón"@es,
        "250 gr de azúcar"@es,
        "½ kg de tomates de palo bien maduros"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/41/step/2a3dc2c659bb42569c00af39223c0515>,
        <http://example.org/recipes/postre/41/step/7385e118ec18456383b1b2c0a2f507b3>,
