<http://example.org/recipes/plato-principal/11> a schema1:Recipe ;
    schema1:description "El bollo de pescado es un platillo típico tradicional de la costa ecuatoriana, pero que es consumido en todo el país. Su ingrediente principal es el plátano verde y el condumio de pescado."@es ;
    schema1:name "Bollo de pescado"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada (paiteña)"@es,
        "1 cucharada de cilantro picado fino"@es,
        "1 kg de filete de pescado (picudo, corvina, albacora, dorado)"@es,
        "1 pimiento verde"@es,
        "1 taza de caldo de pescado"@es,
        "1 taza de pasta de maní"@es,
        "2 tazas de agua"@es,
        "2 tomates"@es,
        "3 limones sutil"@es,
        "4 cucharadas de aceite o achiote"@es,
        "4 dientes de ajo machacados"@es,
        "8 plátanos verdes"@es,
        "Hojas de plátano para envolver"@es,
        "Sal, pimienta y comino"@es ;
