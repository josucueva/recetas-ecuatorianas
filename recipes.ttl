<http://example.org/recipes/plato-principal/4> a schema1:Recipe ;
    schema1:description "La receta de arroz y pollo ecuatoriana se acompaña con plátano frito. Es un plato simple y muy nutritivo."@es ;
    schema1:name "Arroz con pollo a la ecuatoriana"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla en cubos"@es,
        "1 cucharada de achiote"@es,
