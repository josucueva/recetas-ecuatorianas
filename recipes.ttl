        <http://example.org/recipes/plato-principal/110/step/a95444d652544707911d767cf94a9743> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/111> a schema1:Recipe ;
    schema1:description "Estos ricos tamales de arroz rellenos con carne, son un plato muy completo y con un sabor impresionante. Son ideales para un almuerzo, ya que combina la carne con los vegetales y el arroz, y sin olvidar el toque delicioso de la salsa de maní. Anímate y manos a la obra."@es ;
    schema1:name "Tamal de arroz en hoja de col"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 kg de carne de cerdo sin grasa"@es,
        "2 dientes de ajo triturados"@es,
        "2 tomates en rodajas"@es,
        "250 gr de maní tostado"@es,
        "3 cebollas paiteñas"@es,
        "3 cucharadas de hierbas y especies"@es,
        "3 cucharadas de perejil picadito"@es,
        "3 tazas de arroz blanco cocido"@es,
        "30 ml de aceite de achiote"@es,
        "500 ml de leche"@es,
        "Sal, pimienta y comino c/n"@es,
        "½ taza de crema de leche"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/111/step/0bd01cebb07844fe96d18c407c2a0ea8>,
        <http://example.org/recipes/plato-principal/111/step/15a9aabe41014fa8962264d85c951fb4>,
        <http://example.org/recipes/plato-principal/111/step/1d9afed5476a4f42a94502dc5c0db5cf>,
        <http://example.org/recipes/plato-principal/111/step/5091bd6706074b269e3f7f0a9d2104b8>,
        <http://example.org/recipes/plato-principal/111/step/5170429cffe64eacb139b754c7be9e8e>,
        <http://example.org/recipes/plato-principal/111/step/51a0dedbfe8c41adbc564d574c1c267a>,
        <http://example.org/recipes/plato-principal/111/step/9fdfed39c924428dae202a3478f4dc35>,
