<http://example.org/recipes/entrada/46> a schema1:Recipe ;
    schema1:description "La empanada de morocho es una receta tradicional que forma parte de la trilogía de las empanadas ecuatorianas y son ideales para acompañar con café, agua aromática y cualquier otra bebida."@es ;
    schema1:name "Empanadas de morocho"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 lb de maíz morocho quebrado"@es,
