<http://example.org/recipes/postre/36> a schema1:Recipe ;
    schema1:description "La javishca es una clásica bebida caliente de Ecuador, sus ingredientes principales son el zapallo y la leche y es la bebida preferida de la región serrana en épocas de cosecha."@es ;
    schema1:name "Javishca de zapallo"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 litro leche"@es,
        "1 zapallo mediano maduro"@es,
        "2 ramas de canela"@es,
        "2 tazas de panela"@es,
        "5 estrellas de anís estrellado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/36/step/31d4f2ac66c140eda6ff3f73abf6c42e>,
        <http://example.org/recipes/postre/36/step/3528f387e3cb42eebe9937728f08316d>,
