<http://example.org/recipes/plato-principal/34> a schema1:Recipe ;
    schema1:description "Esta deliciosa receta de pescado en crema te exaltará los sentidos, ya que forma parte de la variedad gastronómica que nos ofrecen los pueblos de la costa ecuatoriana. Te animamos a que la prepares y te luzcas en esta ocasión."@es ;
    schema1:name "Corvina en crema"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
