<http://example.org/recipes/postre/52> a schema1:Recipe ;
    schema1:description "Los pristiños con miel son muy tradicionales en Ecuador para disfrutar en cualquier fecha del año, son deliciosas masitas bañadas con miel."@es ;
    schema1:name "Pristiños"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de jugo de limón"@es,
