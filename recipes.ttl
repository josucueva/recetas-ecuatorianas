<http://example.org/recipes/plato-principal/107> a schema1:Recipe ;
    schema1:description "El sudado de pescado es un rico plato cocinado al vapor. Acompañado de chifles o arroz. Toda una delicia."@es ;
    schema1:name "Sudado de pescado con chifles"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
