<http://example.org/recipes/plato-principal/95> a schema1:Recipe ;
    schema1:description "El sango de verdes con pescado es una receta clásica de la gastronomía ecuatoriana, típica de la zona costera, el maní le da un sabor único!"@es ;
    schema1:name "Sango de verdes con pescado"@es ;
