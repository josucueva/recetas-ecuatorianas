<http://example.org/recipes/entrada/54> a schema1:Recipe ;
    schema1:description "Esta rica ensalada es una de las delicias de la cocina ecuatoriana, que se prepara preferiblemente con cangrejos frescos. Es muy fácil de elaborar y puede disfrutarse acompañada de un rico encurtido de cebollas."@es ;
    schema1:name "Ensalada de cangrejo"@es ;
