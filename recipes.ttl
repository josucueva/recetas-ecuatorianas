    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/35> a schema1:Recipe ;
    schema1:description "La corvina en salsa de mariscos, es un delicioso plato muy popular de las zonas costeras de Ecuador. Esta receta es muy sencilla de preparar, además de presentar una combinación de sabores exquisitos propias de los frutos del mar."@es ;
    schema1:name "Corvina en salsa de mariscos"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de jugo de limón"@es,
        "1 taza de harina"@es,
