<http://example.org/recipes/postre/5> a schema1:Recipe ;
    schema1:description "El arroz con leche es un postre típico del Ecuador que le encanta principalmente a los niños, se sirve frío o caliente."@es ;
    schema1:name "Arroz con leche"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de vainilla"@es,
        "1 taza de arroz"@es,
        "2 cucharadas de canela en polvo para espolvorear"@es,
        "2 ramas de canela"@es,
        "2 tazas de leche"@es,
        "5 clavos de olor"@es,
        "½ lata de leche condensada o 2 huevos batidos"@es,
