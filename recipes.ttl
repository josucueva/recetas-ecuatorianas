    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/42> a schema1:Recipe ;
    schema1:description "Rico postre característico de Ecuador. Generalmente se come en forma de orejitas. Endulzado con canela y azúcar."@es ;
    schema1:name "Milhojas y orejitas ecuatorianas"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 huevo"@es,
        "1 kg hojaldrina"@es,
        "Azucar al gusto"@es,
        "Canela al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/42/step/0207ba7820ca4ab6ab3586cb26c74cdc>,
