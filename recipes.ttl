<http://example.org/recipes/postre/18> a schema1:Recipe ;
    schema1:description "Suculentos higos acaramelados. Con un toque autentico de Ecuador del queso y la canela."@es ;
    schema1:name "Dulce de higo con queso"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 taza de panela"@es,
        "1 taza de queso"@es,
        "3 ramitas de canela"@es,
        "5 higos"@es,
