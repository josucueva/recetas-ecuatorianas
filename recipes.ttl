<http://example.org/recipes/bebida/4> a schema1:Recipe ;
    schema1:description "El mango es una de las frutas características de todo el caribe, en Ecuador crece en la región de Guayas y es consumido los días de mucho calor en forma de jugos y coladas frescas."@es ;
    schema1:name "Batido de mangos"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 durazno amarillo"@es,
        "1 litro de leche"@es,
        "4 mangos maduros"@es,
        "50 gr de azúcar morena"@es,
        "Hielo picado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/4/step/66a8446a40cb4420aa6ed067fd9d8e41>,
        <http://example.org/recipes/bebida/4/step/6e24858723854aba89507d28948f5046>,
        <http://example.org/recipes/bebida/4/step/76dc8c2b09db4a54853aa999e05b1a54>,
