<http://example.org/recipes/postre/16> a schema1:Recipe ;
    schema1:description "El babaco es una fruta original de la provincia de Loja, en Ecuador. Es un híbrido natural resultante del cruce entre toronche y chamburo. El dulce de babaco es una especie de almíbar hecho con la fruta, azúcar, agua y un poco de canela. Existen variantes de la receta donde añaden ron, cachaca o aguardiente."@es ;
    schema1:name "Dulce de Babaco"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 babaco maduro"@es,
        "1 rama de canela"@es,
        "2 clavos de olor"@es,
        "2 tazas de azúcar"@es,
        "Agua"@es,
        "Jugo de 1 limón"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/16/step/03dd79e547dc4571b3b131dfc3872b73>,
        <http://example.org/recipes/postre/16/step/529a5006b2c14f19aa8b237bb06dc85d>,
