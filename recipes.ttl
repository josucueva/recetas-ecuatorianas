    schema1:recipeYield 12 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/25> a schema1:Recipe ;
    schema1:description "Los envueltos de maqueño o plátano maduro es muy popular en Ecuador y su consumo se ha generalizado principalmente gracias a los migrantes colombianos que han llegado al país."@es ;
    schema1:name "Envueltos de maqueño"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 copa de licor anisado"@es,
        "125 gr de mantequilla"@es,
        "2 cucharaditas de polvo de hornear"@es,
        "3 huevos"@es,
        "4 plátanos maqueño rallados"@es,
        "Hojas de achira o de plátano"@es,
        "Vainilla al gusto"@es,
        "½ lb de queso"@es,
        "½ taza de azúcar"@es,
        "½ taza de maicena"@es,
        "½ taza de pasas enharinadas"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/25/step/52fbe6e485674a89b27c9d38be6acdea>,
