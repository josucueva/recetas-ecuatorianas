<http://example.org/recipes/postre/49> a schema1:Recipe ;
    schema1:description "Las nogadas son dulces artesanales muy ricos y típicos de la gastronomía de Ibarra. Tradicionalmente se les puede encontrar en cajitas de sauce envueltas en papel celofán."@es ;
