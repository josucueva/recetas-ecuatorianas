<http://example.org/recipes/bebida/27> a schema1:Recipe ;
    schema1:description "El coctel Ecuatoriano es una rica bebida con licor o ron, con un toque de hierba buena."@es ;
    schema1:name "Coctel ecuatoriano"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "120 ml de soda"@es,
        "2 cucharadas de azúcar blanca o morena"@es,
        "60 ml de ron blanco"@es,
        "8 hojas de hierba buena fresca"@es,
        "Hielo picadito"@es,
        "Jugó de maracuya"@es,
        "½ limón picado en trocitos"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/27/step/61a857a71dd149658d8fa10905c482e4>,
        <http://example.org/recipes/bebida/27/step/9d78b4d14f0e4331b1632e2bf094f938>,
