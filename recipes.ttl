<http://example.org/recipes/entrada/78> a schema1:Recipe ;
    schema1:description "En Ecuador, es común encontrarse con las clásicas salchipapas en ferias y fiestas. Es una entrada muy rica de papas fritas con salchichas. Es un plato súper fácil de hacer. Es perfecto para los días en que no hay mucho ánimo de cocinar o cuando hay visitas."@es ;
    schema1:name "Salchipapas Ecuatorianas"@es ;
