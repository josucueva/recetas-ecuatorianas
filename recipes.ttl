    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/53> a schema1:Recipe ;
    schema1:description "Los camarones son considerados afrodisíacos en Ecuador. Son parte del grupo de los mariscos y aportan al organismo elementos muy importantes para conservar o mejorar la salud masculina."@es ;
    schema1:name "Ensalada de camarones y manzanas"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cucharada de perejil picado"@es,
        "1 kg de camarones limpios, pelados y desvenados"@es,
        "1 lechuga escarola"@es,
        "1 limón"@es,
        "1 taza de agua"@es,
        "2 tallos de apio"@es,
        "4 manzanas rojas"@es,
        "Sal y pimienta al gusto"@es,
        "¼ de taza de pimiento rojo"@es,
        "¼ taza de cebollino"@es,
        "¼ taza de mayonesa"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/53/step/220f15c8421f491499124c80ea7a3844>,
