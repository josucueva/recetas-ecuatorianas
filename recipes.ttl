<http://example.org/recipes/bebida/65> a schema1:Recipe ;
    schema1:description "La guayusa es una planta autóctona de la región selvática ecuatoriana. Los pueblos originarios realizan infusiones con ella ya que tiene según la cultura poderes energizantes."@es ;
