<http://example.org/recipes/entrada/62> a schema1:Recipe ;
    schema1:description "Las humitas son pastelitos que se preparan con choclo y queso, un plato típico de la región andina de Ecuador que se acompañan bien con café."@es ;
    schema1:name "Humitas ecuatorianas"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla grande"@es,
        "1 cucharada de cilantro"@es,
        "2 dientes de ajo"@es,
        "2 huevos"@es,
        "3 tazas de queso rallado"@es,
        "6 choclos con sus hojas"@es,
        "Sal a gusto"@es,
        "½ taza de crema de leche"@es ;
