    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/24> a schema1:Recipe ;
    schema1:description "El tamarindo es cultivado en la provincia de Manabi, pero en todo el país es consumido ya sea en jugos o para darle un realce de sabor a los platos fuertes como el cerdo en salsa de tamarindo."@es ;
    schema1:name "Cerdo en salsa de tamarindo"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 rama de romero"@es,
        "1 taza de caldo de res o pollo"@es,
        "1 zanahoria amarilla"@es,
        "2 cucharadas de azúcar o miel"@es,
        "2 dientes de ajo"@es,
        "3 lb de lomo de cerdo o pernil de cerdo"@es,
        "Aceite de oliva o de aguacate"@es,
        "Sal y pimienta al gusto"@es,
        "½ lb de pulpa de tamarindo"@es,
        "½ taza de salsa de tomate"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/24/step/0b46f8a7f61b4fb996e7e2919b884182>,
        <http://example.org/recipes/plato-principal/24/step/8c80d22056924d2288412a7d79f3f092>,
        <http://example.org/recipes/plato-principal/24/step/8e980176e73f4ce79e124b64ab8dbc16>,
        <http://example.org/recipes/plato-principal/24/step/c41aa3d71e014b2ca6c9b38557da92de>,
        <http://example.org/recipes/plato-principal/24/step/cd28455bc11d47eea4bb2622dafe116a>,
        <http://example.org/recipes/plato-principal/24/step/ce051b0ba8284142bcc08e4ee9695677> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/plato-principal/25> a schema1:Recipe ;
    schema1:description "El tamarindo es un fruto consumido en todo el país ya sea en jugos, coladas o para realzar el sabor de platos fuertes como el de esta receta que presentamos aquí."@es ;
    schema1:name "Cerdo en salsa de tamarindos"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 taza de caldo"@es,
        "1 zanahoria"@es,
        "150 gr de salsa de tomate"@es,
        "1500 gr de pernil de cerdo"@es,
        "2 cucharadas de miel"@es,
        "250 gr de pulpa de tamarindo"@es,
        "4 dientes de ajo"@es,
        "Aceite de oliva"@es,
        "Sal, romero y pimienta a gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/25/step/3c26d9ebc7cc43c8a29a6ddb999d982a>,
