<http://example.org/recipes/postre/50> a schema1:Recipe ;
    schema1:description "Los paquetitos de maqueño o plátano maduro son un dulce muy popular en Ecuador, comparte su origen con la patria colombiana. Simples de realizar, son una delicia."@es ;
