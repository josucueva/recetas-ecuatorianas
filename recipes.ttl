    schema1:recipeYield 10 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/13> a schema1:Recipe ;
    schema1:description "El ceviche de camarón ecuatoriano es una de las recetas más fáciles y rápidas de preparar. Es considerado como el plato estrella dentro de la gastronomía ecuatoriana."@es ;
    schema1:name "Ceviche de Camarón"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cucharada de mostaza"@es,
        "1 kilo de camarones"@es,
