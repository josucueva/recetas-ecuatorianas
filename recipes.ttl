    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/33> a schema1:Recipe ;
    schema1:description "El helado frito está ganando bastante popularidad en Ecuador, especialmente en las ciudades grandes como Quito y Guayaquil"@es ;
    schema1:name "Helado frito"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 huevo"@es,
        "1 taza y media de harina de trigo"@es,
        "1 taza y media de leche de vaca, soja, almendras o la que prefieras."@es,
        "2 bolas de helado de tu sabor favorito"@es,
        "4 rebanadas de pan de molde blanco sin corteza"@es,
        "Aceite para freír"@es,
        "Sirope de chocolate, miel o nata (opcional)"@es ;
