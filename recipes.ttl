<http://example.org/recipes/postre/62> a schema1:Recipe ;
    schema1:description "El choclo es muy popular en la gastronomía de Ecuador y la torta de choclo es una de las tantas recetas tradicionales con este alimento delicioso y nutritivo. Este postre viene bien a cualquier hora del día acompañado con una buena taza de café."@es ;
    schema1:name "Torta de Choclo con Coco"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de esencia de vainilla"@es,
        "1 cucharadita de polvo de hornear"@es,
        "1 lata de leche condensada"@es,
        "2 huevos"@es,
        "5 cucharadas de mantequilla"@es,
        "6 choclos desgranados"@es,
        "Harina de trigo y mantequilla (para el molde)"@es,
        "½ taza de coco rallado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/62/step/1108c179a5e74ee5b5ca78845db22a6c>,
        <http://example.org/recipes/postre/62/step/293d2270de9842a381deac01a1e2f368>,
        <http://example.org/recipes/postre/62/step/4e9a1556ae2d49b286834abd3419d0cf>,
        <http://example.org/recipes/postre/62/step/687ba14edc8b4852a282752d4a896e5a>,
        <http://example.org/recipes/postre/62/step/838935c1727d4c798881dc51061eea9d> ;
    schema1:recipeYield 10 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/63> a schema1:Recipe ;
    schema1:description "Esta receta ecuatoriana de la torta de naranja es muy fácil, rica y económica de preparar. Esta torta esponjosa es ideal para compartir a la hora de la merienda acompañada de té o café."@es ;
    schema1:name "Torta de Naranja"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 taza de azúcar"@es,
        "1 taza de jugo de naranja"@es,
        "2 cucharaditas de polvo para hornear"@es,
        "3 huevos"@es,
        "3 tazas de harina de trigo previamente tamizada"@es,
        "Ralladura de una naranja"@es,
        "½ taza de aceite"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/63/step/0a85aa9202f5409c8aa98b002b36487c>,
        <http://example.org/recipes/postre/63/step/1031d710ef7441a0a9a8f4231a6b3ac1>,
        <http://example.org/recipes/postre/63/step/1d8b46f8a93b435f927bbdcb0e48eaaa>,
        <http://example.org/recipes/postre/63/step/40996a880a7541cd8b125170c2056110>,
        <http://example.org/recipes/postre/63/step/436b579122c14466bb614e7d9e93e99e> ;
    schema1:recipeYield 10 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/64> a schema1:Recipe ;
    schema1:description "El zapallo es una de las hortalizas más conocidas para hacer cremas, sopas o alguna otra preparación y últimamente han ganado mucha popularidad los pasteles de zapallo que son muy consumidos especialmente en la Semana Santa."@es ;
    schema1:name "Torta de zapallo"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 copita de ron"@es,
        "1 cucharadita de mantequilla"@es,
        "1 zapallo mediano"@es,
        "2 cucharaditas de canela en polvo"@es,
        "2 cucharaditas de polvo de hornear"@es,
        "3 huevos"@es,
        "¼ lb de queso fresco"@es,
        "½ cucharadita de sal"@es,
        "½ lb de azúcar"@es,
        "½ taza de leche"@es,
        "½ taza de pasas"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/64/step/23b4bff640be4bfead44efa3f0d6d281>,
        <http://example.org/recipes/postre/64/step/3069b8c48db84ffe91186b40c6cd6181>,
