<http://example.org/recipes/entrada/71> a schema1:Recipe ;
    schema1:description "El pan de ajo se puede servir sólo o acompañado de queso o embutido. Se puede preparar con antelación ya que aguanta crujiente hasta el día siguiente, aunque es mejor prepararlo la misma jornada."@es ;
    schema1:name "Pan de ajo"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 baguette de pan"@es,
