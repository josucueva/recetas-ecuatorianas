<http://example.org/recipes/sopa/37> a schema1:Recipe ;
    schema1:description "El locro es una sopa espesa, muy parecido a un guiso, muy popular en Sudamérica. En Ecuador, se prepara diferentes variaciones del locro de papas. En esta receta, la preparación es con habas, las cuales son muy populares en la Sierra ecuatoriana."@es ;
    schema1:name "Locro de Habas"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla blanca cortada en cubos"@es,
        "1 cucharadita de chile molido o ají en polvo"@es,
        "1½ tazas de queso desmenuzado"@es,
        "2 cucharadas de aceite"@es,
        "2 tomates pelados, sin semillas y cortados en cubos"@es,
        "3 cucharadas de cilantro finamente cortado"@es,
        "3 huevos ligeramente batidos"@es,
        "3 papas peladas y cortadas en cubos"@es,
        "4 dientes de ajo machacados"@es,
        "4 tazas de habas peladas"@es,
        "6 tazas de agua o caldo de pollo"@es,
        "Sal al gusto"@es,
        "½ cucharada de comino molido"@es,
        "½ cucharadita de achiote molido"@es,
        "½ taza de leche"@es ;
