    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/39> a schema1:Recipe ;
    schema1:description "Las medias lunas son un delicioso postre que puedes encontrar en los restaurantes ecuatorianos y que son muy fáciles de preparar en tu hogar para que te luzcas con tus invitados."@es ;
    schema1:name "Medias Lunas de Nuez"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharadita de extracto de vainilla"@es,
        "1 taza de mantequilla"@es,
        "2 tazas de harina de trigo"@es,
        "2 tazas de nueces picadas"@es,
        "½ cucharadita de sal"@es,
        "½ taza de azúcar glass"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/39/step/05bf7b2a338c498b8d65e9944477beae>,
        <http://example.org/recipes/postre/39/step/1ca7601308164ec9baf26c566900e843>,
