<http://example.org/recipes/postre/11> a schema1:Recipe ;
    schema1:description "Las cocadas son un dulce clásico de Ecuador. Manjar famoso que lleva al coco como su ingrediente estrella."@es ;
    schema1:name "Cocadas ecuatorianas"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 coco entero rallado"@es,
