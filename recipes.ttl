<http://example.org/recipes/sopa/14> a schema1:Recipe ;
    schema1:description "El caldo de mondongo es un plato típico en la gastronomía ecuatoriana, es muy rico con mucho sabor, que se elabora bajo un proceso un poco laborioso pero que sin duda resultará en un plato suculento. Anímate a probarla."@es ;
    schema1:name "Caldo de mondongo"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 ají rocoto"@es,
        "1 cebolla blanca picada"@es,
        "1 cucharada de culantro"@es,
        "1 manojo de cilantro"@es,
        "1 rama de cebolla en ramas"@es,
        "2 cucharadas de aceite con achiote"@es,
        "2 limones"@es,
        "5 dientes de ajo"@es,
        "500 gr de mondongo"@es,
        "Hojas de hierbabuena"@es,
        "Sal y pimienta c/n"@es ;
