<http://example.org/recipes/sopa/33> a schema1:Recipe ;
    schema1:description "La fanesca es un plato popular en Ecuador conocido por ser preparado durante la época de Semana Santa. Es una sopa a base de granos tiernos y pescado seco y suele servirse caliente con trozos de bacalao, plátano maduro frito, ají rojo, hojas de perejil, queso y rodajas de huevos cocidos."@es ;
    schema1:name "Fanesca Ecuatoriana"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cucharada de comino molido"@es,
        "1 cucharada de orégano seco"@es,
        "1 cucharadita de achiote molido"@es,
        "1 cucharadita de pimienta molida"@es,
        "1 kilo de bacalao seco"@es,
        "1 taza de cebolla cortada"@es,
        "1 taza de crema de leche"@es,
        "1 taza de queso rallado"@es,
        "10 dientes de ajo machacados"@es,
        "12 onzas de queso crema"@es,
        "12 tazas de leche"@es,
        "2 tazas de alubias o frijol blanco cocinado"@es,
        "2 tazas de arroz cocinado"@es,
        "2 tazas de chochos pelados"@es,
        "2 tazas de col cortada finamente"@es,
        "2 tazas de habitas blancas cocinadas"@es,
        "2 tazas de maní tostado"@es,
        "3 tazas de arvejas cocinadas"@es,
        "4 tazas de choclo desgranado y cocinado"@es,
        "4 tazas de habas cocinadas y peladas"@es,
        "6 cucharadas de cilantro o perejil cortado finamente"@es,
        "6 tazas de sambo fresco cortado en cubos"@es,
        "6 tazas de zapallo"@es,
