<http://example.org/recipes/entrada/56> a schema1:Recipe ;
    schema1:description "El palmito y el aguacate son muy consumidos por los ecuatorianos. Además Ecuador es el principal exportador de palmito."@es ;
    schema1:name "Ensalada de palmito y aguacate"@es ;
