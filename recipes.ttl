<http://example.org/recipes/postre/54> a schema1:Recipe ;
    schema1:description "Las quesadillas, son bocados dulces de gran sabor, que son tradicionales en la ciudad de Quito, capital de los ecuatorianos. Esta delicia criolla suele acompañarse con helado o los famosos salpicones (jugos de fruta natural con hielo raspado)."@es ;
    schema1:name "Quesadillas Ecuatorianas"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de maicena"@es,
        "1 cucharadita de mantequilla"@es,
        "1 huevo"@es,
        "1 taza de azúcar impalpable"@es,
        "1 taza de harina de trigo"@es,
        "1 taza de queso rallado"@es,
        "4 yemas de huevo"@es,
        "½ cucharadita de sal disuelta en 2 cucharadas de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/54/step/037885fe169c481b983fb561eb4eda7f>,
