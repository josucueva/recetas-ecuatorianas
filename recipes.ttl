    schema1:recipeYield 2 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/115> a schema1:Recipe ;
    schema1:description "La tilapia es un pescado que muestra crecimiento en el consumo y producción en el Ecuador y la tilapia apanada es un platillo muy delicioso y fácil de preparar"@es ;
    schema1:name "Tilapia apanada"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 huevo"@es,
        "1 taza harina"@es,
        "2 dientes ajo"@es,
        "2 filetes de tilapia"@es,
        "2 limones sutil"@es,
        "Paprika"@es,
        "Sal y pimienta al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/115/step/0b9f9dc38d144c99a85820819ac83973>,
        <http://example.org/recipes/plato-principal/115/step/2916376e43d14933aa4b41002fb6d822>,
