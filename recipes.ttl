<http://example.org/recipes/postre/4> a schema1:Recipe ;
    schema1:description "El aplanchado es un dulce tradicional de la Sierra, en el Ecuador. Este postre consiste en una capa de masa de hojaldre cubierta por una capa de azúcar glasé."@es ;
    schema1:name "Aplanchados"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 huevo entero"@es,
        "1 pizca de sal"@es,
        "1½ cucharadita de esencia de vainilla"@es,
        "1½ cucharaditas de polvo de hornear"@es,
        "2 tazas de azúcar impalpable"@es,
        "2 yemas de huevo"@es,
        "4 cucharadas de jugo de naranja"@es,
        "5 cucharadas de mantequilla"@es,
        "¼ de taza de aceite"@es,
        "½ kilo de harina de trigo"@es,
        "½ taza de azúcar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/4/step/06ea26f4c80a4f8984cca9f5bfdf93c7>,
        <http://example.org/recipes/postre/4/step/2db74693cf494b5e994346599953bf40>,
