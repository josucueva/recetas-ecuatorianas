    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/15> a schema1:Recipe ;
    schema1:description "La chirimoya es originaria de la parte sur del Ecuador, en la provincia de Loja, donde se encuentra formando densos bosques silvestres. La crema de chirimoyas es un postre que tiene un exquisito sabor y es muy fácil de realizar."@es ;
    schema1:name "Crema de chirimoyas"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 lata de leche evaporada"@es,
        "1 taza azúcar"@es,
        "1 taza de agua"@es,
        "4 sobres de gelatina sin sabor"@es,
        "900 gr de pulpa de chirimoya"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/15/step/181a0044e11c44fe84f43e52b7c6c1c3>,
