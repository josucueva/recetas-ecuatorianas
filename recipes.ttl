    schema1:recipeYield 6 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/plato-principal/49> a schema1:Recipe ;
    schema1:description "La receta del filete de corvina frito entra en el grupo de recetas más utilizadas en la cocina ecuatoriana, debido a su fácil preparación y a su exquisito sabor la corvina tiene gran aceptación en los hogares ecuatorianos."@es ;
    schema1:name "Filete de corvina frita"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 huevo"@es,
        "1 kilogramo de filete de corvina"@es,
        "1 limón"@es,
        "Aceite para freír"@es,
        "Sal al gusto"@es,
        "½ taza de harina"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/49/step/0e3d729e98fe454f95897d592e39d1d6>,
        <http://example.org/recipes/plato-principal/49/step/876f1788bdfd4473a37a713e666113a0>,
