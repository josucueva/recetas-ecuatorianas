    schema1:recipeYield 8 ;
    schema1:totalTime "PT15M"^^xsd:duration .

<http://example.org/recipes/postre/14> a schema1:Recipe ;
    schema1:description "La chirimoya es una planta comestible originaria del sur del Ecuador, donde crece de forma silvestre, tiene un exquisito sabor que se expresa muy bien en esta crema."@es ;
    schema1:name "Crema de chirimoya"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 lata de leche condensada"@es,
        "1 taza azúcar"@es,
        "1 taza de agua"@es,
        "3 sobres de gelatina sin sabor"@es,
        "750 gr de pulpa de chirimoya"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/14/step/25c91ec84a5b4d0b9267e8336493959f>,
        <http://example.org/recipes/postre/14/step/3fc509a6c94d4d538ccc4d07abab8944>,
