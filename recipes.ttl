<http://example.org/recipes/sopa/29> a schema1:Recipe ;
    schema1:description "El encebollado de pescado es un plato típico de la gastronomía ecuatoriana que se elabora con albacora o atún fresco, yuca, vegetales y hierbas. Se suele acompañar con curtido de cebollas, ají o salsa picante. Anímate a prepararlo y disfrutarás de un plato con mucho sabor."@es ;
    schema1:name "Encebollado de pescado"@es ;
