    schema1:recipeYield 8 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/entrada/19> a schema1:Recipe ;
    schema1:description "Una receta tradicional ecuatoriana, el delicioso ceviche de conchas negras. Este platillo se prepara a base de conchas prietas embebidas en un curtido de cebollas, tomates limón sutil y culantro. Se degusta acompañadas de patacones o maíz tostado."@es ;
    schema1:name "Ceviche de conchas"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 pimiento verde"@es,
        "1 rama de culantro"@es,
        "10 limones sutiles"@es,
        "2 cebollas paiteñas cortadas en rodajas finas"@es,
        "2 cucharadas de cebollita verde"@es,
        "2 tomates cortados en cuadros"@es,
        "50 conchas negras o prietas (vivas y bien frescas)"@es,
        "Aceite de oliva"@es,
        "Sal"@es,
        "Salsa de tomate y mostaza al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/19/step/7faf174e69f04b9282547b21203f20bb>,
        <http://example.org/recipes/entrada/19/step/9119839b5573424e8a02b9822dd9282e>,
        <http://example.org/recipes/entrada/19/step/a290ced59aeb40e8a52270003fbff239>,
        <http://example.org/recipes/entrada/19/step/cd88549a729f41bb94441fd8b99782fa>,
        <http://example.org/recipes/entrada/19/step/d2b6862029134810951f8b49c5b09ef1>,
        <http://example.org/recipes/entrada/19/step/ee66b26f66d84d8fbbdbf4007be358c7> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/entrada/2> a schema1:Recipe ;
    schema1:description "Los aguacates rellenos con camarones son una de las entradas más deliciosas de la gastronomía ecuatoriana. El exquisito relleno se realiza con el camarón como estrella, acompañado de rábanos, pimientos, huevos y mayonesa de hierbas. Te invitamos a disfrutarlos."@es ;
    schema1:name "Aguacates rellenos con camarones"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla paiteña"@es,
        "1 huevo cocido"@es,
        "1 pimiento rojo"@es,
        "1 tallo de apio"@es,
        "2 cucharadas de mayonesa de hierbas"@es,
        "2 limones sutil"@es,
        "200 gr de camarones cocidos (sin vena y sin conchas)"@es,
        "4 aguacates maduros"@es,
        "4 rabanitos"@es,
        "Sal y pimienta al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/2/step/85311d17435146b58c1b0225f8ea6579>,
        <http://example.org/recipes/entrada/2/step/9a48d446da7741ea9f2e65b4be73189e>,
        <http://example.org/recipes/entrada/2/step/ace53e154279417984d63158f88ec590>,
        <http://example.org/recipes/entrada/2/step/c8cb38e3240e463399ba217267d9ebfd>,
        <http://example.org/recipes/entrada/2/step/fee6a17eaabd4f45822b36a1784538ce> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/20> a schema1:Recipe ;
    schema1:description "En Ecuador uno de los platos típicos es el ceviche de pescado. Suele prepararse con una variedad de estos, pero en esta ocasión lo haremos con corvina fresca. Una explosión de sabores y la textura tierna del pescado marinado en limón, le confieren un lugar privilegiado dentro de la cocina latinoamericana."@es ;
    schema1:name "Ceviche de corvina"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla colorada cortada en tiras"@es,
        "1 kg de filetes de corvina fresca"@es,
        "15 limones"@es,
        "Ají chile al gusto"@es,
        "Culantro al gusto"@es,
        "Sal y pimienta al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/20/step/029cdfd28e074a9c9e31afb1c0b13d6f>,
        <http://example.org/recipes/entrada/20/step/09f24c3b85cc496baafbd62797b93e06>,
        <http://example.org/recipes/entrada/20/step/1ffebe4373a94c629ab5e62a8c9dc1bf>,
        <http://example.org/recipes/entrada/20/step/445908b7f9c444c49495b719cdbd5624>,
        <http://example.org/recipes/entrada/20/step/e5b9efcbabed4f4ba2807f70b5cb6433> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/21> a schema1:Recipe ;
    schema1:description "Delicia de sabor preparado como ceviche. Compuestos por langostinos frescos y cilantro picadito. Ideal como entrada."@es ;
    schema1:name "Ceviche de langostinos"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla morada"@es,
        "1 cucharada de mostaza"@es,
        "1 kg langostinos"@es,
        "1 naranja"@es,
        "5 limones"@es,
        "5 tomates"@es,
        "Cilantro picado"@es,
        "Sal"@es,
        "Salsa kétchup al gusto"@es,
        "½ lts de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/21/step/1303d132777543f1b0e89cd29a5c397f>,
        <http://example.org/recipes/entrada/21/step/54040485a19e435eba672e38e46fb3b5>,
