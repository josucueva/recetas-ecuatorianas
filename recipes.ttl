<http://example.org/recipes/sopa/53> a schema1:Recipe ;
    schema1:description "Deliciosa sopa, de las mejores que se puede probar en Ecuador. Tienen por mucho, su toque gourmet, innovada de las mejor cocinas de la costa meridional."@es ;
