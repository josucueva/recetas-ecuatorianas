<http://example.org/recipes/plato-principal/86> a schema1:Recipe ;
    schema1:description "El pollo al horno es exquisito y muy popular en las culturas gastronómicas del mundo. En esta receta lo prepararemos dándole el toque y el sabor ecuatoriano. No pierdas la oportunidad de deleitarte con este suculento plato."@es ;
    schema1:name "Pollo al horno al estilo ecuatoriano"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharadita de pasta de ajo"@es,
        "1 rama de cebolla verde"@es,
        "8 piezas de pollo con piel"@es,
        "Sal, pimienta, y comino c/n"@es,
        "¼ taza de agua"@es ;
