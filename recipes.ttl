<http://example.org/recipes/bebida/1> a schema1:Recipe ;
    schema1:description "El batido de borojó es famoso en toda la población ecuatoriana debido a los efectos afrodisíacos naturales que se le conocen. Vale la pena probarlo!"@es ;
    schema1:name "Batido de borojó"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de agua"@es,
        "1 litro de leche"@es,
        "2 huevos"@es,
        "2 tazas de azúcar"@es,
        "250 gr de pulpa de borojó"@es,
        "Esencia de vainilla"@es,
        "Pizca de nuez moscada"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/1/step/49e49562837c411598628c29db0ecd46>,
        <http://example.org/recipes/bebida/1/step/7d2ea107121b44dbacd78a0dc82b5bf9>,
        <http://example.org/recipes/bebida/1/step/936c617df0f7420daf877607b976baf2>,
        <http://example.org/recipes/bebida/1/step/d616a0ed21d14de5a825685a42fb9d9a> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT15M"^^xsd:duration .

<http://example.org/recipes/bebida/10> a schema1:Recipe ;
    schema1:description "Ecuador cultiva uno de los chocolates más apreciados del mundo y en todas las regiones del país se preparan numerosas bebidas de chocolate."@es ;
    schema1:name "Bebida de chocolate"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "2 ramas de canela"@es,
        "4 pepitas de pimienta dulce"@es,
        "4 tazas de leche"@es,
        "Azúcar al gusto"@es,
        "½ taza de chocolate"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/10/step/4d33d22c74e243a8adae01c7e34f9258>,
        <http://example.org/recipes/bebida/10/step/760adaa8a88c44d195404806ad09a4bc>,
