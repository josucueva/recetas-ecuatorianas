    schema1:recipeYield 2 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/93> a schema1:Recipe ;
    schema1:description "La quinua marinera o quinua con mariscos, es una receta muy parecida a la paella de mariscos donde el arroz es sustituido por la quinua. Este es un grano de alto valor nutritivo y grandes propiedades, por lo que dentro de la gastronomía tiene su protagonismo. Así que manos a la obra y anímate a preparar este exquisito plato que es ejemplo de la comida saludable y deliciosa."@es ;
    schema1:name "Quinua marinera"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 manojo de cilantro"@es,
        "1 pimiento verde picado en cubos"@es,
        "1 taza de arvejas"@es,
        "10 dientes de ajo"@es,
        "2 cebollas blanca finamente picadas"@es,
        "2 tazas de quinua"@es,
        "200 gr de vieiras"@es,
        "300 gr de calamares frescos"@es,
        "4 tazas de caldo de mariscos"@es,
        "500 gr de almejas o conchas frescas"@es,
        "500 gr de camarones frescos y limpios"@es,
        "Comino"@es,
        "Pimienta"@es,
        "Sal"@es,
        "½ taza de aceite de achiote"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/93/step/4a840f52059b4a71b5c5d8036affb031>,
        <http://example.org/recipes/plato-principal/93/step/803cfc4a749246df8c7f2eea9086687c>,
