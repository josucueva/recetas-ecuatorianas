<http://example.org/recipes/plato-principal/117> a schema1:Recipe ;
    schema1:description "Este es un plato oriundo de la región serrana del Ecuador, su ingrediente estrella son las tripas de res asada. El nombre del plato significa \"de buen sabor\"."@es ;
    schema1:name "Tripa mhisqui"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 kg de mote"@es,
        "1 kg de papas cocidas"@es,
        "1 kg de tripas de res"@es,
        "2 dientes de ajo"@es,
        "Jugo de 2 limones"@es,
        "Menta hierba buena"@es,
        "Sal al gusto"@es,
        "Una pizca de achiote"@es,
        "Una pizca de comino"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/117/step/3048cd24476541c3820487adbb0c44e4>,
