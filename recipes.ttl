<http://example.org/recipes/entrada/34> a schema1:Recipe ;
    schema1:description "En Ecuador, es típico encontrar venta de choclos asados en las calles. Suelen servirlos con una deliciosa salsa de queso y cilantro. Esta receta ecuatoriana es muy fácil de preparar y es ideal como entrada o acompañante de otros platos."@es ;
    schema1:name "Choclos con Salsa de Queso y Cilantro"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 huevo"@es,
        "2 dientes de ajo machacados"@es,
        "4 choclos o mazorcas de maíz"@es,
        "6 onzas de queso desmenuzado"@es,
        "Jugo de 1 limón"@es,
        "Mantequilla para engrasar"@es,
        "Sal al gusto"@es,
        "¼ taza de cilantro picado finamente"@es,
        "¾ de taza de aceite"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/34/step/17b71612ad63460cb90cc85c4908f38e>,
