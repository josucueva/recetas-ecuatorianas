<http://example.org/recipes/entrada/27> a schema1:Recipe ;
    schema1:description "El chapati es un pan sin levadura típico de la India y Pakistán, pero es muy consumido en Ecuador debido a la influencia que tiene la comida hindú en el país."@es ;
    schema1:name "Chapati"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cucharada de aceite vegetal."@es,
        "1 taza de agua"@es,
        "1 ½ lb de harina de trigo integral"@es,
