    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/sopa/48> a schema1:Recipe ;
    schema1:description "El repe es la sopa más popular de Loja, ubicada al sur de Ecuador. Con una base de verde, leche, quesillo lojano y culantro, el repe lojano ha caracterizado la gastronomía de la región."@es ;
    schema1:name "Repe Lojano"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla cortada en cubos"@es,
        "2 cucharadas de aceite"@es,
        "2 dientes de ajo machacados"@es,
        "4 onzas de quesillo desmenuzado o queso mozzarella"@es,
        "6 plátanos verdes, pelados y cortados en cubos"@es,
        "8 tazas de agua"@es,
        "Sal al gusto"@es,
        "½ taza de cilantro o culantro cortado finamente"@es,
        "½ taza de leche o crema de leche"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/48/step/569c37f760d44c528b646edb526e354f>,
        <http://example.org/recipes/sopa/48/step/b83c409c823248bab538dbcf50e5ea4d>,
