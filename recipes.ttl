        <http://example.org/recipes/entrada/60/step/f83e62bb091b49b9ba60cf53f7bb318d> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/61> a schema1:Recipe ;
    schema1:description "Las humitas son un plato característico de Ecuador. Compuesto a base de choclos tiernos. Toda una exquisitez."@es ;
    schema1:name "Humitas dulces"@es ;
