<http://example.org/recipes/plato-principal/68> a schema1:Recipe ;
    schema1:description "El locro de Ecuador es una sopa cremosa hecha en base a papas y queso. Es una comida tradicional de la zona serrana donde se le da el nombre de locro quiteño."@es ;
