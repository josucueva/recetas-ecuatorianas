        <http://example.org/recipes/plato-principal/19/step/c3cacf8c40574d97abbb3309345d6256>,
        <http://example.org/recipes/plato-principal/19/step/f2b1f54e4bf148288153c36a5cc52a9c> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/plato-principal/2> a schema1:Recipe ;
    schema1:description "El arroz es muy popular entre los ecuatorianos y existe gran variedad de recetas con arroz, en especial los que contienen mariscos. Esta receta de arroz con camarones, plato típico de la costa de Ecuador, es exquisita y muy fácil de preparar."@es ;
    schema1:name "Arroz con Camarones"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada cortada en cubos"@es,
        "1 cucharadita de achiote molido"@es,
        "1 kilo de camarones lavados y sin tripita (sin pelar)"@es,
        "1 pimiento cortado en cubos"@es,
        "2 cucharadas de aceite"@es,
        "2 cucharaditas de comino molido"@es,
        "2 tazas de arroz (sin cocer)"@es,
        "2 tomates pelados y sin semillas cortados en cubos"@es,
        "3 cucharadas de mantequilla"@es,
        "4 dientes de ajo cortados"@es,
        "4 dientes de ajo machacados"@es,
        "6 cucharadas de perejil finamente cortado"@es,
        "sal y pimienta al gusto"@es,
        "½ taza de vino blanco"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/2/step/38db36bb330747929b6fe053381d1367>,
        <http://example.org/recipes/plato-principal/2/step/3f15e301b87b4a12b9fc34978067bdcb>,
