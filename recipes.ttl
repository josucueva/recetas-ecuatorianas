<http://example.org/recipes/plato-principal/78> a schema1:Recipe ;
    schema1:description "El Pandao de pescado o Panda, como tradicionalmente se le llama, es un plato típico de los pueblos afrodescendientes del Ecuador. Se preparaba originalmente con pescado de río pero en la actualidad se utilizan pescados de mar, los cuales son envueltos en hojas blancas para posteriormente asarlos a la brasa."@es ;
    schema1:name "Pandao de pescado o panda"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla blanca en brunoise"@es,
        "1 cucharada de ajo molido"@es,
        "1 cucharada de jugo de limón"@es,
        "1 kg de filetes de corvina"@es,
        "1 taza de leche de coco"@es,
        "2 cucharadas de aceite de achiote"@es,
        "2 cucharadas de jugo de naranja"@es,
        "2 hojas de bijao medianas"@es,
        "Hierbas (chillangua, oreganón y chirarán)"@es,
        "Sal, pimienta c/n"@es ;
