    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/sopa/55> a schema1:Recipe ;
    schema1:description "Esta deliciosa sopa, también conocida con mucho cariño como arvejitas con guineo, es típica de la provincia de Loja, en el sur del Ecuador. La sopa de arvejas con guineo se sirve acompañada de aguacate y ají."@es ;
    schema1:name "Sopa de Arvejas con Guineo"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla finamente cortada"@es,
        "1 taza de leche"@es,
        "2 cucharadas de aceite"@es,
        "4 cucharadas de cilantro finamente cortado"@es,
        "6 dientes de ajo machacados"@es,
        "6 guineos verdes pelados y cortados en cubos pequeños"@es,
        "6 tazas de agua"@es,
        "Sal y pimienta al gusto"@es,
        "½ cucharada de achiote molido (opcional)"@es,
        "½ cucharada de comino molido"@es,
        "½ kilo de arvejas secas"@es,
