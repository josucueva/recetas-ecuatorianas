<http://example.org/recipes/bebida/7> a schema1:Recipe ;
    schema1:description "El taxo, tumbo o curuba es una fruta de la región serrana ecuatoriana, es conocida por sus beneficios sobre la salud al ser rica en vitaminas y minerales, una forma rica de incorporarla es en batidos frescos."@es ;
    schema1:name "Batido de taxos"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de agua"@es,
        "2 claras de huevo"@es,
        "2 tazas de leche"@es,
        "50 gr de azúcar"@es,
        "6 taxos maduros"@es,
        "Esencia de vainilla"@es,
        "½ litro de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/7/step/48beb9fcbe494cb4802d01f6f5bc805d>,
