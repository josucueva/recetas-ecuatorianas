    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/29> a schema1:Recipe ;
    schema1:description "Las guaguas son un pan muy tradicional de Ecuador preparadas especialmente para celebrar el día de los difuntos."@es ;
    schema1:name "Guaguas de pan"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de azúcar"@es,
