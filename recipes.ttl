        <http://example.org/recipes/postre/31/step/cda2ab425ca9491898d5212ff67dbfbc> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/32> a schema1:Recipe ;
    schema1:description "Rico postre frió preparado en paila con la ayuda de hielo. Un autentico Helado Ecuatoriano."@es ;
    schema1:name "Helado de paila de mora y mango ecuatoriano"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 mango grande picado en trozos pequeños"@es,
        "1 taza de mora"@es,
        "1,5 lb de sal en grano"@es,
        "200 gr de azúcar"@es,
        "Pala de madera"@es,
        "Un recipiente grande para colocar hielo"@es,
        "Un yute para poner debajo de la paila o bolsa plástica"@es,
        "Una bolsa grande de hielo picado"@es,
        "Una paila pequeña"@es,
        "½ tasa de crema de leche fria"@es ;
