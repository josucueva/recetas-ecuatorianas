    schema1:recipeYield 2 ;
    schema1:totalTime "PT15M"^^xsd:duration .

<http://example.org/recipes/bebida/15> a schema1:Recipe ;
    schema1:description "Esta deliciosa bebida originaría de las culturas prehispánicas, es un tipo de mazamorra realizada principalmente con harina de maíz, frutas nativas, especias y el toque especial del chaguarmishqui. Generalmente se sirve bien frío."@es ;
    schema1:name "Champús"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 babaco picado"@es,
        "1 panela"@es,
        "10 naranjillas"@es,
        "2 tazas de piña cortada en cuadros"@es,
        "3 litros de agua"@es,
        "3 ramas de canela"@es,
        "5 hojas de naranjo"@es,
        "500 gr de maíz quebrado"@es,
        "6 clavos de olor"@es,
        "Hielo"@es,
        "Ishpingo"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/15/step/1802d68c9388450ba5442b51f16fba3e>,
        <http://example.org/recipes/bebida/15/step/4745254159124e2696c870b5da6f4727>,
        <http://example.org/recipes/bebida/15/step/4bd42d71f0c84e8da92c1684ad4e4523>,
        <http://example.org/recipes/bebida/15/step/550d930017db4db6af26a00883dda511>,
        <http://example.org/recipes/bebida/15/step/6af0e8fca15b49cbae229828944c39dd>,
        <http://example.org/recipes/bebida/15/step/fa741a0cbfef433ea3219de2ce3c3703> ;
    schema1:recipeYield 10 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/16> a schema1:Recipe ;
    schema1:description "La chicha de arroz es una bebida muy refrescante. Tradicional de Ecuador. Preparada a base de arroz con un toque de canela."@es ;
    schema1:name "Chicha de arroz"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de leche"@es,
        "1 taza de arroz, remojado un día antes"@es,
        "Canela molida"@es,
        "Clavos dulces"@es,
        "Panela o azúcar"@es,
        "Pimienta dulce"@es,
        "Vainilla"@es,
        "½ litro de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/16/step/170c39e9a04c4333a5541ad1cdd1027b>,
        <http://example.org/recipes/bebida/16/step/46c5a3a9c7b641529e911897e8890216>,
        <http://example.org/recipes/bebida/16/step/9a53546729c6464d827604df3c41737e>,
        <http://example.org/recipes/bebida/16/step/9e8ad75ddb2744db9ea84221f1544233>,
        <http://example.org/recipes/bebida/16/step/aa29a4a52f904694b5a1f419bedb0247>,
        <http://example.org/recipes/bebida/16/step/afb35c9226d34ef6a1fa686b2abf8dbc>,
        <http://example.org/recipes/bebida/16/step/cab90ea97b7f427da69096d02a0cb3bd>,
