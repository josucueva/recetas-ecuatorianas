    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/75> a schema1:Recipe ;
    schema1:description "El pernil de cerdo es la extremidad trasera del cerdo horneada, se suele acompañar de tortillas de papa o papas cocidas."@es ;
