    schema1:recipeYield 10 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/28> a schema1:Recipe ;
    schema1:description "Las tradicionales galletas de coco rallado, son uno de los postres más apetecidos para compartir en las meriendas vespertinas. Estos deliciosos bocadillos dulces tienen un sabor muy especial, característico del coco y pueden disfrutarse acompañadas de helado o con una taza de café o chocolate caliente."@es ;
    schema1:name "Galletas de coco"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 huevo"@es,
        "100 gr de harina"@es,
        "100 gr de mantequilla"@es,
        "200 gr de coco rallado"@es,
        "220 gr de azúcar"@es,
        "½ cucharadita de polvo de hornear"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/28/step/2b534b95f66c41b586ad571fed35f52f>,
        <http://example.org/recipes/postre/28/step/3c3a98ac712743bb94a22313174c8c79>,
