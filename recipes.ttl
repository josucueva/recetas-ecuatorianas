<http://example.org/recipes/entrada/77> a schema1:Recipe ;
    schema1:description "El risotto de camarones y aguacate es una verdadera delicia que contiene dos productos muy consumidos en todo el territorio ecuatoriano y que incluso son considerados afrodisíacos."@es ;
