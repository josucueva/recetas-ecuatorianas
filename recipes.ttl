<http://example.org/recipes/entrada/42> a schema1:Recipe ;
    schema1:description "Las deliciosas empanadas de atún son una de las recetas más fáciles de preparar. Suelen servirse como platillos de entrada en cualquier ocasión y su secreto está en las variantes del relleno, que le aportarán ese toque especial."@es ;
    schema1:name "Empanadas de atún"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla blanca"@es,
