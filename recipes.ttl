    schema1:recipeYield 10 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/2> a schema1:Recipe ;
    schema1:description "Ricos dulces de alfajores rellenos con manjar o dulce de leche. Tradicionales de Ecuador."@es ;
    schema1:name "Alfajores rellenos de manjar"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 huevo"@es,
        "1 tapita de limón"@es,
