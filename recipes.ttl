<http://example.org/recipes/plato-principal/23> a schema1:Recipe ;
    schema1:description "La cecina es un plato distintivo de la Provincia de la Loja. Es muy apetecido y de acuerdo a la tradición, se prepara a base de carne de cerdo fileteada adobada y que se cocina sobre el ahumado de leña."@es ;
    schema1:name "Cecina lojana"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 ½ kg de lomo de cerdo"@es,
        "2 cucharadas de aceite de achiote"@es,
        "2 cucharadas de pasta de ajo"@es,
        "Comino"@es,
        "Pimienta"@es,
        "Sal"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/23/step/3117e4d37e814f08aec33170b5d66f45>,
        <http://example.org/recipes/plato-principal/23/step/5598938df9fa4285969e30624b35dd8a>,
