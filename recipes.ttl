    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/26> a schema1:Recipe ;
    schema1:description "La chanfaina es un plato de origen español que fue introducido en el Ecuador con la conquista. Este plato está basado en vísceras picadas, que pueden ser de chancho, de borrego, de res, o de otro animal."@es ;
    schema1:name "Chanfaina"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cabeza de ajo machacado"@es,
        "1 cucharada de manteca de chancho"@es,
        "2 cebollas coloradas (paiteña)"@es,
        "2 cucharadas de manteca con color"@es,
        "2 cucharadas de perejil finamente picado"@es,
        "2 lb de menudencia de chancho, chivo o res (debe incluir hígado, intestinos cocidos y lengua cocida)"@es,
        "2 lb de papitas pequeñas"@es,
        "2 tazas de arroz cocido"@es,
        "Sal al gusto"@es,
        "½ cucharadita de comino en polvo"@es,
        "½ cucharadita de pimienta en polvo"@es,
        "½ taza de cebolla blanca bien picada"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/26/step/0a984f7bac1540f7a80b4fe0ff76bc2e>,
        <http://example.org/recipes/plato-principal/26/step/0e845034606c4c408b3e23b23d4a6043>,
        <http://example.org/recipes/plato-principal/26/step/227cbcb0644e4e4b9845bd86d5ca438d>,
        <http://example.org/recipes/plato-principal/26/step/3975027d366e40e48d14fc729e8f528a>,
        <http://example.org/recipes/plato-principal/26/step/4c6d6520a05d4048843d69a45017f4d7>,
        <http://example.org/recipes/plato-principal/26/step/6d3df2a57b25460588acc6f99b845dde>,
        <http://example.org/recipes/plato-principal/26/step/ebbb3d78f1cc450cb0b15db0147cfa31> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/27> a schema1:Recipe ;
    schema1:description "El verdadero origen de la chanfaina es español, pero tal fue su aceptación en todo Ecuador que este potaje se ha vuelto parte de la gastronomía del país."@es ;
    schema1:name "Chanfaina ecuatoriana"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 kg de menudencia de chancho o res"@es,
        "1 kg de papines"@es,
        "2 cebollas moradas"@es,
        "2 cucharadas de perejil finamente picado"@es,
        "2 tazas de arroz cocido"@es,
        "25 gr de manteca de chancho"@es,
        "4 ajos"@es,
        "50 gr de manteca"@es,
        "Sal, comino y pimienta a gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/27/step/2ebb789f3e35498a9d2bbb47873d57d9>,
