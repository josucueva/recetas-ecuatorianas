    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/plato-principal/91> a schema1:Recipe ;
    schema1:description "El puchero de cabeza de chancho con yucas es un delicioso guisado muy completo y popular que puede disfrutarse en un buen almuerzo. Es un plato bastante tradicional, lleno de sabores exquisitos que te invitamos a probar."@es ;
    schema1:name "Puchero de cabeza de chancho con yucas"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharadita de comino en polvo"@es,
        "1 kg de cuero de la cabeza de chancho"@es,
        "1 kg de yuca"@es,
        "1 rama de cebolla blanca"@es,
        "2 cebollas paiteñas"@es,
        "2 cucharadas de manteca con achiote"@es,
        "2 cucharadas de perejil picado"@es,
        "6 dientes de ajo triturados"@es,
        "½ cucharadita de pimienta molida"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/91/step/03142b123f764692845ae40b2486eb17>,
