    schema1:recipeYield 4 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/44> a schema1:Recipe ;
    schema1:description "El jugo de ciruelas es una bebida deliciosa muy popular en Ecuador. De un sabor y una cremosidad exquisitas, combina el toque ácido de la fruta y los aromas de las especias. No dudes en probarlo."@es ;
    schema1:name "Jugo de ciruela"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 ramita de canela"@es,
        "1 taza de ciruelas frescas"@es,
        "1 taza de leche"@es,
        "2 tazas de agua"@es,
        "3 clavos de olor"@es,
        "½ taza de panela o azúcar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/44/step/775323d660324a2584bd06750fa11649>,
        <http://example.org/recipes/bebida/44/step/89a70a175cdc484391b6edb883a823be>,
        <http://example.org/recipes/bebida/44/step/8ed03e02fc4b4598a8ad157c6cc567d5>,
