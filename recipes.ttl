    schema1:recipeYield 12 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/22> a schema1:Recipe ;
    schema1:description "El sambo es un fruto tradicional del Ecuador, crece de forma silvestre en toda la región de la sierra siendo el ingrediente principal de muchas compotas, sopas y dulces exquisitos."@es ;
    schema1:name "Dulce de sambos"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 kg de sambos maduros"@es,
        "3 clavos de olor"@es,
        "400 gr de azúcar morena"@es,
        "400 gr de nueces"@es,
        "Ralladura de una naranja"@es,
        "Una rama de canela"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/22/step/08199fa6f9a3444193e0f842e711dded>,
        <http://example.org/recipes/postre/22/step/1c0103728e6f48be8e8ee66d7acba9c9>,
