        "1 pimiento verde"@es,
        "1 tomate"@es,
        "1 ½ cebolla morada"@es,
        "2 cucharadas de pasta de tomate o tomate frito"@es,
        "Hiervita al gusto"@es,
        "Oregano al gusto"@es ;
