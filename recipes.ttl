<http://example.org/recipes/bebida/33> a schema1:Recipe ;
    schema1:description "El guarapo se hace con la caña de azúcar. Una bebida muy refrescante que tienen nutrientes, azucares,minerales y vitaminas beneficiosas para la salud"@es ;
