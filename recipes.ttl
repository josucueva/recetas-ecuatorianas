<http://example.org/recipes/bebida/9> a schema1:Recipe ;
    schema1:description "Los jugos verdes son una muy buena opción para mantener una vida saludable, ya que estos jugos nos ayudan a limpiar nuestra sangre y depurar nuestros órganos vitales"@es ;
