<http://example.org/recipes/entrada/14> a schema1:Recipe ;
    schema1:description "El ceviche de camarón ecuatoriano es un plato delicioso y rápido, considerado la estrella de la marisquería ecuatoriana."@es ;
    schema1:name "Ceviche de camarón ecuatoriano"@es ;
    schema1:recipeCategory "Entrada"@es ;
