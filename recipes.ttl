<http://example.org/recipes/plato-principal/112> a schema1:Recipe ;
    schema1:description "El tapao arrecho es un plato típico del Ecuador originario de la provincia de Esmeraldas"@es ;
    schema1:name "Tapao arrecho"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada (paiteña)"@es,
        "1 cucharada de aceite"@es,
        "1 cucharada de achiote"@es,
        "1 cucharada de orégano"@es,
        "1 lb de carne de cerdo"@es,
