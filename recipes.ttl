<http://example.org/recipes/postre/34> a schema1:Recipe ;
    schema1:description "Los ricos helados de Salcedo, son uno de los postres favoritos de niños y adultos en Ecuador. Y si eres de los que le encantan los helados, estos son una deliciosa alternativa si quieres disfrutar del sabor de las frutas naturales. Tradicionalmente se hacen a base de capas multicolores que representan los diferentes sabores."@es ;
    schema1:name "Helados de salcedo"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "120 gr de azúcar"@es,
        "150 gr de tazas de leche en polvo"@es,
        "2 tazas de agua"@es,
        "200 gr de crema de leche"@es,
        "30 gr de glucosa"@es,
        "Jugo de frutas frescas (moras, naranjilla, taxo, guanabana)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/34/step/202265d5bdc545eda8a5a0a93dc7d7e9>,
        <http://example.org/recipes/postre/34/step/28209e5558ab4ab4968b6d902a7866b0>,
