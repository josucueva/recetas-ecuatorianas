<http://example.org/recipes/entrada/10> a schema1:Recipe ;
    schema1:description "Los calamares fritos son uno de los platillos más deliciosos para compartir como botanas o abrebocas. En la gastronomía ecuatoriana no pueden faltar, con su fresco sabor y su textura crujiente será una delicia a su paladar."@es ;
    schema1:name "Calamares fritos"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cucharada de comino"@es,
        "1 huevo"@es,
        "250 gr de calamares frescos"@es,
        "50 gr de harina de trigo"@es,
        "50 gr de miga de pan"@es,
        "8 dientes de ajo"@es,
        "Aceite para freír"@es,
        "Pimienta c/n"@es,
        "½ taza de jugo de limón"@es,
        "½ taza de salsa de soya"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/10/step/32207ab4b8f7489388c2d9bc6c320550>,
        <http://example.org/recipes/entrada/10/step/44a545e6d2a04342bb0f38aa118dc4d0>,
