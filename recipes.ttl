    schema1:recipeYield 1 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/bebida/12> a schema1:Recipe ;
    schema1:description "Deliciosa bebida a base de aguardiente de caña y limón. Se sirve bien fría con hielo."@es ;
    schema1:name "Caipirinha"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "2 limones"@es,
        "3 cucharadas de azúcar"@es,
        "Aguardiente de caña"@es,
        "Hielo"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/12/step/28a81f81fce547288a3128e9e040b73d>,
