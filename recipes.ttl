<http://example.org/recipes/entrada/12> a schema1:Recipe ;
    schema1:description "La carne en palito es un plato nacional y tradicional de la gastronomía del Ecuador, principalmente de su Región Litoral. Es también conocido como chuzo o pinchos. Puede servirse como entrada condimentado con unas gotas de ají o acompañado de una salsa."@es ;
    schema1:name "Carne en Palito"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cucharada de aceite"@es,
        "1 cucharadita de comino molido"@es,
        "2 cucharaditas de achiote molido"@es,
        "3 cucharadas de jugo de naranja"@es,
        "Ajo machacado"@es,
        "Palitos de madera para pinchos"@es,
        "Sal y pimienta al gusto"@es,
        "½ kilo de carne de res"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/12/step/08f68e3b7a3c45b8b54385421c774b54>,
        <http://example.org/recipes/entrada/12/step/35e789388559469b88578c43383f3e45>,
