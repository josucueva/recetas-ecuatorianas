<http://example.org/recipes/bebida/45> a schema1:Recipe ;
    schema1:description "El jugo de coco es una de las bebidas más populares en las costas de Ecuador, ideal para refrescar en los días de sol."@es ;
    schema1:name "Jugo de Coco"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 taza de hielo"@es,
        "2 gotitas de esencia de vainilla"@es,
        "2 tazas de coco rallado"@es,
        "4 tazas de agua de coco"@es,
        "Aguardiente"@es,
        "Leche condensada al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/45/step/51b1d8b070224b8b9a8d3dbd04e3597e>,
