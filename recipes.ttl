<http://example.org/recipes/postre/13> a schema1:Recipe ;
    schema1:description "El come y bebe es una ensalada de frutas ecuatoriana muy fácil de preparar que contiene frutas exóticas y muy frescas, como papaya, banano, piña, mango, guineos maduros, moras, etc., acompañadas con zumo de naranja. Esta mezcla de trozos enteros de frutas y zumo de naranja, puede comerse y beberse a la vez, de ahí el nombre peculiar de este postre."@es ;
    schema1:name "Come y Bebe"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 papaya grande y madura"@es,
        "1 piña pelada"@es,
        "6 bananos o guineos maduros"@es,
        "6 mangos maduros"@es,
        "Azúcar o miel al gusto"@es,
        "Jugo de 10 naranjas"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/13/step/19c6b7c1c7864333913f669ca365ee36>,
        <http://example.org/recipes/postre/13/step/30b2b12414104edfb3887ea601b55cd7>,
