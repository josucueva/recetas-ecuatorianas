<http://example.org/recipes/plato-principal/58> a schema1:Recipe ;
    schema1:description "La guatita se considera plato nacional en Ecuador. Consiste en un estofado hecho a base de trozos de estómago de vacuno, a lo que se le llama guatitas (también conocido en otras regiones como mondongo). Se distingue por ser un plato muy calórico."@es ;
    schema1:name "Guatita"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharadita de orégano seco"@es,
        "1 kilo de panza de res o mondongo (bien lavado y limpio)"@es,
        "1 taza de cebolla colorada cortada en cubos"@es,
        "1 tomate pelado y sin semillas cortado en cubos"@es,
        "10 tazas de agua"@es,
        "2 cucharadita de comino molido"@es,
        "2 cucharaditas de achiote molido"@es,
        "2 tazas de cebolla blanca cortada en cubos"@es,
        "2 tazas de leche"@es,
        "3 cucharadas de mantequilla"@es,
        "4 papas peladas cortadas en cubos"@es,
        "5 ramitas de cilantro"@es,
        "8 dientes de ajo machacados"@es,
        "Jugo de 1 limón"@es,
        "Sal y pimienta al gusto"@es,
        "½ pimiento rojo o verde cortado en cubos"@es,
        "½ taza de mantequilla de maní"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/58/step/65db96da52c745888eb27d35998d70c9>,
        <http://example.org/recipes/plato-principal/58/step/6e975d9feaf84ba6b5c20e105d327818>,
        <http://example.org/recipes/plato-principal/58/step/76b207cf1d3d4198b2ea0222917ed86d>,
        <http://example.org/recipes/plato-principal/58/step/76e744e429f04fbab2f67017fdd86132>,
        <http://example.org/recipes/plato-principal/58/step/ad616411e5444e758aa0713bcce44b4e>,
        <http://example.org/recipes/plato-principal/58/step/cea1322911b146b2988fed23d1a60b62>,
        <http://example.org/recipes/plato-principal/58/step/dae2830b2cb442c0953e8971b2a73d25>,
        <http://example.org/recipes/plato-principal/58/step/ec2c5e08adb84d32a227974e01a8e654> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/59> a schema1:Recipe ;
    schema1:description "La guatita es el plato nacional en Ecuador por excelencia, consta de un potaje estofado hecho a base de mondongo a lo que se le llama guatitas. Ideal para los días de frío."@es ;
    schema1:name "Guatitas"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada"@es,
        "1 kg de mondongo de vaca"@es,
        "1 limón"@es,
        "1 pimiento rojo"@es,
        "1 tomate"@es,
        "10 tazas de agua"@es,
        "2 cebolla blancas"@es,
        "2 tazas de leche"@es,
        "20 gr de mantequilla"@es,
        "4 papas"@es,
        "5 dientes de ajo"@es,
        "Pizca de achiote molido"@es,
        "Pizca de comino molido"@es,
        "Pizca de orégano seco"@es,
        "Sal y pimienta a gusto"@es,
