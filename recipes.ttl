<http://example.org/recipes/sopa/34> a schema1:Recipe ;
    schema1:description "El guiso chamorro es un potaje muy nutritivo realizado en todo Ecuador con carne vacuna, legumbres y verduras. Ideal para los días mas fríos del año por su valor calorico."@es ;
    schema1:name "Guiso chamorro"@es ;
    schema1:recipeCategory "Sopa"@es ;
