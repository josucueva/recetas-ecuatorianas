<http://example.org/recipes/bebida/62> a schema1:Recipe ;
    schema1:description "El Rosero es una refrescante bebida tradicional de Quito que se prepara a base de frutas, aromatizada con especias y el toque especial del agua de rosas y azahares. Se disfruta bien fría."@es ;
    schema1:name "Rosero"@es ;
    schema1:recipeCategory "Bebida"@es ;
