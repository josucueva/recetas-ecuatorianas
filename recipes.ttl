<http://example.org/recipes/postre/59> a schema1:Recipe ;
    schema1:description "El maduro es el plátano tradicional de la gastronomía ecuatoriana, ingrediente principal de múltiples recetas, en este caso una tarda de maduro y queso. Una delicia."@es ;
