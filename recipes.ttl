    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/53> a schema1:Recipe ;
    schema1:description "Este es un plato delicioso y muy popular en todo el país, el ingrediente estrella es la carne de cerdo. Se sirve con salsa de ají."@es ;
    schema1:name "Fritada de cerdo a la ecuatoriana"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 taza de cerveza negra"@es,
        "2 kg de costillas de cerdo trozadas"@es,
        "4 cebollas de verdeo medianas"@es,
        "6 dientes de ajo"@es,
        "Hojas de lechuga para decorar"@es,
        "Sal y comino a gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/53/step/3546ff4513764227b553b49e8d85b35b>,
        <http://example.org/recipes/plato-principal/53/step/54f0925ca2574e2690879bea8161dced>,
        <http://example.org/recipes/plato-principal/53/step/5a1c23abd7b24388a9ca018ff45bc08f>,
        <http://example.org/recipes/plato-principal/53/step/6b6aeae951874c9db3cfcc9f50e5c370> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/54> a schema1:Recipe ;
    schema1:description "La fritada de chancho es uno de deliciosos platos típicos de Ecuador. La carne de chancho (cerdo o puerco) se cocina en agua y jugo de naranja con comino, ajo, cebolla, chalote, sal y pimienta"@es ;
    schema1:name "Fritada de Chancho"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla blanca cortada en trozos"@es,
        "1 chalote cortado en trozos"@es,
        "1 cucharadita de comino molido"@es,
        "1 taza de jugo de naranja"@es,
        "10 dientes de ajo (5 enteros y 5 machacados)"@es,
        "2 kilos de carne de chancho cortado en trozos medianos (½ kg de costillas y 1½ kg de lomo)"@es,
        "3 tazas de agua"@es,
        "Sal y pimienta al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/54/step/67f4f98a60114e2bbf834d2607c8de2f>,
        <http://example.org/recipes/plato-principal/54/step/8d6e738ce8d14f3a9ce1132660322546>,
        <http://example.org/recipes/plato-principal/54/step/a11e80be29284c458f00af31de2a9b7f>,
        <http://example.org/recipes/plato-principal/54/step/e4ad5d8ef2ea4e49af627574e8c68971> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/55> a schema1:Recipe ;
    schema1:description "Este es un plato tradicional de la Costa Ecuatoriana. Tiene mucho sabor ya que consiste de una clásica menestra acompañada con gallareta que es una ave típica de la región. No pierdas la oportunidad de disfrutar de los sabores que encontrarás en este exquisito platillo."@es ;
    schema1:name "Gallareta asada y arroz con menestra"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla blanca"@es,
        "1 cebolla colorada"@es,
        "1 pimiento verde"@es,
        "2 cucharaditas de comino"@es,
        "3 cucharadas de aceite de achiote"@es,
        "3 tomates"@es,
        "4 cucharadas de cilantro"@es,
        "400 gr de fréjol"@es,
        "5 gallaretas limpias y troceadas"@es,
        "6 dientes de ajo"@es,
        "7 tazas de agua"@es,
        "Sal c/n"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/55/step/1e93a51ed610480cac076d04658e9936>,
        <http://example.org/recipes/plato-principal/55/step/31cbccfec62b4b80a00783ab9ad92370>,
        <http://example.org/recipes/plato-principal/55/step/3d6cc4d6ccdc4b3dae8310dce52753be>,
