<http://example.org/recipes/entrada/47> a schema1:Recipe ;
    schema1:description "Las deliciosas empanadas de verde, son muy tradicionales en el Ecuador. Su preparación es sencilla y se basa en una masa de plátano verde que se rellena con un condumio de carne, con queso o camarones. Sin lugar a dudas son una delicia que si no la has probado, ya es tiempo de hacerlo."@es ;
    schema1:name "Empanadas de verde rellenas con camarón"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla colorada mediana"@es,
        "1 cucharada de cilantro picado"@es,
        "1 cucharada de pasta de maní"@es,
        "1 cucharada de perejil picado"@es,
        "1 cucharadita de mantequilla o crema de leche"@es,
        "1 pimiento verde"@es,
        "1 yema de huevo"@es,
        "2 cucharadas de aceite de achiote"@es,
        "2 dientes de ajo"@es,
        "250 gr de camarones"@es,
        "4 plátanos verdes"@es,
        "Sal. pimienta y comino c/n"@es,
        "½ taza de leche"@es ;
