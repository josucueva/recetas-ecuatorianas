<http://example.org/recipes/plato-principal/10> a schema1:Recipe ;
    schema1:description "El bistec de res cocido al estilo ecuatoriano, es un plato popular que se consume generalmente durante el almuerzo o una cena. Tiene gran sabor y proporciona una excelente opción para preparar a la familia."@es ;
    schema1:name "Bistec de res ecuatoriano"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla"@es,
        "1 cucharada de aceite de achiote"@es,
        "1 cucharada de mostaza"@es,
        "1 cucharada de salsa de tomate"@es,
        "1 pimiento"@es,
        "2 dientes de ajo triturados"@es,
        "2 tomates"@es,
        "500 gr de carne de res (lomo de falda)"@es,
        "Comino"@es,
        "Sal"@es,
        "½ manojo de eneldo"@es,
        "½ taza de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/10/step/14d8c49074c447519e78023b0914a132>,
        <http://example.org/recipes/plato-principal/10/step/1d125355ee324dd6aed12d053e1632ab>,
        <http://example.org/recipes/plato-principal/10/step/3b927b2e72394bb3983f1c3e10adc0c6>,
        <http://example.org/recipes/plato-principal/10/step/a4c9a88254a8456d88cb700a7d90d2ec>,
        <http://example.org/recipes/plato-principal/10/step/a9b6b6a9f8cb4b4e8c2ff75957f254ea>,
        <http://example.org/recipes/plato-principal/10/step/ba560fd6b2de402db873e30686de373c> ;
    schema1:recipeYield 2 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/100> a schema1:Recipe ;
    schema1:description "Exquisito seco de cerdo con vegetales y naranjilla, al estilo Ecuatoriano. Se puede acompañar con arroz y aguacate."@es ;
    schema1:name "Seco de cerdo"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorado"@es,
        "1 cucharada de ajo triturado"@es,
        "1 kg de carne de cerdo picado en cuadritos"@es,
        "1 naranjilla"@es,
        "1 pimiento"@es,
        "1 vaso de cerveza"@es,
        "2 cucharadas aceite de achiote"@es,
        "Sal, pimienta, al gusto"@es,
        "½ cucharada comino"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/100/step/5efa4dac90a341608d2f276a8932f96c>,
        <http://example.org/recipes/plato-principal/100/step/8b87ac51928f40849f042352831d5004>,
