<http://example.org/recipes/plato-principal/29> a schema1:Recipe ;
    schema1:description "Esta versión ecuatoriana del chaulafán de pollo se prepara con arroz frito y pollo, tocino, cebolla, ajo, pimientos, arvejas, zanahorias, huevos, pasas, especias y hierbas."@es ;
