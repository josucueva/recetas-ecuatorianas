<http://example.org/recipes/entrada/24> a schema1:Recipe ;
    schema1:description "El ceviche de pulpo al estilo ecuatoriano es un plato delicioso cuya preparación combina la frescura y jugosidad del pulpo con el sabor de vegetales y hierbas aromáticas. Para los amantes de los frutos del mar, esta receta los transportará a otra dimensión. No puedes perdértela."@es ;
    schema1:name "Ceviche de pulpo ecuatoriano"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 pimiento verde cortado en julianas"@es,
        "1 pulpo"@es,
        "1 rama de cilantro"@es,
        "1 rama de perejil"@es,
        "2 cebollas paiteñas cortadas en julianas"@es,
        "2 tazas de consomé de camarones"@es,
        "2 tomates cortado en cubos"@es,
        "Ají picado"@es,
        "Sal al gusto"@es,
        "½ taza de jugo de limón fresco"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/24/step/62338559456d48c2add5089d842aed3e>,
        <http://example.org/recipes/entrada/24/step/845c2e2dc44b4c4485ae304d4dc4cdf7>,
        <http://example.org/recipes/entrada/24/step/956e8ff9109a4bb8b90d57aba24c39d4>,
