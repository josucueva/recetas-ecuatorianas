        "5 cucharadas de mantequilla"@es,
        "5 huevos"@es,
        "5 plátanos maduros cortados en cubitos"@es,
        "½ kilo de harina de trigo"@es,
        "½ taza de agua"@es,
        "½ taza de queso blanco rallado"@es ;
