    schema1:recipeYield 4 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/57> a schema1:Recipe ;
    schema1:description "El naranjillazo es una bebida ecuatoriana y una de las variaciones más populares del canelazo. Se prepara con jugo de naranjilla, una fruta de sabor ácido típica de Ecuador."@es ;
    schema1:name "Naranjillazo"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1¼ taza de azúcar o panela rallada"@es,
        "2 tazas de concentrado de naranjilla"@es,
        "4 tazas de agua"@es,
        "8 palitos de canela"@es,
