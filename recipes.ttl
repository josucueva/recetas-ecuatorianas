<http://example.org/recipes/plato-principal/37> a schema1:Recipe ;
    schema1:description """El cordero es un borrego muy joven (una cría o un juvenil), y uno de los cortes más tiernos y deliciosos del cordero son las costillas
que acompañadas con un curry con especias, condimentos y hierbas que más nos gustan de seguro te harán chupar los dedos."""@es ;
    schema1:name "Costillas de cordero con curry"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de jengibre finamente picado"@es,
        "1 kg de costillas de cordero"@es,
        "2 cucharadas de curry"@es,
        "3 dientes de ajo"@es,
        "3 tazas de caldo de verduras o carne de res"@es,
        "5 cebollas perla"@es,
        "50 ml de aceite girasol"@es,
        "Sal y pimienta al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/37/step/0b6393f3647c435fa44b4ec6d9414d63>,
