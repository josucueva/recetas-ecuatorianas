        <http://example.org/recipes/entrada/24/step/fa6c65185a7b4735bf3b28865b3a7fa1> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/25> a schema1:Recipe ;
    schema1:description "Exquisito ceviche mixto compuesto por camarones, pescado. Preparados con una deliciosa salsa de tomate y un toque de cilantro picadito al final."@es ;
    schema1:name "Ceviche mixto de camarón y pescado"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla"@es,
        "1 cucharada de azúcar"@es,
        "1 cucharadita mostaza"@es,
        "1 kg de camarón"@es,
        "2 tomates"@es,
        "3 limones"@es,
        "Cilantro picadito al gusto"@es,
        "½ kg pescado"@es,
        "½ naranja"@es,
        "¾ de salsa de tomate"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/25/step/08db0c6874a945e996369813314759ec>,
