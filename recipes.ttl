        <http://example.org/recipes/plato-principal/47/step/f1a66538c0a947adbe018ad540eec584> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/plato-principal/48> a schema1:Recipe ;
    schema1:description "Existen mil maneras de preparar pimientos, en Ecuador una de estas maneras es forma de salsa para acompañar a los filetes de carne, los pimientos son una muy buena fuente de vitaminas y fibra."@es ;
    schema1:name "Filete de cerdo con salsa de pimientos"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de aceite de oliva"@es,
        "1 ½ tazas de salsa de tomate"@es,
        "1/3 taza de vinagre blanco"@es,
        "2 pimientos rojos grandes"@es,
        "3 cucharadas de orégano fresco"@es,
        "3 dientes de ajo picados en cubitos"@es,
        "6 filetes de pierna de cerdo"@es,
        "Sal y pimienta al gusto"@es,
        "½ cebolla"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/48/step/00bf2761aaff4decb3cf840b9c036ee3>,
        <http://example.org/recipes/plato-principal/48/step/492eeb0b5f8a41f2b09f841c0f10a304>,
