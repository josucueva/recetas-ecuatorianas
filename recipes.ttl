<http://example.org/recipes/bebida/64> a schema1:Recipe ;
    schema1:description "La maracuyá es una de las frutas mas famosas del caribe, incluido todo el territorio ecuatoriano dulce y refrescante es ideal para jugos, batidos y helados."@es ;
