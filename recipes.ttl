    schema1:recipeYield 20 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/entrada/73> a schema1:Recipe ;
    schema1:description "Si bien la papa a la huancaina tiene su origen en el Perú, actualmente es un platillo que se puede disfrutar en casi todos los países de la región, incluido Ecuador que tiene gran influencia de la comida peruana."@es ;
    schema1:name "Papa a la huancaina"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 lechuga"@es,
        "16 papas pequeñas"@es,
        "2 tomates"@es,
        "3 huevos duros"@es,
        "4 vainas de ají amarillo"@es,
        "Sal al gusto"@es,
        "½ lb de maní tostado"@es,
        "½ litro de leche entera"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/73/step/19dc83cba97440fea5d79a0a900d60ce>,
