<http://example.org/recipes/plato-principal/92> a schema1:Recipe ;
    schema1:description "Esta receta es uno de los platos tradicionales de la gastronomía del Ecuador. Consiste en un guiso de carne de cerdo con granos y plátanos verdes. Es una comida que se sirve usualmente durante el almuerzo, ya que te deja completamente satisfecho. Te invitamos a que lo prepares y sorprendas a tus comensales."@es ;
    schema1:name "Puchero de cerdo, frejol y verde"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla paiteña en cubos"@es,
        "1 cucharada de ajo molido"@es,
        "1 pimiento verde en cubos"@es,
        "1 tomate cortado en cubos"@es,
        "1 verde cortado en cubos pequeños"@es,
        "1 ¾ ml de agua"@es,
        "250 gr de frejol remojado"@es,
        "3 hojas de laurel"@es,
        "500 gr de carne de cerdo cocida"@es,
        "Aceite de achiote c/n"@es,
        "Hierbas (oreganón y chirarán)"@es,
        "Sal, comino, pimienta c/n"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/92/step/2e1a8c09b56f494a8342ed1ff8bd3463>,
        <http://example.org/recipes/plato-principal/92/step/48a323d322c84068aa81bbacbbc35e54>,
