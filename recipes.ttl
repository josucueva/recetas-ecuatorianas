<http://example.org/recipes/entrada/3> a schema1:Recipe ;
    schema1:description "El ají de librillo es un platillo muy apetecido en la sierra ecuatoriano y se lo puede encontrar en los mercados populares a precios económicos."@es ;
    schema1:name "Ají de librillo"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 ají entero"@es,
