        <http://example.org/recipes/postre/16/step/f727f7d2341e4c25bf00a04fc78e3669> ;
    schema1:recipeYield 10 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/17> a schema1:Recipe ;
    schema1:description "El babaco es una fruta originaria del Ecuador. En esta receta se preparará una especie de almíbar hecho con la fruta, azúcar, agua y canela."@es ;
    schema1:name "Dulce de babacos"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 babaco maduro"@es,
        "1 rama de canela"@es,
        "2 clavos de olor"@es,
        "2 tazas de agua"@es,
        "2 tazas de azúcar"@es,
