        "1 pimentón rojo"@es,
        "1 pimentón verde"@es,
        "10 cebollitas chiquitas"@es,
        "2 dientes de ajo"@es,
        "3 tomates rojos"@es,
        "800 gr de bacalao fresco"@es,
        "Harina"@es,
        "Pimienta"@es,
        "Sal"@es,
        "½ cucharadita de romero o tomillo"@es ;
