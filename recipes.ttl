<http://example.org/recipes/sopa/17> a schema1:Recipe ;
    schema1:description "El famoso caldo de salchicha ecuatoriano, también conocido como caldo de manguera, es una de las sopas más populares que se prepara con salchichas elaboradas como una morcilla de menudencias de cerdo y con relleno de plátanos verdes. No pierdas la oportunidad de disfrutar este plato típico."@es ;
    schema1:name "Caldo de salchichas"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla blanca"@es,
        "1 col"@es,
        "1 cucharada de culantro"@es,
        "1 cucharada de hierba buena"@es,
        "1 cucharada de manteca de cerdo"@es,
        "1 cucharada de orégano"@es,
        "1 kg de menudencias de cerdo"@es,
        "1 pimiento"@es,
        "2 tazas	de sangre de cerdo"@es,
        "3 tazas	de arroz"@es,
        "4 limones"@es,
        "5 verdes"@es,
        "6 dientes de ajo"@es,
        "Sal, pimienta y comino c/n"@es ;
