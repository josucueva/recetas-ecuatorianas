<http://example.org/recipes/entrada/17> a schema1:Recipe ;
    schema1:description "Un delicioso plato vegetariano Este delicioso plato es muy común de la zona de Pesillo en Ecuador. Su elaboración es similar al tradicional ceviche de pescado con la variante de que el ingrediente estrella son los hongos comestibles. Su preparación es muy fácil por lo que te invitamos a probarlo. Anímate."@es ;
    schema1:name "Ceviche de champiñones"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 aguacate"@es,
        "1 cebolla colorada mediana"@es,
        "1 rama de cilantro"@es,
        "1 tomate"@es,
        "250 gr de champiñones"@es,
        "4 limones sutil"@es,
        "Sal y pimienta c/n"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/17/step/14a2f23e80ee40dcb3b60d01ef4afe91>,
        <http://example.org/recipes/entrada/17/step/763841016c4d4144ba7cfec137f06124>,
        <http://example.org/recipes/entrada/17/step/8a4ad09db9f64642842a7b0e749653c2>,
        <http://example.org/recipes/entrada/17/step/902abd2bb22b4e219edb2c01ddeed35a>,
        <http://example.org/recipes/entrada/17/step/da2d8ff32e4541cda640e009a2b1b7d5>,
        <http://example.org/recipes/entrada/17/step/fdf58e05283d4f5dbd22774c56272177> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/18> a schema1:Recipe ;
    schema1:description "En Ecuador, especialmente en la región andina, hay un ceviche vegetariano muy popular que se prepara con chochos (tipo de legumbre, leguminosa o granos)."@es ;
    schema1:name "Ceviche de Chochos"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla colorada cortada en rodajas finas"@es,
        "1 manojo de cilantro finamente cortado"@es,
        "2 cucharadas de aceite de oliva"@es,
        "3 tomates cortados en cubos"@es,
        "4 tazas de chochos cocidos"@es,
        "Sal al gusto"@es,
        "jugo de 10 limones"@es,
        "jugo de 2 naranjas"@es,
        "½ taza salsa o jugo de tomate"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/18/step/0b6761d0ddf74bf8b4fe00ea1a47acdb>,
        <http://example.org/recipes/entrada/18/step/37a0e227a8f241c7936ceba2fb301536>,
