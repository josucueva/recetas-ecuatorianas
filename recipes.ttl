        "1 cucharada de perejil picado"@es,
        "1 cucharadita de azúcar"@es,
        "1 kg de corvina"@es,
        "1 taza de crema de leche"@es,
        "1 tomate pelado y cortado en cubos"@es,
        "2 copas de vino blanco"@es,
        "2 cucharadas de mantequilla"@es,
        "Pimienta"@es,
        "Sal"@es ;
