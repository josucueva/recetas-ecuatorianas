        <http://example.org/recipes/bebida/29/step/76fd27dd8cce428ca19c15c03ed89f22>,
        <http://example.org/recipes/bebida/29/step/e9fc4a080a184ef7b184ee0710dccccd> ;
    schema1:recipeYield 10 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/bebida/3> a schema1:Recipe ;
    schema1:description "El mango ecuatoriano se cultiva principalmente en la provincia del Guayas y la mayoría se exporta, pero también es muy consumido por la población local en varías presentaciones incluidos los batidos"@es ;
    schema1:name "Batido de mango"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de leche fresca o yogurt natural"@es,
        "4 mangos grandes"@es,
        "Hielo y azúcar al gusto"@es,
        "Trozos de durazno para la decoración"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/3/step/10cd3058babb4bb5a056251acad69fd6>,
        <http://example.org/recipes/bebida/3/step/93aeb65afcbe474e98c261224654f0d3>,
        <http://example.org/recipes/bebida/3/step/a41aefa479a74673a34a38ac5da003b8>,
        <http://example.org/recipes/bebida/3/step/d51dce551bc8445b96b8525e31b09385>,
        <http://example.org/recipes/bebida/3/step/feaedc4c0bd0413aac7d72ffe23ae612> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/bebida/30> a schema1:Recipe ;
    schema1:description "En Ecuador, como en otros países latinoamericanos, se celebra el Día de los Difuntos el 2 de Noviembre. Esta celebración va acompañada de una importante tradición gastronómica: la colada morada, una bebida espesa de color morado que se prepara con frutas típicas ecuatorianas, hierbas y especias."@es ;
    schema1:name "Colada Morada"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 taza de piña cortada en cubitos"@es,
        "1 taza de pulpa de naranjilla"@es,
        "2 hojas de laurel"@es,
        "2 litros de agua fría"@es,
        "4 rajas de canela"@es,
        "8 clavos de olor"@es,
        "la cáscara de 1 limón"@es,
        "la cáscara de 1 naranja"@es,
        "la cáscara de 1 piña"@es,
        "¼ kilo de moras"@es,
        "¼ kilo de mortiños (o arándano azul)"@es,
        "¼ taza de maicena disuelta en 1 taza de agua"@es,
        "½ cucharadita de hierba luisa seca"@es,
        "½ cucharadita de pimienta de olor molido"@es,
        "½ taza azúcar granulada"@es,
        "½ taza de babaco cortado (opcional)"@es,
        "½ taza de frutillas (o fresas) cortadas"@es,
        "½ taza de panela (o piloncillo)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/30/step/0859444484d94fd1b727a0294a62367f>,
        <http://example.org/recipes/bebida/30/step/1785ad1d4faa468bb862beb9eafb4021>,
        <http://example.org/recipes/bebida/30/step/5b839a4412e548b8baadd25a253ba9b3>,
        <http://example.org/recipes/bebida/30/step/6bee29e0c5ae485d8f168f5c44a34b2c>,
        <http://example.org/recipes/bebida/30/step/aeabeb815bdf4068acfcf42f476ca97d> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/31> a schema1:Recipe ;
    schema1:description "Esta ensalada de frutas ecuatoriana contiene frutas exóticas deliciosas y muy frescas, como papaya, sambos, piña, mango, plátanos y acompañadas con jugo de naranjas. Esta ensalada puede comerse o beberse y de allí su característico nombre."@es ;
    schema1:name "Ensalada come y bebe"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 papaya grande"@es,
        "1 piña pelada"@es,
        "1 sambos"@es,
        "10 naranjas jugosas"@es,
        "6 mangos"@es,
        "6 plátanos maduros"@es,
        "Azúcar o miel al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/31/step/10ba351dac5a4733b62797b16136bed4>,
        <http://example.org/recipes/bebida/31/step/91332f3ece784c298917276295716c5c>,
