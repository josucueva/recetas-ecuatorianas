    schema1:recipeYield 5 ;
    schema1:totalTime "PT15M"^^xsd:duration .

<http://example.org/recipes/bebida/46> a schema1:Recipe ;
    schema1:description "El jugo de guanábana es una bebida muy refrescante que se consume en todas las regiones del Ecuador"@es ;
    schema1:name "Jugo de guanábana"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 guanábana madura"@es,
        "Azúcar al gusto"@es,
        "Hielo en cubitos"@es,
        "½ litro de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/46/step/0367ab85311c46a1aaca8c3fde7a6556>,
