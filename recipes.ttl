<http://example.org/recipes/sopa/57> a schema1:Recipe ;
    schema1:description "La sopa de avena es un caldo que se prepara basándonos en hojuelas de avena y verduras. Es un caldo delicioso y muy saludable. Su elaboración es bastante sencilla por lo que no puedes perderte esta receta para disfrutar de un plato completo , tradicional y con grandes beneficios nutricionales."@es ;
    schema1:name "Sopa de avena"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cucharada de sabora (ajo-pimienta.orégano y sal)"@es,
        "1 taza de avena"@es,
        "1 tomate licuado"@es,
        "2 cucharadas de aceite de achiote"@es,
        "2 dientes de ajo"@es,
        "2 litros de agua caliente"@es,
        "6 papas cortadas en cubos"@es,
        "Queso fresco"@es,
        "Sal, pimienta y comino c/n"@es,
        "½ cebolla blanca en cuadros"@es,
        "½ taza de leche"@es ;
