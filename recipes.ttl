<http://example.org/recipes/bebida/26> a schema1:Recipe ;
    schema1:description "La chucula ecuatoriana, un riquísimo batido de maduro como energizante. Esta bebida es una las tradiciones culinarias de los pueblos indígenas que aún se conserva en Ecuador."@es ;
    schema1:name "Chucula Ecuatoriana"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 cucharadita de esencia de vainilla"@es,
        "2 tazas de azúcar"@es,
        "2 tazas de leche"@es,
        "4 cucharadas de queso sin sal rallado"@es,
        "4 palitos de canela"@es,
        "4 plátanos maduros pelados cortados en rodajas"@es,
        "½ taza de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/26/step/1c234d7ef1eb493a9636de474f112e53>,
