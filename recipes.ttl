    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/47> a schema1:Recipe ;
    schema1:description "El estofado de pescado es un plato muy consumido a la hora del almuerzo en los hogares ecuatorianos es fácil de preparar y pueden emplearse pescados de agua dulce como la vieja de río o de agua salada como la corvina"@es ;
    schema1:name "Estofado de pescado"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada (paiteña)"@es,
        "1 cucharada de ajo molido"@es,
        "1 cucharadita de cilantro finamente picado"@es,
        "1 lb de pescado cortada en 4 porciones (vieja de río o corvina de mar)"@es,
        "1 papa"@es,
        "1 pimiento verde"@es,
        "1 tomate"@es,
        "Sal, pimienta y comino al gusto"@es,
        "½ cucharadita de achiote"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/47/step/3aa1f0e5803a4f39a057ad59707778ed>,
        <http://example.org/recipes/plato-principal/47/step/80503766d8fd46c087743615f8304d45>,
        <http://example.org/recipes/plato-principal/47/step/8985d915736240398d9a23aaffb39a6c>,
