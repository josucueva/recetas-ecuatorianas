        <http://example.org/recipes/plato-principal/62/step/d0ae60f32179472fa7561ddeedf05c77>,
        <http://example.org/recipes/plato-principal/62/step/e71ff5373cf148ba8c8efaee3697b2bd>,
        <http://example.org/recipes/plato-principal/62/step/f4b986aa93324631bfd0346132762f24> ;
    schema1:recipeYield 20 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/63> a schema1:Recipe ;
