    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/plato-principal/15> a schema1:Recipe ;
    schema1:description "La famosa cangrejada ecuatoriana se prepara con los pangora, jaibas, azules y rojos, algunas de las diversas especies de cangrejos que se crían en la zona costera de Ecuador. La cangrejada suele servirse acompañada de una ensalada que se prepara con cebolla, canguil y chifles."@es ;
    schema1:name "Cangrejada"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 atado de cangrejos"@es,
        "1 botella grande de cerveza"@es,
        "2 plátanos maduros cortados en 4 trozos"@es,
        "2 plátanos verdes cortados en 4 trozos"@es,
        "4 cebollas blancas cortada en cubos"@es,
        "5 ramitas de cilantro entero"@es,
        "¼ taza de comino en grano"@es,
        "¼ taza de pimienta negra en grano"@es,
        "½ taza de dientes de ajos machacados"@es,
        "½ taza de sal"@es,
        "½ taza orégano"@es ;
