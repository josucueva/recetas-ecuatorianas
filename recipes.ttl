        <http://example.org/recipes/postre/64/step/9c9ca623ba994ddd85819a3b81a3a44d> ;
    schema1:recipeYield 12 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/65> a schema1:Recipe ;
    schema1:description "Muchos de los desayunos en Ecuador tienen al plátano verde, o simplemente verde, como un ingrediente infaltable para sus preparaciones, en esta ocasión tortillas de verde."@es ;
    schema1:name "Tortillas de verde"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cebolla morada picada"@es,
        "1 cucharadita de achiote"@es,
        "1 vaso de aceite neutro"@es,
        "3 plátanos verdes"@es,
        "Queso mozzarella"@es,
        "Sal a gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/65/step/36b4217471104e5a94346b12c382f391>,
        <http://example.org/recipes/postre/65/step/7598207bdded4003a03afdfa745d5606>,
