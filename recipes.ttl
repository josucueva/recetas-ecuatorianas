        <http://example.org/recipes/postre/45/step/c0facfb3ee6b4b65b71c3efbc7a970a7> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/46> a schema1:Recipe ;
    schema1:description "En Ecuador el consumo de manzana es bastante alto e incluso su producción local no alcanza para cubrir la demanda, las personas la consumen generalmente frescas pero también en postres como el muffins de manzana y canela"@es ;
    schema1:name "Muffins de manzana y canela"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de harina"@es,
        "1 cucharadita de canela molida"@es,
        "1 cucharadita de polvo de hornear"@es,
        "1 huevo"@es,
        "1 taza de leche"@es,
        "1/3 taza de azúcar morena"@es,
        "2 cucharadas de mantequilla"@es,
        "2 manzanas peladas y ralladas"@es,
        "Aceite de oliva o manteca"@es,
        "½ cucharadita de sal"@es,
        "½ lb de harina"@es,
        "½ taza de azúcar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/46/step/0049e7a1c152410da94baf7618ad1d41>,
