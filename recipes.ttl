<http://example.org/recipes/sopa/30> a schema1:Recipe ;
    schema1:description "El encebollado es un plato original de la provincia de Guayas, al suroeste de Ecuador, así como de Manabí, de ahí el nombre de encebollado manabita o manaba. El caldo que acompaña al pescado se elabora a base de yuca licuada y se puede condimentar con ají en polvo, comino u otras especias al gusto."@es ;
    schema1:name "Encebollado Manaba"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cucharadita de ají en polvo"@es,
        "1 kilo de atún o albacora fresco"@es,
