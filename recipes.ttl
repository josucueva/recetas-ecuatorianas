    schema1:recipeYield 8 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/51> a schema1:Recipe ;
    schema1:description "El tomate de árbol es muy común Ecuador y se cultiva en clima frío-templado de varías provincias de la sierra"@es ;
    schema1:name "Jugo de tomate de árbol"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de agua o leche"@es,
        "4 tomates de árbol maduros"@es,
        "Azúcar o miel al gusto"@es,
        "Cubitos de hielo (opcional)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/51/step/29945b0726f84b958719ddd0f283eded>,
        <http://example.org/recipes/bebida/51/step/321145f2c94d4886b55a8bba0b313ef8>,
