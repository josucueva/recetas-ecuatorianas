<http://example.org/recipes/bebida/17> a schema1:Recipe ;
    schema1:description "Esta deliciosa chicha, es una de las tradiciones gastronómicas del Ecuador. Esta bebida debe fermentarse para que adquiera el sabor fuerte y ácido que la caracteriza. Si bien es una bebida ancestral, se continúa preparando cuando es temporada del chontaduro. Anímate y no dejes de probarla."@es ;
    schema1:name "Chicha de chontaduro y yuca"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de agua"@es,
        "1 taza de panela molida"@es,
        "1 taza de yuca cocida"@es,
        "2 tazas de chontaduro cocido"@es,
        "5 hojas de bijao"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/17/step/106be35b1cf24d91b9fc467da66774d9>,
        <http://example.org/recipes/bebida/17/step/4ab5fb207c204c809188416337fe2d46>,
        <http://example.org/recipes/bebida/17/step/a76707e2f1994b4b89816851d165fe09>,
        <http://example.org/recipes/bebida/17/step/baa1c5e072c442da8aa4437cd9be8ebc>,
        <http://example.org/recipes/bebida/17/step/da3de7f1428045adad3bbe9a7a9bf90e> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/18> a schema1:Recipe ;
    schema1:description "La chicha de jora es una bebida fermentada popular en Ecuador. Se prepara de diversas maneras según la región pero su preparación se compone principalmente de la jora, que es básicamente el maíz germinado."@es ;
    schema1:name "Chicha de Jora"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 cucharada de clavos de olor"@es,
        "1 kilo de cebada"@es,
        "10 litros de agua"@es,
        "1½ kilo de maíz de jora"@es,
        "Azúcar al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/18/step/3935c53cc4024a75b56d0f2b294b37f3>,
        <http://example.org/recipes/bebida/18/step/71b8133d0aab4e76bcd315c0cc5e675d>,
        <http://example.org/recipes/bebida/18/step/9f07c5691e4746a18a5479f8c3cafcc9>,
        <http://example.org/recipes/bebida/18/step/e940e207fee74483ad2d741afcad4710>,
        <http://example.org/recipes/bebida/18/step/f76cb8e70df241619d012fd97cc1fdde> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/19> a schema1:Recipe ;
    schema1:description "La chicha de piña es una bebida de piña que se prepara cociendo a fuego lento las cortezas y el núcleo de la piña con agua, panela o azúcar morena, y especias. Esta chicha se encuentra en la mayoría de restaurantes en Ecuador y se suelen servir como refrescos para acompañar los almuerzos."@es ;
    schema1:name "Chicha de Piña"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "12 tazas de agua"@es,
        "Especias variadas: canela, pimienta dulce, clavo de olor, anís, etc."@es,
        "Las cortezas y el núcleo de 1 piña bien lavada"@es,
        "¼ kilo de panela o azúcar morena"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/19/step/3892466b590844a0beb72955e3fc1801>,
        <http://example.org/recipes/bebida/19/step/930d13b466ec45899a007c8df2a87603>,
        <http://example.org/recipes/bebida/19/step/a3cb98a71aec497bafba888e50b7713a>,
        <http://example.org/recipes/bebida/19/step/bdadea62ebd34836823a88c0c4e7ccfd>,
        <http://example.org/recipes/bebida/19/step/f2ac2dfae6a244f281d8de69f59799aa> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/2> a schema1:Recipe ;
    schema1:description "Los batidos de guineo son deliciosos y muy fáciles de preparar en casa con ingredientes relativamente baratos."@es ;
    schema1:name "Batido de guineo"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 cucharadita de esencia de vainilla"@es,
        "2 tazas de leche"@es,
        "3 guineos o bananas"@es,
        "Hielo"@es,
        "½ taza de azúcar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/2/step/0f48f3ebb9414bfd8807084f9062129d>,
        <http://example.org/recipes/bebida/2/step/6a54f6f933ea48d1b8b991bb045a8070>,
        <http://example.org/recipes/bebida/2/step/8c7c882632af403a8944a168dd7ba040> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT15M"^^xsd:duration .

<http://example.org/recipes/bebida/20> a schema1:Recipe ;
    schema1:description "La chicha es una bebida que se prepara con la cocción de las cortezas y el núcleo de la piña y azúcar morena. La chicha de piña acompaña bien los almuerzos en todo Ecuador."@es ;
    schema1:name "Chicha de piñas"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 piña grande y madura"@es,
        "2 litros de agua"@es,
        "200 gr de panela o azúcar morena"@es,
        "Canela o clavo de olor"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/20/step/0480c55de39a41bb9df90b711dcf0929>,
        <http://example.org/recipes/bebida/20/step/60ce90ff938d48bebd1896836f6296fb>,
        <http://example.org/recipes/bebida/20/step/977212107c69460a9b1ba379fb7b27b6> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/bebida/21> a schema1:Recipe ;
    schema1:description "Bebida típica de Ecuador. Compuesta por 7 maices. Su preparación tarda varios días para fermentarse."@es ;
    schema1:name "Chicha de quito"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "Canguil"@es,
        "Cantidades iguales de cada uno:"@es,
        "Chulpi"@es,
        "Jora"@es,
        "Maíz amarillo"@es,
        "Maíz blanco"@es,
        "Maíz negro"@es,
        "Morocho"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/21/step/1b7919f3772c46e9a20bb54e6b36427a>,
        <http://example.org/recipes/bebida/21/step/1ebd5d40321946a0b12780880b896646>,
        <http://example.org/recipes/bebida/21/step/4735aeee57ed4824aadabb8b6266910c>,
        <http://example.org/recipes/bebida/21/step/a5685eaa811448aeb1e457ff690621a6>,
        <http://example.org/recipes/bebida/21/step/cacdaff1802942369278358e69472bd6> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/bebida/22> a schema1:Recipe ;
    schema1:description "Es una bebida tradicional muy popular en la cultura otavaleña. Se prepara con siete diferentes clases de maíz, y se endulza con panela. Su sabor es refrescante y es típica en las fiestas del Yamor, de allí su nombre, donde se agradece a la Madre Tierra por las cosechas."@es ;
    schema1:name "Chicha del yamor"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 taza de canguil"@es,
        "1 taza de chulpi"@es,
        "1 taza de jora (maíz fermentado)"@es,
        "1 taza de maíz amarillo"@es,
        "1 taza de maíz blanco"@es,
        "1 taza de maíz negro"@es,
        "1 taza de morocho"@es,
        "6 litros de agua"@es,
        "Miel de panela al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/22/step/1cdeee5c42724631be03b5a997c07341>,
        <http://example.org/recipes/bebida/22/step/274ab2c2a9b144d2815378a1965d81a1>,
        <http://example.org/recipes/bebida/22/step/43a300e11b134bc9aae958a5fa64f6da>,
        <http://example.org/recipes/bebida/22/step/59e7b20bd40b41a4b42ccad0f46dbab2>,
        <http://example.org/recipes/bebida/22/step/c2b768231d2442afa6f202c75063e35e>,
        <http://example.org/recipes/bebida/22/step/c89945b6f61c41099b11f91a40c70164>,
        <http://example.org/recipes/bebida/22/step/e908c23dddff42b0aba6b6cec4ef2c24>,
        <http://example.org/recipes/bebida/22/step/ff656133deaa4b01b736b578b21c85ae> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/bebida/23> a schema1:Recipe ;
    schema1:description "La chicha resbaladera es una bebida artesanal ecuatoriana preparada a base de arroz tradicional de la ciudad de Guayaquil. Su preparación es muy antigua, se ofrecía en las casas y en celebraciones especiales."@es ;
    schema1:name "Chicha Resbaladera"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 lata de leche condensada"@es,
        "2 cucharaditas de esencia de vainilla"@es,
        "2 palitos de canela"@es,
        "3 cucharadas de cebada en grano"@es,
        "6 tazas de leche"@es,
        "8 clavos de olor"@es,
        "8 granos de pimienta dulce (de olor)"@es,
        "8 tazas de agua"@es,
        "Canela en polvo"@es,
        "Nuez moscada"@es,
        "¼ kilo de arroz crudo"@es,
        "½ taza de azúcar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/23/step/0525238f55a9433e8480b666bfe53ab7>,
        <http://example.org/recipes/bebida/23/step/2934b2f3f08045fcaff5b3aad6e58a43>,
        <http://example.org/recipes/bebida/23/step/4d759ab89cad414e8501bddb11cc7017>,
        <http://example.org/recipes/bebida/23/step/a3b60b078a0a4bfc9daf685b41a67a72>,
        <http://example.org/recipes/bebida/23/step/d33f380261814052a0a750ed3d88bb56> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/24> a schema1:Recipe ;
    schema1:description "Es una bebida caliente exquisita y tradicional, que se prepara con el chocolate producido en la localidad de Ambato. Su sabor es fuerte debido a la pureza y calidad del chocolate, y con un aroma característico de las especias lo convertirán en una delicia irresistible."@es ;
    schema1:name "Chocolate de ambato"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de leche"@es,
        "2 tabletas de chocolate amargo de ambato"@es,
        "5 rajas de canela"@es,
        "8 clavos de olor"@es,
        "½ taza de azúcar al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/24/step/0fc4d6b98fc44644bea3de81f83a1610>,
        <http://example.org/recipes/bebida/24/step/35cb73fbf9fa4ba3a52f069ae9a8e754>,
        <http://example.org/recipes/bebida/24/step/a2e062e9f0824f9fa1d50d3bc00d5926>,
        <http://example.org/recipes/bebida/24/step/d2ff8fb0dfd94a92bbe1ba8204f4a24c>,
        <http://example.org/recipes/bebida/24/step/e5e285cfed6e4acd88d63d1a9bc816d4> ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/bebida/25> a schema1:Recipe ;
    schema1:description "La chucula ecuatoriana, es una bebida tradicional de los pueblos originarios de Ecuador, realizada con plátanos, que se considera un energizante natural. Una delicia!"@es ;
    schema1:name "Chucula"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 cucharadita de esencia de vainilla"@es,
        "1 vaso de agua"@es,
        "2 tazas de azúcar morena"@es,
        "2 tazas de leche"@es,
        "4 cucharadas de queso blanco"@es,
        "4 plátanos maduros"@es,
        "Una rama de canela"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/25/step/2af822522b7b446abe0d06223f565683>,
