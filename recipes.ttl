<http://example.org/recipes/plato-principal/101> a schema1:Recipe ;
    schema1:description "El seco de chivo es un plato ecuatoriano popular en las provincias de Loja, Santa Elena y Guayas. Se le llama “seco” debido a que, en su preparación, se deja evaporar la mayoría del líquido del guiso. En algunos casos se reemplaza la carne de chivo por carne de borrego, aunque el plato conserva el mismo nombre."@es ;
    schema1:name "Seco de Chivo"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 ají"@es,
        "1 cebolla colorada cortada finamente"@es,
        "1 cucharadita de comino molido"@es,
        "1 cucharadita de orégano"@es,
        "1 cucharadita de pimienta dulce molida"@es,
        "1 kilo de carne de chivo, con huesos, cortada en trozos grandes"@es,
        "1 pimiento cortado finamente"@es,
        "2 cucharadas de aceite"@es,
        "2 cucharadas de cilantro cortado finamente"@es,
        "2 cucharadas de panela rallada (piloncillo)"@es,
        "2 cucharaditas de achiote molido"@es,
        "2 tazas de chicha"@es,
        "3 tomates"@es,
        "6 dientes de ajo machacados"@es,
        "Sal al gusto"@es,
        "½ manojo de cilantro"@es,
        "½ taza de jugo de naranjilla (lulos)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/101/step/1b058373ddee4574a740d7206a637a59>,
        <http://example.org/recipes/plato-principal/101/step/21f149ed4fb046c8a63e75508e17ed79>,
        <http://example.org/recipes/plato-principal/101/step/48b52ba751b04dc3a6a21b3e9a9784ee>,
        <http://example.org/recipes/plato-principal/101/step/5868c0130a594a44932a5c476ac74622>,
        <http://example.org/recipes/plato-principal/101/step/684fa90f6f134662b95595f282b70839>,
        <http://example.org/recipes/plato-principal/101/step/68e5e93017304de282c4350973f57089>,
        <http://example.org/recipes/plato-principal/101/step/b7d17246424a40e493ba98efcd1038df> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/102> a schema1:Recipe ;
    schema1:description "El seco de guanta es una plato típico de la región amazónica del Ecuador a pesar de ser considerada en peligro de extinción."@es ;
    schema1:name "Seco de guanta"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 ají picado"@es,
        "1 cebolla colorada (paiteña)"@es,
        "1 cucharada de ajo machacado"@es,
        "1 litro de chicha o de vinagre de guineos"@es,
        "2 cucharadas de chillangua"@es,
        "2 cucharadas de cilantro picado"@es,
        "2 cucharadas de maní tostado"@es,
        "2 pimientos verdes"@es,
        "2 ramitas de cebolla blanca picada"@es,
        "4 lb de carne de guanta"@es,
        "Aceite de freir"@es,
        "Sal comino y pimienta al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/102/step/051e4ef5988b492bad5f2510e2b740ac>,
        <http://example.org/recipes/plato-principal/102/step/0df576dc5cd944cc87349ac80516154a>,
        <http://example.org/recipes/plato-principal/102/step/3c338d68a507415c8312f1b4af8ae999>,
        <http://example.org/recipes/plato-principal/102/step/994f758deadd424cb99086d6af35c78b> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/103> a schema1:Recipe ;
    schema1:description "El tradicional Seco de Pato, es muy popular en las festividades de los pueblos de la Costa. En Ecuador se consume mucho la carne de aves, por lo que este plato de sabor exquisito es una buena opción para compartir y degustar de la identidad gastronómica de esta región."@es ;
    schema1:name "Seco de pato"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de aceite de achiote"@es,
        "1 pato cortado en presas"@es,
        "1 rama de cilantro"@es,
        "2 tazas de jugo de naranjillas"@es,
        "3 cebollas"@es,
        "3 pimientos verdes"@es,
        "4 dientes de ajo triturados"@es,
        "Sal y comino c/n"@es,
        "¼ taza de chicha"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/103/step/445fdb48142245eab61b14414d32a235>,
        <http://example.org/recipes/plato-principal/103/step/6bd36759063e4cf6aecbea23642f0164>,
        <http://example.org/recipes/plato-principal/103/step/82904fdd4fd8420abad6c27153a599da>,
        <http://example.org/recipes/plato-principal/103/step/a548bbe8558d4e18aed7c9379de14812> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/104> a schema1:Recipe ;
    schema1:description "Jugoso Seco de pollo preparado con vegetales y naranjilla. Toda una explosión de sabor. Se puede servir con arroz."@es ;
    schema1:name "Seco de pollo ecuatoriano"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla"@es,
        "1 cubito de caldo concentrado de pollo"@es,
        "1 ½ kg de pollo"@es,
        "2 pimiento verde"@es,
        "250 gr de jugo de naranjilla"@es,
        "3 dientes de ajo"@es,
        "8 tomates"@es,
        "Aceite vegetal"@es,
        "Ajo en polvo"@es,
        "Cilantro fresco"@es,
        "Comino molido"@es,
        "Pimenton dulce"@es,
        "Pimienta negra"@es,
        "Sal al gusto"@es ;
