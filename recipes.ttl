<http://example.org/recipes/plato-principal/38> a schema1:Recipe ;
    schema1:description "El cuy es un roedor autóctono del Ecuador. Existen diversos platos en la gastronomía ecuatoriana que lo tienen como ingrediente principal en esta receta se encuentra asado."@es ;
    schema1:name "Cuy asada con papas"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla morada"@es,
        "1 kg de cuy"@es,
        "1 kg de papas peladas"@es,
        "1 pizca de achiote"@es,
        "1 pizca de cilantro"@es,
        "1 pizca de comino"@es,
        "1 pizca de orégano"@es,
        "1 pizca de pimienta molida"@es,
        "2 cebollas de verdeo"@es,
        "3 dientes de ajo"@es,
        "Sal a gusto"@es,
        "½ vaso de aceite"@es ;
