    schema1:recipeYield 10 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/56> a schema1:Recipe ;
    schema1:description "Los quimbolitos son pasteles, propios del Ecuador y del sur de Colombia elaborados con harina de maíz, cocidos al vapor envueltos en hojas de achira."@es ;
    schema1:name "Quimbolitos"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharadita de esencia de vainilla"@es,
        "1 cucharadita de polvo de hornear"@es,
        "1 lb de queso de mesa"@es,
        "1 taza de azúcar"@es,
        "1 taza de harina de maíz"@es,
        "1 taza de harina de trigo"@es,
        "1 taza de margarina"@es,
