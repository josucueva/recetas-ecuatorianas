        <http://example.org/recipes/sopa/83/step/a5266cd54773469f98838bb3bc8cb543>,
        <http://example.org/recipes/sopa/83/step/a7ae6839d2804552a056c72385f58f41>,
        <http://example.org/recipes/sopa/83/step/c1f76aa2177b4a05bc62f0053518a3fc>,
        <http://example.org/recipes/sopa/83/step/f67293afd664458c97e90e892ee554dc> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/sopa/84> a schema1:Recipe ;
    schema1:description "La sopa sancocho es un plato que se utiliza como acompañamiento en los almuerzos ecuatorianos volviéndose un clásico nacional."@es ;
    schema1:name "Sopa sancocho"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla"@es,
        "1 cucharadita de orégano"@es,
        "1 kg de carne vacuna con hueso"@es,
        "1 plátano verde"@es,
        "1 tomate"@es,
        "1 yuca pequeña"@es,
        "2 ramas de perejil"@es,
        "3 choclos tiernos en trozos"@es,
        "4 litros de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/84/step/08f058d2527549a2a46ae4003334c817>,
        <http://example.org/recipes/sopa/84/step/13394f58cc604b2db3beebaf53521f2c>,
        <http://example.org/recipes/sopa/84/step/4119b149365a42d5933eefaceae04083>,
        <http://example.org/recipes/sopa/84/step/58e24ac6f35743979f4fbfc70845b655>,
        <http://example.org/recipes/sopa/84/step/f5c44e5def2845559b40173356ba605d> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/sopa/85> a schema1:Recipe ;
    schema1:description "Es una sopa tradicional de la Sierra Ecuatoriana que se elabora como un locro a base de maní, leche, col, papas y costillas de res. Es un plato delicioso que puedes disfrutar en días fríos en compañía de la familia."@es ;
    schema1:name "Timbushca"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla blanca picada"@es,
        "1 cucharada de aceite con achiote"@es,
        "1 cucharadita de perejil picado"@es,
        "1 huevo duro"@es,
        "1 rama de cebolla larga"@es,
        "1 taza de leche"@es,
        "2 dientes de ajo machacados"@es,
        "200 gr de mote cocido"@es,
        "4 hojas	de col picadas"@es,
        "700 gr de costilla de res"@es,
        "8 papas cortadas"@es,
        "Sal y pimienta c/n"@es,
        "½ taza de maní tostado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/85/step/2ff20c10d71d4e7db1c0111e5e852161>,
        <http://example.org/recipes/sopa/85/step/a2e1896a83be4c5c91cc017fb5448bf0>,
        <http://example.org/recipes/sopa/85/step/a33145ae2d7d41e284b8fedbcee4e937>,
        <http://example.org/recipes/sopa/85/step/b3bb7a064c5f4856be97a76fc3d6dbf4> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/sopa/86> a schema1:Recipe ;
    schema1:description "El yahuarlocro es una de las preparaciones más famosas de Ecuador y su nombre nace de las palabras Yahuar (sangre) y locro (sopa o caldo). Este plato es preparado a nivel nacional, aunque es más popular en Guayabamba, ciudad cercana a la capital ecuatoriana."@es ;
    schema1:name "Yahuarlocro"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cucharada de comino molido"@es,
        "1 cucharada de orégano"@es,
        "1 cucharadita de achiote molido"@es,
        "1 diente de ajo machacado"@es,
        "1 litro de sangre fresca de borrego"@es,
        "2 cebollas finamente cortadas"@es,
        "2 cucharadas de cilantro finamente cortado"@es,
        "2 cucharadas de perejil finamente cortado"@es,
        "2 kilos de papas peladas y cortadas en cubos"@es,
        "2 limones"@es,
        "4 cucharadas de aceite"@es,
        "4 onzas de maní licuado disuelto en una taza con leche"@es,
        "Hojas de hierba buena"@es,
        "Menudo de borrego (panza, librillo, tripas)"@es,
        "Sal y pimienta al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/86/step/0fbe2cb537c74a9c9a73b42f511cd974>,
        <http://example.org/recipes/sopa/86/step/1411e83c32de41b0a68023ca0fdc3349>,
        <http://example.org/recipes/sopa/86/step/5688318a7745429a88b3e0a163c26021>,
        <http://example.org/recipes/sopa/86/step/59cdef608ce84f9abc4b60356350f5f9>,
        <http://example.org/recipes/sopa/86/step/6c229b7f0209498e8b518f59d2a093ae>,
        <http://example.org/recipes/sopa/86/step/aecc32f9777f42d996965a8dfcb31696>,
        <http://example.org/recipes/sopa/86/step/c7a44ba9fc764a209436014d43a260b8>,
        <http://example.org/recipes/sopa/86/step/d83e93e7633e4f11a5fe0086ae7ab976>,
        <http://example.org/recipes/sopa/86/step/f13de5c175304835bfac75531056f15e> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/sopa/9> a schema1:Recipe ;
    schema1:description "El bagre es una especie de pez que se conoce en Ecuador como pez camchimala y comúnmente en todo el mundo como pez gato, debido a los bigotes que posee. Esta sopa se prepara con bagre, yuca, cilantro, tomate, aceite, comino, ajo y sal."@es ;
    schema1:name "Caldo de Bagre"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cabeza de bagre"@es,
        "1 cucharada de cilantro cortado"@es,
        "1 cucharadita de comino molido"@es,
        "1 yuca grande cortada en trozos"@es,
        "2 cucharadas de aceite"@es,
        "2 dientes de ajo machacados"@es,
        "2 tomates cortados en cubos"@es,
        "4 rodajas de bagre"@es,
        "5 tazas de agua"@es,
        "Sal y pimienta al gusto"@es,
        "½ cebolla cortada en cubos"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/9/step/112271c263924b1390eb7d6ff29710bd>,
        <http://example.org/recipes/sopa/9/step/1b2b2ca1ea7545f9ad5f307f114273f1>,
        <http://example.org/recipes/sopa/9/step/2bef2a2300bd44af8aea94b5afb1bb7d>,
        <http://example.org/recipes/sopa/9/step/3a4e99248e804f149c007da3214c5b27>,
        <http://example.org/recipes/sopa/9/step/8112b977d86e418ca2ef393d7bcef2d0> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/bebida/1/step/49e49562837c411598628c29db0ecd46> a schema1:HowToStep ;
    schema1:text "Colocar en una licuadora la pulpa del borojó, la leche, el azúcar y moscada en una licuadora, batir por 3 minutos."@es .

<http://example.org/recipes/bebida/1/step/7d2ea107121b44dbacd78a0dc82b5bf9> a schema1:HowToStep ;
    schema1:text "Colocar hielo picado y licuar durante un minuto más."@es .

<http://example.org/recipes/bebida/1/step/936c617df0f7420daf877607b976baf2> a schema1:HowToStep ;
    schema1:text "Servir frío."@es .

<http://example.org/recipes/bebida/1/step/d616a0ed21d14de5a825685a42fb9d9a> a schema1:HowToStep ;
    schema1:text "Incorporar luego los huevos batidos aparte, la vainilla y la nuez y licuar en máxima velocidad por 3 minutos más."@es .

<http://example.org/recipes/bebida/10/step/4d33d22c74e243a8adae01c7e34f9258> a schema1:HowToStep ;
    schema1:text "Continuar hirviendo a fuego lento hasta que el chocolate se derrita."@es .

<http://example.org/recipes/bebida/10/step/760adaa8a88c44d195404806ad09a4bc> a schema1:HowToStep ;
    schema1:text "Agregar el chocolate una vez que se formen pequeñas burbujas en la parte superior de la leche."@es .

<http://example.org/recipes/bebida/10/step/77df7d8d35eb47d09bcd261e8a203128> a schema1:HowToStep ;
    schema1:text "Retirar y agitar hasta que el chocolate se disuelva completamente en la leche y se vuelve espumoso."@es .

<http://example.org/recipes/bebida/10/step/852bd6e294a04ff593be058100f6a673> a schema1:HowToStep ;
    schema1:text "Servir caliente."@es .

<http://example.org/recipes/bebida/10/step/a1f303240bcb4843842741051ba65f32> a schema1:HowToStep ;
    schema1:text "Hervir la leche a fuego, agregar la canela y las pepitas pimienta dulce."@es .

<http://example.org/recipes/bebida/11/step/32253a2a63b6479b8b487667ef9a67de> a schema1:HowToStep ;
    schema1:text "Pelar la zanahoria y trocearla."@es .

<http://example.org/recipes/bebida/11/step/3ed980a9ddf249cb90e4f7153313163b> a schema1:HowToStep ;
    schema1:text "Licuar a velocidad máxima todos los ingredientes."@es .

<http://example.org/recipes/bebida/11/step/71488d9da699409ba2701874fdab23f4> a schema1:HowToStep ;
    schema1:text "Lavar minuciosamente las hojas de espinaca."@es .

<http://example.org/recipes/bebida/11/step/ea1cc4cfaf024ed19e9a5ff1fc6d3f62> a schema1:HowToStep ;
    schema1:text "Servir bien fría."@es .

<http://example.org/recipes/bebida/12/step/28a81f81fce547288a3128e9e040b73d> a schema1:HowToStep ;
    schema1:text "Lavamos bien los dos limones, le cortamos la tapita de arriba y la de abajo, luego los cortamos en cuadritos y colocamos estos cuadritos de limones en un vaso de vidrio."@es .

<http://example.org/recipes/bebida/12/step/3c9633403129400f83db2b1f23a7c7cd> a schema1:HowToStep ;
    schema1:text "Se puede decorar con una rodaja de limón en el borde del vaso. Otros les gusta agregar sal al borde del vaso."@es .

<http://example.org/recipes/bebida/12/step/8346e455751c4eb796cc96b2f3d21cbc> a schema1:HowToStep ;
    schema1:text "Rompemos trozos pequeños de hielo hasta llenar el vaso y se le agrega el aguardiente de caña hasta arriba, o hasta el grado de alcohol que sea de su gusto."@es .

<http://example.org/recipes/bebida/12/step/90104cb0ea2242e4ac884dad32c7d8bd> a schema1:HowToStep ;
    schema1:text "Se agarra otro vaso de de plástico que tenga la abertura o boca más grande y tapamos bien un vaso con el otro y comenzamos a batir para que se mezcle muy bien la bebida."@es .

<http://example.org/recipes/bebida/12/step/ef0e82bb419d402880ea882b98550136> a schema1:HowToStep ;
    schema1:text "Agregamos las 2 cucharadas de azúcar y con un brazo de mortero los vamos machacando."@es .

<http://example.org/recipes/bebida/12/step/f2e26cc9f65c48dea2db935234b2c85e> a schema1:HowToStep ;
    schema1:text "Los limones los machacamos junto con el azúcar hasta hacer una especie de jarabe."@es .

<http://example.org/recipes/bebida/12/step/f582759399be417eba03048a880e635c> a schema1:HowToStep ;
    schema1:text "Luego de un rato de estar batiendolos se deja la bebida en el vaso de vidrio ."@es .

<http://example.org/recipes/bebida/13/step/5247919197b34b1fbd57d4675b587e42> a schema1:HowToStep ;
    schema1:text "Reducir la temperatura y cocinar a fuego lento, con la olla tapada, durante 40 minutos."@es .

<http://example.org/recipes/bebida/13/step/974b9c4ccb3c403bad32b7e4a4009e21> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, agregar el aguardiente y servir el canelazo inmediatamente."@es .

<http://example.org/recipes/bebida/13/step/e93d45e9f7874e2aa0c806b29be7fe3b> a schema1:HowToStep ;
    schema1:text "Colocar en una olla el agua, la canela y el azúcar o panela rallada y esperar hasta que hierva."@es .

<http://example.org/recipes/bebida/14/step/1fed9f084b5742dcba1483ef51ddb1fa> a schema1:HowToStep ;
    schema1:text "Decorar espolvoreando con la canelal o el cacao en polvo y servimos al momento, muy caliente."@es .

<http://example.org/recipes/bebida/14/step/3756fa7c692e4fa293a0738bed1f7de3> a schema1:HowToStep ;
    schema1:text "Colocar la espuma espesa de leche en la taza e ir vertiendo el café azucarado por un lateral con cuidado. De esta forma el café se va abajo y la espuma queda arriba."@es .

<http://example.org/recipes/bebida/14/step/fb975ada7da44b958de9512e74a8f46c> a schema1:HowToStep ;
    schema1:text "Colocar la leche con azúcar en un recipiente y batimos con batidora durante 2 minutos o hasta que la leche espume bastante y aumente mucho su tamaño."@es .

<http://example.org/recipes/bebida/14/step/fd9b6c529bda47df874bb842a048c378> a schema1:HowToStep ;
    schema1:text "Poner la leche ya batida en el microondas unos 30 segundos y así la espuma se compacta."@es .

<http://example.org/recipes/bebida/15/step/1802d68c9388450ba5442b51f16fba3e> a schema1:HowToStep ;
    schema1:text "Prepare un melado con la panela, 1 litro de agua, especias y las hojas de naranjo. Cocine por 20 minutos y retire del fuego. Cuele y reserve."@es .

<http://example.org/recipes/bebida/15/step/4745254159124e2696c870b5da6f4727> a schema1:HowToStep ;
    schema1:text "Añadir a la mezcla de maíz, la pulpa de las naranjillas, la piña y el babaco. Mezcle muy bien todos los ingredientes y deje enfriar."@es .

<http://example.org/recipes/bebida/15/step/4bd42d71f0c84e8da92c1684ad4e4523> a schema1:HowToStep ;
    schema1:text "Una vez que el maíz ablande, retire los granos y proceda a molerlos. Deje algunos sin moler."@es .

<http://example.org/recipes/bebida/15/step/550d930017db4db6af26a00883dda511> a schema1:HowToStep ;
    schema1:text "Agregar hielo picado y sirva bien frio."@es .

<http://example.org/recipes/bebida/15/step/6af0e8fca15b49cbae229828944c39dd> a schema1:HowToStep ;
    schema1:text "Verter la masa en la olla y disuelva bien en el agua. Siga cocinando a fuego mínimo por unos minutos."@es .

<http://example.org/recipes/bebida/15/step/fa741a0cbfef433ea3219de2ce3c3703> a schema1:HowToStep ;
    schema1:text "Coloque el maíz en una cacerola con 2 litros de agua y cocine a fuego medio durante 1 hora."@es .

<http://example.org/recipes/bebida/16/step/170c39e9a04c4333a5541ad1cdd1027b> a schema1:HowToStep ;
    schema1:text "Se revuelve por 25 minutos para que no se pegue. Si nota que se esta secando el arroz, agregurle mas agua hasta que que se cocine el arroz. Aproximadamente de 15 a 20 minutos."@es .

<http://example.org/recipes/bebida/16/step/46c5a3a9c7b641529e911897e8890216> a schema1:HowToStep ;
    schema1:text "Se agaga el fuego. Luego se retiran las especies; Ya el arroz agarró todo el sabor y olor de la canela, clavos y pimienta dulce."@es .

<http://example.org/recipes/bebida/16/step/9a53546729c6464d827604df3c41737e> a schema1:HowToStep ;
    schema1:text "Se calienta por 10 minutos y se deja enfriar."@es .

<http://example.org/recipes/bebida/16/step/9e8ad75ddb2744db9ea84221f1544233> a schema1:HowToStep ;
    schema1:text "En una olla colocamos medio litro de agua. Al hervir el agua se coloca el arroz y las especies. Se hechan: la canela de palo, las pimientas dulces y los clavos dulces."@es .

<http://example.org/recipes/bebida/16/step/aa29a4a52f904694b5a1f419bedb0247> a schema1:HowToStep ;
    schema1:text "Se pasa por una coladora todo el arroz y se vuelve a colocar en la olla por 10 minutos."@es .

<http://example.org/recipes/bebida/16/step/afb35c9226d34ef6a1fa686b2abf8dbc> a schema1:HowToStep ;
    schema1:text "Se sirve con suficiente hielo picadito y canela molida."@es .

<http://example.org/recipes/bebida/16/step/cab90ea97b7f427da69096d02a0cb3bd> a schema1:HowToStep ;
    schema1:text "Se pone el arroz en una licuadora con la leche. Primero en velocidad baja, luego en velocidad rápida."@es .

<http://example.org/recipes/bebida/16/step/cbba077cd9d542cc9eed5edb6ca2055e> a schema1:HowToStep ;
    schema1:text "Luego se le agrega la vainilla y la panela o el azúcar."@es .

<http://example.org/recipes/bebida/16/step/d8976ead836349bdb3116b40dc8cedbb> a schema1:HowToStep ;
    schema1:text "Si quieren se puede colocar una pizca de sal y de nuez moscada."@es .

<http://example.org/recipes/bebida/17/step/106be35b1cf24d91b9fc467da66774d9> a schema1:HowToStep ;
    schema1:text "Sirva bien fría."@es .

<http://example.org/recipes/bebida/17/step/4ab5fb207c204c809188416337fe2d46> a schema1:HowToStep ;
    schema1:text "Endulce con la panela molida"@es .

<http://example.org/recipes/bebida/17/step/a76707e2f1994b4b89816851d165fe09> a schema1:HowToStep ;
    schema1:text "En una licuadora coloque la mezcla fermentada con el agua y procese."@es .

<http://example.org/recipes/bebida/17/step/baa1c5e072c442da8aa4437cd9be8ebc> a schema1:HowToStep ;
    schema1:text "Moler el chontaduro y la yuca."@es .

<http://example.org/recipes/bebida/17/step/da3de7f1428045adad3bbe9a7a9bf90e> a schema1:HowToStep ;
    schema1:text "Colocar la preparación en hojas de bijao y dejarla fermentar por 48 horas."@es .

<http://example.org/recipes/bebida/18/step/3935c53cc4024a75b56d0f2b294b37f3> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, dejar reposar hasta que se enfríe, colar y añadir azúcar al gusto. Colocarlo en una jarra y dejarlo fermentar durante 5 días."@es .

<http://example.org/recipes/bebida/18/step/71b8133d0aab4e76bcd315c0cc5e675d> a schema1:HowToStep ;
    schema1:text "Servir la chicha de jora frío."@es .

<http://example.org/recipes/bebida/18/step/9f07c5691e4746a18a5479f8c3cafcc9> a schema1:HowToStep ;
    schema1:text "Cuando la mitad del agua se haya reducido, agregar los 5 litros de agua restantes y dejar hervir durante 1 hora y media más."@es .

<http://example.org/recipes/bebida/18/step/e940e207fee74483ad2d741afcad4710> a schema1:HowToStep ;
    schema1:text "Colocar en una sartén la cebada y el maíz de jora y tostar durante 25 minutos."@es .

<http://example.org/recipes/bebida/18/step/f76cb8e70df241619d012fd97cc1fdde> a schema1:HowToStep ;
    schema1:text "En una olla grande, colocar 5 litros de agua, la cebada, el maíz de jora y los clavos de olor. Dejar hervir, revolviendo constantemente la mezcla para que no se espese."@es .

<http://example.org/recipes/bebida/19/step/3892466b590844a0beb72955e3fc1801> a schema1:HowToStep ;
    schema1:text "Colar el líquido y servir la chicha de piña fría o caliente."@es .

<http://example.org/recipes/bebida/19/step/930d13b466ec45899a007c8df2a87603> a schema1:HowToStep ;
    schema1:text "Opcionalmente, se puede dejar las cortezas de la piña y las especias en el líquido para que el sabor se siga concentrando."@es .

<http://example.org/recipes/bebida/19/step/a3cb98a71aec497bafba888e50b7713a> a schema1:HowToStep ;
    schema1:text "Colocar en una olla el agua, la piña, la panela y especias y esperar hasta que hierva."@es .

<http://example.org/recipes/bebida/19/step/bdadea62ebd34836823a88c0c4e7ccfd> a schema1:HowToStep ;
    schema1:text "Puede guardarse en la refrigeradora por varios días."@es .

<http://example.org/recipes/bebida/19/step/f2ac2dfae6a244f281d8de69f59799aa> a schema1:HowToStep ;
    schema1:text "Reducir la temperatura y cocinar a fuego lento, tapada parcialmente y revolviendo de vez en cuando, durante 1 hora."@es .

<http://example.org/recipes/bebida/2/step/0f48f3ebb9414bfd8807084f9062129d> a schema1:HowToStep ;
    schema1:text "Mezclar la leche, los guineos, la vainilla y el azúcar en una licuadora, mezclar por varios minutos hasta que este líquida."@es .

<http://example.org/recipes/bebida/2/step/6a54f6f933ea48d1b8b991bb045a8070> a schema1:HowToStep ;
    schema1:text "Pelar los guineos y trozearlos."@es .

<http://example.org/recipes/bebida/2/step/8c7c882632af403a8944a168dd7ba040> a schema1:HowToStep ;
    schema1:text "Añadir el hielo y mezclar hasta que estén relativamente molidos."@es .

<http://example.org/recipes/bebida/20/step/0480c55de39a41bb9df90b711dcf0929> a schema1:HowToStep ;
    schema1:text "Cuando rompa en hervor llegar a fuego mínimo y cocinar por una hora."@es .

<http://example.org/recipes/bebida/20/step/60ce90ff938d48bebd1896836f6296fb> a schema1:HowToStep ;
    schema1:text "Colar el líquido y servir bien frio."@es .

<http://example.org/recipes/bebida/20/step/977212107c69460a9b1ba379fb7b27b6> a schema1:HowToStep ;
    schema1:text "En una cacerola colocar el agua con la panela, las especias y la piña y dejar hervir."@es .

<http://example.org/recipes/bebida/21/step/1b7919f3772c46e9a20bb54e6b36427a> a schema1:HowToStep ;
    schema1:text "Esta lista para disfrutar y servir."@es .

<http://example.org/recipes/bebida/21/step/1ebd5d40321946a0b12780880b896646> a schema1:HowToStep ;
    schema1:text "En una olla se coloca agua a hervir. Aparte mezclamos las harinas con un poquito de agua fría. Cuando el agua de la olla ya este hirviendo se agrega la mezcla de la harina con agua fría y se va mezclando constantemente hasta que levante la chicha."@es .

<http://example.org/recipes/bebida/21/step/4735aeee57ed4824aadabb8b6266910c> a schema1:HowToStep ;
    schema1:text "Una vez que hierva se apaga y se reserva para luego colarla dos veces. Luego se lleva a un tonel de 3 a 4 días para que madure."@es .

<http://example.org/recipes/bebida/21/step/a5685eaa811448aeb1e457ff690621a6> a schema1:HowToStep ;
    schema1:text "Pasado los 4 días se vierte en una vasija de barro y se le agrega miel."@es .

<http://example.org/recipes/bebida/21/step/cacdaff1802942369278358e69472bd6> a schema1:HowToStep ;
    schema1:text "Se ventean todos los maíces para que se limpien bien y se trituran para después llevarlos a moler y tenerlos en harina fina."@es .

<http://example.org/recipes/bebida/22/step/1cdeee5c42724631be03b5a997c07341> a schema1:HowToStep ;
    schema1:text "Tueste los granos por separado en un tiesto."@es .

<http://example.org/recipes/bebida/22/step/274ab2c2a9b144d2815378a1965d81a1> a schema1:HowToStep ;
    schema1:text "Vuelva a colarla y endulce con la miel de panela al gusto."@es .

<http://example.org/recipes/bebida/22/step/43a300e11b134bc9aae958a5fa64f6da> a schema1:HowToStep ;
    schema1:text "Mezcle los granos y muela hasta obtener una harina fina."@es .

<http://example.org/recipes/bebida/22/step/59e7b20bd40b41a4b42ccad0f46dbab2> a schema1:HowToStep ;
    schema1:text "Disolver la harina en el agua y llevar a cocción durante 5 horas, hasta que la mezcla obtenga el color y el espesor deseado."@es .

<http://example.org/recipes/bebida/22/step/c2b768231d2442afa6f202c75063e35e> a schema1:HowToStep ;
    schema1:text "Almacene la mezcla en un pondo o en un recipiente de barro para su fermentación por unas 24 horas. Esto permitirá que adquiera el sabor ideal."@es .

<http://example.org/recipes/bebida/22/step/c89945b6f61c41099b11f91a40c70164> a schema1:HowToStep ;
    schema1:text "Retire del fuego y cuele."@es .

<http://example.org/recipes/bebida/22/step/e908c23dddff42b0aba6b6cec4ef2c24> a schema1:HowToStep ;
    schema1:text "Sirva y disfrute."@es .

<http://example.org/recipes/bebida/22/step/ff656133deaa4b01b736b578b21c85ae> a schema1:HowToStep ;
    schema1:text "Seleccionar el maíz para obtener granos nuevos."@es .

<http://example.org/recipes/bebida/23/step/0525238f55a9433e8480b666bfe53ab7> a schema1:HowToStep ;
    schema1:text "Lavar el arroz y la cebada en un colador. Colocarlos en un tazón de vidrio con 4 tazas de agua, tapar y dejar reposar toda la noche en un lugar fresco (no en la refrigeradora)."@es .

<http://example.org/recipes/bebida/23/step/2934b2f3f08045fcaff5b3aad6e58a43> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, agregar el azúcar, la leche fría y la leche condensada, y mezclar bien. Servir la chicha resbaladera con cubitos de hielo, espolvoreada con canela molida y nuez moscada."@es .

<http://example.org/recipes/bebida/23/step/4d759ab89cad414e8501bddb11cc7017> a schema1:HowToStep ;
    schema1:text "Al día siguiente, licuar todo, colar y colocar el líquido en una olla grande."@es .

<http://example.org/recipes/bebida/23/step/a3b60b078a0a4bfc9daf685b41a67a72> a schema1:HowToStep ;
    schema1:text "Aparte, colocar en una olla las otras 4 tazas de agua, los palitos de canela, la pimienta dulce y los clavos de olor, y esperar hasta que hierva."@es .

<http://example.org/recipes/bebida/23/step/d33f380261814052a0a750ed3d88bb56> a schema1:HowToStep ;
    schema1:text "Añadir la mezcla licuada a la olla, dejar hervir, revolviendo constantemente y esperar hasta que la mezcla espese."@es .

<http://example.org/recipes/bebida/24/step/0fc4d6b98fc44644bea3de81f83a1610> a schema1:HowToStep ;
    schema1:text "Batir con paleta de madera por unos 5 minutos hasta que el chocolate esté homogéneo y espeso."@es .

<http://example.org/recipes/bebida/24/step/35cb73fbf9fa4ba3a52f069ae9a8e754> a schema1:HowToStep ;
    schema1:text "Mezclar el chocolate derretido con la leche hirviendo y agregue el azúcar."@es .

<http://example.org/recipes/bebida/24/step/a2e062e9f0824f9fa1d50d3bc00d5926> a schema1:HowToStep ;
    schema1:text "Derretir el chocolate en un poco de agua."@es .

<http://example.org/recipes/bebida/24/step/d2ff8fb0dfd94a92bbe1ba8204f4a24c> a schema1:HowToStep ;
    schema1:text "Ponga a hervir la leche con la canela y los clavos."@es .

<http://example.org/recipes/bebida/24/step/e5e285cfed6e4acd88d63d1a9bc816d4> a schema1:HowToStep ;
    schema1:text "Servir caliente y disfrute."@es .

<http://example.org/recipes/bebida/25/step/2af822522b7b446abe0d06223f565683> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y licuar con la leche, retirando previamente la canela."@es .

<http://example.org/recipes/bebida/25/step/51c8f9aedee0456f91321cab6080cbe2> a schema1:HowToStep ;
    schema1:text "Colocar la preparación en una olla, añadir el queso y la vainilla. Cocinar revolviendo constantemente hasta que hierva y retirar del fuego."@es .

<http://example.org/recipes/bebida/25/step/52372f83dc0649f990c6edcad82a038a> a schema1:HowToStep ;
    schema1:text "En una cacerola colocar los plátanos, el azúcar, el agua y la canela y cocinar a fuego bajo por 15 minutos."@es .

<http://example.org/recipes/bebida/25/step/e2bb9908c12e455e9ae31bc3c64be333> a schema1:HowToStep ;
    schema1:text "Servir bien fría."@es .

<http://example.org/recipes/bebida/26/step/1c234d7ef1eb493a9636de474f112e53> a schema1:HowToStep ;
    schema1:text "Colocar en una olla los plátanos, el agua la canela y el azúcar. Cocinar a fuego lento durante 10 minutos y retirar del fuego."@es .

<http://example.org/recipes/bebida/26/step/2574780c16b349139cd9e8bbf643352a> a schema1:HowToStep ;
    schema1:text "Retirar la canela. Licuar los plátanos, el agua y el azúcar con la leche."@es .

<http://example.org/recipes/bebida/26/step/559a832e48774332886eea40aa0b71e8> a schema1:HowToStep ;
    schema1:text "Servir la chucula ecuatoriana en copas con un poco de espumilla de limón."@es .

<http://example.org/recipes/bebida/26/step/c4841e900a9c42daac47e39e31acd45e> a schema1:HowToStep ;
    schema1:text "Verter el batido en una olla, añadir el queso y la vainilla. Cocinar a fuego lento, revolviendo constantemente, esperar hasta que hierva y retirar del fuego."@es .

<http://example.org/recipes/bebida/27/step/61a857a71dd149658d8fa10905c482e4> a schema1:HowToStep ;
    schema1:text "Listo para disfrutar."@es .

<http://example.org/recipes/bebida/27/step/9d78b4d14f0e4331b1632e2bf094f938> a schema1:HowToStep ;
    schema1:text "Aparte se coloca el hielo y el ron. Luego se agrega la soda y los que prefieran sin soda pueden colocarle jugó de Maracuy"@es .

<http://example.org/recipes/bebida/27/step/b64650a4cdb842d78295aef215db62f6> a schema1:HowToStep ;
    schema1:text "Primeramente se agrega la hierba buena en él vaso, los trocitos de limón y lo mezclamos muy bien con el azúcar."@es .

<http://example.org/recipes/bebida/27/step/cf5e08df533d49358a73769068d78da1> a schema1:HowToStep ;
    schema1:text "Se adorna el vaso con hierba buena y otros con rodaja de limon u otra fruta."@es .

<http://example.org/recipes/bebida/28/step/1da9ae093cbb4559bb606087f58fb7ee> a schema1:HowToStep ;
    schema1:text "Bajar la temperatura y cocinar a fuego lento durante 15 minutos hasta que la colada no sepa a avena cruda. Colar el líquido para remover cualquier grumo de avena."@es .

<http://example.org/recipes/bebida/28/step/3ffaf3f570824b21b6419b72542ce8d1> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, colar el líquido y colocar el líquido una olla. Licuar la pulpa de naranjilla con la avena remojada (incluyendo el agua), verter en el líquido colado y esperar hasta que hierva."@es .

<http://example.org/recipes/bebida/28/step/a095403db3a54c838cc5a89e590637d7> a schema1:HowToStep ;
    schema1:text "Colocar en una olla grande el agua, las cortezas y el centro de la piña, la panela, la canela, la pimienta dulce, los clavos de olor, la cáscara de limón y la hierba luisa seca. Cocinar a fuego medio durante 30 minutos."@es .

<http://example.org/recipes/bebida/28/step/e25d1806a5c244dd9c62563a03648466> a schema1:HowToStep ;
    schema1:text "Servir la colada de avena caliente o dejar enfriar y servir fría."@es .

<http://example.org/recipes/bebida/29/step/24ac37e8da89460e8d102fc95e5cbc06> a schema1:HowToStep ;
    schema1:text "Unificar las dos preparaciones en una sola olla, la piña y continuar cocinando por un par de minutos."@es .

<http://example.org/recipes/bebida/29/step/295a9a3ee3a842a5a5cb000b22c1caa1> a schema1:HowToStep ;
    schema1:text "Servir la colada morada bien fría."@es .

<http://example.org/recipes/bebida/29/step/2dee5eeb755542c69c6148e975494a71> a schema1:HowToStep ;
    schema1:text "En otra olla, colocar un litro de agua y los frutos rojos y hervir por media hora."@es .

<http://example.org/recipes/bebida/29/step/40a17f9a444747e4badc7dcafaae41b6> a schema1:HowToStep ;
    schema1:text "Por ultimo agregar las frutillas y dejar hervir por 10 minutos más."@es .

<http://example.org/recipes/bebida/29/step/5edc981b5d784286ae32d90b43b864af> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y colocar a hierba luisa, dejar reposar unos minutos, colar y volver a la cacerola."@es .

<http://example.org/recipes/bebida/29/step/76fd27dd8cce428ca19c15c03ed89f22> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, dejar enfriar y licuar el jugo de naranja."@es .

<http://example.org/recipes/bebida/29/step/e9fc4a080a184ef7b184ee0710dccccd> a schema1:HowToStep ;
    schema1:text "En una cacerola colocar la canela, los clavos de olor, las cáscaras de frutas, el azúcar y la panela cuando rompa en hervor dejar cocinando por 15 minutos más."@es .

<http://example.org/recipes/bebida/3/step/10cd3058babb4bb5a056251acad69fd6> a schema1:HowToStep ;
    schema1:text "Decorar con los trozos de durazno."@es .

<http://example.org/recipes/bebida/3/step/93aeb65afcbe474e98c261224654f0d3> a schema1:HowToStep ;
    schema1:text "Servir frío."@es .

<http://example.org/recipes/bebida/3/step/a41aefa479a74673a34a38ac5da003b8> a schema1:HowToStep ;
    schema1:text "Lavar y pelar los mangos."@es .

<http://example.org/recipes/bebida/3/step/d51dce551bc8445b96b8525e31b09385> a schema1:HowToStep ;
    schema1:text "Mezclar el mango, la leche o yogurt natural y el hielo en cubitos."@es .

<http://example.org/recipes/bebida/3/step/feaedc4c0bd0413aac7d72ffe23ae612> a schema1:HowToStep ;
    schema1:text "Batir hasta que se forme una mezcla homogénea."@es .

<http://example.org/recipes/bebida/30/step/0859444484d94fd1b727a0294a62367f> a schema1:HowToStep ;
    schema1:text "Agregar las frutillas y el babaco, esperar hasta que vuelva a hervir y retirar del fuego. Servir la colada morada tibia o colocarla en la refrigeradora y tomarla fría."@es .

<http://example.org/recipes/bebida/30/step/1785ad1d4faa468bb862beb9eafb4021> a schema1:HowToStep ;
    schema1:text "Agregar la mezcla licuada a la otra olla con el líquido de especias. Agregar la maicena diluida, revolver constantemente y esperar hasta que hierva. Agregar la piña y continuar cocinando por otros 10 minutos."@es .

<http://example.org/recipes/bebida/30/step/5b839a4412e548b8baadd25a253ba9b3> a schema1:HowToStep ;
    schema1:text "Colocar en una olla grande 1 litro de agua, la canela, los clavos de olor, las cáscaras de limón, naranja y piña, el azúcar y la panela. Dejar hervir durante 20 minutos."@es .

<http://example.org/recipes/bebida/30/step/6bee29e0c5ae485d8f168f5c44a34b2c> a schema1:HowToStep ;
    schema1:text "Aparte, en otra olla, colocar el otro litro de agua, los mortiños, las moras y la pimienta de olor molida, y hervir durante 30 minutos. Retirar del fuego, licuar esta mezcla con la naranjilla y colar para eliminar las semillas."@es .

<http://example.org/recipes/bebida/30/step/aeabeb815bdf4068acfcf42f476ca97d> a schema1:HowToStep ;
    schema1:text "Apagar el fuego, agregar las hojas de laurel y la hierba luisa, tapar y dejar reposar por 5 minutos. Colar el líquido y colocarlo nuevamente en una olla grande."@es .

<http://example.org/recipes/bebida/31/step/10ba351dac5a4733b62797b16136bed4> a schema1:HowToStep ;
    schema1:text "Refrigerar por unos 30 minutos (si se prefiere frío) o servir el come y bebe inmediatamente en copas de postres."@es .

<http://example.org/recipes/bebida/31/step/91332f3ece784c298917276295716c5c> a schema1:HowToStep ;
    schema1:text "Exprimir el jugo de las naranjas en el momento y agregar al bol mezclando bien,"@es .

<http://example.org/recipes/bebida/31/step/ae46e5497c594e708d138fd099c7758c> a schema1:HowToStep ;
    schema1:text "Colocar todas las frutas en un bol grande."@es .

<http://example.org/recipes/bebida/31/step/e2a5a8bf5ae94f3ba8b4b118b6a942b6> a schema1:HowToStep ;
    schema1:text "Probar y, si se desea, agregar azúcar o miel a gusto."@es .

<http://example.org/recipes/bebida/31/step/ebeb8c66ea3a4b45a7a85369e476b2b8> a schema1:HowToStep ;
    schema1:text "Comenzar lavando y pelando todas las frutas, cortarlas en trozos pequeños y simétricos."@es .

<http://example.org/recipes/bebida/32/step/52f718241e3844349f7bb0c8e43262f8> a schema1:HowToStep ;
    schema1:text "Dejar reposar en el congelador y remover cada 15 minutos para cristalizar."@es .

<http://example.org/recipes/bebida/32/step/61a09c0876e74e02a1948281a009c6f3> a schema1:HowToStep ;
    schema1:text "Una vez que enfríe agregar el café y la medida de coñac."@es .

<http://example.org/recipes/bebida/32/step/7c403a729cf147228527901dcf147c5d> a schema1:HowToStep ;
    schema1:text "Colocar en una olla el azúcar y el agua y hervir por 10 minutos."@es .

<http://example.org/recipes/bebida/32/step/d978c37934c2443886511e42990086d4> a schema1:HowToStep ;
    schema1:text "Servir en copas de coctel con una cucharada de crema y café espolvoreado."@es .

<http://example.org/recipes/bebida/33/step/23a221911c794273b48d02cce8eaea52> a schema1:HowToStep ;
    schema1:text "Se pica hielo y se sirve en vaso con el hielo picado."@es .

<http://example.org/recipes/bebida/33/step/ada8d5966c484180984473b8c87ded1c> a schema1:HowToStep ;
    schema1:text "Primero se corta la caña y se lava muy bien."@es .

<http://example.org/recipes/bebida/33/step/eebe76145900492280d04afde2c6c253> a schema1:HowToStep ;
    schema1:text "Luego este jugo se cuela para quitarle cualquier residuo."@es .

<http://example.org/recipes/bebida/33/step/febff2366b474e8fa0be1eb689750835> a schema1:HowToStep ;
    schema1:text "Se corta a todo lo largo de ella. Ya cortadas las cañas, cada una partida en dos partes, se pasan por un trapiche y se extrae todo el jugo."@es .

<http://example.org/recipes/bebida/34/step/03f7d689777845f18e5333c670459707> a schema1:HowToStep ;
    schema1:text "Agregar el hielo picado al servir."@es .

<http://example.org/recipes/bebida/34/step/35d1b19d4bdb4f2bb3230d4d38a27af0> a schema1:HowToStep ;
    schema1:text "Lo pasamos por la coladora, exprimirmos bien hasta extraerle la leche."@es .

<http://example.org/recipes/bebida/34/step/7f4692ef7b834dfaae3e8bf4af3f245b> a schema1:HowToStep ;
    schema1:text "Dejamos enfriar y agregarmos las 2 cucharadas de azucar."@es .

<http://example.org/recipes/bebida/34/step/986dbcca39f147ef80ba9ea99aa80dbc> a schema1:HowToStep ;
    schema1:text "Seguido de esto escurrirmos y licuamos junto con el agua tibia."@es .

<http://example.org/recipes/bebida/34/step/f465174499b74322beff08eb0e2228ca> a schema1:HowToStep ;
    schema1:text "Lave bien el ajonjolí. Luego lo remojamos en la taza de agua durante varias horas."@es .

<http://example.org/recipes/bebida/35/step/1798599b7466431ab2934f5919e890b9> a schema1:HowToStep ;
    schema1:text "Luego se licúa durante un minuto, se cuela y lo que quedó en la voladora se vuelve a colar con él otro medio litro que quedó"@es .

<http://example.org/recipes/bebida/35/step/56105c042fe6412099305b965afcc821> a schema1:HowToStep ;
    schema1:text "Seguido de eso se cuela, se agrega el azúcar y las rayaduras de limón."@es .

<http://example.org/recipes/bebida/35/step/63ea4c0a74394eec9fa2ad93400018de> a schema1:HowToStep ;
    schema1:text "Se sirve con hielo picadito y si le gusta canela molida."@es .

<http://example.org/recipes/bebida/35/step/8cf6508e0c3c40e6b0adbaefeb820756> a schema1:HowToStep ;
    schema1:text "Se toman las Almendras peladas (200 grs) y se trituran con la ayuda de un procesador o picatodo, hasta que se obtenga un polvo fino."@es .

<http://example.org/recipes/bebida/35/step/a0694d7d612249e3adf7894c594ca5b0> a schema1:HowToStep ;
    schema1:text "Se coloca este polvo fino en un cuenco con 1/2 litro de agua a macerar por 15 minutos, para ablandarlas."@es .

<http://example.org/recipes/bebida/35/step/e2d3738f6d9b4a5ea0693cb1c22430d0> a schema1:HowToStep ;
    schema1:text "Lo ponemos a enfriar."@es .

<http://example.org/recipes/bebida/36/step/0c7a3236f4194eeaaec24db08a3129c6> a schema1:HowToStep ;
    schema1:text "Luego se cuela para extraer los trozitos de canela."@es .

<http://example.org/recipes/bebida/36/step/39054f60c92f4fe48f4318b24de81c14> a schema1:HowToStep ;
    schema1:text "Licuamos muy bien hasta que todo este bien mezclado."@es .

<http://example.org/recipes/bebida/36/step/7a7bd73cf8cc412ba395ef1c0cf3763e> a schema1:HowToStep ;
    schema1:text "Agregar hielo bien picado y servir bien fría, adornada con mas hojuelas de avena."@es .

<http://example.org/recipes/bebida/36/step/8189e524ffd547f9b555027f3e18fcff> a schema1:HowToStep ;
    schema1:text "Colocar en la licuadora la leche evaporada, la canela, la avena Quaker, el agua, el azúcar y extracto de vainilla."@es .

<http://example.org/recipes/bebida/37/step/182ad5c5cb9f485eb77ca8e18c2f7f8d> a schema1:HowToStep ;
    schema1:text "Agregar al agua caliente la mezcla de flores y hierbas aromáticas, y dejar reposar durante 5 minutos."@es .

<http://example.org/recipes/bebida/37/step/6d0b6e5a8cd64e8c868b9b26ebb048eb> a schema1:HowToStep ;
    schema1:text "Hacer hervir el agua y retirar del fuego."@es .

<http://example.org/recipes/bebida/37/step/a6e39680615a48d9bc628f7161fb5900> a schema1:HowToStep ;
    schema1:text "Colar la mezcla, añadir el jugo de limón y endulzar con azúcar o miel al gusto."@es .

<http://example.org/recipes/bebida/37/step/ff22bd25becb41a492486eeed7fb7a6e> a schema1:HowToStep ;
    schema1:text "Servir la horchata lojana caliente o fría."@es .

<http://example.org/recipes/bebida/38/step/3f36a69f340a41b795cc9a7797bc1b82> a schema1:HowToStep ;
    schema1:text "Añadir el jugo del limón mandarina."@es .

<http://example.org/recipes/bebida/38/step/4b34e05252c64c5789a2692594d59eb2> a schema1:HowToStep ;
    schema1:text "Servir frío o caliente."@es .

<http://example.org/recipes/bebida/38/step/af86009ac1514ba2ba7a6272c5df3a88> a schema1:HowToStep ;
    schema1:text "Agregar las hojas de guayusa, apagar y tapar para que se haga la infusión."@es .

<http://example.org/recipes/bebida/38/step/e288a55de8d14961a43f9ec75ff38f86> a schema1:HowToStep ;
    schema1:text "Endulzar con panela o miel."@es .

<http://example.org/recipes/bebida/38/step/f437d0ef7cc44a819308fb9bb2dad99b> a schema1:HowToStep ;
    schema1:text "Hervir previamente el ishpingo, el cedrón y la canela."@es .

<http://example.org/recipes/bebida/39/step/4aefca7cb7dc4fb78145a7775749d09a> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y añadir la panela. Servir el javishca caliente."@es .

<http://example.org/recipes/bebida/39/step/bf5754e688504537a88f6e538669a51e> a schema1:HowToStep ;
    schema1:text "Colocar el zapallo con agua en una olla y cocinar a fuego medio hasta que esté blando. Licuar el zapallo con la leche."@es .

<http://example.org/recipes/bebida/39/step/f527ce372d7f4e9c8f5d23f011dd094f> a schema1:HowToStep ;
    schema1:text "Colocar el licuado en una olla al fuego nuevamente, agregar el anís y la canela y cocinar durante 5 minutos."@es .

<http://example.org/recipes/bebida/4/step/66a8446a40cb4420aa6ed067fd9d8e41> a schema1:HowToStep ;
    schema1:text "Colocar en procesadora o licuadora la leche, el mango, el azúcar y el hielo picado."@es .

<http://example.org/recipes/bebida/4/step/6e24858723854aba89507d28948f5046> a schema1:HowToStep ;
    schema1:text "Servir en copas grandes decorando con gajos de durazno."@es .

<http://example.org/recipes/bebida/4/step/76dc8c2b09db4a54853aa999e05b1a54> a schema1:HowToStep ;
    schema1:text "Comenzar pelando los mangos y el durazno."@es .

<http://example.org/recipes/bebida/4/step/9551697440334412b28629629497c39b> a schema1:HowToStep ;
    schema1:text "Batir hasta que se forme una mezcla homogénea y espumosa."@es .

<http://example.org/recipes/bebida/40/step/03bc1315830c4b20b89634e5745c844d> a schema1:HowToStep ;
    schema1:text "Puede consumirse frío o caliente."@es .

<http://example.org/recipes/bebida/40/step/0ba54408f494486d9274fcacb0269253> a schema1:HowToStep ;
    schema1:text "Añada los duraznos y cocine hasta que estén tiernos."@es .

<http://example.org/recipes/bebida/40/step/8c13f836fca0453881282f09e3d66593> a schema1:HowToStep ;
    schema1:text "Endulce con panela."@es .

<http://example.org/recipes/bebida/40/step/8d34c92305254a7895e3baebe1eb1f73> a schema1:HowToStep ;
    schema1:text "En una cacerola, coloque a hervir el agua con el azúcar y los clavos de olor, pimienta y la canela."@es .

<http://example.org/recipes/bebida/40/step/f4d6e1e5c0b9422dbf031d75dfd7653f> a schema1:HowToStep ;
    schema1:text "Luego incorpore los capulíes y el almidón disuelto en un poco de agua. Siga cocinando por unos 10 minutos hasta obtener una consistencia un poco espesa."@es .

<http://example.org/recipes/bebida/41/step/13d59946e28f4af6afc6fefd61afa118> a schema1:HowToStep ;
    schema1:text "Coloque las naranjillas lavadas y peladas en la licuadora junto al agua."@es .

<http://example.org/recipes/bebida/41/step/2dcf71aa14ed467c8ec23163af0b1478> a schema1:HowToStep ;
    schema1:text "Cuele la bebida y sirva con hielo."@es .

<http://example.org/recipes/bebida/41/step/4ec61f9fd0194ad0b87903bd07b25993> a schema1:HowToStep ;
    schema1:text "Mientras procese la preparación, añada el manojo de alfalfa y un poco de azúcar."@es .

<http://example.org/recipes/bebida/42/step/2f86071491d742cc93b189cffb525908> a schema1:HowToStep ;
    schema1:text "Sernir lo que se ha licuado."@es .

<http://example.org/recipes/bebida/42/step/5d4c0c14705242b8bdaffcc7db9896cb> a schema1:HowToStep ;
    schema1:text "Juntar la pulpa del borojó, el agua, la leche, el azúcar, los huevos batidos, la vainilla y la nuez moscada en una licuadora."@es .

<http://example.org/recipes/bebida/42/step/7153c55c55aa4eafa9a9fdaf1a635481> a schema1:HowToStep ;
    schema1:text "Volver a licuar con el hielo picado."@es .

<http://example.org/recipes/bebida/42/step/7b21d843238f41f8a5d907b506d7ed9e> a schema1:HowToStep ;
    schema1:text "Servir frío."@es .

<http://example.org/recipes/bebida/42/step/d1cfee129ffc43b38e9e0d567469d489> a schema1:HowToStep ;
    schema1:text "Licuar a alta velocidad hasta lograr un licuado homogéneo."@es .

<http://example.org/recipes/bebida/43/step/3a74b11eae3c42ee8b500cbc111729a9> a schema1:HowToStep ;
    schema1:text "Agregar al jugo recogido cubitos de hielo y en caso de haber usado un molido en este paso se debe agregar el jugo de limón, mandarino o agua."@es .

<http://example.org/recipes/bebida/43/step/4092646df6ae4358b926db18d3d7163e> a schema1:HowToStep ;
    schema1:text "Consumir inmediatamente."@es .

<http://example.org/recipes/bebida/43/step/6e5758a1267c4eb884ebd9ce43729b42> a schema1:HowToStep ;
    schema1:text "Triturar los trozos de caña en un molino o en un exprimidor (en caso de usar exprimidor agregar en este momento el jugo de limón, mandarina o agua), recoger el jugo."@es .

<http://example.org/recipes/bebida/43/step/ff0cd664e68440dd9093eb036635c496> a schema1:HowToStep ;
    schema1:text "Cortar las cañas de azúcar en pedazos pequeños de 10 cm aproximadamente y luego pelar con un cuchillo haciendo corts de tiras largas. Reservar un pequeño trozo para decorar la bebida."@es .

<http://example.org/recipes/bebida/44/step/775323d660324a2584bd06750fa11649> a schema1:HowToStep ;
    schema1:text "Una vez que ha hervido por unos 10 minutos, se retira del fuego y se cuela. Dejar enfriar."@es .

<http://example.org/recipes/bebida/44/step/89a70a175cdc484391b6edb883a823be> a schema1:HowToStep ;
    schema1:text "En una cacerola ponemos a hervir el agua con las especias y la panela o azúcar."@es .

<http://example.org/recipes/bebida/44/step/8ed03e02fc4b4598a8ad157c6cc567d5> a schema1:HowToStep ;
    schema1:text "Procesar el jugo con los restos de la fruta. Colar."@es .

<http://example.org/recipes/bebida/44/step/ab47e6eedc0b4328ba13d01c305020c6> a schema1:HowToStep ;
    schema1:text "En un bol colocar las ciruelas con un poco de agua, retirar las semillas con las manos."@es .

<http://example.org/recipes/bebida/44/step/c60b10b8b70649e3bb446594ddb2e773> a schema1:HowToStep ;
    schema1:text "Añadirle la leche cuando haya enfriado la preparación."@es .

<http://example.org/recipes/bebida/44/step/e9bb665f60574bc6872deff1759971af> a schema1:HowToStep ;
    schema1:text "Servir bien frío con suficiente hielo."@es .

<http://example.org/recipes/bebida/44/step/f75ac38350ec4bc98274cc29843764e0> a schema1:HowToStep ;
    schema1:text "En una licuadora, batir el jugo de frutas con la preparación de leche y especias. Si falta dulce agregar un poco más de azúcar."@es .

<http://example.org/recipes/bebida/45/step/51b1d8b070224b8b9a8d3dbd04e3597e> a schema1:HowToStep ;
    schema1:text "Colocar en la licuadora el coco rallado, el agua de coco, la esencia de vainilla, la leche condensada y el hielo."@es .

<http://example.org/recipes/bebida/45/step/a4e54ad39904401eacbdd222a455425d> a schema1:HowToStep ;
    schema1:text "Licuar todos los ingredientes, agregar una mínima cantidad de aguardiente (opcional) y servir el jugo de coco frío."@es .

<http://example.org/recipes/bebida/46/step/0367ab85311c46a1aaca8c3fde7a6556> a schema1:HowToStep ;
    schema1:text "Servir en vasos"@es .

<http://example.org/recipes/bebida/46/step/03d81f077e6b40198a093fc461429d56> a schema1:HowToStep ;
    schema1:text "Pelar la guanábana en un recipiente para extraerle la pulpa."@es .

<http://example.org/recipes/bebida/46/step/14ae6d8354f54f3c817df174d8271ba4> a schema1:HowToStep ;
    schema1:text "Proceder a licuar la guanábana agregando un poco de agua para que no se atasque la licuadora."@es .

<http://example.org/recipes/bebida/46/step/5306d342905f428182febed681166eb4> a schema1:HowToStep ;
    schema1:text "Colocar azúcar al gusto y cubitos de hielo"@es .

<http://example.org/recipes/bebida/46/step/6267820f88884f7abe59bf66b90a7ae6> a schema1:HowToStep ;
    schema1:text "Sacar las semillas de la pulpa."@es .

<http://example.org/recipes/bebida/47/step/6e603318820743b5b877118df9e221bc> a schema1:HowToStep ;
    schema1:text "Usar un colador para quitar los grumos y las semillas, también va a servir para extraer la cáscara en caso de que las trocearas con todo y cáscara."@es .

<http://example.org/recipes/bebida/47/step/b297e22235f54f56a28241697533ebc9> a schema1:HowToStep ;
    schema1:text "Lavar y trocear las guayabas, si desea le puede quitar las cáscaras."@es .

<http://example.org/recipes/bebida/47/step/b3436d25d6824ce680e075e230adad22> a schema1:HowToStep ;
    schema1:text "Servir en vaso con cubitos de hielo o dejar refrigerar antes de servir."@es .

<http://example.org/recipes/bebida/47/step/ecc949162f1b4955ad8cd6aae5db0872> a schema1:HowToStep ;
    schema1:text "Licuar los trozos de guayaba junto con el azúcar y el agua o leche."@es .

<http://example.org/recipes/bebida/48/step/0d4045edd95149529ce7bb435302a27f> a schema1:HowToStep ;
    schema1:text "Continuar hirviendo la mezcla durante 2 minutos, revolviendo de vez en cuando."@es .

<http://example.org/recipes/bebida/48/step/232e12148d51440dbbda3e7f592f339d> a schema1:HowToStep ;
    schema1:text "Servir con cubitos de hielo y con una rodaja de limón para decorar"@es .

<http://example.org/recipes/bebida/48/step/63ed584d58624cc7a207d37d935c90ea> a schema1:HowToStep ;
    schema1:text "Cernir, agregar el otro litro de agua y revolver."@es .

<http://example.org/recipes/bebida/48/step/9b99b30432414304ba7d07ab5ff03942> a schema1:HowToStep ;
    schema1:text "​​​​​​Primero hervir 1 litro de agua."@es .

<http://example.org/recipes/bebida/48/step/ceeae201dfa2437ba3cc4c97c8c1768f> a schema1:HowToStep ;
    schema1:text "Apagar el fuego, cubrir el recipiente y dejar reposar 10 minutos."@es .

<http://example.org/recipes/bebida/48/step/da255213183b489ebf4644a070bf7402> a schema1:HowToStep ;
    schema1:text "Añadir las flores de jamaica y el azúcar cuando el agua haya hervido."@es .

<http://example.org/recipes/bebida/49/step/af0907196f4b4a8aae7ba8c7f1ab157b> a schema1:HowToStep ;
    schema1:text "Colocar la pulpa en la licuadora y completar con agua."@es .

<http://example.org/recipes/bebida/49/step/c25c40c1e8b542ffb23e42f9a049de76> a schema1:HowToStep ;
    schema1:text "Colar para obtener la pulpa sin semillas y mezclar con azúcar al gusto."@es .

<http://example.org/recipes/bebida/49/step/ce7f8d0b8654473bb9b44c69a4d4b8d1> a schema1:HowToStep ;
    schema1:text "Sacar la pulpa de la maracuyá partiendo por en dos mitades la fruta y usando una cuchara para extraer."@es .

<http://example.org/recipes/bebida/49/step/db287ce953df414c8f4a47014641ca84> a schema1:HowToStep ;
    schema1:text "Licuar a velocidad baja por 30 segundos para separar las semillas."@es .

<http://example.org/recipes/bebida/49/step/e6336af6e53041f4b7dff7b5b1745d87> a schema1:HowToStep ;
    schema1:text "Servir con hielo o almacenar en la refrigeradora."@es .

<http://example.org/recipes/bebida/5/step/077c43fb88954c95b0e1602f98c653d6> a schema1:HowToStep ;
    schema1:text "Añadir el helado y continuar batiendo."@es .

<http://example.org/recipes/bebida/5/step/1fcd786d56664c8a8bc4178e23e70cbd> a schema1:HowToStep ;
    schema1:text "Batir junto al resto de la leche."@es .

<http://example.org/recipes/bebida/5/step/3be34138fa934c9998882011cb433f1d> a schema1:HowToStep ;
    schema1:text "Triturar 4 galletas oreo."@es .

<http://example.org/recipes/bebida/5/step/57909cd1608d416c8bd467e84f2f13e7> a schema1:HowToStep ;
    schema1:text "Servir y agregar nata montada para decorar. Colocar las 2 galletas restantes hechas trozos."@es .

<http://example.org/recipes/bebida/5/step/cf9945220da74db8b2ac8e6247c06e2a> a schema1:HowToStep ;
    schema1:text "Vertir la mitad de la leche en un recipiente junto a las galletas trituradas. Dejar hasta que las galletas se ablanden."@es .

<http://example.org/recipes/bebida/50/step/04c32b15135c41f9b953f5c2d1130115> a schema1:HowToStep ;
    schema1:text "Disfrute bien frío."@es .

<http://example.org/recipes/bebida/50/step/1bd81100feea4f0b9d0dcff0e6e5760d> a schema1:HowToStep ;
    schema1:text "Coloque la fruta con el azúcar y el agua en una licuadora y procese bien."@es .

<http://example.org/recipes/bebida/50/step/216dd1626aa64f7eb5e3cb7e45341422> a schema1:HowToStep ;
    schema1:text "Sirva en vasos con abundante hielo."@es .

<http://example.org/recipes/bebida/50/step/54d430ef0ad44e949a49a091ddb74495> a schema1:HowToStep ;
    schema1:text "Pase el jugo por un colador."@es .

<http://example.org/recipes/bebida/50/step/a21086cf7bc84cf28cd963e591032dde> a schema1:HowToStep ;
    schema1:text "Pele las naranjillas."@es .

<http://example.org/recipes/bebida/51/step/29945b0726f84b958719ddd0f283eded> a schema1:HowToStep ;
    schema1:text "Colar el jugo para separar la semilla."@es .

<http://example.org/recipes/bebida/51/step/321145f2c94d4886b55a8bba0b313ef8> a schema1:HowToStep ;
    schema1:text "Pelar los tomates de árbol (se usa una olla de agua hirviendo para hablandar la cáscara o directamente se pela con el cuchillo) y cortarlos en 4 partes."@es .

<http://example.org/recipes/bebida/51/step/3fad9fcdd55144c484a2a4bc45721052> a schema1:HowToStep ;
    schema1:text "Licuar los tomates picadas junto con el agua o leche. Adicionar azúcar o miel al gusto."@es .

<http://example.org/recipes/bebida/51/step/8f161b8836d04c2b98bf4e06b6491a48> a schema1:HowToStep ;
    schema1:text "Volver a licuar para lograr una mejor contextura."@es .

<http://example.org/recipes/bebida/51/step/e8a90fdcdd5440da82a2665499520e34> a schema1:HowToStep ;
    schema1:text "Servir agregando hielo o guardar en el refrigerador."@es .

<http://example.org/recipes/bebida/52/step/2ab0e4c9dbf54bf6acc5d4f79bd95028> a schema1:HowToStep ;
    schema1:text "Se recomienda beberla de inmediato para evitar que se amargue."@es .

<http://example.org/recipes/bebida/52/step/2b0e7600a0804fca995560a30317e706> a schema1:HowToStep ;
    schema1:text "Colocar en la licuadora el limón, 4 tazas de agua y el azúcar."@es .

<http://example.org/recipes/bebida/52/step/80d33641a1d04a6ca30d218ba1bf7849> a schema1:HowToStep ;
    schema1:text "Colar y mezclar con el resto de agua. Servir la limonada inmediatamente con hielo y decorar los vasos con hojitas de menta o hierba buena y rodajas de limón."@es .

<http://example.org/recipes/bebida/52/step/cfa17617179542bab7a6786d0fe1d6af> a schema1:HowToStep ;
    schema1:text "Licuar los ingredientes hasta obtener una mezcla homogénea, quedará un poco espumosa y con un color medio blanco."@es .

<http://example.org/recipes/bebida/53/step/bc95af733f8d4775a776defb6b0bec03> a schema1:HowToStep ;
    schema1:text "Agregar el resto del agua y mezclar bien. Ajustar azúcar y agua a gusto."@es .

<http://example.org/recipes/bebida/53/step/cc55ae6adfd3464cb2763a08b972607b> a schema1:HowToStep ;
    schema1:text "Servir la limonada de mango con hielo y decorar los vasos con hojitas de menta o hierba buena y rodajas de limón."@es .

<http://example.org/recipes/bebida/53/step/e1c3c00fe7be42b6a482fae8cba6053c> a schema1:HowToStep ;
    schema1:text "Colocar en una licuadora el mango, el jugo de limón, la azúcar o miel, 2 tazas de agua y unos cubitos de hielo. Licuar bien, opcionalmente se puede colar."@es .

<http://example.org/recipes/bebida/54/step/a64c0bb7bdce4e32bf36d1d7132c455e> a schema1:HowToStep ;
    schema1:text "Añadir el azúcar o panela, los palitos de canela y las pasas, y cocinar durante unos 20 minutos más, revolviendo con frecuencia."@es .

<http://example.org/recipes/bebida/54/step/ad0f50fe0f3640b7a3f1eb9dfefd1cf6> a schema1:HowToStep ;
    schema1:text "Al día siguiente, colar el maíz y colocarlo en una olla con las 8 tazas de leche. Cocinar a fuego lento durante 3 horas, revolviendo de vez en cuando, hasta que el morocho esté blando y tierno."@es .

<http://example.org/recipes/bebida/54/step/d303384eee8444378381098a383edf13> a schema1:HowToStep ;
    schema1:text "Dejar el maíz morocho con las 6 tazas de agua en remojo durante la noche."@es .

<http://example.org/recipes/bebida/54/step/de3faff6aa6b470da4f1601c03ae9a5d> a schema1:HowToStep ;
    schema1:text "Servir el morocho caliente, espolvoreado con canela molida."@es .

<http://example.org/recipes/bebida/55/step/25f4d678acf14282a54ac9a1f0d36b9f> a schema1:HowToStep ;
    schema1:text "Remojar el maíz morocho en un litro de agua y dejarlo al menos 12 horas."@es .

<http://example.org/recipes/bebida/55/step/ab04e2878c3b40d08366dffe4a71d8c5> a schema1:HowToStep ;
    schema1:text "Agregar el azúcar, la canela y cocinar por media hora más, revolviendo esporádicamente."@es .

<http://example.org/recipes/bebida/55/step/e0816a843a87465cb43de5f1e58e136d> a schema1:HowToStep ;
    schema1:text "Lavar el maíz y ponerlo a hervir en la leche, el fuego debe ser muy bajo y la cocción de unas dos horas hasta que el maíz se ablande."@es .

<http://example.org/recipes/bebida/55/step/fa293fbdf6244f9aa00d32c4d7e47988> a schema1:HowToStep ;
    schema1:text "Servir el morocho caliente en tazas, espolvoreado con canela y chocolate rallado."@es .

<http://example.org/recipes/bebida/56/step/056b4713909544cfadbcc155c3e7cf68> a schema1:HowToStep ;
    schema1:text "Las picamos y colocamos en una licuadora. Seguido agregamos media taza de azúcar. Licuamos muy bien y agregamos un toque de vainilla. o."@es .

<http://example.org/recipes/bebida/56/step/ab9eb6b729794983ad1228f3304c9e74> a schema1:HowToStep ;
    schema1:text "Se sirve con bastante hielo picado."@es .

<http://example.org/recipes/bebida/56/step/b1f7921288fc4861a7878cacf019f80e> a schema1:HowToStep ;
    schema1:text "Primero se lavan muy bien las frutas y se pelan con la ayuda de las manos. Si estan duras quitar la piel con un cuchillo."@es .

<http://example.org/recipes/bebida/57/step/07639670e5de4eb2bd1b14277ff97eda> a schema1:HowToStep ;
    schema1:text "Reducir la temperatura y cocinar a fuego lento, con la olla tapada, durante 40 minutos."@es .

<http://example.org/recipes/bebida/57/step/61dfffd6b8bc4e8ba0ac28ef3e5fed48> a schema1:HowToStep ;
    schema1:text "Colocar en una olla el agua, el concentrado de naranjilla, el azúcar o panela rallada, la canela, y esperar hasta que hierva."@es .

<http://example.org/recipes/bebida/57/step/c957ff3f8e654375b751b5eabd250059> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, agregar el aguardiente y servir el naranjillazo inmediatamente."@es .

<http://example.org/recipes/bebida/58/step/70099c354daf4870a3c6b49017f58243> a schema1:HowToStep ;
    schema1:text "Hervir la leche con el azúcar y la astilla de canela por 10 minutos aproximadamente."@es .

<http://example.org/recipes/bebida/58/step/93cab484a5794408a12ee5fb48234f29> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y dejar entibiar."@es .

<http://example.org/recipes/bebida/58/step/d5137d63cc1d478eaca22844324c6395> a schema1:HowToStep ;
    schema1:text "Servir frío o caliente agregando una copa de coñac (o la cantidad que creas conveniente)."@es .

<http://example.org/recipes/bebida/58/step/e9477be6a5254fd69f141b8ba1ae695f> a schema1:HowToStep ;
    schema1:text "En un recipiente batir los huevos con un poco de leche fría y mezclar con la leche hervida."@es .

<http://example.org/recipes/bebida/58/step/fd618db0273e4808951b411f687d6571> a schema1:HowToStep ;
    schema1:text "Batir todo hasta lograr una textura espumosa (usar batidora preferentemente)."@es .

<http://example.org/recipes/bebida/59/step/0da44bc241fd4bef95549e94c57a92b7> a schema1:HowToStep ;
    schema1:text "Mezclar el ginger ale, los hielos elaborados y el hielo triturado."@es .

<http://example.org/recipes/bebida/59/step/44cfe28560124605b94cf4adf316d7b4> a schema1:HowToStep ;
    schema1:text "Repartir en porciones iguales en moldes de muffins los mortiños y las fresas."@es .

<http://example.org/recipes/bebida/59/step/488656b8eb4a4fb2be0ca6a2e6105492> a schema1:HowToStep ;
    schema1:text "Desmoldar colocando un paño caliente bajo el molde e invertir."@es .

<http://example.org/recipes/bebida/59/step/5c00101bd5554366adcd64cc48c60d3c> a schema1:HowToStep ;
    schema1:text "Completar el molde con jugo de arándanos y congelar hasta que se formen hielos."@es .

<http://example.org/recipes/bebida/59/step/5c3051769728479fb6921caacd481998> a schema1:HowToStep ;
    schema1:text "Agregar la esencia de naranja y mezclar."@es .

<http://example.org/recipes/bebida/59/step/7cdc6389ad96431b8b9de27b7da0365e> a schema1:HowToStep ;
    schema1:text "Servir inmediatamente."@es .

<http://example.org/recipes/bebida/59/step/7d23fc13c11a4dd28cf4db86c1051bfd> a schema1:HowToStep ;
    schema1:text "Combinar el jugo de arándanos restante con el jugo de piña en una ponchera."@es .

<http://example.org/recipes/bebida/59/step/855dd07475434d4caa0d8d20e776b1b0> a schema1:HowToStep ;
    schema1:text "Hervir el jugo de piña con el azúcar por 5 minutos. Dejar enfriar."@es .

<http://example.org/recipes/bebida/6/step/a47fb32b8f0d4c1bb0f504a7883f30d8> a schema1:HowToStep ;
    schema1:text "Servir frío."@es .

<http://example.org/recipes/bebida/6/step/b4a061f9b61a493f95ec43e14212f9d1> a schema1:HowToStep ;
    schema1:text "Sernir con una coladera."@es .

<http://example.org/recipes/bebida/6/step/d87d319726254864b2ff4ae16a85c960> a schema1:HowToStep ;
    schema1:text "Lavar bien los taxos, partirlos por lamitad y extraer toda la pulpa."@es .

<http://example.org/recipes/bebida/6/step/f7eadd600aaf407c98db1633ffb5bb78> a schema1:HowToStep ;
    schema1:text "Volver a licuar junto con el hielo."@es .

<http://example.org/recipes/bebida/6/step/f91308e37fa3472f87a10d1fdd229063> a schema1:HowToStep ;
    schema1:text "Agregar la pulpa a la licuadora junto con el agua y los demás ingredientes (menos el hielo) por 4 minutos aproximadamente."@es .

<http://example.org/recipes/bebida/60/step/65b446271c554d2e8e980c55bc9d0876> a schema1:HowToStep ;
    schema1:text "Pasado los días agregamos hielo y servimos al gusto."@es .

<http://example.org/recipes/bebida/60/step/70c6bcb096e2488c93f4125448088d9f> a schema1:HowToStep ;
    schema1:text "En un frasco de vidrio colocamos la raíz mediana de un jengibre picado muy finito, añadimos 2 tazas de agua y azúcar o miel. Se disuelve muy bien y se tapa con un paño por 4 días."@es .

<http://example.org/recipes/bebida/60/step/7995dbf940a94db7b4c4c61a3e3cd989> a schema1:HowToStep ;
    schema1:text "Dejamos reposar hasta que este a temperatura ambiente y añadimos ¾ del líquido que habíamos fermentado. Luego la podemos colar si se desea y se embotella y se tapan bien. Dejamos 4 días mas para que termine de fermentar."@es .

<http://example.org/recipes/bebida/60/step/b33275fc8a6942c4b2971e256152de24> a schema1:HowToStep ;
    schema1:text "Cada día se alimenta con trocitos de jengibre y más azúcar. Pasado los 4 días que comiencen a salir unas burbujitas, agarramos otra raíz de jengibre la picamos bien chiquitico y la colocamos en una ollita con 2 litros de agua y azúcar. Dejamos hervir por 5 minutos. Apagamos y la retiramos del fuego."@es .

<http://example.org/recipes/bebida/61/step/1f2ba881e06741329fc8232fb108d576> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y añadir el azúcar. Mezclar bien, entibiar en un baño de hielo y colar."@es .

<http://example.org/recipes/bebida/61/step/61441bb74a354f30b1a1c1fb0ba6496f> a schema1:HowToStep ;
    schema1:text "Una vez uniforme la mezcla, verterla a la leche hervida con especias y cocinar a fuego lento, revolviendo constantemente, durante 15 minutos hasta que la mezcla esté ligeramente espesa."@es .

<http://example.org/recipes/bebida/61/step/71bf7afb4d6341839f6df50dcd0252c4> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y colar nuevamente. Añadir la esencia de vainilla y el aguardiente. Servir el rompope frío en una copa con un palito de canela (opcional)."@es .

<http://example.org/recipes/bebida/61/step/dac6cf404adc4983890e25a268f02cf1> a schema1:HowToStep ;
    schema1:text "Colocar en una olla 3 tazas de leche con los clavos de olor, la pimienta dulce y la canela, y hervir a fuego medio durante 15 minutos."@es .

<http://example.org/recipes/bebida/61/step/dee94ab19a824e4f824dddcf13df7e8c> a schema1:HowToStep ;
    schema1:text "Aparte, agregar lentamente la taza de leche restante a la crema batida de yemas mezclando homogéneamente."@es .

<http://example.org/recipes/bebida/61/step/f96a1c69f09b4b34b8fc3e824eb2de5a> a schema1:HowToStep ;
    schema1:text "Batir las cinco yemas de huevo en un tazón hasta blanquear. Reposar hasta más tarde."@es .

<http://example.org/recipes/bebida/62/step/1848fc8fa3b748c39efee711d5e90495> a schema1:HowToStep ;
    schema1:text "En una fuente mezclar el mote, el jugo de frutas, el liquido reservado y el resto de las frutas picadas en trocitos."@es .

<http://example.org/recipes/bebida/62/step/594e1020649b4402935f778d5075b22d> a schema1:HowToStep ;
    schema1:text "Agregar el agua de azahar."@es .

<http://example.org/recipes/bebida/62/step/951a4d7397374261a60389cf746b5260> a schema1:HowToStep ;
    schema1:text "Retirar las cortezas de la piña, y cortar en trozos la pulpa."@es .

<http://example.org/recipes/bebida/62/step/bb36ab40d32d41bb958832f84db02794> a schema1:HowToStep ;
    schema1:text "Moler el mote con ayuda de un procesador de alimentos."@es .

<http://example.org/recipes/bebida/62/step/cd036e41e2ef4fb8acb01d4aff4b18a8> a schema1:HowToStep ;
    schema1:text "Hacer un licuado con la mitad de las frutas."@es .

<http://example.org/recipes/bebida/62/step/cd4f643855a240e58cbc98dd16c0b772> a schema1:HowToStep ;
    schema1:text "Llevar al fuego una cacerola con 2 litros de agua, los clavos de olor, canela, anís estrellado, pimienta dulce y las hojas de cedrón, yerbaluisa y naranja. Añadir el azúcar, la panela y las cortezas de la piña. Dejar hervir por unos 45 minutos y al enfriar proceda a colar. Reserve."@es .

<http://example.org/recipes/bebida/62/step/d82376044a7b45f99d975f6706f43bca> a schema1:HowToStep ;
    schema1:text "Servir bien frío decorado con frutillas a su gusto."@es .

<http://example.org/recipes/bebida/63/step/58b16d6ce52c462b9cd9f07b7de3a8df> a schema1:HowToStep ;
    schema1:text "Pelar la manzana, la 1/2 piña, las peras y cortar en cubos,"@es .

<http://example.org/recipes/bebida/63/step/6e1f630f3d714022bfb9a5e76ee3c56f> a schema1:HowToStep ;
    schema1:text "Añadir el jugo de naranja y todas la frutas al vino."@es .

<http://example.org/recipes/bebida/63/step/e27a960cd4f84339b6cd4ce18ad85d8c> a schema1:HowToStep ;
    schema1:text "Agregar hielo o dejar en refrigración."@es .

<http://example.org/recipes/bebida/63/step/f2ca701fd15249e7926a14e718d370a2> a schema1:HowToStep ;
    schema1:text "Extraer el jugo de las 3 naranjas"@es .

<http://example.org/recipes/bebida/63/step/f48ad4b56b3c47d191354680cf7e0948> a schema1:HowToStep ;
    schema1:text "Vertir el vino en una jarra y adicionar el azúcar, mezclar bien hasta que el azúcar se haya disuelto completamente."@es .

<http://example.org/recipes/bebida/64/step/0e202cec0ed84d099968865d4a2e1bba> a schema1:HowToStep ;
    schema1:text "Servir con mucho hielo granizado y un sorbete."@es .

<http://example.org/recipes/bebida/64/step/107dff8879c047ccb9767f897d9b0b73> a schema1:HowToStep ;
    schema1:text "Esta preparación tiene pocos pasos y es realmente simple, colocar en la procesadora la pulpa y la leche."@es .

<http://example.org/recipes/bebida/64/step/9d7288279afb47f88705f7f2172461e0> a schema1:HowToStep ;
    schema1:text "Licuar a la mínima velocidad para centrifugar las semillas de la fruta que son relativamente grandes."@es .

<http://example.org/recipes/bebida/64/step/a26bb16e010d4ee8bfb77b50f64221bc> a schema1:HowToStep ;
    schema1:text "Colar la preparación para separar las semillas y mezclar con azúcar o panela. Batir unos 2 minutos a velocidad máxima."@es .

<http://example.org/recipes/bebida/65/step/7322383827cd44739c5b982312b6b64a> a schema1:HowToStep ;
    schema1:text "Añadir el jugo de limón y la miel a gusto."@es .

<http://example.org/recipes/bebida/65/step/8306575415b14241bb726deedb136285> a schema1:HowToStep ;
    schema1:text "Comenzar hirviendo las canelas y el cedrón por 5 minutos."@es .

<http://example.org/recipes/bebida/65/step/c9b2a3bae77f4dae87dacb21df8b447a> a schema1:HowToStep ;
    schema1:text "Servir frío o caliente."@es .

<http://example.org/recipes/bebida/65/step/e936e85386c94e0c9a5c3981bef92ad0> a schema1:HowToStep ;
    schema1:text "Agregar la guayusa, retirar del fuego y dejar reposar para que se haga una infusión."@es .

<http://example.org/recipes/bebida/7/step/48beb9fcbe494cb4802d01f6f5bc805d> a schema1:HowToStep ;
    schema1:text "Colocar por último el hielo y volver a licuar."@es .

<http://example.org/recipes/bebida/7/step/5df9705e62df4d81bd9b13fd12388ab6> a schema1:HowToStep ;
    schema1:text "Servir bien frío."@es .

<http://example.org/recipes/bebida/7/step/5eb7fe3946904297a04ed916f10dd44b> a schema1:HowToStep ;
    schema1:text "Para el batido comenzar lavando y pelando los taxos para luego extraer toda la pulpa."@es .

<http://example.org/recipes/bebida/7/step/7d5644eea1744c7d9da1274950e1183d> a schema1:HowToStep ;
    schema1:text "Batir por dos minutos y agregar la esencia de vainilla y el azúcar, batir por 3 minutos más."@es .

<http://example.org/recipes/bebida/7/step/92ae1b89df5d47e0839103698d54d425> a schema1:HowToStep ;
    schema1:text "Colocar en la licuadora la fruta, el agua, la leche y las claras de huevo"@es .

<http://example.org/recipes/bebida/8/step/1c81861b39074740853b9f3a148f3224> a schema1:HowToStep ;
    schema1:text "Quitar la piel al tomate y las semillas."@es .

<http://example.org/recipes/bebida/8/step/98c9b8bfeeae44439492c8078ba05703> a schema1:HowToStep ;
    schema1:text "Licuar todos los ingredientes."@es .

<http://example.org/recipes/bebida/8/step/a17d16c8607743b4b32fcc1682fe5488> a schema1:HowToStep ;
    schema1:text "Servir con hielo."@es .

<http://example.org/recipes/bebida/8/step/fd95b52931b34fbd92c0f08582767bda> a schema1:HowToStep ;
    schema1:text "Pelar el pepinillo y quitarle la semilla."@es .

<http://example.org/recipes/bebida/9/step/0f74b7cb6fc9482ba1ad4eaba287d025> a schema1:HowToStep ;
    schema1:text "Servir la bebida fría."@es .

<http://example.org/recipes/bebida/9/step/6254598959784e5da17ce45f440271b5> a schema1:HowToStep ;
    schema1:text "Licuar tdos los ingredientes."@es .

<http://example.org/recipes/bebida/9/step/96c6554a56dc42e48bd7baf1899a703d> a schema1:HowToStep ;
    schema1:text "Lavar muy bien las hojas de berros y espinacas."@es .

<http://example.org/recipes/entrada/1/step/0ae33f2ee5e342c4934ee2ae1f0944d8> a schema1:HowToStep ;
    schema1:text "Seguido de esto picamos la cebolla finita, luego el tomate (previamente lavado) le cortamos la colita y lo picamos finito."@es .

<http://example.org/recipes/entrada/1/step/117a7649bf6e47919d77af954df871fa> a schema1:HowToStep ;
    schema1:text "Para finalizar cortamos los aguacates, le quitamos el hueso, le ponemos un poquito de limón en el borde para que no se ponga negro y rellenamos con el atún."@es .

<http://example.org/recipes/entrada/1/step/b5a5000d95f94847a94f582ffbcd75d3> a schema1:HowToStep ;
    schema1:text "Primero abrimos la lata de atún y botamos el agua. Escurrimos bien. Luego lo colocamos en un envase."@es .

<http://example.org/recipes/entrada/1/step/d2cdfc11977b4610b7f1254c416eb0bc> a schema1:HowToStep ;
    schema1:text "Luego cortamos el limón y lo exprimimos en el atún, le agregamos 2 cucharadas de mayonesa, el resto de los ingredientes y revolvemos bien."@es .

<http://example.org/recipes/entrada/10/step/32207ab4b8f7489388c2d9bc6c320550> a schema1:HowToStep ;
    schema1:text "Fría los calamares en aceite bien caliente hasta que se doren."@es .

<http://example.org/recipes/entrada/10/step/44a545e6d2a04342bb0f38aa118dc4d0> a schema1:HowToStep ;
    schema1:text "Mezcle bien todos los ingredientes y cubra el bol con papel film. Deje macerar en el refrigerador por unas 2 horas aproximadamente."@es .

<http://example.org/recipes/entrada/10/step/94c36c3e791c4afba0e6539b1ef94ec4> a schema1:HowToStep ;
    schema1:text "Coloque los calamares en un bol y agregue el ajo machacado, comino, pimienta, salsa de soya y el jugo de limón."@es .

<http://example.org/recipes/entrada/10/step/9f86a6845f4349aaa40650bb6f8ea494> a schema1:HowToStep ;
    schema1:text "Sírvalos decorados con rodajas de limón y acompañados con alguna salsa de su preferencia."@es .

<http://example.org/recipes/entrada/10/step/f5935802524d4113880b3d2ed1616acc> a schema1:HowToStep ;
    schema1:text "Transcurrido el tiempo de maceración, pase los calamares por harina, luego por huevo batido y por último por la miga de pan."@es .

<http://example.org/recipes/entrada/10/step/fa2e60bb13f4408591104f425e2aca35> a schema1:HowToStep ;
    schema1:text "Lavar bien los calamares y córtelos en ruedas."@es .

<http://example.org/recipes/entrada/11/step/29f5fb436e214004bcbe51922e832a0e> a schema1:HowToStep ;
    schema1:text "Luego si gusta se puede servir con arroz y listo para disfrutar."@es .

<http://example.org/recipes/entrada/11/step/2c9d5579d01b4542bd5d0a9ddd278bb8> a schema1:HowToStep ;
    schema1:text "En una tacita aparte colocamos 1 huevo y batimos."@es .

<http://example.org/recipes/entrada/11/step/c79e1bb1040442fbad6f5ca6082d8e84> a schema1:HowToStep ;
    schema1:text "En un tazón colocaremos pan rallado o molido."@es .

<http://example.org/recipes/entrada/11/step/c9084c2cd05142b783eed72a94541331> a schema1:HowToStep ;
    schema1:text "Luego tomamos uno a uno los camarones y pasamos por harina de trigo, por el huevo batido y luego por el pan rallado."@es .

<http://example.org/recipes/entrada/11/step/f035d95e58bd42c580ad7aac0ae71bf6> a schema1:HowToStep ;
    schema1:text "Luego en otro envase tendremos harina de trigo, una cucharadita de sal y un poquito de pimienta."@es .

<http://example.org/recipes/entrada/11/step/f543150379cb457f8a6264d6551ef5ae> a schema1:HowToStep ;
    schema1:text "En un envase colocamos los camarones y agregamos encima el ajo, el comino, la pimienta y el jengibre y mezclamos todo muy bien."@es .

<http://example.org/recipes/entrada/11/step/f8ada5bce9a6417886728e6cf676f5d6> a schema1:HowToStep ;
    schema1:text "En una cacerola colocamos bastante aceite una vez que esté caliente colocamos los camarones. Al estar dorados los colocamos en un papel absorbente."@es .

<http://example.org/recipes/entrada/12/step/08f68e3b7a3c45b8b54385421c774b54> a schema1:HowToStep ;
    schema1:text "Mezclar el jugo de naranja, el aceite, el ajo, el achiote, el comino, la sal y la pimienta. Sazonar la carne con la mezcla y dejarla reposar en la refrigeradora durante unas horas."@es .

<http://example.org/recipes/entrada/12/step/35e789388559469b88578c43383f3e45> a schema1:HowToStep ;
    schema1:text "Servir la carne en palito inmediatamente, acompañado de ají o salsa de preferencia."@es .

<http://example.org/recipes/entrada/12/step/866d0210c9be4e19b00d31b80ff05a90> a schema1:HowToStep ;
    schema1:text "Remojar los palitos en agua mientras la carne reposa, para que no se quemen en la parrilla."@es .

<http://example.org/recipes/entrada/12/step/cfdfc304eebf446b9e5e92dcb19ac7a1> a schema1:HowToStep ;
    schema1:text "Calentar la parrilla y colocar la carne en los palitos de pinchos. Asarlos unos minutos en cada lado hasta que estén cocidos a gusto."@es .

<http://example.org/recipes/entrada/12/step/d0304e91ea3f4d0ba07a09b1eeeb2a06> a schema1:HowToStep ;
    schema1:text "Cortar la carne finamente en tiras largas."@es .

<http://example.org/recipes/entrada/13/step/01c0ec2a1360462e825194a4bab82d3b> a schema1:HowToStep ;
    schema1:text "Cuando los camarones fríos, colocarlos dentro de la mezcla anterior. Dejar reposar en la refrigeradora durante 2 horas aproximadamente."@es .

<http://example.org/recipes/entrada/13/step/65cebb4a247b407aa7841fef6e37ed2e> a schema1:HowToStep ;
    schema1:text "Pelar la cebolla y cortarla en medias lunas bien finas. Enjuagar los trozos en agua y sal. Pelar los tomates, sacarle las semillas y cortarlos en cubos. Cortar los pimientos en cubos."@es .

<http://example.org/recipes/entrada/13/step/b05b78179a424cdcb511c07779bca21c> a schema1:HowToStep ;
    schema1:text "Servir el ceviche con patacones, chifles, chulpi (maíz tostado) o canguil (palomitas de maíz)."@es .

<http://example.org/recipes/entrada/13/step/d59bcf7dc80646bcb4db6cc678dd660b> a schema1:HowToStep ;
    schema1:text "Colocar los camarones en una olla de agua hirviendo con sal y dejarlos hervir por 5 minutos. Colar los camarones y dejarlos enfriar en agua con cubos de hielo para cortar la cocción inmediatamente."@es .

<http://example.org/recipes/entrada/13/step/f9bbd1a3149a4d8ea8d0885a93943aa2> a schema1:HowToStep ;
    schema1:text "Mezclar la cebolla, los tomates y los pimientos con la salsa de tomate, la mostaza, el cilantro picado, la sal, la pimienta y el aceite."@es .

<http://example.org/recipes/entrada/14/step/187c3afaedfb46b29f9691188dcb20be> a schema1:HowToStep ;
    schema1:text "Mezclar los ingredientes con la salsa de tomate y agregar la mostaza y condimentar."@es .

<http://example.org/recipes/entrada/14/step/1d20df2423c049878658b248c0178f19> a schema1:HowToStep ;
    schema1:text "Servir el ceviche en pequeñas cazuelas."@es .

<http://example.org/recipes/entrada/14/step/4d1cc13481d146c8a3ebc95a72773fc2> a schema1:HowToStep ;
    schema1:text "Colocar finalmente los camarones fríos y dejar reposar en heladera por unas horas."@es .

<http://example.org/recipes/entrada/14/step/561fa522450e48e491c2dfc732e625ed> a schema1:HowToStep ;
    schema1:text "Hervir los camarones en agua con sal, por 5 minutos. Retirar del fuego y dejar enfriar en agua con hielo."@es .

<http://example.org/recipes/entrada/14/step/7b0f244eeaec44a78bacad8a0d190e5c> a schema1:HowToStep ;
    schema1:text "Cortar la cebolla en rodajas bien finas y lavar en agua con sal."@es .

<http://example.org/recipes/entrada/14/step/cb8f3754f9864522bcac06e48b0fa0b5> a schema1:HowToStep ;
    schema1:text "Cortar los tomates y los pimientos en cubos."@es .

<http://example.org/recipes/entrada/15/step/049c9c740202431ea3a3cd45b270c4b4> a schema1:HowToStep ;
    schema1:text "Cortar la cebolla, el tomate y el pimiento en pedazitos muy pequeños (brunoise), dejar curtiendo con sal y limón."@es .

<http://example.org/recipes/entrada/15/step/149b15d699774b04acbf17d9753359fd> a schema1:HowToStep ;
    schema1:text "Marinar la canchalagua con sal y limón por 10 minutos."@es .

<http://example.org/recipes/entrada/15/step/390ea3e6fa754723b6c9a66aab115f6c> a schema1:HowToStep ;
    schema1:text "Cortar la canchalagua en pedazos pequeñosde 1x1 cm aprox."@es .

<http://example.org/recipes/entrada/15/step/70e44011482a4619bf8b5fe24d317737> a schema1:HowToStep ;
    schema1:text "Aliñar con sal, cilantro y aceite vegetal."@es .

<http://example.org/recipes/entrada/15/step/e283f26786dc46039089f082b37794c0> a schema1:HowToStep ;
    schema1:text "Limpiar minuciosamente la canchalagua bajo chorro de agua."@es .

<http://example.org/recipes/entrada/15/step/efe23461f28549b2becebb50621405f8> a schema1:HowToStep ;
    schema1:text "Enfriar por 10 minutos y servir con canguil y chifles."@es .

<http://example.org/recipes/entrada/16/step/0e1a6db84bad4c93b2e30cd03ecb85e4> a schema1:HowToStep ;
    schema1:text "Lavar el pescado con abundante agua, cortarlo en rodajas de 1 centímetro."@es .

<http://example.org/recipes/entrada/16/step/98bf036ec9314aabafd8fe206a1264c7> a schema1:HowToStep ;
    schema1:text "Marinar el pescado en sal y limón por 20 minutos."@es .

<http://example.org/recipes/entrada/16/step/a6361086f8aa44deafb2913291bff3b0> a schema1:HowToStep ;
    schema1:text "Refrigerar por 10 minutos y servir con canguil."@es .

<http://example.org/recipes/entrada/16/step/cbf73f31c2c740b684eafceeabe170e6> a schema1:HowToStep ;
    schema1:text "trozos muy pequeños. Dejar reposando con sal y limón por una hora."@es .

<http://example.org/recipes/entrada/16/step/d0b1617dd84a4539871c15521f2ba48b> a schema1:HowToStep ;
    schema1:text "Preparar un aliño con sal, cilantro y aceite y dejar la canchalagua reposando por 10 minutos."@es .

<http://example.org/recipes/entrada/16/step/e9534cf43a5c47eba9e1ddf04c5e36fa> a schema1:HowToStep ;
    schema1:text "Comenzar cortando las verduras en"@es .

<http://example.org/recipes/entrada/17/step/14a2f23e80ee40dcb3b60d01ef4afe91> a schema1:HowToStep ;
    schema1:text "Cortar la cebolla y el tomate en cuadros pequeños."@es .

<http://example.org/recipes/entrada/17/step/763841016c4d4144ba7cfec137f06124> a schema1:HowToStep ;
    schema1:text "Lavar muy bien los hongos para eliminar restos de sucio."@es .

<http://example.org/recipes/entrada/17/step/8a4ad09db9f64642842a7b0e749653c2> a schema1:HowToStep ;
    schema1:text "Cortar los champiñones en láminas."@es .

<http://example.org/recipes/entrada/17/step/902abd2bb22b4e219edb2c01ddeed35a> a schema1:HowToStep ;
    schema1:text "Servir decorado con rodajas de aguacate y una ramita de cilantro."@es .

<http://example.org/recipes/entrada/17/step/da2d8ff32e4541cda640e009a2b1b7d5> a schema1:HowToStep ;
    schema1:text "En un bol, colocar los vegetales y los champiñones y les añadimos el jugo de limón. Condimentamos con sal y pimienta y un poco de cilantro picadito."@es .

<http://example.org/recipes/entrada/17/step/fdf58e05283d4f5dbd22774c56272177> a schema1:HowToStep ;
    schema1:text "Dejamos en el refrigerador por unos 60 minutos."@es .

<http://example.org/recipes/entrada/18/step/0b6761d0ddf74bf8b4fe00ea1a47acdb> a schema1:HowToStep ;
    schema1:text "Dejar macerar o marinar el ceviche de chochos durante un par de horas en la refrigeradora."@es .

<http://example.org/recipes/entrada/18/step/37a0e227a8f241c7936ceba2fb301536> a schema1:HowToStep ;
    schema1:text "Servir el ceviche bien frío con chulpi (maíz tostado), chifles, aguacate o ají criollo."@es .

<http://example.org/recipes/entrada/18/step/548bee9a47a141bbbf8417623918a641> a schema1:HowToStep ;
    schema1:text "Mezclar la cebolla, los tomates, los chochos, la salsa de tomate, el cilantro, el jugo de limón, el jugo de naranja, el aceite y la sal."@es .

<http://example.org/recipes/entrada/18/step/eaa9fb341d604dfba6b80ea12b69dc99> a schema1:HowToStep ;
    schema1:text "Colocar la cebolla colorada en un tazón, espolvorear con sal y cubrir con agua tibia. Dejar remojar durante 10 minutos, colar el agua y enjuagar las cebollas con agua fría."@es .

<http://example.org/recipes/entrada/19/step/7faf174e69f04b9282547b21203f20bb> a schema1:HowToStep ;
    schema1:text "Verter el jugo de 8 limones a la fuente con las conchas."@es .

<http://example.org/recipes/entrada/19/step/9119839b5573424e8a02b9822dd9282e> a schema1:HowToStep ;
    schema1:text "Servir las conchas con un poco del curtido de cebollas. Puede añadir un toque de salsa de tomate y mostaza a su gusto. Acompañe con patacones, canguil o tostado, chifles, o pan."@es .

<http://example.org/recipes/entrada/19/step/a290ced59aeb40e8a52270003fbff239> a schema1:HowToStep ;
    schema1:text "Colocar las conchas en una fuente, cuidando de no botar el líquido interno de las mismas."@es .

<http://example.org/recipes/entrada/19/step/cd88549a729f41bb94441fd8b99782fa> a schema1:HowToStep ;
    schema1:text "Lavar las conchas y desechar las que no estén bien cerradas. Puede frotarlas con un cepillo para limpiarlas bien."@es .

<http://example.org/recipes/entrada/19/step/d2b6862029134810951f8b49c5b09ef1> a schema1:HowToStep ;
    schema1:text "En un bol se prepara el curtido con las cebollas paiteñas, los tomates, el pimiento, la cebollita verde y el culantro picadito. Incorporar el jugo de 2 limones, aceite de oliva y sal. Mezclar bien los ingredientes para integrar los sabores."@es .

<http://example.org/recipes/entrada/19/step/ee66b26f66d84d8fbbdbf4007be358c7> a schema1:HowToStep ;
    schema1:text "Abrir las conchas ayudándose con una guillotina o cuchillo grande."@es .

<http://example.org/recipes/entrada/2/step/85311d17435146b58c1b0225f8ea6579> a schema1:HowToStep ;
    schema1:text "Rellenar los aguacates con la mezcla preparada."@es .

<http://example.org/recipes/entrada/2/step/9a48d446da7741ea9f2e65b4be73189e> a schema1:HowToStep ;
    schema1:text "Cortar los aguacates a la mitad y retirar la semilla y la pulpa. A la pulpa puede rociarle jugo de limón para que no oscurezca."@es .

<http://example.org/recipes/entrada/2/step/ace53e154279417984d63158f88ec590> a schema1:HowToStep ;
    schema1:text "Agregar la mayonesa y remover muy bien para integrar todo. Rectificar el sabor con sal, pimienta y un toque de jugo de limón."@es .

<http://example.org/recipes/entrada/2/step/c8cb38e3240e463399ba217267d9ebfd> a schema1:HowToStep ;
    schema1:text "Sirva decorado con un poco de mayonesa de cilantro, camarones y tomates. Disfrute."@es .

<http://example.org/recipes/entrada/2/step/fee6a17eaabd4f45822b36a1784538ce> a schema1:HowToStep ;
    schema1:text "Colocar en un bol, la pulpa de los aguacates, los camarones, la cebolla, rabanitos, el huevo cocido, el apio y los pimientos cortados en cubos."@es .

<http://example.org/recipes/entrada/20/step/029cdfd28e074a9c9e31afb1c0b13d6f> a schema1:HowToStep ;
    schema1:text "En una fuente de cristal coloque el pescado troceado y sazone con sal y pimienta."@es .

<http://example.org/recipes/entrada/20/step/09f24c3b85cc496baafbd62797b93e06> a schema1:HowToStep ;
    schema1:text "Lavar bien la corvina. Cortarla en trozos."@es .

<http://example.org/recipes/entrada/20/step/1ffebe4373a94c629ab5e62a8c9dc1bf> a schema1:HowToStep ;
    schema1:text "Poner en remojo la cebolla colorada en agua fría con sal por unos minutos. Escurra y reserve."@es .

<http://example.org/recipes/entrada/20/step/445908b7f9c444c49495b719cdbd5624> a schema1:HowToStep ;
    schema1:text "Añada el jugo de limón, la cebolla colorada, el ají y el culantro finamente picado. Mezcle muy bien todos los ingredientes y deje en reposo por unos 20 minutos."@es .

<http://example.org/recipes/entrada/20/step/e5b9efcbabed4f4ba2807f70b5cb6433> a schema1:HowToStep ;
    schema1:text "Sirva el ceviche en copas, decorado con cilantro picadito y rodajas de limón. Acompáñelo con patacones o chifles."@es .

<http://example.org/recipes/entrada/21/step/1303d132777543f1b0e89cd29a5c397f> a schema1:HowToStep ;
    schema1:text "Luego que lo sacamos a un envase y lo licuamos con un batidor y lo colamos en un colador."@es .

<http://example.org/recipes/entrada/21/step/54040485a19e435eba672e38e46fb3b5> a schema1:HowToStep ;
    schema1:text "En un bold a fuego medio ponemos el agua con la sal y agregamos las cabezas. Dejamos hervir y las sacamos."@es .

<http://example.org/recipes/entrada/21/step/9f315a8dde8843cca84250e16ce4fabb> a schema1:HowToStep ;
    schema1:text "Primero pelamos los langostinos y reservamos las cabezas."@es .

<http://example.org/recipes/entrada/21/step/a221bf04f9ea40768ea9821871fe94eb> a schema1:HowToStep ;
    schema1:text "Aparte cortamos los tomates, las cebollas, exprimimos el limón, naranja y mezclamos todos los ingredientes en un bold grande. Añadimos tambien cilantro , moztasa , sal, ketchup y servimos."@es .

<http://example.org/recipes/entrada/21/step/a9846df949d84ccc8d4ee748ea722f25> a schema1:HowToStep ;
    schema1:text "Una vez colado la mezcla la ponemos a cocinas y añadiños los langostinos durante unos minutos. Una vez cocidos los sacamos y los reposamos"@es .

<http://example.org/recipes/entrada/22/step/055ad1f827414c60ad971d80af5830af> a schema1:HowToStep ;
    schema1:text "Limpiar muy bien el pescado y córtalo en cubos de tamaño medio, como de un bocado."@es .

<http://example.org/recipes/entrada/22/step/7a8db75363264f7a9a3ef09d916b9d8f> a schema1:HowToStep ;
    schema1:text "Una hora antes de que el pescado esté listo, mezclar en otro tazón las cebollas, los tomates, los pimientos y el cilantro con el resto del jugo de limón. Añadir una pizca de sal y también reservar en la refrigeradora durante una hora aproximadamente."@es .

<http://example.org/recipes/entrada/22/step/b62fb01f0ec9491da5d2a01f7ca50303> a schema1:HowToStep ;
    schema1:text "Cortar finamente las cebollas, los tomates, los pimientos y el cilantro."@es .

<http://example.org/recipes/entrada/22/step/bec05437d16244e6a936cc221823df7d> a schema1:HowToStep ;
    schema1:text "Servir el ceviche con chifles, patacones o chulpi (maíz tostado)."@es .

<http://example.org/recipes/entrada/22/step/dd3347fa79664ca19bedc567f4a02291> a schema1:HowToStep ;
    schema1:text "Colocar el pescado con la mitad del jugo de los limones en un tazón, comprobando que el líquido cubra por completo el pescado. Añadir una pizca de sal y tapar el tazón. Reservar en la refrigeradora unas 3 o 4 horas para que el ácido de limón \"cocine\" el pescado."@es .

<http://example.org/recipes/entrada/22/step/e381fd57d595438eac66b605a66191b9> a schema1:HowToStep ;
    schema1:text "Retirar el pescado de la nevera y escurrir del jugo de limón. Mezclar el pescado con la mezcla anterior. Añadir sal y aceite al gusto."@es .

<http://example.org/recipes/entrada/23/step/0f360ef18d7146b3913f072fd10a8b89> a schema1:HowToStep ;
    schema1:text "Cortar las cebollas en julianas de no más de 1 centímetro de grosor."@es .

<http://example.org/recipes/entrada/23/step/0f5e594df7774961be59bf52ae303dfc> a schema1:HowToStep ;
    schema1:text "Remover las semillas y el corazón del ají amarillo. Cortar en julianas solo la mitad."@es .

<http://example.org/recipes/entrada/23/step/13a85bd0a7db4699ba3aecea86a87aa4> a schema1:HowToStep ;
    schema1:text "Retirar y servir utilizando la lechuga como base y acompañar de una porción de arroz blanco decorado con la ramita de cilantro."@es .

<http://example.org/recipes/entrada/23/step/41509277da2d45d08402fdbf1038b57b> a schema1:HowToStep ;
    schema1:text "Dejar cocinar por 5 minutos a fuego medio, luego verter el caldo de pollo y remover."@es .

<http://example.org/recipes/entrada/23/step/715ed47bd5c5429b8ccb1d192f9db9a9> a schema1:HowToStep ;
    schema1:text "Dejar cocinar por 3 minutos y agregar el zumo de limón y sal."@es .

<http://example.org/recipes/entrada/23/step/c8ab1dd302c84795ad5d409c36a37444> a schema1:HowToStep ;
    schema1:text "Sofreír los ajos, el ají amarillo molido y el ají colorado molido en una olla con el aceite vegetal."@es .

<http://example.org/recipes/entrada/23/step/d8405a6dc8ef467ca8c889fb26daf6f0> a schema1:HowToStep ;
    schema1:text "Remover y dejar cocinar entre 3 a 5 minutos, sin que la cebolla y el ají se sobre cocinen."@es .

<http://example.org/recipes/entrada/23/step/ed4cf6ebd53248b7a564b07640e9f748> a schema1:HowToStep ;
    schema1:text "Cortar el pollo en pedazitos de 1 pulgada cuadrada."@es .

<http://example.org/recipes/entrada/23/step/f5ca1588a3e047cdbd2498bf0edd43b3> a schema1:HowToStep ;
    schema1:text "Agregar las piezas de pollo a la preparación con sal y pimienta al gusto."@es .

<http://example.org/recipes/entrada/23/step/ffd3a3aaabfc4774aa9297fff22adb20> a schema1:HowToStep ;
    schema1:text "Dejar cocinar por 5 minutos adicionales, luego agregar las cebollas y el ají amarillo cortado en julianas y remover."@es .

<http://example.org/recipes/entrada/24/step/62338559456d48c2add5089d842aed3e> a schema1:HowToStep ;
    schema1:text "Lavar y limpiar bien el pulpo. Cortar los tentáculos y utilizarlos para la preparación."@es .

<http://example.org/recipes/entrada/24/step/845c2e2dc44b4c4485ae304d4dc4cdf7> a schema1:HowToStep ;
    schema1:text "Para cocinar el pulpo, debe sumergirse en agua hirviendo con sal y retirarse inmediatamente. Este procedimiento se repite unas tres veces. Luego se deja cocinar el pulpo en el agua, por unos 50 o 60 minutos, hasta que esté blando."@es .

<http://example.org/recipes/entrada/24/step/956e8ff9109a4bb8b90d57aba24c39d4> a schema1:HowToStep ;
    schema1:text "Añadir sal a los tentáculos y fregarlos bien. Luego lavarlos con agua."@es .

<http://example.org/recipes/entrada/24/step/c1ea1f85e9cf4e099c54d53c39926dae> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y dejar enfriar para cortarlo en rodajas."@es .

<http://example.org/recipes/entrada/24/step/e97a695541ee42c9b61edcc671d68801> a schema1:HowToStep ;
    schema1:text "Dejar en reposo en el refrigerador hasta el momento de servir."@es .

<http://example.org/recipes/entrada/24/step/fa6c65185a7b4735bf3b28865b3a7fa1> a schema1:HowToStep ;
    schema1:text "En una fuente o bol de vidrio, colocar las cebollas y agregar sal y el jugo de limón. Mezclar bien e incorporar el pimiento, los tomates, el ají picado, el pulpo, el consomé, cilantro y perejil finamente picados. Rectificar el sabor."@es .

<http://example.org/recipes/entrada/25/step/08db0c6874a945e996369813314759ec> a schema1:HowToStep ;
    schema1:text "A las cebollas le agregamos el jugo de 3 limones. Después de reposado le agregamos 1 cucharadda de sal."@es .

<http://example.org/recipes/entrada/25/step/22b0724a65da44559e8919655223ff99> a schema1:HowToStep ;
    schema1:text "En una olla con agua hirviendo agregamos los camarones y el pescado durante 2 minutos. Una vez pasado el tiempo los colamos."@es .

<http://example.org/recipes/entrada/25/step/72926e404fd24a3bba12ddf6b623288b> a schema1:HowToStep ;
    schema1:text "Aparte en un envase colocamos la salsa de tomate ¾ taza, 1 cucharadita de moztaza lo revolvemos y le agregamos el jugo de 1/2 naranja."@es .

<http://example.org/recipes/entrada/25/step/9b1be26781c149c9b31b400d5de3ab2e> a schema1:HowToStep ;
    schema1:text "Lo revolvemos muy bien. Dejamos reposar y podemos disfrutar con cilantro picadito."@es .

<http://example.org/recipes/entrada/25/step/bb250fdf6a3b44698e000c7603124225> a schema1:HowToStep ;
    schema1:text "Aparte cortamos la cebolla en rodajas finas y le agregamos una cucharada de azúcar . luego de 10 miutos la lavamos para quitarle el azúcar. Aparte picamos 2 tomates en cuadritos."@es .

<http://example.org/recipes/entrada/25/step/d1d27d4c981f42f4a7b18b022e1551e3> a schema1:HowToStep ;
    schema1:text "Una vez reposado camarones y pescado mezclamos todos los ingredientes. Camarones con cebolla, el jugo, cilantro , tomates y el resto de ingredientes."@es .

<http://example.org/recipes/entrada/25/step/fcc474a17cad4c42898931f45df5f52f> a schema1:HowToStep ;
    schema1:text "En el agua del camaron los cocinamos hasta que estén rosados. Dejamos enfriar."@es .

<http://example.org/recipes/entrada/26/step/0c28e534bed24439b601573277b3cbe1> a schema1:HowToStep ;
    schema1:text "Servir el ceviche de atún con chifles o chulpi (maíz tostado) o rodajas de limón. También se le puede agregar rodajas de aguacate."@es .

<http://example.org/recipes/entrada/26/step/7ea33ef026c94d569c726361ac60ba3e> a schema1:HowToStep ;
    schema1:text "Mezclar la cebolla con el tomate, el cilantro, el ají, el jugo de limón, el atún, el aceite de oliva y sal al gusto. Se puede servir inmediatamente o dejar reposar durante unos 30 minutos antes de servir."@es .

<http://example.org/recipes/entrada/26/step/c63be2530fe64abba5be50b703eb54fc> a schema1:HowToStep ;
    schema1:text "Colocar la cebolla colorada en un tazón, espolvorear con sal y cubrir con agua tibia. Dejar remojar durante 10 minutos, colar el agua y enjuagar las cebollas con agua fría."@es .

<http://example.org/recipes/entrada/27/step/4c9fe72dcdb245e1890dbf71e04f4b26> a schema1:HowToStep ;
    schema1:text "Mezclar la harina integral, la sal y el aceite. Empezar a amasar añadiendo poco a poco el agua hasta conseguir una pasta homogénea y que no se peque a los dedos."@es .

<http://example.org/recipes/entrada/27/step/73095901be4041dfbcb64c06322159f5> a schema1:HowToStep ;
    schema1:text "Cocinar la masa sobre una plancha o un sartén unos minutos por cada lado."@es .

<http://example.org/recipes/entrada/27/step/d36857d091af41e1ba563fee5a77fd47> a schema1:HowToStep ;
    schema1:text "Untar ligeramente con aceite. Así no se pegan unos con otros y además quedan más sabrosos."@es .

<http://example.org/recipes/entrada/27/step/e026180121eb41b1941ae91aac3c054e> a schema1:HowToStep ;
    schema1:text "Tapar la masa con un paño y dejar reposar por 30 minutos."@es .

<http://example.org/recipes/entrada/27/step/ea36a33d086348b7b7b4ace79d45ba1b> a schema1:HowToStep ;
    schema1:text "Pasado el tiempo de reposo dividir la masa en bolas del tamaño aproximado de un huevo y estirar con un rodillo intentando que queden finas y redondas."@es .

<http://example.org/recipes/entrada/28/step/0accf9d899054669aaa27f0a5bcf29ee> a schema1:HowToStep ;
    schema1:text "Cuando los plátanos estén blandos, retírelos del fuego, quite las cortezas y haga un puré con la parte interna. Reserve."@es .

<http://example.org/recipes/entrada/28/step/71737405c03747f1a32f7436d6e26ae5> a schema1:HowToStep ;
    schema1:text "Vuelva a cocinarlo por unos 40 minutos."@es .

<http://example.org/recipes/entrada/28/step/799083d9930d45368e1fd806655d1817> a schema1:HowToStep ;
    schema1:text "Añada el puré de plátanos a las chontas y agregue azúcar si hace falta."@es .

<http://example.org/recipes/entrada/28/step/81a7f17eab6e43b2bd21425993502703> a schema1:HowToStep ;
    schema1:text "Enfríe (si desea puede dejarlo fermentar durante 24 horas)."@es .

<http://example.org/recipes/entrada/28/step/9b08cb37c00c469689e4846d9d273944> a schema1:HowToStep ;
    schema1:text "Cuele bien la preparación."@es .

<http://example.org/recipes/entrada/28/step/ad6cda397d424b08814cdaba5cc8a7b2> a schema1:HowToStep ;
    schema1:text "Sirva y disfrute."@es .

<http://example.org/recipes/entrada/28/step/b53505d74ce447d792fc9ba9708e3a56> a schema1:HowToStep ;
    schema1:text "Licue las chontas y cuele la preparación varias veces."@es .

<http://example.org/recipes/entrada/28/step/cf23a9f5c81d4ec191eb4f8fe4dc612b> a schema1:HowToStep ;
    schema1:text "Siga cocinando las chontas hasta que ablanden por completo."@es .

<http://example.org/recipes/entrada/28/step/d45b84e3eedb4c46a5473fa5083dfc3e> a schema1:HowToStep ;
    schema1:text "Cocine en una cacerola con el agua, los plátanos con la concha, la chonta pelada y la canela."@es .

<http://example.org/recipes/entrada/29/step/0c2f9ce6b3d141098c91317db2b3d51b> a schema1:HowToStep ;
    schema1:text "Cuando el agua haya evaporado, incorpore los vegetales y sofría todos los ingredientes por unos 20 minutos aproximadamente. La carne terminará de cocinarse en su propia grasa y la del bacon."@es .

<http://example.org/recipes/entrada/29/step/0c606888cd3a4f898de1b19667e2296f> a schema1:HowToStep ;
    schema1:text "Sírvalos con un poco de encurtido de cebollas, mote o plátanos. Puede espolvorear un poco de cilantro picado."@es .

<http://example.org/recipes/entrada/29/step/283d8192e7e14852ae1f7c79c894ee94> a schema1:HowToStep ;
    schema1:text "Cortar la carne en trozos y aderezar con suficiente sal y un toque de pimienta."@es .

<http://example.org/recipes/entrada/29/step/32b43ae0c96c4aa193134e9fafc07758> a schema1:HowToStep ;
    schema1:text "Una vez que la carne obtenga un color dorado y una textura crujiente, retire del fuego."@es .

<http://example.org/recipes/entrada/29/step/8a3942823b2844ea9fdf82578313cba2> a schema1:HowToStep ;
    schema1:text "Colocar los trozos de carne en una olla y cubrirlos con agua. Cocinar a fuego bajo por suficiente tiempo hasta que el agua comience a evaporarse."@es .

<http://example.org/recipes/entrada/29/step/b0f4b1fe602b4d89a92943a752511d72> a schema1:HowToStep ;
    schema1:text "Limpiar la carne de cerdo, retirando el exceso de grasa."@es .

<http://example.org/recipes/entrada/29/step/f7b973fcba174928bf2e6aa5d922fbee> a schema1:HowToStep ;
    schema1:text "Picar la cebolla, el bacon, el cilantro y el ajo en trozos pequeños."@es .

<http://example.org/recipes/entrada/3/step/116911a0b1924c7c82c72073aa441cf4> a schema1:HowToStep ;
    schema1:text "Preparar salsa de maní en una olla colocando el aceite de color, la cebolla, el cilantro y el ají, sazonar con sal, comino y pimienta."@es .

<http://example.org/recipes/entrada/3/step/16c4d6f4d7f2425bafc306e459f9db16> a schema1:HowToStep ;
    schema1:text "Hacer un refrito con la salsa de maní, el librillo picado y la leche."@es .

<http://example.org/recipes/entrada/3/step/28b87cc3f972408da8d3e8f8bc4f6750> a schema1:HowToStep ;
    schema1:text "Hervir por 20 minutos removiendo ocasionalmente."@es .

<http://example.org/recipes/entrada/3/step/33298546fae140789343799dcc653c1d> a schema1:HowToStep ;
    schema1:text "Cocinar el librillo en una olla de presión con 2 ramas de cebolla blanca, el perejil y el ajo hasta que esté suave."@es .

<http://example.org/recipes/entrada/3/step/57ed426a08a64bfabc1be2bbf4104dfc> a schema1:HowToStep ;
    schema1:text "Pelar y cocinar las papas enteras en agua hirviendo con sal."@es .

<http://example.org/recipes/entrada/3/step/b15c905384354b01a1cd5f85ffffb16e> a schema1:HowToStep ;
    schema1:text "Retirar del caldo el librillo y picarlo."@es .

<http://example.org/recipes/entrada/3/step/c1607c6cd67344fabdab41661d1cbca0> a schema1:HowToStep ;
    schema1:text "Colocar las papas escurridas en un plato hondo y rellenar con una buena porción del ají de librillo."@es .

<http://example.org/recipes/entrada/3/step/ce6d9f17b6f74fbbbd2e11ea9f845673> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y agregar el huevo picado."@es .

<http://example.org/recipes/entrada/30/step/2c552cdbfd9240a68823928f1eb01333> a schema1:HowToStep ;
    schema1:text "Primero pelamos los platanos y los cortamos muy finitos. Lo ideal seria utilizar una herramienta para que queden lo mas fino posible."@es .

<http://example.org/recipes/entrada/30/step/79a678f742354cc29108f542d0dea4f4> a schema1:HowToStep ;
    schema1:text "Una vez picado en rodajas todos los platanos , ponemoas a calentar el aceite en una cacerola."@es .

<http://example.org/recipes/entrada/30/step/b1d116d2f20243d7b63463ac439a7b70> a schema1:HowToStep ;
    schema1:text "Listos para servir."@es .

<http://example.org/recipes/entrada/30/step/c7aace4ff90b4704ac853c3756a11287> a schema1:HowToStep ;
    schema1:text "Una vez que estén dorados escurrimos bien y dejamos reposar en papel absorbente y le agregamos sal."@es .

<http://example.org/recipes/entrada/30/step/d84a754b5f43439787beda5629aedfa9> a schema1:HowToStep ;
    schema1:text "Una vez que este bastante caliente el aceite procedemos a colocar los chifles, tratando de no colocarlos juntos porque se pegan. Preferible hacerlo por separado."@es .

<http://example.org/recipes/entrada/31/step/2ca71df36ad940edb344ac60282370ea> a schema1:HowToStep ;
    schema1:text "Freír hasta que las tajadas de plátano comiencen a dorarse."@es .

<http://example.org/recipes/entrada/31/step/a361ee9dcaf84238bfcf83e0162951cf> a schema1:HowToStep ;
    schema1:text "Espolvorear los chifles con sal al gusto y servirlos calientes o fríos."@es .

<http://example.org/recipes/entrada/31/step/a80dffa835da4e7cb95293b8f608694b> a schema1:HowToStep ;
    schema1:text "Sacar los chifles del aceite y colocarlos en toallas de papel para escurrir el exceso de aceite."@es .

<http://example.org/recipes/entrada/31/step/e74130a6c5734864bf8e45d4667e172a> a schema1:HowToStep ;
    schema1:text "Calentar abundante aceite y agregar las tajadas de plátano, asegurando que estén cubiertas por el aceite. Tratar de no freír demasiadas a la misma vez para evitar que se peguen."@es .

<http://example.org/recipes/entrada/31/step/f43346c74afe4b248411f36bb6166f59> a schema1:HowToStep ;
    schema1:text "Pelar los plátanos verdes y cortarlos en tajadas largas muy finas."@es .

<http://example.org/recipes/entrada/32/step/08b1efdb2be446f2ab35e068a894c545> a schema1:HowToStep ;
    schema1:text "Colocar en una sarten el aceite y calentarlo a fuego alto por unos 5 minutos."@es .

<http://example.org/recipes/entrada/32/step/49390e9822304f0a80bb9b4c710580d1> a schema1:HowToStep ;
    schema1:text "Pelar los plátanos y cortarlos en rodajas alargadas."@es .

<http://example.org/recipes/entrada/32/step/4ec076741abe4ab7a7f5417e8abd700a> a schema1:HowToStep ;
    schema1:text "Sacar los platanitos y dejarlos sobre papel absorvente."@es .

<http://example.org/recipes/entrada/32/step/d02a48ead31f4d76a3929df01359c047> a schema1:HowToStep ;
    schema1:text "Freir las tajadas hasta quie esten doradas de ambos lados."@es .

<http://example.org/recipes/entrada/32/step/ddd59f5ff77344268d668e33a37eeb96> a schema1:HowToStep ;
    schema1:text "Espolvorear con sal marina y servir calientes."@es .

<http://example.org/recipes/entrada/33/step/283f5ddcaa7241c699342cefc496856c> a schema1:HowToStep ;
    schema1:text "Una vez listo se agrega encima de los choclos y podemos disfrutar y servir."@es .

<http://example.org/recipes/entrada/33/step/5c6ef7e1371c4bd39632854d341c6084> a schema1:HowToStep ;
    schema1:text "Primero hervimos los choclos, agregamos sal al agua y agregamos los 8 choclos. Poner a hervir entre 20 minutos hasta que estén blandos."@es .

<http://example.org/recipes/entrada/33/step/c3888290e0044fcaa73e400e565b9157> a schema1:HowToStep ;
    schema1:text "En la licuadora agregamos el manojo de ciclantro, los ajo, la taza de aceite, la sal gusto, el jugo de limon y el queso. Batimos muy bien."@es .

<http://example.org/recipes/entrada/34/step/17b71612ad63460cb90cc85c4908f38e> a schema1:HowToStep ;
    schema1:text "Servir los choclos con la salsa vertida encima y adornar con cilantro o queso rallado."@es .

<http://example.org/recipes/entrada/34/step/8251e53efc114dfc9718ff90865fde3a> a schema1:HowToStep ;
    schema1:text "Agregar el aceite restante poco a poco y continuar licuando hasta que la salsa comience a ponerse espesa. Agregar el queso y el jugo de limón y licuar hasta obtener una salsa cremosa. Probar y ajustar la sal al gusto."@es .

<http://example.org/recipes/entrada/34/step/b8d9cc36249940b587a4363c912b6b7b> a schema1:HowToStep ;
    schema1:text "Pelar y limpiar los choclos o mazorcas de maíz. Cocinar los choclos en agua hirviendo durante 2-3 minutos, luego frotarlos con mantequilla y asarlos en la parrilla durante 10 o 15 minutos, dándoles vueltas cada 3 o 4 minutos."@es .

<http://example.org/recipes/entrada/34/step/f7660dfe67ab41db8c1cf07e4921f5f6> a schema1:HowToStep ;
    schema1:text "Colocar en una licuadora el huevo, el ajo machacado, el cilantro, una pizca de sal y ¼ de taza de aceite y mezcle hasta que los ingredientes estén bien licuados."@es .

<http://example.org/recipes/entrada/35/step/1afe35b9612844108c1e5975d45531d8> a schema1:HowToStep ;
    schema1:text "Espolvorear el chulpi con sal al gusto y servir caliente o frío."@es .

<http://example.org/recipes/entrada/35/step/3270502788e84f5e8532d89c6fadd319> a schema1:HowToStep ;
    schema1:text "Colocar el maíz tostado en una toalla de papel para absorber el exceso de aceite."@es .

<http://example.org/recipes/entrada/35/step/41158c9aa2d9457a9e9a66182718e486> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una sartén a fuego medio. Agregar el maíz y revolverlo cuando comience a reventar."@es .

<http://example.org/recipes/entrada/35/step/9efe02ace9764836851e43790b095a1c> a schema1:HowToStep ;
    schema1:text "Continuar revolviendo para evitar que el maíz se queme y cocinar hasta que los granos estén dorados."@es .

<http://example.org/recipes/entrada/35/step/ab0a9e891efe4f3c9174ffc8feeea932> a schema1:HowToStep ;
    schema1:text "Cubrir parcialmente con una tapa para evitar que el tostado salte de la sartén."@es .

<http://example.org/recipes/entrada/36/step/0b197f9ee5074a73a7284225edff62c7> a schema1:HowToStep ;
    schema1:text "Con un paño tomar la cacerola tapada y removerla para evitar que se queme, pero logrando que quede dorado."@es .

<http://example.org/recipes/entrada/36/step/33cf957f4ede438098cb7aa0eda21326> a schema1:HowToStep ;
    schema1:text "Aguardar a que el maíz se abra por completo para que no escape de la olla."@es .

<http://example.org/recipes/entrada/36/step/4e156952cd6e4b01be2373e5868fb464> a schema1:HowToStep ;
    schema1:text "Espolvorear el chulpi con sal y pimienta y servir."@es .

<http://example.org/recipes/entrada/36/step/c282c1d58bcf43878dda9f7d74348f26> a schema1:HowToStep ;
    schema1:text "Retirar el maíz y colocar en un recipiente con papel absorbente."@es .

<http://example.org/recipes/entrada/36/step/d003f0f8177145339a983ed67f2a1a92> a schema1:HowToStep ;
    schema1:text "Colocar en una sartén a fuego medio las dos cucharadas de aceite, una vez que este caliente agregar el maíz, remover y tapar."@es .

<http://example.org/recipes/entrada/37/step/40d61f6bc39942089f0c10fc2f68a450> a schema1:HowToStep ;
    schema1:text "Abrir las conchas con una guillotina o un cuchillo."@es .

<http://example.org/recipes/entrada/37/step/4ddadaaf20c34a95a8b24fc3d704137e> a schema1:HowToStep ;
    schema1:text "Calentar el grill."@es .

<http://example.org/recipes/entrada/37/step/4eeec77e451841ca99f037ef39a43796> a schema1:HowToStep ;
    schema1:text "Servir las conchas acompañadas de curtido de cebollas, patacones y rodajas de limón."@es .

<http://example.org/recipes/entrada/37/step/7dd3e09b1a4044ab9d50741f27d93f07> a schema1:HowToStep ;
    schema1:text "En un bol se prepara la salsa para las conchas. Para ello, coloque el aceite, el ajo, culantro, perejil, la chillangua y el jugo de 1 limón. Aderezar con sal, pimienta, y una pizca de comino. Mezclar muy bien todos los ingredientes. Reserve."@es .

<http://example.org/recipes/entrada/37/step/9c9197d7d1904e43bce5c7409b4f8c1e> a schema1:HowToStep ;
    schema1:text "Lavar y limpiar bien las conchas negras."@es .

<http://example.org/recipes/entrada/37/step/ad4ca39a298a4f6d8d091d5dadb030e5> a schema1:HowToStep ;
    schema1:text "Para el curtido, coloque en un bol la cebolla paiteña, el tomate, un poco de culantro, sal y pimienta al gusto. Añada el jugo de 1 limón. Mezcle todos los ingredientes y reserve."@es .

<http://example.org/recipes/entrada/37/step/b50a977ef57b48769b5639e9bb7441ea> a schema1:HowToStep ;
    schema1:text "Colocar las conchas abiertas sobre el grill y adobarlas con la salsa preparada. Asarlas por unos 5 minutos aproximadamente."@es .

<http://example.org/recipes/entrada/38/step/024a0eeb319b4fc2add69bd97c90cc1e> a schema1:HowToStep ;
    schema1:text "Rallar la mitad de verde crudo y la otra mitad cocinar, luego majar todo y mezclar."@es .

<http://example.org/recipes/entrada/38/step/22e71d39f7c1496b97a38534335529de> a schema1:HowToStep ;
    schema1:text "Formar bolas ovaladas o alargadas con la masa de verde y rellenarlas con el condumio de pescado."@es .

<http://example.org/recipes/entrada/38/step/345b111aa7824842ba7a8e1d491370c8> a schema1:HowToStep ;
    schema1:text "Colocar aceite en el sartén para proceder a hacer el refrito. Agregamos la cebolla, el pimiento, el tomate, el ajo y mezclamos."@es .

<http://example.org/recipes/entrada/38/step/65805b413bb74f82a8664928bc6e8e55> a schema1:HowToStep ;
    schema1:text "Freír en abundante aceite o preparar el horno a 180 grados C."@es .

<http://example.org/recipes/entrada/38/step/9edff66d654142ab842fab1891a13225> a schema1:HowToStep ;
    schema1:text "Agregar el pescado en trozos y sazonar con el cilantro, comino, sal y pimienta."@es .

<http://example.org/recipes/entrada/38/step/ac7fb6c5f12d4249ad62545f5499f655> a schema1:HowToStep ;
    schema1:text "Picar finamente la cebolla, el pimiento, el tomate."@es .

<http://example.org/recipes/entrada/38/step/df7ccb8ff7394cd09952207e86aa8cf8> a schema1:HowToStep ;
    schema1:text "Agregar a esta mezcla el maní molido, achiote y amasar"@es .

<http://example.org/recipes/entrada/39/step/1d6c7668f1dc45d5a1257c24fa5b844c> a schema1:HowToStep ;
    schema1:text "Preparar la masa en un recipiente grande con la harina, la sal y el azúcar, la mantequilla. Unir y mezclar bien los ingredientes hasta que quede una mezcla homogénea."@es .

<http://example.org/recipes/entrada/39/step/30c3439e0d2d463eb3ee952da0185f36> a schema1:HowToStep ;
    schema1:text "Al retirar poner sobre papel absorbente para quitar el exceso de aceite."@es .

<http://example.org/recipes/entrada/39/step/4b1cbf53dd14497eb93e51921f6a63c7> a schema1:HowToStep ;
    schema1:text "Una vez lista la masa cortar el queso.o la mortadela. En caso de ser queso, usar un queso blanco, de consistencia dura y preferiblemente salado."@es .

<http://example.org/recipes/entrada/39/step/648cfdf8dca8438cae692c1e3e5f0be4> a schema1:HowToStep ;
    schema1:text "Agregar agua fría y amasar hasta que la mezcla no sea pegajosa y quede compacta."@es .

<http://example.org/recipes/entrada/39/step/b8bd1e2cc7ff4e7ba78a1068145dfc14> a schema1:HowToStep ;
    schema1:text "Tomar un pedazo de queso o mortadela y con la masa se le va dando vuelta hasta cubrirlo, con forma de tornillo o espiral. Es muy importante no dejar ningún pedazo al descubierto."@es .

<http://example.org/recipes/entrada/39/step/c274a9502ad841ac9cbe24b6812dc6a4> a schema1:HowToStep ;
    schema1:text "Extender la masa con un mazo sobre una superficie plana, limpia y enharinada previamente. Dejar extendida la masa hasta que alcance unos 3 milímetros de grosor y se corta en tiras de 2 centímetros aproximadamente."@es .

<http://example.org/recipes/entrada/39/step/ccb5886b5e2c40be841c7233d4f3b3fb> a schema1:HowToStep ;
    schema1:text "Freir en una sartén con aceite muy caliente hasta que la masa se dore. Recuerda controlar el fuego para que las piezas no se quemen muy rápido."@es .

<http://example.org/recipes/entrada/4/step/006ae9d656df476ea0842afcfc39c393> a schema1:HowToStep ;
    schema1:text "En un envase aparate colocaremos: 1 taza y media salsa ketchup, 2 cucharadas azúcar, mascarbano, ½ cucharadita de ajo en polvo , ¼ cucharadita de pimienta molida, sal al gusto , jugo de limón, ½ cucharadita cebolla polvo, ½ cucharadita chile polvo, ¾ cucharada paprika, 20 gramos mantequilla y ¼ taza de miel."@es .

<http://example.org/recipes/entrada/4/step/26fb37ab5b3e495fbe3d195c75cb4330> a schema1:HowToStep ;
    schema1:text "Aparte agregamos aceite en un sarten y una vez que este caliente se frie el pollo por 15 minutos. Luego las dejamos escurrir en papel absorbente"@es .

<http://example.org/recipes/entrada/4/step/51bd9c97da4e49b2a1a4ac436ae1099d> a schema1:HowToStep ;
    schema1:text "Comenzaremos salpimentando las alitas en todas las piezas de pollo. Luego las cubrimos con un poco de harina de trigo."@es .

<http://example.org/recipes/entrada/4/step/b8356437e6004f44890f89e9f18b8d2c> a schema1:HowToStep ;
    schema1:text "Cuando hierva la retiramos del fuego. Una vez cocido todo el pollo colocamos la salsa en fuego medio, agregamos las alitas y nos aseguramos que queden bien cubiertas. Cocinamos por unos minutos y listas para disfrutar."@es .

<http://example.org/recipes/entrada/4/step/e1a1c952b3584963b10c02dc22ee8724> a schema1:HowToStep ;
    schema1:text "Acompañar con ensalada o papas fritas."@es .

<http://example.org/recipes/entrada/4/step/e6903629ba994ec1b21de294f4f2ca7a> a schema1:HowToStep ;
    schema1:text "En una olla derretimos la mantequilla y agregamos la salsa ketchup, luego la miel, los ingredientes secos y el jugo de limón."@es .

<http://example.org/recipes/entrada/40/step/2d6ec725abe94ac4bd2bb5bbc11517a4> a schema1:HowToStep ;
    schema1:text "Añadir la mantequilla cortada en pedazos y mezclar hasta formar una masa compacta (Puede agregar más agua si la masa esta seca o un poquito de aceite si la masa está pegajosa)."@es .

<http://example.org/recipes/entrada/40/step/313547d39010435797b1a052c3b4fd16> a schema1:HowToStep ;
    schema1:text "Proceder a compartir la masa en porciones, con la mano formamos bolitas para luego extenderla con un rodillo, formando un disco."@es .

<http://example.org/recipes/entrada/40/step/35acd2a2b94346f694fc6bcd021831f3> a schema1:HowToStep ;
    schema1:text "Ponga las empanadas encima de toallas de papel para que se absorba la grasa y luego servir."@es .

<http://example.org/recipes/entrada/40/step/40e2dec1140244a0b0ea346e3c44bb83> a schema1:HowToStep ;
    schema1:text "Al extender la masa rellenamos con el queso desmenuzado y la cebolla picada (opcional)."@es .

<http://example.org/recipes/entrada/40/step/97353049575c4be9abc1984f4f2571d6> a schema1:HowToStep ;
    schema1:text "Mezclar con las manos e ir añadiendo el agua mineral."@es .

<http://example.org/recipes/entrada/40/step/c7d2cf9b354d4ab8808b1ffd0f2090f0> a schema1:HowToStep ;
    schema1:text "Mezclar la harina, la sal, el azúcar, y el polvo de hornear en un bol."@es .

<http://example.org/recipes/entrada/40/step/d853a746587b4705a1cf26433a6203bc> a schema1:HowToStep ;
    schema1:text "Freír en abundante aceite y espolvorear con azúcar."@es .

<http://example.org/recipes/entrada/40/step/fffd500f08ef4f39a551fd8892905158> a schema1:HowToStep ;
    schema1:text "Dejar reposar media hora."@es .

<http://example.org/recipes/entrada/41/step/43fc1536056f4bbe8adcdf17d4037bb9> a schema1:HowToStep ;
    schema1:text "Para finalizar agregamos queso de nuestra preferencia."@es .

<http://example.org/recipes/entrada/41/step/74ba1e28c0a247bc9bceb32798c0315b> a schema1:HowToStep ;
    schema1:text "Luego en una olla con agua colocamos los platanos, cuando esten hirviendo. los dejarmos hervir por 15 minutos."@es .

<http://example.org/recipes/entrada/41/step/85862ed48ee5472fa7b18dca1e8e67a8> a schema1:HowToStep ;
    schema1:text "Trituramos bien y extendemos bien con la ayuda de un plástico y rodillo."@es .

<http://example.org/recipes/entrada/41/step/9754f5e4642b4d27b8da6ccc31867c64> a schema1:HowToStep ;
    schema1:text "Se pelan los platanos y se cortan en rodajas gruesa."@es .

<http://example.org/recipes/entrada/41/step/f5a5559255a74fedbfc9c203f2e28f17> a schema1:HowToStep ;
    schema1:text "Seguido de esto en un procesador o triturador agregamos los platanos, con un toque de azúcar al gusto."@es .

<http://example.org/recipes/entrada/42/step/657e7ad858ac440b84dce1faeee98913> a schema1:HowToStep ;
    schema1:text "Añada el atún desmenuzado. Mezcle los ingredientes y siga cocinando por otros 5 minutos."@es .

<http://example.org/recipes/entrada/42/step/6ae37ecf591c4fb2ab719906b0eff50e> a schema1:HowToStep ;
    schema1:text "Sírvalas acompañadas con una mayonesa de aguacate o salsa de su preferencia y rodajas de limón."@es .

<http://example.org/recipes/entrada/42/step/72eba4f4fc8f40d9809b2dff78bfae39> a schema1:HowToStep ;
    schema1:text "Coloque los discos de empanadas sobre una encimera y agregue una porción del relleno de atún en el centro. Doble la empanada y haga un repulgue en los bordes para sellarla."@es .

<http://example.org/recipes/entrada/42/step/cdf7e4d409af492db2e34487ef981c9d> a schema1:HowToStep ;
    schema1:text "Hornear por unos 15 minutos a unos 200°C."@es .

<http://example.org/recipes/entrada/42/step/dd315c8d3a35475ba6fe3152772c688d> a schema1:HowToStep ;
    schema1:text "Incorpore las alcaparras, las aceitunas, el orégano o albahaca, el chile molido y un poco de jugo de limón. Sazone con sal y pimienta. Cocine por otros 3 minutos y retire del fuego. Deje reposar."@es .

<http://example.org/recipes/entrada/42/step/e1ab6fe7a4a8473581ef1b9015dc1122> a schema1:HowToStep ;
    schema1:text "Coloque las empanadas sobre una bandeja y guarde en el refrigerador por unos 20 minutos."@es .

<http://example.org/recipes/entrada/42/step/fa9c5df44f3b42a88a18c0cf001ddc9a> a schema1:HowToStep ;
    schema1:text "En una sartén coloque a calentar el aceite y agregue la cebolla y el pimiento picaditos. Incorpore el pimentón molido y el ajo. Sofría por unos 7 a 10 minutos."@es .

<http://example.org/recipes/entrada/42/step/fce51eaea9714a72bdff4a638fea3ac3> a schema1:HowToStep ;
    schema1:text "Una vez transcurrido el tiempo, saqué la bandeja del refrigerador y proceda a pintar las empanadas con el huevo batido. Esto hará que adquieran un color dorado al hornearse."@es .

<http://example.org/recipes/entrada/43/step/3ffaae6b89b745bbb7009e727a9b76cc> a schema1:HowToStep ;
    schema1:text "Amasar suavemente sobre la mesada. Cubrir con un paño y dejar reposar por 15 minutos."@es .

<http://example.org/recipes/entrada/43/step/58f2ce23824c42c1b31391220c7dfb08> a schema1:HowToStep ;
    schema1:text "En una olla colocar el queso, las yemas y el azúcar, a fuego medio integrar todos los ingredientes hasta formar una pasta espesa."@es .

<http://example.org/recipes/entrada/43/step/6da075b22fd34f4e91cf32700df2b1ef> a schema1:HowToStep ;
    schema1:text "Extender la masa con palote y cortar círculos medianos."@es .

<http://example.org/recipes/entrada/43/step/7c050be328ad4d90a805a78f0fedc6d9> a schema1:HowToStep ;
    schema1:text "Una vez que el mejido se enfríe, rellenar los discos, cerrar con el repulgue que prefiera y freír hasta dorar."@es .

<http://example.org/recipes/entrada/43/step/84be484a19904f749af9dbf5b4193dad> a schema1:HowToStep ;
    schema1:text "Mezclar con cornete hasta que quede todo incorporado."@es .

<http://example.org/recipes/entrada/43/step/910f12a4b7d2493aa754620cec9ff5ea> a schema1:HowToStep ;
    schema1:text "Colocar en un recipiente los ingredientes secos junto con la mantequilla."@es .

<http://example.org/recipes/entrada/43/step/f0f11ba13cd94594a0372a5213064e69> a schema1:HowToStep ;
    schema1:text "Agregar de a poco el agua hasta lograr que la masa quede suave."@es .

<http://example.org/recipes/entrada/44/step/36cad111968c46f889ca2efb48096120> a schema1:HowToStep ;
    schema1:text "Agregar las yemas de huevo y amasar."@es .

<http://example.org/recipes/entrada/44/step/4c510689354d47478d627ef18c7e2ccf> a schema1:HowToStep ;
    schema1:text "Retirar la masa del fuego y dejar enfriar un poco."@es .

<http://example.org/recipes/entrada/44/step/7d86305c90ea4ecd96ef7f43624be955> a schema1:HowToStep ;
    schema1:text "Dejar reposar la masa por 20 minutos."@es .

<http://example.org/recipes/entrada/44/step/90fa8d49234d4d33842f53b5f2aa874f> a schema1:HowToStep ;
    schema1:text """Dejar cocer por 5 minutos removiendo continuamente. Al final agregue el huevo.
	Mezclar bien y retirar del fuego."""@es .

<http://example.org/recipes/entrada/44/step/cd692fe76a5a4588af8181466b02d9cc> a schema1:HowToStep ;
    schema1:text "Cernir la harina."@es .

<http://example.org/recipes/entrada/44/step/d0bd4ad5c8db450fbbdf3273dc25044b> a schema1:HowToStep ;
    schema1:text "Tomar un poco de masa, haga con ella una bolita y extienda sobre un plástico."@es .

<http://example.org/recipes/entrada/44/step/df42c064439e450ea02b5dcb165c2b90> a schema1:HowToStep ;
    schema1:text "Sofreír la cebolla y el ajo hasta que estén transparentes. Incorporar la carne, las arvejas, sazonar a gusto con sal, pimienta y comino."@es .

<http://example.org/recipes/entrada/44/step/e7cdc4fa067e46e98d3fca09398331bd> a schema1:HowToStep ;
    schema1:text "Colocar agua y sal en una paila o sartén profunda y poner a cocinar.Cuando suelte el hervor agregue toda la harina y cocínela hasta que se forme una costra en el fondo y la masa se separe."@es .

<http://example.org/recipes/entrada/44/step/ef4bdfde5f9f4d6cabd9aa310216e727> a schema1:HowToStep ;
    schema1:text "Rellenar y freir en abundante aceite caliente."@es .

<http://example.org/recipes/entrada/45/step/0bf69d2a322b40e0be1c054066d82451> a schema1:HowToStep ;
    schema1:text "Extender la masa finamente con un bolillo y cortar discos de unos 5 centímetros de diámetro."@es .

<http://example.org/recipes/entrada/45/step/1055328b815a49f89c957b5d92290a5c> a schema1:HowToStep ;
    schema1:text "Poner la masa sobre la mesa enharinada y amasar suavemente, si está muy húmeda agregar más harina.Tapar con una servilleta y dejar reposar por 10 minutos."@es .

<http://example.org/recipes/entrada/45/step/27789c8ce0f84a42a6cf03251f6936ce> a schema1:HowToStep ;
    schema1:text "Agregar poco a poco agua fría hasta formar una masa suave."@es .

<http://example.org/recipes/entrada/45/step/9a3ba3cd949743028358097f2008d540> a schema1:HowToStep ;
    schema1:text "Poner en un tazón la harina, sal, polvo de hornear y mantequilla."@es .

<http://example.org/recipes/entrada/45/step/9ff1a83986a648b18ba7db4412ed88e6> a schema1:HowToStep ;
    schema1:text "Mezclar todo hasta que se pierda toda la grasa y quede todo incorporado."@es .

<http://example.org/recipes/entrada/46/step/0f49eb9ed8f54b74b5d464ad4250a955> a schema1:HowToStep ;
    schema1:text "Tomar la masa necesaria para hacer una empanada y extender cuidadosamente sobre la mesa."@es .

<http://example.org/recipes/entrada/46/step/154223f0e9874df78c90404dabd0ee8c> a schema1:HowToStep ;
    schema1:text "Escurrir y moler hasta lograr una masa uniforme."@es .

<http://example.org/recipes/entrada/46/step/27f0481ca7a0434ea48b97869e3bbdb7> a schema1:HowToStep ;
    schema1:text "Repetir el procedimiento hasta terminar la masa y dejar reposar las empanadas por 1 hora."@es .

<http://example.org/recipes/entrada/46/step/5d67b845a24448349b5688de07550ad5> a schema1:HowToStep ;
    schema1:text "Engrasar con manteca la mesa y el bolillo que va a utilizar para extenderla."@es .

<http://example.org/recipes/entrada/46/step/931455851075455a95425c3c317c3bfb> a schema1:HowToStep ;
    schema1:text "Freír en abundante aceite caliente (si gusta puede agregar un poco de achiote al aceite)."@es .

<http://example.org/recipes/entrada/46/step/a789795eb0a14c31b457ea156609d99d> a schema1:HowToStep ;
    schema1:text """Sofría en una sartén el aceite, la cebolla, el cilantro, la sal, la pimienta y el comino.
	Agregar las arvejas, la carne y sofreir.
	Añadir los huevos picados y quedará listo el relleno."""@es .

<http://example.org/recipes/entrada/46/step/b8a8437417664a72b4a6757ad8b92ad0> a schema1:HowToStep ;
    schema1:text "Colocar en el centro una cucharada de relleno, doblar la masa y presionar los bordes con los dientes de un tenedor para que selle debidamente."@es .

<http://example.org/recipes/entrada/46/step/f7c31c91a3834ff39a856617b165f2a1> a schema1:HowToStep ;
    schema1:text "Remojar el morocho en agua fría con 3 días de anterioridad (cambiar el agua diariamente)."@es .

<http://example.org/recipes/entrada/46/step/fc0fe3f869644fe59410b6fa8f9cf2fc> a schema1:HowToStep ;
    schema1:text "Enjuagar el morocho remojado y poner a cocinar hasta que esté suave."@es .

<http://example.org/recipes/entrada/47/step/50bad0ec49df4df2b2105bbe34a9d6c9> a schema1:HowToStep ;
    schema1:text "En una sartén con un poco de aceite de achiote, sofría la cebolla y el pimiento en julianas."@es .

<http://example.org/recipes/entrada/47/step/647264d7b7ba465c9f76400de12a0b84> a schema1:HowToStep ;
    schema1:text "Retire la corteza de los plátanos y cocínelos en agua con un poco de sal hasta que estén blandos. Colar los plátanos y tritúrelos para obtener la masa."@es .

<http://example.org/recipes/entrada/47/step/7eb052fed42a46f5a0327a64d0e31677> a schema1:HowToStep ;
    schema1:text "Sobre un papel plástico untado de aceite, coloque una bola de masa y extiéndala cuidadosamente. Añada una porción del relleno de camarones y doble la empanada de manera que los bordes se unan."@es .

<http://example.org/recipes/entrada/47/step/810cf24e388846709f4f81f3a38c121a> a schema1:HowToStep ;
    schema1:text "Sírvalas calientes. Buen provecho."@es .

<http://example.org/recipes/entrada/47/step/a964baaa333c4bb2a6c82f08c3d9ebe5> a schema1:HowToStep ;
    schema1:text "Añada el ajo machacado, la pasta de maní, perejil, cilantro y los camarones. Sazone con sal, pimienta y una pizca de comino. Sofría por unos 3 minutos hasta que adquiera una textura cremosa. Reserve y deje enfriar."@es .

<http://example.org/recipes/entrada/47/step/cc0c214c438c4afca9a64d455bcde1e4> a schema1:HowToStep ;
    schema1:text "Fría las empanadas en aceite bien caliente hasta que doren."@es .

<http://example.org/recipes/entrada/47/step/f5f758c763af4b2a956a32c7d478bafa> a schema1:HowToStep ;
    schema1:text "Limpie bien los camarones, retirando las cabezas, las conchas y las venas internas. Córtelos en cubos y reserve."@es .

<http://example.org/recipes/entrada/47/step/f9cf793158794fcd982c0d4e2ace0882> a schema1:HowToStep ;
    schema1:text "Espere a que la masa repose y luego incorpore el huevo batido, la mantequilla y una pizca de sal. Amase todos los ingredientes. Forme bolas de masa."@es .

<http://example.org/recipes/entrada/48/step/0616b03a820a4cbca0c5839ff884adfa> a schema1:HowToStep ;
    schema1:text "Lavar y pelar los plátanos verdes. Cortar 3 de los plátanos por la mitad y hervirlos con abundante agua unos 30 minutos hasta que estén suaves. Mantener el plátano pelado restante en un tazón con agua fría."@es .

<http://example.org/recipes/entrada/48/step/13faf5ed171c4e66bf075f54fd1625e0> a schema1:HowToStep ;
    schema1:text "Calentar abundante aceite en una sartén, freír y voltear las empanadas por ambos lados hasta que queden doraditas. Colocarlas sobre papel para quitar cualquier exceso de aceite."@es .

<http://example.org/recipes/entrada/48/step/27b2b187a3c44abe863f144c8af99199> a schema1:HowToStep ;
    schema1:text "Servir las empanadas calientes con ají criollo o ají de tomate de árbol."@es .

<http://example.org/recipes/entrada/48/step/8f7fd3c7a3e248cdbe24ec971f3a74b1> a schema1:HowToStep ;
    schema1:text "Dejar los plátanos hervidos en el agua donde se cocinaron hasta que se enfríen lo suficiente para manipularlos. Rallar el plátano crudo restante usando un rallador fino."@es .

<http://example.org/recipes/entrada/48/step/a9c11779fcc443fc8ecec1930672cbfa> a schema1:HowToStep ;
    schema1:text "Estirar la masa con un rodillo hasta obtener una lámina fina. Utilizar un molde redondo (como un plato o un vaso) para cortar la masa en discos para las empanadas."@es .

<http://example.org/recipes/entrada/48/step/d70878a65900485bb0e643202e1092d4> a schema1:HowToStep ;
    schema1:text "Colocar la masa en un tazón, agregar el plátano crudo finamente rallado y ½ cucharadita de sal. Amasar bien hasta que quede una mezcla suave. Formar la masa en una bola y dejarla reposar en un tazón a temperatura ambiente durante unos 15-30 minutos."@es .

<http://example.org/recipes/entrada/48/step/ddc1051fd03f44009743bd521467385c> a schema1:HowToStep ;
    schema1:text "Colocar los plátanos hervidos en un procesador de alimentos y mezclar hasta que estén molidos y quede una masa gruesa. Añadir el huevo y la mantequilla o el aceite, y mezclar hasta que los ingredientes estén homogéneos y la masa quede más suave. Si no se tiene un procesador de alimentos, triturar los plátanos hervidos y luego mezclarlos con el huevo (ligeramente batido) y la mantequilla."@es .

<http://example.org/recipes/entrada/48/step/e51810e30be74e2797c8e41639fc0e12> a schema1:HowToStep ;
    schema1:text "Mezclar el queso y la cebolla. Colocar una cucharada del relleno de queso en el medio de cada disco, doblar y sellar las empanadas con cuidado. Colocar las empanadas crudas en la refrigeradora durante una hora para que estén mejor selladas."@es .

<http://example.org/recipes/entrada/49/step/4ae23807b1df46d1acfdf212e7bd086a> a schema1:HowToStep ;
    schema1:text "Estirar con palote y cortar formando discos para las empanadas."@es .

<http://example.org/recipes/entrada/49/step/5fe0e48542f345139ad463fd10914aa3> a schema1:HowToStep ;
    schema1:text "Comenzar hirviendo tres de los plátanos hasta tiernizarlos. Conservar el cuarto plátano en agua."@es .

<http://example.org/recipes/entrada/49/step/695f5788c58d42a9b313b4f3c30f5f33> a schema1:HowToStep ;
    schema1:text "Servir calientes."@es .

<http://example.org/recipes/entrada/49/step/76c7441c75a5453d89db8f57357e2261> a schema1:HowToStep ;
    schema1:text "Procesar los plátanos hervidos hasta lograr una pasta homogénea y añadir el huevo y la mantequilla y procesar nuevamente. Agregar sal."@es .

<http://example.org/recipes/entrada/49/step/7be9b74fe9a6406695d3e4b03c7ec566> a schema1:HowToStep ;
    schema1:text "Tomar la masa formada y rallarle el plátano crudo, dejar reposar por media hora."@es .

<http://example.org/recipes/entrada/49/step/8ac3b557d6864e769a16765e8abadd94> a schema1:HowToStep ;
    schema1:text "Colocar en un recipiente el queso y la cebolla mezclar y agregar una cucharada del relleno en cada disco, cerrar y dejar descansar en heladera."@es .

<http://example.org/recipes/entrada/49/step/a529a78b778340c18c50198ef65093a3> a schema1:HowToStep ;
    schema1:text "En una sartén, calentar el aceite a fuego medio, freír las empanadas por ambos lados hasta que se doren, secar en papel absorbente."@es .

<http://example.org/recipes/entrada/5/step/5a73c0128ed1457b8edae130295ed1dd> a schema1:HowToStep ;
    schema1:text "Para preparar la salsa huacatay, coloque un sartén con un poco de aceite y sofreír la cebolla cortada en cuadros con los ajíes amarillos. Añada un poco de ajo, el maní y las hojas de huacatay."@es .

<http://example.org/recipes/entrada/5/step/5a94398f6f1849c68d8fee7cb65ab421> a schema1:HowToStep ;
    schema1:text "Sirva las alitas de pollo acompañadas de la salsa y lechuga."@es .

<http://example.org/recipes/entrada/5/step/5b7e3ff036c14389ace8b40fc270b15f> a schema1:HowToStep ;
    schema1:text "Mezclar todo muy bien y tapar el bol con papel film. Macerar en el refrigerador por unas dos horas."@es .

<http://example.org/recipes/entrada/5/step/62c48777fb824c7e8c98328dc88788c1> a schema1:HowToStep ;
    schema1:text "Coloque en la licuadora el sofrito, el queso fresco, las galletas y una pizca de sal y pimienta. Licuar con un poco de caldo de pollo hasta obtener una mezcla ligeramente espesa."@es .

<http://example.org/recipes/entrada/5/step/89c6ebdc21a049b286fa5d81723c3518> a schema1:HowToStep ;
    schema1:text "Cortar las puntas a las alitas de pollo. Lavarlas bien."@es .

<http://example.org/recipes/entrada/5/step/a4534e3893e141169a43155d29c8e7ac> a schema1:HowToStep ;
    schema1:text "En un bol, colocar las alitas de pollo junto con el ajo machacado, orégano, romero, culantro, el vinagre y la pasta de tomate. Sazone con sal, pimienta y comino."@es .

<http://example.org/recipes/entrada/5/step/f8ee75f589794cb78c2347fde62ebc83> a schema1:HowToStep ;
    schema1:text "Pasar las alitas por harina de trigo y freírlas en aceite bien caliente."@es .

<http://example.org/recipes/entrada/50/step/151cc6a6072f4bf3b5fe8b00460ba812> a schema1:HowToStep ;
    schema1:text "Rellenar los discos con queso rallado."@es .

<http://example.org/recipes/entrada/50/step/3296c94c87eb429d881d94772fd666d7> a schema1:HowToStep ;
    schema1:text "Colocar en papel de cocina y servir."@es .

<http://example.org/recipes/entrada/50/step/3ba838cb8f834637b60440807afe0281> a schema1:HowToStep ;
    schema1:text "Freír en aceite caliente, retirar y espolvorear con azúcar."@es .

<http://example.org/recipes/entrada/50/step/77135ef749d440f1ac5866df79b04bea> a schema1:HowToStep ;
    schema1:text "Añadir de a poco el agua y la mantequilla en cubos hasta formar una masa suave al tacto."@es .

<http://example.org/recipes/entrada/50/step/a4152327534048b2a7ff62fa15fd502d> a schema1:HowToStep ;
    schema1:text "Comenzar la preparación mezclando la harina, el azúcar, la sal y el polvo de hornear en un recipiente."@es .

<http://example.org/recipes/entrada/50/step/ac94c1f227f44382a350a1bbe3f480f8> a schema1:HowToStep ;
    schema1:text "Dejar descansar por 20 minutos."@es .

<http://example.org/recipes/entrada/50/step/cbd01aac8300496994b3c9a23a1f27cd> a schema1:HowToStep ;
    schema1:text "Formar bollitos y extenderlos con palote para que se forme un disco."@es .

<http://example.org/recipes/entrada/51/step/04aef50102194c4b8907968b39c3e0d5> a schema1:HowToStep ;
    schema1:text "Colocar en una ensaladera la lechuga, el pollo y vierta sobre ellos la salsa."@es .

<http://example.org/recipes/entrada/51/step/774e195fef5e4342ac0cc9d2a1fab032> a schema1:HowToStep ;
    schema1:text "Licuar las yemas de huevo, el ajo, la mostaza, el jugo de limón, la salsa inglesa, el aceite de oliva, la sal y la pimienta hasta formar una salsa homogénea y espesa."@es .

<http://example.org/recipes/entrada/51/step/87a777b91fed485fb09be28b43c4c6b1> a schema1:HowToStep ;
    schema1:text "Untar un poco de mantequilla sobre los panes y córtelos en cubos de aproximadamente 2 centímetro por lado y coloque al horno por diez minutos a 180°C o hasta que estén dorados."@es .

<http://example.org/recipes/entrada/51/step/d98749c243504efcb711c6c4460b6fe6> a schema1:HowToStep ;
    schema1:text "Retirar y dejar reposar en la refrigeradora hasta el momento de servir."@es .

<http://example.org/recipes/entrada/51/step/e6eac8cb25044cccae69a475e317080f> a schema1:HowToStep ;
    schema1:text "Cortar la pechuga de pollo en cuadrados. Dorar en un sartén a fuego fuerte con un poco de aceite de oliva y condimentadas con sal y pimienta."@es .

<http://example.org/recipes/entrada/52/step/612ef2f503b744e9af9b36b2ddf23eac> a schema1:HowToStep ;
    schema1:text "Disfrute."@es .

<http://example.org/recipes/entrada/52/step/956b472bf1eb421e87f6fff65189cc03> a schema1:HowToStep ;
    schema1:text "Mantenga refrigerada hasta servir."@es .

<http://example.org/recipes/entrada/52/step/97a4c082dc1e4b07ac35ce2c60257e97> a schema1:HowToStep ;
    schema1:text "Mezcle los ingredientes. Añada el aceite, sal y el jugo de limón."@es .

<http://example.org/recipes/entrada/52/step/a028ee9c96db4d72bdfdac3987e980e8> a schema1:HowToStep ;
    schema1:text "En un bol, agregue el atún desmenuzado, los tomates, la cebolla y el culantro picadito."@es .

<http://example.org/recipes/entrada/52/step/d6f9dc3b51b04310ac78b12369b67822> a schema1:HowToStep ;
    schema1:text "Sírvala como relleno de sandwich, o encima de patacones y galletas saladas."@es .

<http://example.org/recipes/entrada/53/step/220f15c8421f491499124c80ea7a3844> a schema1:HowToStep ;
    schema1:text "Cocinar los camarones en agua con sal y limón por unos 50 segundos."@es .

<http://example.org/recipes/entrada/53/step/3534ecd4587b46b381b71f4d4024868d> a schema1:HowToStep ;
    schema1:text "Trocear el apio y picar el cebollino. Picar el pimiento rojo en dados pequeños."@es .

<http://example.org/recipes/entrada/53/step/83bd188bc4314dae994922a891f48e89> a schema1:HowToStep ;
    schema1:text "Servir sobre hojas de lechuga escarola."@es .

<http://example.org/recipes/entrada/53/step/ce28b6af51104073b7b43cfadd11eae3> a schema1:HowToStep ;
    schema1:text "Cortar las manzanas en cubos y bañarlas con zumo de limón."@es .

<http://example.org/recipes/entrada/53/step/e1d3c91038f24f3c9b934de5322fbb9a> a schema1:HowToStep ;
    schema1:text "Disponre en una ensaladera las manzanas, el camarón, el apio y los pimientos. Aderezar con la mayonesa, el perejil, el cebollino y sazonar con sal y pimienta."@es .

<http://example.org/recipes/entrada/53/step/e6dddbb95c054f08bc1baf74311e0310> a schema1:HowToStep ;
    schema1:text "Pelar las manzanas, retirarle el corazón, cortarlas en medias lunas finas"@es .

<http://example.org/recipes/entrada/54/step/304d8d71a6b14451bf590ca5a1c7a06a> a schema1:HowToStep ;
    schema1:text "En un bol agregar la cebolla morada, aceite de oliva y el zumo de limón. Mezclar bien todos los ingredientes. Sazonar con sal y pimienta. Reservar."@es .

<http://example.org/recipes/entrada/54/step/305d00f8e93248d38b941ef7eef0e142> a schema1:HowToStep ;
    schema1:text "Incorporar el tomate y la cebolla blanca picados en cuadros pequeños."@es .

<http://example.org/recipes/entrada/54/step/493efd460f20467594b9b014807d117f> a schema1:HowToStep ;
    schema1:text "Servir decorado con las tenazas de cangrejo."@es .

<http://example.org/recipes/entrada/54/step/a1510855695844428dff267d7a073cbe> a schema1:HowToStep ;
    schema1:text "Lavar bien los cangrejos y colocarlos en una olla con suficiente agua. Llevar al fuego alto y dejar hervir por unos 10 minutos. Una vez cocidos, retirar del fuego y dejar enfriar."@es .

<http://example.org/recipes/entrada/54/step/ae4fc61309a24c2bb000ea117b4117e1> a schema1:HowToStep ;
    schema1:text "Mezclar bien todos los ingredientes. Rectificar el sabor."@es .

<http://example.org/recipes/entrada/54/step/d506e37e91b04536b6a4b8f4c8eb9170> a schema1:HowToStep ;
    schema1:text "Pelar las papas y cortarlas en cubos. Luego cocinarlas en agua y un poco de sal por unos 20 minutos."@es .

<http://example.org/recipes/entrada/54/step/d80d109461af49d19c61cbd0846b1ce9> a schema1:HowToStep ;
    schema1:text "Cuando los cangrejos estén fríos, retirar la carne del caparazón y reservar las tenazas."@es .

<http://example.org/recipes/entrada/54/step/df06ea983d7647c3afc37725accc90aa> a schema1:HowToStep ;
    schema1:text "En un bol agregar la carne de cangrejo, las patatas y el encurtido de cebollas moradas. Mezclar bien."@es .

<http://example.org/recipes/entrada/55/step/2a41d3f2405c4375a31729eb537e3e81> a schema1:HowToStep ;
    schema1:text "Luego preparamos el aderezo con 1 taza de miel, 2 cucharadas de mostaza, un toque de sal, revolvemos y agregamos un toque de aceite de oliva."@es .

<http://example.org/recipes/entrada/55/step/dce47c37f92744b5a733ec12d1f44318> a schema1:HowToStep ;
    schema1:text "En un envase colocamos el cuscus con el doble de agua, dejamos reposar por 15 minutos."@es .

<http://example.org/recipes/entrada/55/step/ded4f916806543a7a87488f42296c6c8> a schema1:HowToStep ;
    schema1:text "Listo para servir y disfrutar."@es .

<http://example.org/recipes/entrada/55/step/eaf941855f6140e798e230c9bd732e99> a schema1:HowToStep ;
    schema1:text "Luego de esto agregamos el aderezo a la mezcla de ingredientes picados y luego el cuscus y mezclamos todo."@es .

<http://example.org/recipes/entrada/55/step/ecbcbca6986d48feb7fe1ce689194950> a schema1:HowToStep ;
    schema1:text "Mientras agarramos un zapallo y lo picamos en cuadritos, luego un pimiento verde en trocitos, perejil fresco, 1 tomate en cuadritos, 1 aguacate en cuadritos."@es .

<http://example.org/recipes/entrada/56/step/5d7d663ebe6f42088b3bc7993cc398e7> a schema1:HowToStep ;
    schema1:text "Rociar la ensalada con el aderezo y mezclar bien todo. Servir inmediatamente."@es .

<http://example.org/recipes/entrada/56/step/859abd3a8d7a4178b053fe82c95d431a> a schema1:HowToStep ;
    schema1:text "Poner las hojas de lechuga, las rodajas de tomate, la cebolla, el pepino, los palmitos, el aguacate y las aceitunas en una ensaladera."@es .

<http://example.org/recipes/entrada/56/step/f5841feceda040319e2a0261048af5af> a schema1:HowToStep ;
    schema1:text "Combinar bien hasta obtener un aderezo cremoso, probar y ajustar los ingredientes al gusto."@es .

<http://example.org/recipes/entrada/56/step/f9e2fda5179d4c1f98cb3b83c2e687b9> a schema1:HowToStep ;
    schema1:text "Mezclar bien el vinagre, el jugo de limón, el aceite o la mayonesa, sal y pimienta."@es .

<http://example.org/recipes/entrada/57/step/38f926f01e0347d18bfc42acb02de044> a schema1:HowToStep ;
    schema1:text "Primero preparamos los vegetales. Comenzamos quitando la piel al pepino y lo cortamos en medias lunas, tambien se puede quitar las semillas."@es .

<http://example.org/recipes/entrada/57/step/710c4ffc43b3422d96f05cc707ed5850> a schema1:HowToStep ;
    schema1:text "Podemos servir y disfrutar."@es .

<http://example.org/recipes/entrada/57/step/9f01ee6cf20548628241de7b8c240e05> a schema1:HowToStep ;
    schema1:text "Seguido de esto en un envase mezclamos todo junto con cilantrio picado. Luego sasonamos con jjugo de limón, sal , pimienta, aceite de oliva y oregano."@es .

<http://example.org/recipes/entrada/57/step/ee7d8ccf705a4935afd469f9ae295cfc> a schema1:HowToStep ;
    schema1:text "Luego los tomates los picamos en cuadritos. El rabano en rodajas no muy gruesas ni muy medianas y las cebollas en rodajitas."@es .

<http://example.org/recipes/entrada/57/step/f4c2376926e2472c8df9961a87eeaaff> a schema1:HowToStep ;
    schema1:text "Metemos al refrigerador por media hora. Y al final agregarlmos el aguacate en trocitos."@es .

<http://example.org/recipes/entrada/58/step/530013b26ee14fa4961df9aa7d9e2e44> a schema1:HowToStep ;
    schema1:text "Luego en una paila colocamos la carne y grasa .luego añadiremos agua para cubrirlo completamente. Adicionamos cebolla blanca y tallo de cilantro hasta que se ablande. Una vez que se evapore el agua la grasa se derritira y esta hara algo crocante. Movemos y nuestro cerdo quedara crocante"@es .

<http://example.org/recipes/entrada/58/step/539962a2319a462eb447e4828a52d134> a schema1:HowToStep ;
    schema1:text "Luego a estos trozos le agregaremos pasta de ajo y pimienta. Seguido agregaremos un poco de comino y mezclamos todo muy bien."@es .

<http://example.org/recipes/entrada/58/step/59fdce1db00948748007ec87423d148e> a schema1:HowToStep ;
    schema1:text "Aparte preparamos una salsa criolla con cebolla, limón, tomate, cilantro, sal y pimienta. Mezclamos todo muy bien y servimos."@es .

<http://example.org/recipes/entrada/58/step/8abdb6854df44bccbf172b8975a1eb65> a schema1:HowToStep ;
    schema1:text "En el mismo aceite que preparamos el cerdo hacemos los chifles con los que acompañaremos la fritada."@es .

<http://example.org/recipes/entrada/58/step/a62f1c3e19a748d19bfe169ac7c5556d> a schema1:HowToStep ;
    schema1:text "Una vez listo agregamos un poco de cerveza y mezclamos muy bien. Sazonada la carne la dejamos reposar unos 30 minutos."@es .

<http://example.org/recipes/entrada/58/step/e86f5bc5db084e35a11189f83245d478> a schema1:HowToStep ;
    schema1:text "Primero cortaremos la carne de cerdo y la grasa de cerdo en trozos pequeños y lo colocamos en una bandeja."@es .

<http://example.org/recipes/entrada/59/step/065beb42dcba4b0eb00c768b05cb6a22> a schema1:HowToStep ;
    schema1:text "Cocinar 2 huevos."@es .

<http://example.org/recipes/entrada/59/step/0ee9a49b8b5e42ed8b8ed04aa0a327b3> a schema1:HowToStep ;
    schema1:text "Cocinar la gallina agregando aliño de cebolla y de ajo. Cuando este lista dejar enfriar y desmenuzar."@es .

<http://example.org/recipes/entrada/59/step/449a2447dcf740279bd3ab619544d74e> a schema1:HowToStep ;
    schema1:text "Incorporar la harina de maíz previamente cernida (remover y batir constantemente para que no se formen grumos) y con una espátula y en forma envolvente las claras batidas a punto de nieve, sazone con sal y pimienta."@es .

<http://example.org/recipes/entrada/59/step/67ab1c8b5a3445d1872434e5b985da74> a schema1:HowToStep ;
    schema1:text "Batir en un tazón la mantequilla y la manteca junto con 6 yemas de huevo, batiendo muy bien luego de cada adición."@es .

<http://example.org/recipes/entrada/59/step/b161875b23254a0594773d80b4c7e771> a schema1:HowToStep ;
    schema1:text "Envolver la hoja, de la misma forma que se envuelve un regalo, y se amarra con el hilo."@es .

<http://example.org/recipes/entrada/59/step/c50139c0eceb4fbc8e6d086200a167f1> a schema1:HowToStep ;
    schema1:text "Colocar una cucharada grande de la masa en el centro del rectángulo de la hoja de plátano."@es .

<http://example.org/recipes/entrada/59/step/eb7dde3f788a4d09891c43493da527a8> a schema1:HowToStep ;
    schema1:text "Cocinar al vapor durante 45 minutos o hasta que la masa este firme"@es .

<http://example.org/recipes/entrada/59/step/f75f64a7a87f4398b76883df01a9ba2c> a schema1:HowToStep ;
    schema1:text "Hacer un hoyo en el centro de la masa, agregar los pedazs de gallina, tiras de pimiento verde y rojo, el huevo duro, y pasas."@es .

<http://example.org/recipes/entrada/6/step/0f44675ce5e54703a07fd87957449137> a schema1:HowToStep ;
    schema1:text "Luego agregamos el achiote y revolvemos nuevamente y lo tapamos. Cocinamos a fuego medio. Pasado 15 minutos le colocamos una hojita de oregano y dejamos cocinar 5 minutos mas"@es .

<http://example.org/recipes/entrada/6/step/13f880b08f484e96a620da5dfa5c70db> a schema1:HowToStep ;
    schema1:text "Primero freimos unas papas fritas"@es .

<http://example.org/recipes/entrada/6/step/149ea7a745ae4c259874210b9015d597> a schema1:HowToStep ;
    schema1:text "Pasado unos minutos esta listo para disfrutar y servir."@es .

<http://example.org/recipes/entrada/6/step/a5ee64156b61418ebdaa6fe14de6dc19> a schema1:HowToStep ;
    schema1:text "Luego agregamos las papas nuevamente al sarten y revolvemos."@es .

<http://example.org/recipes/entrada/6/step/d1394c59dcb44c6f8835a810f5ffe712> a schema1:HowToStep ;
    schema1:text "Luego en el mismo aceite comenzaremos colocando la carne y el cerdo en un sarten con aceite. Seguido de eso agregamos tomate, cebolla, pimiento, ajo, pimienta, sal comino y yerbita. Lo revolvemos todo muy bien ."@es .

<http://example.org/recipes/entrada/60/step/2e0f26293491452d823d286792a17840> a schema1:HowToStep ;
    schema1:text "Servir las humitas calientes acompañadas de ají de tomate de árbol y una taza de café."@es .

<http://example.org/recipes/entrada/60/step/3b08007e04b941c582083d3a5088cb74> a schema1:HowToStep ;
    schema1:text "En una olla, colocar 2½ tazas de agua y la vaporera, el nivel de agua debe estar justo debajo de la parte superior de la vaporera. Si no se tiene una vaporera, colocar las mazorcas peladas y algunas hojas de choclo en el fondo de la olla, igual el nivel de agua debe llegar justo a la parte superior de las mazorcas peladas pero sin cubrirlas completamente."@es .

<http://example.org/recipes/entrada/60/step/3c14cfa827b54188bfc8e60bd1464339> a schema1:HowToStep ;
    schema1:text "Limpiar bien los choclos pelados y desgranarlos. Si no se tiene una vaporera para cocinar las humitas, guardar las mazorcas peladas para hacer una vaporera."@es .

<http://example.org/recipes/entrada/60/step/6c99495c689c40d78e3d9d270fe0af4d> a schema1:HowToStep ;
    schema1:text "Colocar los granos de choclo en el procesador de alimentos con el queso, la cebolla, el ajo, el cilantro, la crema, los huevos y la sal. Triturar todos los ingredientes hasta obtener un puré."@es .

<http://example.org/recipes/entrada/60/step/7d95bc22cb574150b0a2194c36f97568> a schema1:HowToStep ;
    schema1:text "Pelar los choclos y sacar las hojas. Colocar las hojas en agua hirviendo durante un par de minutos, colarlas y guardarlas hasta el momento de envolver las humitas."@es .

<http://example.org/recipes/entrada/60/step/acfebeb1c6a4427abee26895378520c9> a schema1:HowToStep ;
    schema1:text "Usar 2 hojas de buen tamaño para cada humita, colocar las hojas una encima de otra, doblar el costado y luego doblar la punta creando un pequeño bolsillo. Rellenar las hojas con una buena cucharada de la mezcla de choclo, colocar un poco de queso en el centro y luego doblar el otro costado de las hojas. Use las tiras de las hojas pequeñas para amarrar las humitas."@es .

<http://example.org/recipes/entrada/60/step/f83e62bb091b49b9ba60cf53f7bb318d> a schema1:HowToStep ;
    schema1:text "Colocar cada humita de forma un poco inclinada en la olla y si tienen alguna apertura colocarlas con esa parte hacia arriba. Cubrir las humitas con las hojas que sobren y tapar bien la olla. Cocinar a fuego alto hasta que el agua comience a hervir, bajar la temperatura y cocinar a vapor durante 35 a 40 minutos."@es .

<http://example.org/recipes/entrada/61/step/07e0f7cd496445cb957aa8dbdc81baf6> a schema1:HowToStep ;
    schema1:text "Pasado el tiempo estan listos para disfrutar."@es .

<http://example.org/recipes/entrada/61/step/0ea5056250d34d0cbd52def81376b11b> a schema1:HowToStep ;
    schema1:text "Una vez listo, le agregamos la mezcla de margarina, la cebolla, sal al gusto y azúcar. Mezclamos todo muy bien si esta dura se le puede agregar un poquito de leche."@es .

<http://example.org/recipes/entrada/61/step/12695dc804364e0185a7d75a8c846865> a schema1:HowToStep ;
    schema1:text "Una vez lista agregamos un poquito de la mezcla en la hoja y dentro le colocamos un poquito de la mezcla de queso y envolvemos la humita y colocamos como por 45 minutos."@es .

<http://example.org/recipes/entrada/61/step/1f0d0e31b0d34052aef3da24bdfc8a59> a schema1:HowToStep ;
    schema1:text "Primero picamos finamente la cebolla. Luego en un sarten caliente agregamos la margarina y esperamos que se derrita, una vez lista freimos la cebolla blanca."@es .

<http://example.org/recipes/entrada/61/step/3c2e9ecbb4a9492c8e7de0dc0a7910cc> a schema1:HowToStep ;
    schema1:text "Luego esta mezcla de sarten la dividimos en dos partes y colocamos una en cada envase."@es .

<http://example.org/recipes/entrada/61/step/9ebcad6a2da4404aa28c119bc4acbcad> a schema1:HowToStep ;
    schema1:text "En una de ellas le colocaremos un punto de color con achiote y ½ taza de queso."@es .

<http://example.org/recipes/entrada/61/step/bac16f33675d4558ab80c59eadb1424d> a schema1:HowToStep ;
    schema1:text "Luego retiramos las hoja del choclo y la reservamos para utilizarlas después para hacer la humita. Desgranamos el choclo y molemos los granos, luego le agregamos un huevo batido a esta mezcla."@es .

<http://example.org/recipes/entrada/62/step/0a76af38f3034a9482137dcc40f2c2a1> a schema1:HowToStep ;
    schema1:text "Triturar todos los ingredientes hasta obtener un puré."@es .

<http://example.org/recipes/entrada/62/step/2646e6de9e0d4c158d571d97de31218c> a schema1:HowToStep ;
    schema1:text "Servir las humitas calientes con un café negro."@es .

<http://example.org/recipes/entrada/62/step/4005fb73282d4e34ac338406362fa234> a schema1:HowToStep ;
    schema1:text "Desgranar los choclos y colocarlos en la procesadora junto con los demás ingredientes."@es .

<http://example.org/recipes/entrada/62/step/8a639043d7e644df8f559fea31c4ae2e> a schema1:HowToStep ;
    schema1:text "Colocar en una cacerola medio litro de agua y una vaporera."@es .

<http://example.org/recipes/entrada/62/step/ae1c8e542f9d435eb13b96dc249cc1b7> a schema1:HowToStep ;
    schema1:text "Usar 2 hojas de choclo para armar cada humita, ponerlas en forma de cruz, rellenar con una cucharada de la mezcla y cerrar. Amarrar con tiras finas."@es .

<http://example.org/recipes/entrada/62/step/c8e1ff71910e4c83a426070c9a16fdb5> a schema1:HowToStep ;
    schema1:text "Limpiar los choclos y reservar las hojas lavadas y hervidas para la decoración."@es .

<http://example.org/recipes/entrada/62/step/cb6392245bd0404dbbde137199c160c1> a schema1:HowToStep ;
    schema1:text "Tomar las humitas y colocarlas en la olla, cocinar a fuego alto hasta hervir, bajar la temperatura y cocinar a vapor por 40 minutos."@es .

<http://example.org/recipes/entrada/63/step/176ffa29e080493b9271ba8c2cff5682> a schema1:HowToStep ;
    schema1:text "Colar la preparación para retirar semillas y restos de cascara que hayan quedado y volver a licuar a velocidad máxima y con el hielo picado por 2 minutos más."@es .

<http://example.org/recipes/entrada/63/step/da00b9ba6ce744b6b7ad5256a8c03700> a schema1:HowToStep ;
    schema1:text "Servir en vaso de coctel."@es .

<http://example.org/recipes/entrada/63/step/dbf4a0382e364e6db6cba7eb8831b9f2> a schema1:HowToStep ;
    schema1:text "Comenzar por cortar las guayabas peladas en trozos pequeños."@es .

<http://example.org/recipes/entrada/63/step/fc220191224945ac908adaf7abaa3b38> a schema1:HowToStep ;
    schema1:text "Licuar la fruta junto con la leche y el azúcar a velocidad baja por 4 minutos."@es .

<http://example.org/recipes/entrada/64/step/1687d3de10ed4ef7a0f173dfc48a2333> a schema1:HowToStep ;
    schema1:text "Cocinar en planchuela hasta dorar de ambos lados."@es .

<http://example.org/recipes/entrada/64/step/4bd9e2c444ae4f6dbb56a0b5ef811b39> a schema1:HowToStep ;
    schema1:text "Realizar un sofrito con la cebolla y el achiote. Una vez que este dorado incluir el puré y mezclar. Dejar reposando por una hora."@es .

<http://example.org/recipes/entrada/64/step/6a0cc774a82e40a58d758d62d4ec4394> a schema1:HowToStep ;
    schema1:text "Comenzar la receta hirviendo las papas en agua con sal hasta que estén tiernas, realizar con ellas un puré."@es .

<http://example.org/recipes/entrada/64/step/f1644814abd04aca83ff5d48edbb0cd7> a schema1:HowToStep ;
    schema1:text "Con la masa formar pequeñas bolitas, rellenar de queso rallado y cerrar."@es .

<http://example.org/recipes/entrada/64/step/fc48d94f0bfc48f2b9af3c1c3a5fb9df> a schema1:HowToStep ;
    schema1:text "Servir calientes con huevos fritos."@es .

<http://example.org/recipes/entrada/65/step/176adede1bd94d8997573dc470265afa> a schema1:HowToStep ;
    schema1:text "Cocinar las tortillas en una parrilla plana o una sartén caliente hasta que estén doradas por ambos lados. Servir los llapingachos con huevo frito o salsa de maní o de aguacate o chorizo o ají criollo."@es .

<http://example.org/recipes/entrada/65/step/9bb49c721115427d95eeb49faf4e77ba> a schema1:HowToStep ;
    schema1:text "Calentar el aceite a temperatura media y sofreír la cebolla y el achiote. Agregar el refrito de cebolla y sal al gusto al puré de papas y mezclar bien. Cubrir la mezcla y dejar reposar a temperatura ambiente durante una hora."@es .

<http://example.org/recipes/entrada/65/step/b15d4264ab074a298546a1142edfed71> a schema1:HowToStep ;
    schema1:text "Formar bolas pequeñas con la mezcla de papas, hacer un agujero en la mitad de cada bola y rellenarlas con el queso. Aplastar las bolas hasta que tengan forma de tortillas gruesas y dejarlas reposar en la refrigeradora durante 30 minutos o hasta que la hora de cocinarlas."@es .

<http://example.org/recipes/entrada/65/step/e6376a56053f428582463c0abba8c6ef> a schema1:HowToStep ;
    schema1:text "Hervir las papas con agua y sal hasta que estén suaves. Hacer un puré con las papas."@es .

<http://example.org/recipes/entrada/66/step/0c52fa2842254e688d9529684aad8e2e> a schema1:HowToStep ;
    schema1:text "Ubicar los longuitos en una olla cocinando a vapor durante 45 minutos."@es .

<http://example.org/recipes/entrada/66/step/0d7983e05da04685b0acaf3618a4675e> a schema1:HowToStep ;
    schema1:text "Realizar el refrito con la mantequilla, el pimiento, la cebolla blanca, el cilantro picado, ají y los dientes de ajo."@es .

<http://example.org/recipes/entrada/66/step/0e7aab8e774a4122a2a725791f5107c4> a schema1:HowToStep ;
    schema1:text "Ubicar una olla con agua a fuego lento y calentarla bien."@es .

<http://example.org/recipes/entrada/66/step/575a6125287f47519ba9591dc18d8c32> a schema1:HowToStep ;
    schema1:text "Licuar el choclo con la leche, la maicena y la sal."@es .

<http://example.org/recipes/entrada/66/step/8928e22021324fc6b64ee45ace1814df> a schema1:HowToStep ;
    schema1:text "Colocar las hojas de col al agua caliente sumergiéndolas hasta que se encuentre suaves."@es .

<http://example.org/recipes/entrada/66/step/9fd77f53acce4c63a69e8b4606dcd7e4> a schema1:HowToStep ;
    schema1:text "Mezclar el resultado del refrito una vez que esté un poco frío el preparado del choclo, revolver hasta que todo se encuentre incorporado."@es .

<http://example.org/recipes/entrada/66/step/bbd4b9a0f84f4ce4a0c873c408a69bd0> a schema1:HowToStep ;
    schema1:text "Escurrir las hojas y sacar las venas que se encuentran al centro, en el resultado de la hoja ubique 2 cucharadas de la masa obtenida y envuelva formando un cuadrado."@es .

<http://example.org/recipes/entrada/66/step/bc261ec5fe2b4c33a10940943a304d6c> a schema1:HowToStep ;
    schema1:text "Cernir en un colador no muy fino y ubicarlo en un recipiente."@es .

<http://example.org/recipes/entrada/66/step/d3facbf3373a4702b80cbfb1d85a41c2> a schema1:HowToStep ;
    schema1:text "Servir los longuitos calientes con ají."@es .

<http://example.org/recipes/entrada/67/step/1668171c81174bf99b91998c037c8aa6> a schema1:HowToStep ;
    schema1:text "Servir y disfrutar caliente."@es .

<http://example.org/recipes/entrada/67/step/204bef3de2cd4e0aada470d3f1b01bbe> a schema1:HowToStep ;
    schema1:text "Horneamos por 35 minutos hasta que se derrita el queso. Al salir podemos colocar un poco mas de mantequilla."@es .

<http://example.org/recipes/entrada/67/step/6b78274c73f74a6bb960bea49f8580fb> a schema1:HowToStep ;
    schema1:text "Luego en un sarten grande colocamos un poquito de aceite y un poquito de mantequilla. Colocamos los platanos de 2 a 3 minutos hasta que estén dorados. Dejamos enfriar y con un cuchillo los cortamos por encima y rellenamos con queso."@es .

<http://example.org/recipes/entrada/67/step/b12dcb0fd7974d96a478563d19e9fdea> a schema1:HowToStep ;
    schema1:text "Primero pelamos los platanos y les quitamos las onchas."@es .

<http://example.org/recipes/entrada/68/step/0ce28189eb2e41d08072785460d74949> a schema1:HowToStep ;
    schema1:text "Retirar los aborrajados y colocarlos sobre papel absorbente para extraer el exceso de aceite. Servir caliente."@es .

<http://example.org/recipes/entrada/68/step/0fd27260a05a4fa58a8860f493b4bb05> a schema1:HowToStep ;
    schema1:text "Freír en aceite caliente, pinchar con un tenedor para que también se cocinen por dentro."@es .

<http://example.org/recipes/entrada/68/step/107d7fa752d6445385c640aa47fe0312> a schema1:HowToStep ;
    schema1:text "Retirar del fuego los plátanos y dejarlos enfriar. Luego rellenar el corte con las tiras de queso y reservar."@es .

<http://example.org/recipes/entrada/68/step/5cc69e6913fd4594b35d72919cd27d2e> a schema1:HowToStep ;
    schema1:text "Batir en un recipiente la leche, la sal y el polvo de hornear, agregar los huevos, adicionar la harina, y mezclar muy bien hasta obtener una masa homogénea."@es .

<http://example.org/recipes/entrada/68/step/a97a8885982949109e1c68666246261a> a schema1:HowToStep ;
    schema1:text "Cortar los plátanos a lo largo, sin que se separen por completo, dorarlos en una sartén con aceite."@es .

<http://example.org/recipes/entrada/68/step/c1ad8f366d1e48029e01e584c9d7eaf4> a schema1:HowToStep ;
    schema1:text "Introducir los plátanos en la masa y cubrirlos completamente."@es .

<http://example.org/recipes/entrada/68/step/ea2bee4598a94e6793b07818e0bb8e75> a schema1:HowToStep ;
    schema1:text "Sernir la harina."@es .

<http://example.org/recipes/entrada/69/step/007d233989aa40d9836c13ce0b673056> a schema1:HowToStep ;
    schema1:text "Tomar porciones de masa de yuca y agregar una cucharada de la carne, dar forma ovalada y freír hasta dorar."@es .

<http://example.org/recipes/entrada/69/step/05af20f868234e079c7487278c827e4b> a schema1:HowToStep ;
    schema1:text "En un recipiente rallar la yuca y añadirle 2 yemas, achiote y sal y dejar reposar la masa."@es .

<http://example.org/recipes/entrada/69/step/bfc66818b0a44784b684a6228dd9fbe7> a schema1:HowToStep ;
    schema1:text "Sofreír la cebolla con el perejil y cuando este dorada agregar la carne y el comino, cuando este tibio agregar el huevo cocido y salpimentar."@es .

<http://example.org/recipes/entrada/69/step/e088a40501054a01bfcabc7cc641e268> a schema1:HowToStep ;
    schema1:text "Servir calientes."@es .

<http://example.org/recipes/entrada/7/step/02489070971c4671bce58c23391b26bf> a schema1:HowToStep ;
    schema1:text "Servir en un plato los bolones calientes, preferiblemente acompañado de café y huevo frito."@es .

<http://example.org/recipes/entrada/7/step/c03b925483ff4da4a3d80cd2bec990f5> a schema1:HowToStep ;
    schema1:text "Calentar el aceite a fuego alto, agregar las bolas de plátano rellenas y freírlas hasta que estén doradas y crujientes por ambos lados."@es .

<http://example.org/recipes/entrada/7/step/d95e2b9e84e5405da7816f91c33696dc> a schema1:HowToStep ;
    schema1:text "Formar bolas pequeñas con la masa. Hacer un agujero en el centro de cada bola y rellenarlos con el queso (o chorizo o chicharrones). Cerrar la bola nuevamente."@es .

<http://example.org/recipes/entrada/7/step/dad7d52c65e6466e8c46582934141a98> a schema1:HowToStep ;
    schema1:text "Pelar los plátanos, cortarlos en trozos medianos y cocinarlos a temperatura media baja durante unos 30-40 minutos, volteándolos cada 10 minutos, hasta que estén muy suaves y ligeramente dorados."@es .

<http://example.org/recipes/entrada/7/step/f0f99776ee924c8ea6fa43fd647c8436> a schema1:HowToStep ;
    schema1:text "Espolvorear los trozos de plátanos cocidos con ají en polvo, el comino, y sal al gusto. Colocar los plátanos calientes en un tazón grande y triturarlos hasta obtener una masa gruesa."@es .

<http://example.org/recipes/entrada/70/step/0fb0daf470414006909ff68ca8785a6c> a schema1:HowToStep ;
    schema1:text "Dar forma ovalada a la masa rellena y freir con aceite vegetal."@es .

<http://example.org/recipes/entrada/70/step/22eb150f711242a488283fb86227b3ea> a schema1:HowToStep ;
    schema1:text "Hacer un refrito con la cebolla, el perejil y el cilantro."@es .

<http://example.org/recipes/entrada/70/step/337afc8776934b74b99127f44ce784c3> a schema1:HowToStep ;
    schema1:text "Refreir nuevamente en aceite."@es .

<http://example.org/recipes/entrada/70/step/35e857c5afe64e5895b1c67e94a74149> a schema1:HowToStep ;
    schema1:text "Pelar, trocear y rayar la yuca. Dejar escurrir para que se le vaya la mayor cantidad de líquido (No exprimir)."@es .

<http://example.org/recipes/entrada/70/step/48d5db78f9ca4cfe8758d0e56346e742> a schema1:HowToStep ;
    schema1:text "Agregar la carne molida sazonada con sal y comino. Refreir."@es .

<http://example.org/recipes/entrada/70/step/823f5e9621a840d4a0d455fe890214a8> a schema1:HowToStep ;
    schema1:text "Colocar papel absorbente para eliminar la grasa y servir."@es .

<http://example.org/recipes/entrada/70/step/9ad8f1cfc7984765ab29ffb3675fd799> a schema1:HowToStep ;
    schema1:text "Agregar un poco de agua y dejar cocinar hasta que se haya evaporado el agua."@es .

<http://example.org/recipes/entrada/70/step/a38b7729ac854358a604e35aada633b7> a schema1:HowToStep ;
    schema1:text "Tomar porciones de masa y haciendo un hoyo incoporar la carne y pedazitos de huevo cocido."@es .

<http://example.org/recipes/entrada/70/step/a762cfe3c60f49a09da02e16d97e232d> a schema1:HowToStep ;
    schema1:text "Agregar sal, 2 yemas de huevo y achiote para que adquiera color."@es .

<http://example.org/recipes/entrada/71/step/3187bacfc7674aa7967284d7cf1094d0> a schema1:HowToStep ;
    schema1:text "Untar cada una de la rebanadas de pan con esta mezcla para impregnarla de su delicioso sabor."@es .

<http://example.org/recipes/entrada/71/step/781fce1cae454155b6e6c6360c13ea83> a schema1:HowToStep ;
    schema1:text "Colocar en un envase el ajo y el perejil y con la ayuda de una picadora o varilla eléctrica, tritúralos. Luego incorporar la mantequilla y mezclar muy bien todo."@es .

<http://example.org/recipes/entrada/71/step/98b76a3b459c483facc956609f9bd501> a schema1:HowToStep ;
    schema1:text "Retirar del horno y servirlo preferiblemente caliente."@es .

<http://example.org/recipes/entrada/71/step/c0baa65b04f74e86aaa457dd2aff5374> a schema1:HowToStep ;
    schema1:text "Colocar las rebanas en una bandeja para el horno y dejar que el pan se dore y la mantequilla se derrita durante 5 minutos."@es .

<http://example.org/recipes/entrada/71/step/f929c885d5ce4f8ab37c9b454ee9c195> a schema1:HowToStep ;
    schema1:text "Encender el horno a 180 ºC para que se vaya precalentando."@es .

<http://example.org/recipes/entrada/72/step/4928e106f66240c0b8a10adeabfbe64f> a schema1:HowToStep ;
    schema1:text "Formar los panes en bolas pequeñitas y colocarlas en una bandeja engrasada."@es .

<http://example.org/recipes/entrada/72/step/8b33c00cc727418491c9a8d05b7db17b> a schema1:HowToStep ;
    schema1:text "Servir los panes de yuca calientes."@es .

<http://example.org/recipes/entrada/72/step/90171895b9a04d3eb6db4c30499ffcb2> a schema1:HowToStep ;
    schema1:text "Agregar la mantequilla y los huevos y seguir amasando durante 5 minutos hasta que la mezcla adquiera una consistencia suave y homogénea. Si está seca, añadir un poco de agua o leche para suavizar."@es .

<http://example.org/recipes/entrada/72/step/f3cd5f11611547d8b9c7091a29850549> a schema1:HowToStep ;
    schema1:text "Hornear por aproximadamente 7 minutos y encender la parrilla del horno hasta que los panes estén dorados, aproximadamente unos 3-5 minutos."@es .

<http://example.org/recipes/entrada/72/step/f4ddbb9786c1419888462d86c2737a00> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a 500F. Mezclar el almidón de yuca, el queso, el polvo de hornear, la sal y amasar bien."@es .

<http://example.org/recipes/entrada/73/step/19dc83cba97440fea5d79a0a900d60ce> a schema1:HowToStep ;
    schema1:text "Vertir en una cacerola el maní, el ají, la leche y sal al gusto."@es .

<http://example.org/recipes/entrada/73/step/1d8098ab11e7464d811de545fe74d95e> a schema1:HowToStep ;
    schema1:text "Moler el maní con un poco de leche."@es .

<http://example.org/recipes/entrada/73/step/80d1a7a48ef644d6bd065ee33d43d3c9> a schema1:HowToStep ;
    schema1:text "Remojar el ají, luego moler y freír el ají en abundante aceite."@es .

<http://example.org/recipes/entrada/73/step/a4ada8f7a8b544c8bca279c868989b88> a schema1:HowToStep ;
    schema1:text "Poner sobre hojas de lechuga las papas cocidas y bañar con la salsa de maní."@es .

<http://example.org/recipes/entrada/73/step/a9ec701a9edc40a88cc4607231dc1727> a schema1:HowToStep ;
    schema1:text "Servir y adornar con huevos duros y tomates."@es .

<http://example.org/recipes/entrada/73/step/ba81626a320d4ccba09fad07683c5950> a schema1:HowToStep ;
    schema1:text "Cocinar durante 15 minutos o hasta que tome punto de salsa."@es .

<http://example.org/recipes/entrada/74/step/35550d9e7c874e44a43376b8b5ddeaa3> a schema1:HowToStep ;
    schema1:text "Pelar los plátanos y cortarlos en rodajas gruesas, se puede hacer cortes rectos o diagonales."@es .

<http://example.org/recipes/entrada/74/step/48d437ea3c9e431e9ac891ad7b2743be> a schema1:HowToStep ;
    schema1:text "Calentar el aceite a fuego medio en una sartén, la cantidad de aceite debe cubrir las rodajas. Freír los plátanos hasta que empiecen a ponerse amarillos sin dejar que se doren."@es .

<http://example.org/recipes/entrada/74/step/4acf57dfa5a443bba84ab677038839d8> a schema1:HowToStep ;
    schema1:text "Sacar las rodajas de la sartén y aplastar con un utensilio similar a un rodillo que es conocido como pataconera o tostonera, también se puede usar un mortero o el fondo de un vaso."@es .

<http://example.org/recipes/entrada/74/step/6c2909766a8e4434b4c4faa42fc2ecff> a schema1:HowToStep ;
    schema1:text "Retirar los tostones de la sartén y agregar más sal si es necesario. Servir los patacones calientes con ají o alguna salsa."@es .

<http://example.org/recipes/entrada/74/step/b7fc01dc52014419bef1d8be8087d386> a schema1:HowToStep ;
    schema1:text "Espolvorear las rodajas con sal y ajo. Freír nuevamente como 2 minutos aproximadamente hasta que queden completamente dorados y crujientes."@es .

<http://example.org/recipes/entrada/75/step/32919dfd73684a43a87558578b148615> a schema1:HowToStep ;
    schema1:text "Atar la carne con hilo de cocina, dándole forma redonda."@es .

<http://example.org/recipes/entrada/75/step/459e88bf70a646b6849d435238f36442> a schema1:HowToStep ;
    schema1:text "Licuar con agua, el comino, el achiote, el ajo, el orégano, sal y ají al gusto y la cebolla colorada la cebolla. Licuar por 4 minutos hasta que se haya formado una pasta."@es .

<http://example.org/recipes/entrada/75/step/4a772c9f7f164d9aba7091a6c14176bb> a schema1:HowToStep ;
    schema1:text "Separar toda la grasa que está adherida a la carne."@es .

<http://example.org/recipes/entrada/75/step/4b288895746b4684b0f56cab6b58e3c9> a schema1:HowToStep ;
    schema1:text "Pinchar con un cuchillo y frotar con la preparación realizada, procure introducir el aliño en las decisiones."@es .

<http://example.org/recipes/entrada/75/step/572a149d7a72483abcd859afdea7c302> a schema1:HowToStep ;
    schema1:text "Servir con tortillas de papa, aguacate, agrio y lechuga."@es .

<http://example.org/recipes/entrada/75/step/7f10a01c6dda4aa6816210717f23d440> a schema1:HowToStep ;
    schema1:text "Frotar la carne con el jugo de limón y 2 cucharadas de sal, deje en reposo por 2 horas."@es .

<http://example.org/recipes/entrada/75/step/8fb2395042fa481d986856e7c5dc058a> a schema1:HowToStep ;
    schema1:text "Hornear cubierto con papel aluminio a 200 ºC (400 ºF) por 2 horas (o más dependiendo del peso de la pierna)."@es .

<http://example.org/recipes/entrada/75/step/9e3c0af9c83e4141b93cd1929e0ef08e> a schema1:HowToStep ;
    schema1:text "Retirar el papel aluminio y deje dorar durante 20 minutos."@es .

<http://example.org/recipes/entrada/75/step/e93b01fbedf64e1cbccd32d51331d8f4> a schema1:HowToStep ;
    schema1:text "Comprobar la cocción introduciendo un pincho y el jugo que suelte la carne debe ser transparente."@es .

<http://example.org/recipes/entrada/76/step/55dde72606a34588a27cbc6789edaedf> a schema1:HowToStep ;
    schema1:text "Luego podemos presionar un poco para que se aplasten un poco y se cocinen mejor."@es .

<http://example.org/recipes/entrada/76/step/639234bfb31c42d282f1383c4e4bbe3d> a schema1:HowToStep ;
    schema1:text "Una vez que le quitemos la concha, lo cortaremos en rodajas gruesas."@es .

<http://example.org/recipes/entrada/76/step/a09ae2186cee4b79b80bafcbaf449d8c> a schema1:HowToStep ;
    schema1:text "Dorar por ambos lados y servir."@es .

<http://example.org/recipes/entrada/76/step/dff5982d0e8a4bf7ada989bacddeb853> a schema1:HowToStep ;
    schema1:text "Primero lavamos y cortamos los platanos. Estos deben estar bastantes maduros. Escogerlos que la concha este negra por fuera."@es .

<http://example.org/recipes/entrada/76/step/f69d8e438a5c4bc5bd992667ab28db2a> a schema1:HowToStep ;
    schema1:text "En un sarten colocaremos aceite y freiremos por ambos lados."@es .

<http://example.org/recipes/entrada/77/step/860cad6cc9854b108fae6925a930cd18> a schema1:HowToStep ;
    schema1:text "Servir de inmediato."@es .

<http://example.org/recipes/entrada/77/step/8ab2974567b04716b202076f066b4966> a schema1:HowToStep ;
    schema1:text "Cuando se evapora el alcohol contar 18 minutos exactos y comenzar a agregar el agua caliente poco a poco y a fuego lento. De 1/2 taza en 1/2 taza sin dejar de remover hasta que quede al dente, pero todavía hidratado."@es .

<http://example.org/recipes/entrada/77/step/b57362391ada415f80617a2d900e3eea> a schema1:HowToStep ;
    schema1:text "Precalentar un sartény añadir 3 cucharadas de aceite de oliva y una cucharada de mantequilla."@es .

<http://example.org/recipes/entrada/77/step/caf14aa3d79a450a9dad597d14d2eef3> a schema1:HowToStep ;
    schema1:text "Añadir el ajo y la cebolla picada. Saltear por 2 minutos y agregar el arroz crudo. Mezclar bien, sazonar y agregar sal y pimienta. Cuando el arroz comience a secar, agregar el vino blanco."@es .

<http://example.org/recipes/entrada/77/step/e555574996924fd9a4d2d3152af06c22> a schema1:HowToStep ;
    schema1:text "Agregar el aguacate bien picado. Mezclar bien hasta que prácticamente no se vea el aguacate, agregar 2 cucharadas de mantequilla y el queso rallado. Mezclar todo de forma uniforme."@es .

<http://example.org/recipes/entrada/78/step/0f3e69ba849f4891ac97957d8b2dac52> a schema1:HowToStep ;
    schema1:text "Colocar las papas y las salchichas sobre toallas de papel para quitar la grasa y servir inmediatamente acompañados con salsa rosada y curtido de cebolla con tomate."@es .

<http://example.org/recipes/entrada/78/step/6c98b92709a843469e3a669173b30193> a schema1:HowToStep ;
    schema1:text "Colocar las papas en el aceite hirviendo y cocinar hasta que estén tiernas, pero sin dorar. Sacar las papas del aceite y colocarlas encima de toallas de papel para escurrir el aceite. Dejarlas enfriar al menos durante una hora."@es .

<http://example.org/recipes/entrada/78/step/9631b9ac207149d98bd8df403fbf05f2> a schema1:HowToStep ;
    schema1:text "Volver a calentar el aceite, esta vez a temperatura de 375 F. Colocar las papas en el aceite hirviendo y freírlas hasta que estén doradas y crujientes."@es .

<http://example.org/recipes/entrada/78/step/9bcb06bf4c0d4da0875c2d054a116ffb> a schema1:HowToStep ;
    schema1:text "Pelar y cortar las papas en tiras gruesas y remojarlas en agua fría durante media hora. Escurrir el agua y secar bien las papas. Calentar el aceite para freír a temperatura de 325 F."@es .

<http://example.org/recipes/entrada/78/step/9bdb7d20ee3b4506a306f30911bc96ad> a schema1:HowToStep ;
    schema1:text "Cortar las salchichas por la mitad, con un corte de cruz en las puntas y freírlas."@es .

<http://example.org/recipes/entrada/79/step/2368325269ca4d96b11944fcc29c5cf5> a schema1:HowToStep ;
    schema1:text "Hervir la leche, retirarla del fuego y luego dejarla que enfríe."@es .

<http://example.org/recipes/entrada/79/step/48d2c30dd1494225aa3fef0e8143e6ef> a schema1:HowToStep ;
    schema1:text "Añadir el cilantro, el queso rayado, el jugo de limón y el ajo molido,"@es .

<http://example.org/recipes/entrada/79/step/5f0f8b5365cc441f893a1a840bb6de55> a schema1:HowToStep ;
    schema1:text "Sazonar con sal y pimienta."@es .

<http://example.org/recipes/entrada/79/step/6f65dfb60df944ec8e85bc345841bde2> a schema1:HowToStep ;
    schema1:text "Licuar la leche con los chochos, ubicar en una olla el resultado obtenido y llevarla al fuego revolver hasta que espese y retirar."@es .

<http://example.org/recipes/entrada/79/step/7341b6164f0b4ed8a3341097225ba884> a schema1:HowToStep ;
    schema1:text "Refreír en un sartén la cebolla con la mantequilla hasta que la cebolla esté transparente."@es .

<http://example.org/recipes/entrada/79/step/a2e9db5c3d1946efaa7b130ed1455719> a schema1:HowToStep ;
    schema1:text "Dejar que se enfríe completamente antes de servir."@es .

<http://example.org/recipes/entrada/8/step/3f2308eda5de4c6d8f4ceef23f68fc2b> a schema1:HowToStep ;
    schema1:text "Echar de a poco el agua tibia mientras se va amasando hasta obtener un resultado homogéneo y suave."@es .

<http://example.org/recipes/entrada/8/step/555def71572d4640b62aa03540b5c850> a schema1:HowToStep ;
    schema1:text "Retirar las tortillas cuidadosamente para que no se desbaraten y sirva inmediatamente."@es .

<http://example.org/recipes/entrada/8/step/90b3202420cd4c29a816f6bcef6bddfd> a schema1:HowToStep ;
    schema1:text "Calentar poco aceite en un sartén y ubicar las tortillas hasta que se doren totalmente, realizar este proceso de manera que las tortillas queden asadas."@es .

<http://example.org/recipes/entrada/8/step/99e144112b36413c855da6033017cfe4> a schema1:HowToStep ;
    schema1:text "Amasar las papas hasta formar un puré, no dejar grumos."@es .

<http://example.org/recipes/entrada/8/step/9f413472c50b44cda43c4f1283d139b9> a schema1:HowToStep ;
    schema1:text "Mezcle el puré con el queso y el achiote."@es .

<http://example.org/recipes/entrada/8/step/fbced0a1c6ad486882a2f333c4ceaa7a> a schema1:HowToStep ;
    schema1:text "Colocar en un recipiente la harina de maíz, la yema, mantequilla, la sal y la pimienta."@es .

<http://example.org/recipes/entrada/8/step/ff8fa55ea44f426bbb9e3de69366240a> a schema1:HowToStep ;
    schema1:text "Formar bolitas de la masa obtenida con la harina de maíz y rellénelas con la mezcla del puré, luego aplastarlas suavemente hasta obtener la forma de una tortilla."@es .

<http://example.org/recipes/entrada/80/step/0bd77678402341e085be19b313e08160> a schema1:HowToStep ;
    schema1:text "Comenzar adobando las presas de gallina con las especias. Dejar reposar."@es .

<http://example.org/recipes/entrada/80/step/267ac1d91a4044f885d54f991aa84501> a schema1:HowToStep ;
    schema1:text "En una procesadora mixear la cerveza y el jugo de naranja, el tomate, la cebolla, el ajo, los pimientos, el cilantro, el perejil y el orégano hasta obtener una mezcla espesa."@es .

<http://example.org/recipes/entrada/80/step/3b19ee3b8cf54ea385711459e0c85b34> a schema1:HowToStep ;
    schema1:text "Finalizar con el jugo de naranja que equilibra los sabores."@es .

<http://example.org/recipes/entrada/80/step/594629ae918a4604ba093a4dd4d334a2> a schema1:HowToStep ;
    schema1:text "Servir caliente acompañado con arroz blanco."@es .

<http://example.org/recipes/entrada/80/step/8faffe9e25f5434a9b0bd7c0e492f689> a schema1:HowToStep ;
    schema1:text "En una cacerola dorar las presas por ambos lados y añadir la salsa licuada, cuando rompa en hervor bajar el fuego y cocinar por una hora."@es .

<http://example.org/recipes/entrada/81/step/26a935c7389740c5917fd98044f2579e> a schema1:HowToStep ;
    schema1:text "Incorporar los huevos previamente batidos y continúe amasando."@es .

<http://example.org/recipes/entrada/81/step/405fc3bb97604a24a3f0f10753ae0a42> a schema1:HowToStep ;
    schema1:text "Remojar el maíz en agua fría durante 3 días (cambiar el agua diariamente)."@es .

<http://example.org/recipes/entrada/81/step/462a5cc7d8df4c87ab1cf6d588d32fff> a schema1:HowToStep ;
    schema1:text "Cernir el caldo y reservar."@es .

<http://example.org/recipes/entrada/81/step/66dadcaf46cf4b61b36b8dfa139fb6b9> a schema1:HowToStep ;
    schema1:text "Cortar el pollo en trocitos."@es .

<http://example.org/recipes/entrada/81/step/749d38d35d234d46b46794a912013391> a schema1:HowToStep ;
    schema1:text "Preparar un refrito con la cebolla restante picada finamente y el aceite de color, añada el pollo y las arvejas."@es .

<http://example.org/recipes/entrada/81/step/891a727cea484baebf6a5a9ab32aad5a> a schema1:HowToStep ;
    schema1:text "Añadir poco a poco 1 1/2 tazas de caldo caliente y vuelva a amasar."@es .

<http://example.org/recipes/entrada/81/step/b3c3ec9a14974454ace784638d896d78> a schema1:HowToStep ;
    schema1:text "Cocinar al vapor durante una hora en una tamalera, la misma que debe estar con el agua hirviendo."@es .

<http://example.org/recipes/entrada/81/step/c5918add4ce24494b00a4f70fb2fef8a> a schema1:HowToStep ;
    schema1:text "Poner en una olla el pollo, 1 litro de agua, 1 rama de cebolla troceada y el ajo, sazone con sal, pimienta y comino al gusto."@es .

<http://example.org/recipes/entrada/81/step/c6bcbf61735d4024ae9492860896cc07> a schema1:HowToStep ;
    schema1:text "Dejar cocinar hasta que la carne esté suave."@es .

<http://example.org/recipes/entrada/81/step/db7b7b51189f490ebd86c5de2118756b> a schema1:HowToStep ;
    schema1:text "Escurrir el maíz y molerlo finamente. Colocarlo el maíz en un tazón, agregar la manteca y amasar."@es .

<http://example.org/recipes/entrada/82/step/3226ce052d264dd392e50a346b02b0fa> a schema1:HowToStep ;
    schema1:text "Lave bien los plátanos y retire las cortezas."@es .

<http://example.org/recipes/entrada/82/step/4cd4b12dcb1741c3bfb7894ca7bf0197> a schema1:HowToStep ;
    schema1:text "Forme las tortillas y coloque un poco del relleno anterior."@es .

<http://example.org/recipes/entrada/82/step/8bbd5a57208444fd849c4777ec251487> a schema1:HowToStep ;
    schema1:text "Fría las tortillas en una sartén con un poco de aceite hasta que estén doraditas."@es .

<http://example.org/recipes/entrada/82/step/94a6bd4b66764dcdbf5d49a928c6b67f> a schema1:HowToStep ;
    schema1:text "Mezcle en un bol la cebolla y el queso para obtener el relleno."@es .

<http://example.org/recipes/entrada/82/step/a8c0f036b9e94445b0c9dca89ef4d2f5> a schema1:HowToStep ;
    schema1:text "Cocine los plátanos en agua con un poco de sal hasta que ablanden."@es .

<http://example.org/recipes/entrada/82/step/a92a4bf3bcbe423c8c4b0d7b39301e56> a schema1:HowToStep ;
    schema1:text "Hacer un puré con los plátanos cocidos. Incorpore la mantequilla y sal al gusto."@es .

<http://example.org/recipes/entrada/82/step/de3c931717c7483bb704ae4109b58413> a schema1:HowToStep ;
    schema1:text "Sírvalas con encurtido de cebollas y tomates, y acompañadas de una salsa de ají costeño."@es .

<http://example.org/recipes/entrada/83/step/2a30c94b667a47eaaf55eb9888e40d27> a schema1:HowToStep ;
    schema1:text "Ubicar en un sartén el aceite hasta que esté caliente, lanzar las tortillas cuidadosamente y dejarlas freír hasta que estén completamente doradas."@es .

<http://example.org/recipes/entrada/83/step/ab935be073ae427c9fba4c4aa604e136> a schema1:HowToStep ;
    schema1:text "Retirar y servir las tortillas."@es .

<http://example.org/recipes/entrada/83/step/b00c8b91ddb04b209a960aaf6a866796> a schema1:HowToStep ;
    schema1:text "Lavar la quinua, ubicarla en una olla con agua y verificar que queden bien cocidas."@es .

<http://example.org/recipes/entrada/83/step/b1c4bfbc216a41d2bf139740c053cb72> a schema1:HowToStep ;
    schema1:text "Verificar que la masa quede suave y consistente, formar las tortillas rellenándolas del queso suave."@es .

<http://example.org/recipes/entrada/83/step/b4184e6246b042e38bf7ea93f070e1da> a schema1:HowToStep ;
    schema1:text "Cernir en un colador hasta que quede bien escurrida."@es .

<http://example.org/recipes/entrada/83/step/b4ce295b9c234e32803c756948205e67> a schema1:HowToStep ;
    schema1:text "Mezclar la quinua con los ingredientes licuados, agregar la sal, pimienta, el orégano, tomillo y queso parmesano."@es .

<http://example.org/recipes/entrada/83/step/bb58194f5b5f4b35ad53eec5e4ff363f> a schema1:HowToStep ;
    schema1:text "Licuar las zanahorias, cebolla, pimiento, ajo, y los huevos."@es .

<http://example.org/recipes/entrada/84/step/08e9fd69ab1e4507a46c68ce141fd9b2> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, escurrir el agua y dejar enfriar por unos minutos."@es .

<http://example.org/recipes/entrada/84/step/3962da4829814e1ba75653d296d8b6c9> a schema1:HowToStep ;
    schema1:text "Separar en porciones iguales la masa de yuca y preparar un tortilla, en el centro colocar el queso y la cebolla."@es .

<http://example.org/recipes/entrada/84/step/85de3759fed44eeea4828d2c396df449> a schema1:HowToStep ;
    schema1:text "Verter media cucharadita de aceite en un sarten bien caliente para freír las tortillas de yuca hasta que se doren por ambos lados."@es .

<http://example.org/recipes/entrada/84/step/9250f59f51eb4cfd86fdfa4d654ba28d> a schema1:HowToStep ;
    schema1:text "En un sartén caliente verter una cucharadita de aceite y agregar la cebolla, refreír hasta que se vuelva transparente. Dejar enfriar y reservar."@es .

<http://example.org/recipes/entrada/84/step/9a082e448a03480e97a7970037a7876e> a schema1:HowToStep ;
    schema1:text "Pelar y lavar la yuca, cortar en trozo para poner a cocinar a fuego medio, una vez que el agua hierva agregar la sal y dejar la yuca al fuego de hasta que este blanda."@es .

<http://example.org/recipes/entrada/84/step/e245977649a0455eba5c0c2d919c1097> a schema1:HowToStep ;
    schema1:text "Colocar las yucas cocinadas en un recipiente hondo, agregar la mantequilla. Aplastar las yucas hasta obtener una masa homogénea."@es .

<http://example.org/recipes/entrada/85/step/0ecf9716d8404a39af5ed7c7550b422e> a schema1:HowToStep ;
    schema1:text "Lavar nuevamente las tripas con abundante agua."@es .

<http://example.org/recipes/entrada/85/step/652a259446fc4ce2bb3f4026b7f559ac> a schema1:HowToStep ;
    schema1:text "En una grill bien caliente, colocar las tripas y asarlas hasta que queden doradas."@es .

<http://example.org/recipes/entrada/85/step/7d8d4a11aad14b40814221ee59a29df4> a schema1:HowToStep ;
    schema1:text "Servir los snack decorados con hojas de perejil. Acompañe con salsa de maní y un poco de encurtido de cebollas."@es .

<http://example.org/recipes/entrada/85/step/7e0ffbddab46471c9ee6023f7c3a3b44> a schema1:HowToStep ;
    schema1:text "Para preparar el snack, tome una rodaja de papa, coloque encima láminas de tripa y untar un poco de engrudo. Sellar con otra rodaja de papa. Freír en aceite bien caliente."@es .

<http://example.org/recipes/entrada/85/step/865e1f9583f444f4875ad2f4832fdb06> a schema1:HowToStep ;
    schema1:text "Preparar un engrudo, mezclando la harina de trigo con el agua."@es .

<http://example.org/recipes/entrada/85/step/b88b165567eb47a0b66e5912170d32ea> a schema1:HowToStep ;
    schema1:text "Limpiar y lavar bien las tripas. Fregar las tripas con limón y vinagre."@es .

<http://example.org/recipes/entrada/85/step/d9fb895acc9e4f51b17c8f1d83e3eaba> a schema1:HowToStep ;
    schema1:text "Colocar las tripas en un bol y aderezarlas con un poco de aceite de achiote, sal, pimienta, comino, hierbabuena, ajo machacado y cebolla paiteña. Tapar con papel film y dejar marinar por una hora aproximadamente."@es .

<http://example.org/recipes/entrada/85/step/dd1c98e8b18f41f9b5027f502529243f> a schema1:HowToStep ;
    schema1:text "Para preparar la salsa de maní, sofría en una sartén la cebolla blanca finamente picada. Luego añada cilantro, pasta de maní y la leche. Deje cocinar hasta que reduzca y rectifique el sabor."@es .

<http://example.org/recipes/entrada/85/step/fd0954e0c29e4f5d80821524257b790e> a schema1:HowToStep ;
    schema1:text "Cortar las papas y las tripas en láminas."@es .

<http://example.org/recipes/entrada/86/step/12c1aa53510b452785b2a08a55dc599b> a schema1:HowToStep ;
    schema1:text "Combinar en un recipiente las verduras y las frutas."@es .

<http://example.org/recipes/entrada/86/step/51c6ba13687a47cf8fb4bfb05a5974e4> a schema1:HowToStep ;
    schema1:text "Incorporar esta mezcla a las verduras y mezclar."@es .

<http://example.org/recipes/entrada/86/step/758aeb933db343dfad14a52530b63740> a schema1:HowToStep ;
    schema1:text "Cocer al vapor las vainitas y las zanahorias."@es .

<http://example.org/recipes/entrada/86/step/877e1620a422452482997d50f0032b2c> a schema1:HowToStep ;
    schema1:text "Remojar la gelatina remoje la gelatina en un 1/4 de taza de agua fría. Llevar a fuego bajo hasta que se disuelva."@es .

<http://example.org/recipes/entrada/86/step/aa23674f9d2f4b999b770d02162f94df> a schema1:HowToStep ;
    schema1:text "Coloque esta preparación en una bandeja de vídrio y llevar a la refrigeradora hasta que tome consistencia."@es .

<http://example.org/recipes/entrada/86/step/c1dd3ec2dc54488bbbebd90ba94c5d0d> a schema1:HowToStep ;
    schema1:text "Picar las vainitas en trozitos pequeños, la zanahoria, el durazno y las manzanas en cuadritos."@es .

<http://example.org/recipes/entrada/86/step/e384bd91e4104927a5e7adb7015039cb> a schema1:HowToStep ;
    schema1:text "Añadir la crema de leche, el yogurt y sazonar con sal y pimienta."@es .

<http://example.org/recipes/entrada/86/step/f0dbdaeb1fbd45bbab81f957517b33cf> a schema1:HowToStep ;
    schema1:text "Cortar en pedazos para servir."@es .

<http://example.org/recipes/entrada/87/step/43bf0bb177e84b4ea43b8f8c3a29562b> a schema1:HowToStep ;
    schema1:text "Calentar una olla al fuego y tostar la harina por 20 minutos removiendo constantemente."@es .

<http://example.org/recipes/entrada/87/step/8e0e077da8294aa89178d40edfe227aa> a schema1:HowToStep ;
    schema1:text "Pelar los plátanos y colocar sobre la parrilla volteándolos constantemente."@es .

<http://example.org/recipes/entrada/87/step/9301b3b0d89b4ec9bfa2aba19b1c16cd> a schema1:HowToStep ;
    schema1:text "Moler o procesar la harina con el maní, llevar a un tazón, adicionar la manteca de color disuelta con el aceite y la manteca."@es .

<http://example.org/recipes/entrada/87/step/9f3b662f2ec645ffb288756a635ddcd6> a schema1:HowToStep ;
    schema1:text "Sazonar con sal, pimienta y comino."@es .

<http://example.org/recipes/entrada/87/step/cbeecebe367849fb96a3422bdb06a948> a schema1:HowToStep ;
    schema1:text "Añadir el cilantro, intégrelo todo hasta que la harina tome color amarillo intenso."@es .

<http://example.org/recipes/entrada/87/step/d2ece79ce15440998eb14f1087ce0fe8> a schema1:HowToStep ;
    schema1:text "Pasar nuevamente por el procesador."@es .

<http://example.org/recipes/entrada/88/step/1b8ad072af994e399490782b3b172572> a schema1:HowToStep ;
    schema1:text "Agregar por último el cilantro, y mezclar hasta que la harina se torne de un amarillo intenso."@es .

<http://example.org/recipes/entrada/88/step/249d4a0bedcc49d3b84bf5562e168a67> a schema1:HowToStep ;
    schema1:text "En una sartén dorar la harina cuidando no quemarla."@es .

<http://example.org/recipes/entrada/88/step/6c6dabe82fa94a11b02f7d5eac79019e> a schema1:HowToStep ;
    schema1:text "Servir junto con los verdes calientes."@es .

<http://example.org/recipes/entrada/88/step/714e7df984634a4e89fb5e650bf5a9c7> a schema1:HowToStep ;
    schema1:text "Procesar la harina con junto con el maní, la manteca y el aceite. Condimentar y salar."@es .

<http://example.org/recipes/entrada/88/step/b9f6e7feb15d47d184f022563f63c325> a schema1:HowToStep ;
    schema1:text "Comenzar asando los plátanos pelados y trozados sobre una parrilla."@es .

<http://example.org/recipes/entrada/89/step/22fbfc6778244b78a03d75347479a14a> a schema1:HowToStep ;
    schema1:text "Mojar 2 bordes consecutivos de la oblea de masa con la mezcla de harina y agua, colocamos relleno en el centro."@es .

<http://example.org/recipes/entrada/89/step/3e180c077f3c49ddbee6ba68faed576b> a schema1:HowToStep ;
    schema1:text "Prepar el relleno mezclando la carne picada, el cebollin, un poco de pimienta molida, el aceite y la salsa de soja o ostras. Mezclar con un tenedor o con palillos."@es .

<http://example.org/recipes/entrada/89/step/513a27cfec0e49c1854c67c82222219a> a schema1:HowToStep ;
    schema1:text "Aparte mezclar la harina con el agua, que será usada para cerrar los triángulos y que no se abran al freír."@es .

<http://example.org/recipes/entrada/89/step/7692413f68b447c19ac5fd1c41695f42> a schema1:HowToStep ;
    schema1:text "Freir los triángulos en abundante aceite a fuego alto hasta que estén dorados y crujientes."@es .

<http://example.org/recipes/entrada/89/step/dfc60f82583f40ceb55300538ba088a7> a schema1:HowToStep ;
    schema1:text "Doblar en forma de triángulo y presionar bien los bordes para que se queden pegados."@es .

<http://example.org/recipes/entrada/89/step/f44da3aa72654236a2c2c764d1c2f45c> a schema1:HowToStep ;
    schema1:text "Antes de servir se deben escurrir y deben servirse calientes."@es .

<http://example.org/recipes/entrada/9/step/8fae8f58073c4f1789d4d174666ed6c8> a schema1:HowToStep ;
    schema1:text "Añadir el zumo de lima y dejar que se consuma. Servir las Brochetas de Langostinos bien caliente"@es .

<http://example.org/recipes/entrada/9/step/9e2fb2d5e54749818e986e014e23b70d> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una sartén grande. Añadir el ajo picado, y antes de que tome color, colocar las brochetas en la sartén, agregar una pizca de sal por encima y freír entre 2 ó 3 minutos por cada lado, hasta que estén doradas."@es .

<http://example.org/recipes/entrada/9/step/cd7894dc4dc942f089d08e2a011fb6e9> a schema1:HowToStep ;
    schema1:text "Retirar la cabeza y el caparazón de los langostinos, dejando la cola."@es .

<http://example.org/recipes/entrada/9/step/d4e01ca3960f4c1aa73e5d6a3b76b90b> a schema1:HowToStep ;
    schema1:text "Colocar en cada brocheta 3 o 4 langostinos"@es .

<http://example.org/recipes/plato-principal/1/step/35d3a81143014436ba77043791e9dc48> a schema1:HowToStep ;
    schema1:text "Servir el arroz en un plato y colocar encima la ensalada mezclada con el atún."@es .

<http://example.org/recipes/plato-principal/1/step/5777be4b639a4a45bca09a0ad6d4800d> a schema1:HowToStep ;
    schema1:text "Cocinar el arroz blanco."@es .

<http://example.org/recipes/plato-principal/1/step/77da0e99867a40ef95866a5d41dc3831> a schema1:HowToStep ;
    schema1:text "Picar el aguacate en cuadritos y la lechuga finamente."@es .

<http://example.org/recipes/plato-principal/1/step/7dd0b4ae4ee041f5bd7f113e58cb1ffe> a schema1:HowToStep ;
    schema1:text "Cortar el tomate finamente quitándole las semillas y picar la cebolla finamente."@es .

<http://example.org/recipes/plato-principal/1/step/8d7e3af4b93b4d7d8987acd9b8a401ec> a schema1:HowToStep ;
    schema1:text "Mezclar la ensalada con el atún."@es .

<http://example.org/recipes/plato-principal/1/step/f8fbe6d78e68406f9c4727b5804caa22> a schema1:HowToStep ;
    schema1:text "Juntar el tomate, la cebolla, el aguacate y la lechuga y hechar sal y limón al gusto."@es .

<http://example.org/recipes/plato-principal/10/step/14d8c49074c447519e78023b0914a132> a schema1:HowToStep ;
    schema1:text "En una sartén, caliente un poco el aceite de achiote y proceda a sellar los bistec."@es .

<http://example.org/recipes/plato-principal/10/step/1d125355ee324dd6aed12d053e1632ab> a schema1:HowToStep ;
    schema1:text "Sirva el bistec caliente acompañado de arroz blanco, plátanos fritos y ensalada de vegetales."@es .

<http://example.org/recipes/plato-principal/10/step/3b927b2e72394bb3983f1c3e10adc0c6> a schema1:HowToStep ;
    schema1:text "Añada la cebolla y el pimiento cortado en tiras y un tomate cortado en cubos. Cocine tapado a fuego medio por 5 minutos."@es .

<http://example.org/recipes/plato-principal/10/step/a4c9a88254a8456d88cb700a7d90d2ec> a schema1:HowToStep ;
    schema1:text "Licuar el tomate con agua y vierta esta preparación colada en el sartén."@es .

<http://example.org/recipes/plato-principal/10/step/a9b6b6a9f8cb4b4e8c2ff75957f254ea> a schema1:HowToStep ;
    schema1:text "Colocar los bistec en una fuente y sazonarlos con ajo, mostaza, sal y comino."@es .

<http://example.org/recipes/plato-principal/10/step/ba560fd6b2de402db873e30686de373c> a schema1:HowToStep ;
    schema1:text "Se añade el achiote, el eneldo, la salsa de tomate y cocine tapado por 3 minutos más. Rectifique el sabor."@es .

<http://example.org/recipes/plato-principal/100/step/5efa4dac90a341608d2f276a8932f96c> a schema1:HowToStep ;
    schema1:text "Mezclado todo cuando ya se vea bien sofrito , se coloca la Carne que se había reservado y mezclamos muy bien con el sofrito."@es .

<http://example.org/recipes/plato-principal/100/step/8b87ac51928f40849f042352831d5004> a schema1:HowToStep ;
    schema1:text "En la licuadora agregamos 1 Naranjilla picada y un vaso grande de cerveza se licúa y se vuelve agregar Cerveza con un poco de agua, ya licuado bien se cuela y añadimos a la olla este líquido ."@es .

<http://example.org/recipes/plato-principal/100/step/8c6f8bd0a27143629f425373a7461efe> a schema1:HowToStep ;
    schema1:text "En la misma olla ponemos el aceite ,el achiote, la cebolla y pimiento cortados en cuadritos, movemos y añadimos una pizca de comino, seguimos moviendo por unos 2 minutos, ponemos el tomate picado y seguimos moviendo."@es .

<http://example.org/recipes/plato-principal/100/step/b6ecc8dfe72b4f6a8944bc790331863f> a schema1:HowToStep ;
    schema1:text "Dejamos hervir por 25 minutos a fuego medio hasta que la carne de cerdo este cocida."@es .

<http://example.org/recipes/plato-principal/100/step/d444d37bf5d044ce8838e4cbce9929aa> a schema1:HowToStep ;
    schema1:text "Se acompaña este plato con arroz y aguacate"@es .

<http://example.org/recipes/plato-principal/100/step/d832198d760e43b69647e993cfea3de5> a schema1:HowToStep ;
    schema1:text "Agregamos sal, el cilantro picadito y dejamos cocinar por 5 minutos más. Ya listo apagamos y dejamos reposar."@es .

<http://example.org/recipes/plato-principal/100/step/dc94d166cfad4f2bb4ac46811a548abb> a schema1:HowToStep ;
    schema1:text "Comenzamos sazonando la carne con la sal, pimienta y el ajo triturado."@es .

<http://example.org/recipes/plato-principal/100/step/e6256b8865384b6286deb6f1dc8a15f5> a schema1:HowToStep ;
    schema1:text """Colocamos aceite en una olla y añadimos la carne. La freímos 6 minutos.
	Pasado los 6 minutos, Reservamos la Carne en otro tazón."""@es .

<http://example.org/recipes/plato-principal/101/step/1b058373ddee4574a740d7206a637a59> a schema1:HowToStep ;
    schema1:text "Licuar los tomates, el manojo de cilantro, el ají, la taza restante de chicha y el jugo de naranjillas. Colar esta salsa y añadirla a la olla donde se está cocinando la carne."@es .

<http://example.org/recipes/plato-principal/101/step/21f149ed4fb046c8a63e75508e17ed79> a schema1:HowToStep ;
    schema1:text "Colocar en un tazón la carne de chivo, el ajo, el comino, el orégano, sal y 1 taza de chicha y mezclar bien. Dejar marinar por lo menos 1 hora."@es .

<http://example.org/recipes/plato-principal/101/step/48b52ba751b04dc3a6a21b3e9a9784ee> a schema1:HowToStep ;
    schema1:text "Calentar el aceite a temperatura alta en una sartén grande y añadir la carne. Guardar la salsa donde se estaba marinando para más tarde. Freír el chivo hasta que esté dorado por ambos lados."@es .

<http://example.org/recipes/plato-principal/101/step/5868c0130a594a44932a5c476ac74622> a schema1:HowToStep ;
    schema1:text "Servir el seco de chivo acompañado de arroz amarillo, plátanos maduros fritos y aguacate."@es .

<http://example.org/recipes/plato-principal/101/step/684fa90f6f134662b95595f282b70839> a schema1:HowToStep ;
    schema1:text "Agregar la salsa donde se estaba marinando la carne, la panela rallada y la pimienta dulce. Esperar hasta que hierva y reducir la temperatura."@es .

<http://example.org/recipes/plato-principal/101/step/68e5e93017304de282c4350973f57089> a schema1:HowToStep ;
    schema1:text "Cocinar a fuego lento durante unas 2 horas hasta que carne esté muy suave. Rectificar la sal y espolvorear con el cilantro."@es .

<http://example.org/recipes/plato-principal/101/step/b7d17246424a40e493ba98efcd1038df> a schema1:HowToStep ;
    schema1:text "Reducir la temperatura y agregar las cebollas, el pimiento y el achiote, cocinar durante 5 minutos hasta que las cebollas estén blandas."@es .

<http://example.org/recipes/plato-principal/102/step/051e4ef5988b492bad5f2510e2b740ac> a schema1:HowToStep ;
    schema1:text "Incorporar la carne con el líquido de adobo, dejar que se mezcle bien y cocer a fuego lento hasta que esté suave."@es .

<http://example.org/recipes/plato-principal/102/step/0df576dc5cd944cc87349ac80516154a> a schema1:HowToStep ;
    schema1:text "Servir acompañado de arroz y plátanos fritos."@es .

<http://example.org/recipes/plato-principal/102/step/3c338d68a507415c8312f1b4af8ae999> a schema1:HowToStep ;
    schema1:text "Colocar la carne de guanta en un recipiente hondo, agregar el vinagre de guineo o la chicha, cubrir bien y dejar reposar durante 2 horas."@es .

<http://example.org/recipes/plato-principal/102/step/994f758deadd424cb99086d6af35c78b> a schema1:HowToStep ;
    schema1:text "Hacer el refrito en aceite, con todos los ingredientes finamente picados, y los aliños, durante 15-20 minutos"@es .

<http://example.org/recipes/plato-principal/103/step/445fdb48142245eab61b14414d32a235> a schema1:HowToStep ;
    schema1:text "Sirva con arroz y yuca frita."@es .

<http://example.org/recipes/plato-principal/103/step/6bd36759063e4cf6aecbea23642f0164> a schema1:HowToStep ;
    schema1:text "Adobar el pato con sal y el ajo. Se deja en reposo por unas dos horas para que la carne tome sabor."@es .

<http://example.org/recipes/plato-principal/103/step/82904fdd4fd8420abad6c27153a599da> a schema1:HowToStep ;
    schema1:text "En una sartén con un poco de aceite de achiote, se sofríe la cebolla, el pimiento y un poco de ajo. Se agrega el pato troceado y se sofríe junto con los vegetales hasta que dore. Sazonar con sal y comino."@es .

<http://example.org/recipes/plato-principal/103/step/a548bbe8558d4e18aed7c9379de14812> a schema1:HowToStep ;
    schema1:text "Añadir el jugo de naranjillas y la chicha, dejando que se cocine a fuego lento por unas dos horas, para que la carne ablande."@es .

<http://example.org/recipes/plato-principal/104/step/0a775601621147fab736023afa95f806> a schema1:HowToStep ;
    schema1:text "Una vez listo agregamos el pollo, el zumo de naranjilla y revolvemos todo. Luego se le agrega agua hasta que las piezas queden cubiertas hasta la mitad."@es .

<http://example.org/recipes/plato-principal/104/step/11c406ae345e4d71b93584c91d478605> a schema1:HowToStep ;
    schema1:text "A los tomates y pimientos le quitamos las colitas."@es .

<http://example.org/recipes/plato-principal/104/step/40f57194df4c4b19b69bf88d64d7d94b> a schema1:HowToStep ;
    schema1:text "En la misma olla donde se sello el pollo se pone a sofreir todo lo que trituramos y se deja que se consuma el liquido y que solo quede el sofrito."@es .

<http://example.org/recipes/plato-principal/104/step/566216e734804790bc0b8386c103979e> a schema1:HowToStep ;
    schema1:text "Antes de servir dejamos reposar durante 15 minutos."@es .

<http://example.org/recipes/plato-principal/104/step/6c36f37bc400402497050ee4cac71e90> a schema1:HowToStep ;
    schema1:text "Luego agregamos el cilantro lo revolvemos y dejamos cocinar a fuego alto durante 20 minutos."@es .

<http://example.org/recipes/plato-principal/104/step/81355d43d8334766a2f5ce4c94e69dd6> a schema1:HowToStep ;
    schema1:text "Aparte se limpian los pollo quitandole la piel y la grasa. Luego las troceamos. Una vez listas la sazonamos con ajo, sal y pimienta al gusto."@es .

<http://example.org/recipes/plato-principal/104/step/86c546698cd34b14b7a54710d8a78227> a schema1:HowToStep ;
    schema1:text "En un procesador o licuadora colocamos la cebolla, el ajo, los tomates, los pimientos verdes, el cubito de caldo concentrado, 1 cucharadita de comino molido, 2 cucharaditas de aji, una cucharadita de pimenton dulce. Al final agregamos sal y pimienta al gusto. Trituramos o licuamos bien hasta que quede una mezcla fina."@es .

<http://example.org/recipes/plato-principal/104/step/9a2fb3dd0c644e18aceab3c3a6bb3e79> a schema1:HowToStep ;
    schema1:text "Luego en una olla colocamos aceite vegetal como 5 cucharadas y agregamos el pollo para sellarlo. Una vez que esten todas doradas las sacamos de la olla y las reservamos."@es .

<http://example.org/recipes/plato-principal/104/step/bc8be68fe02b454f807eb9e2be8e209b> a schema1:HowToStep ;
    schema1:text "El manojo de cilantro lo picamos finito."@es .

<http://example.org/recipes/plato-principal/104/step/c4b42c4b399d4683b9380185b2280c51> a schema1:HowToStep ;
    schema1:text "Se lavan y se pican muy bien los vegetales en trozos grandes."@es .

<http://example.org/recipes/plato-principal/105/step/37d1c8e7f85c4ac28aa962af54fc7c16> a schema1:HowToStep ;
    schema1:text "Cuando la salsa esté espesa, volver a colocar las presas en la olla y agregar un poco de perejil y cilantro finamente cortados. Servir el seco de pollo o gallina acompañado con arroz amarillo, plátanos maduros fritos, aguacate, papas, ensalada, etc."@es .

<http://example.org/recipes/plato-principal/105/step/7549c8bc7d494bc0a10c543f594c9c71> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una olla grande y agregar las presas. Dorar por ambos lados y añadir la salsa licuada. Esperar hasta que hierva y cocinar a fuego lento durante 1 hora hasta que las presas estén muy suaves, el tiempo de cocción depende de si es carne de pollo o carne de gallina."@es .

<http://example.org/recipes/plato-principal/105/step/b2791c27bed84b30bdeeca797cbcd02d> a schema1:HowToStep ;
    schema1:text "Si el pollo está tierno pero la salsa aún no ha espesado, retirar las presas y cocinar la salsa a fuego medio durante unos 10 minutos hasta que se espese. Rectificar sal y agregar jugo de naranja para equilibrar el sabor amargo de la cerveza."@es .

<http://example.org/recipes/plato-principal/105/step/d29cfbf4f79d4b1db06576aec604f497> a schema1:HowToStep ;
    schema1:text "Espolvorear las presas de pollo o gallina con el comino molido, el achiote molido, sal, y pimienta. Licuar la cerveza y el jugo de naranjilla con el tomate, la cebolla, el ajo, los pimientos, el cilantro, el perejil y el orégano hasta obtener una salsa espesa."@es .

<http://example.org/recipes/plato-principal/106/step/120decf517444e8c852f489762002e18> a schema1:HowToStep ;
    schema1:text "Cocinar a fuego medio por 10 minutos hasta que la salsa se haya reducido y espesado."@es .

<http://example.org/recipes/plato-principal/106/step/235c69f0524b431db07e691a915ead38> a schema1:HowToStep ;
    schema1:text "Escurrir y mezclar con la salsa de albóndigas."@es .

<http://example.org/recipes/plato-principal/106/step/5293d6687e174f7098ce0bd8c94c39d0> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en un sartén a fuego medio y freír las albóndigas."@es .

<http://example.org/recipes/plato-principal/106/step/84b0e63b1e8041ab85e8bbbe34b475fb> a schema1:HowToStep ;
    schema1:text "Colocar la harina en un plato para pasar por ella las albóndigas, se deben sacudir para eliminar el exceso de harina."@es .

<http://example.org/recipes/plato-principal/106/step/88c598fc7ead4eba9d6193ca0e5d6713> a schema1:HowToStep ;
    schema1:text "Retirra la olla del fuego y vertir la salsa sobre las albóndigas."@es .

<http://example.org/recipes/plato-principal/106/step/8ca7a9691fcd4d78b0abb8ed48dd223f> a schema1:HowToStep ;
    schema1:text "Revolver constantemente de 6 a 10 minutos antes de retirar del fuego y dejar reposar."@es .

<http://example.org/recipes/plato-principal/106/step/9761d508c4fd47d6887f17669558f0a8> a schema1:HowToStep ;
    schema1:text "Colocar la carne molida en un recipiente junto con la cebolla, el huevo y el perejil. Hechar sal y pimienta al gusto."@es .

<http://example.org/recipes/plato-principal/106/step/aa185a529709497a8a63071a2d16b19f> a schema1:HowToStep ;
    schema1:text "Forme con las manos húmedas albóndigas pequeñas."@es .

<http://example.org/recipes/plato-principal/106/step/dec1d1e039974a81a3bfc0753c0274a8> a schema1:HowToStep ;
    schema1:text "Decorar con hojas de albahaca y queso parmesano al gusto."@es .

<http://example.org/recipes/plato-principal/106/step/e63d289434eb47e18f7cb7c615fd4af6> a schema1:HowToStep ;
    schema1:text "Colocar en una olla con 1 litro de agua y 2 cucharadas de sal, cuando hierva incorporar los spaghetti y cocinar por 10 minutos o hasta que la pasta esté al dente."@es .

<http://example.org/recipes/plato-principal/106/step/e6b290f62aac4f3cbbaf1e4996811b38> a schema1:HowToStep ;
    schema1:text "Colocar en una olla el tomate pelado sin semillas y picado, la pasta de tomate, sal y pimienta al gusto."@es .

<http://example.org/recipes/plato-principal/106/step/eccbc163db7341ccb9676d6a04c6c874> a schema1:HowToStep ;
    schema1:text "Picar las cebollas en cubos pequeños."@es .

<http://example.org/recipes/plato-principal/107/step/0c1de286715b430e8ad8c5928ab90984> a schema1:HowToStep ;
    schema1:text "Luego en un sarten añadimos un poco de aceite, cebolla en cuadritos, achiote, hiervita, 1 tomate machacado, pimienta, tomate frito, oregano seco y sofreimos todo muy bien."@es .

<http://example.org/recipes/plato-principal/107/step/0fb13a39ab794914a9d1d7d5e60e70f5> a schema1:HowToStep ;
    schema1:text "Primero aliñamos el pescado, colocamos pimienta, comino y sal sal gusto por ambos lados."@es .

<http://example.org/recipes/plato-principal/107/step/440e3e8340b84e8e89cfa360c9829a50> a schema1:HowToStep ;
    schema1:text "Una vez listo podemos acompañar con chifles."@es .

<http://example.org/recipes/plato-principal/107/step/99818974b2744cbe9576153bf56443ff> a schema1:HowToStep ;
    schema1:text "Volteamos y tapamos para que comience a sudar."@es .

<http://example.org/recipes/plato-principal/107/step/ea70f573823d4f4e9d0421531181abf9> a schema1:HowToStep ;
    schema1:text "Agregamos agua y un poco de sal. Revolvemos bien y añadimos los pescados. Durante 5 o 10 minutos."@es .

<http://example.org/recipes/plato-principal/108/step/09957bf6d6ae42f1a571be99f6a8fc13> a schema1:HowToStep ;
    schema1:text "Pasado unos minutos agregamos la carne en trozos, en cuadros pequeños. Si lo desean podemos agregar un poco de cubito de carne. Mezclamos todo muy bien."@es .

<http://example.org/recipes/plato-principal/108/step/1257046052e14ff0ba63823cce4c9afc> a schema1:HowToStep ;
    schema1:text "Para finalizar integramos la salsa junto con la pasta."@es .

<http://example.org/recipes/plato-principal/108/step/12924105630d4f3690a593e6ec393ead> a schema1:HowToStep ;
    schema1:text "Aparte en una olla colocamos agua a cocinar el Spaghetti aproximadamente 1/2 kg de pasta. Una vez listo lo colamos y agregamos mantequilla y aceite de oliva para que no se peguen."@es .

<http://example.org/recipes/plato-principal/108/step/244eeb98da9542bfa5468e345d426496> a schema1:HowToStep ;
    schema1:text "Listo para disfrutar."@es .

<http://example.org/recipes/plato-principal/108/step/37c5b06b7622419ebc6920f10f896079> a schema1:HowToStep ;
    schema1:text "Primero colocaremos en una olla: 1 cebolla morada en cuadritos, un pimiento verde en cuadrito y medio manojo de cilantro. Sofreimos y revolvemos bien y agregamos 2 tomates cortados en cuadritos."@es .

<http://example.org/recipes/plato-principal/108/step/75115baee4144555861adc5e5130fc99> a schema1:HowToStep ;
    schema1:text "Agregamos 1 taza de agua y colocamos todo en nuestra olla de presión por 20 minutos."@es .

<http://example.org/recipes/plato-principal/108/step/7e8607de7fd4454a864cdb94c80827ac> a schema1:HowToStep ;
    schema1:text "Luego agregamos 4 oz de salsa de tomate y revolvemos bien. Una vez integrado todo agregamos 2 cucharadas de pasta de tomate."@es .

<http://example.org/recipes/plato-principal/108/step/f9b4708694004e34afdd966a5bd070dc> a schema1:HowToStep ;
    schema1:text "Sazonamos con 1 cucharadita con sal y pimienta negra."@es .

<http://example.org/recipes/plato-principal/109/step/3215471f1a714a5a9f3214274bdaf60c> a schema1:HowToStep ;
    schema1:text "Agregar el tomate licuado y condimentos adicionales (comino, pasta de tomate) al gusto, cocinar durante 5 minutos."@es .

<http://example.org/recipes/plato-principal/109/step/41eef50e372f45c48cb2db9950867cba> a schema1:HowToStep ;
    schema1:text "Cernir los tallarines en un colador reservando ½ taza de caldo."@es .

<http://example.org/recipes/plato-principal/109/step/632f00770dee4cfcaf326ddacf7e8d9d> a schema1:HowToStep ;
    schema1:text "Hacer un refrito en un sartén grande, con el aceite de achiote, la cebolla blanca, el ajo machacado, el culantro, el orégano, sal, y pimienta."@es .

<http://example.org/recipes/plato-principal/109/step/63bac195cdaf4fb4ac1c5572c343b3e7> a schema1:HowToStep ;
    schema1:text "Servir con arroz blanco y ensalada."@es .

<http://example.org/recipes/plato-principal/109/step/871296648adc4a31867f486cca77736f> a schema1:HowToStep ;
    schema1:text "Reservar las presas de pollos."@es .

<http://example.org/recipes/plato-principal/109/step/97ea7fcf1b2445c7a616efdb99b1de34> a schema1:HowToStep ;
    schema1:text "Cocinar los fideos tallarín y los tomates en el mismo caldo donde se cocinó el pollo por 10 minutos."@es .

<http://example.org/recipes/plato-principal/109/step/9cd2d06e2a10473cb1dff8d42ea38336> a schema1:HowToStep ;
    schema1:text "Licuar los tomates con el caldo y colar para quitar las semillas y la piel del tomate."@es .

<http://example.org/recipes/plato-principal/109/step/bd7deb4463184708acdb0cdc6a60b924> a schema1:HowToStep ;
    schema1:text "Agregar las presas de pollo y los tallarines a la salsa, mezclar bien."@es .

<http://example.org/recipes/plato-principal/109/step/f704900b02ac41e5916019e7a13fb7be> a schema1:HowToStep ;
    schema1:text "Cocinar las presas de pollo en 1 litro de agua y sal por 30 minutos."@es .

<http://example.org/recipes/plato-principal/11/step/0138b3c919ac43c091427ca97c77f216> a schema1:HowToStep ;
    schema1:text "Pelar y rallar finamente los plátanos verdes, hechar un poquito de aceite o achiote para que no se oxide la masa."@es .

<http://example.org/recipes/plato-principal/11/step/0b457afd367c472eb4a6eaa51acbd7dc> a schema1:HowToStep ;
    schema1:text "Dejar cocer hasta obtener una masa dorada, adicione la pasta de maní restante e integre la preparación hasta conseguir una mezcla homogénea que no se pegue.."@es .

<http://example.org/recipes/plato-principal/11/step/112a0f2fcea440a3baa1021271746148> a schema1:HowToStep ;
    schema1:text "En un sartén profundo colocar una parte del refrito con los filetes de pescado."@es .

<http://example.org/recipes/plato-principal/11/step/19167c623aa543cba364cdd2f032fbf9> a schema1:HowToStep ;
    schema1:text "Cortar finamente la cebolla colorada y el pimiento."@es .

<http://example.org/recipes/plato-principal/11/step/1e50ffabe66c4b67bb570d09a7e7b52e> a schema1:HowToStep ;
    schema1:text "Sazonar los filetes de pescado con sal, pimienta y el jugo de los limones."@es .

<http://example.org/recipes/plato-principal/11/step/5a36a117bcd94836844f3d97bd5d5d2b> a schema1:HowToStep ;
    schema1:text "Incorporar el agua y el caldo del pescado y remover constantemente."@es .

<http://example.org/recipes/plato-principal/11/step/7c33df2851904785b41be85c46ac15b5> a schema1:HowToStep ;
    schema1:text "Cocinar los verdes rallados con el refrito restante."@es .

<http://example.org/recipes/plato-principal/11/step/831530d0ebf3412184b8c304e0e007c5> a schema1:HowToStep ;
    schema1:text "Cocinar por treinta minutos."@es .

<http://example.org/recipes/plato-principal/11/step/860b5653e8fe484fb94390bd210fa986> a schema1:HowToStep ;
    schema1:text "Incorporar 1/2 taza de pasta de maní, dejar cocer por un minuto y retirar del fuego."@es .

<http://example.org/recipes/plato-principal/11/step/a4110c51a9a541ecb339ed4b0672bafd> a schema1:HowToStep ;
    schema1:text "Hacer un refrito en aceite o achiote con cebolla, ajo y pimiento."@es .

<http://example.org/recipes/plato-principal/11/step/a9bb17a7c79d4be88067f6ef86f83116> a schema1:HowToStep ;
    schema1:text "Retirar la olla del fuego y armar los bollos añadiendo el cilantro."@es .

<http://example.org/recipes/plato-principal/11/step/b785cf26f3df495cb4581f07a764227b> a schema1:HowToStep ;
    schema1:text "Extender las hojas de plátano sobre su mesa de trabajo. Distribuir la masa de verde y encima el refrito del pescado, luego envolver y llevar a una tamalera con agua hirviendo."@es .

<http://example.org/recipes/plato-principal/11/step/bd40b731b714473a8d083e91cfc6d089> a schema1:HowToStep ;
    schema1:text "Retirar la piel y las semillas de los tomates y cortarlos en dados."@es .

<http://example.org/recipes/plato-principal/11/step/e136912a90834815b21c08f22b45bc57> a schema1:HowToStep ;
    schema1:text "Cocinar por 5 minutos y separar en 2 partes el refrito."@es .

<http://example.org/recipes/plato-principal/11/step/f9c00941f0ff410f96a8d9df4c4cb5bb> a schema1:HowToStep ;
    schema1:text "Incorporar el tomate y sazonar con sal, pimienta y comino."@es .

<http://example.org/recipes/plato-principal/110/step/4352693bd0d542bdb88977a9cad7dcbb> a schema1:HowToStep ;
    schema1:text "Luego agregue la pulpa de cangrejo y sofría bien con el resto de los ingredientes."@es .

<http://example.org/recipes/plato-principal/110/step/51e464c85fe14670a0592466b0986a1e> a schema1:HowToStep ;
    schema1:text "Cocine los tallarines en agua suficiente con un poco de sal, durante el tiempo que especifique el paquete. Cuele y pase por agua fría para detener la cocción."@es .

<http://example.org/recipes/plato-principal/110/step/8561054ab1404c03a79228a937376c8a> a schema1:HowToStep ;
    schema1:text "En una sartén, derrita la mantequilla con el aceite. Sofría las cebollas coloradas, los tomates, las cebollas y el ajo, hasta que queden transparentes. Añada la pasta de tomate disuelta en un poco de agua e incorpore el laurel, el orégano, sal y comino al gusto."@es .

<http://example.org/recipes/plato-principal/110/step/8eb0da67b0444eaaa8fc687b97c5cd34> a schema1:HowToStep ;
    schema1:text "Incorpore los fideos cocidos y remueva todo para que se integren los sabores."@es .

<http://example.org/recipes/plato-principal/110/step/a95444d652544707911d767cf94a9743> a schema1:HowToStep ;
    schema1:text "Servir el plato bien caliente, decorado con tenazas de cangrejo y cilantro picadito."@es .

<http://example.org/recipes/plato-principal/111/step/0bd01cebb07844fe96d18c407c2a0ea8> a schema1:HowToStep ;
    schema1:text "Para la masa, coloque en un bol el arroz cocido y añada los huevos y el queso rallado. Incorpore un punto de sal y mezcle bien hasta obtener una masa homogénea."@es .

<http://example.org/recipes/plato-principal/111/step/15a9aabe41014fa8962264d85c951fb4> a schema1:HowToStep ;
    schema1:text "Sirva los tamales bañados en la salsa de maní. Acompañe con patacones y curtidos de cebollas."@es .

<http://example.org/recipes/plato-principal/111/step/1d9afed5476a4f42a94502dc5c0db5cf> a schema1:HowToStep ;
    schema1:text "Tomar la col y deshojarla cuidadosamente. Lave bien las hojas y cocínelas al vapor por unos 4 minutos hasta que ablanden."@es .

<http://example.org/recipes/plato-principal/111/step/5091bd6706074b269e3f7f0a9d2104b8> a schema1:HowToStep ;
    schema1:text "Para obtener el relleno, coloque la carne desmenuzada en un bol y mezcle con media taza de salsa de maní."@es .

<http://example.org/recipes/plato-principal/111/step/5170429cffe64eacb139b754c7be9e8e> a schema1:HowToStep ;
    schema1:text "En una olla con agua, cocine la carne de cerdo con una cebolla cortada en trozos, ajo, hierbas, sal, comino y un poco de pimienta. Dejar hervir por unos 30 minutos hasta que la carne quede blanda. Retire la carne, espere que enfríe y desmenuce. Reserve."@es .

<http://example.org/recipes/plato-principal/111/step/51a0dedbfe8c41adbc564d574c1c267a> a schema1:HowToStep ;
    schema1:text "Coloque una buena porción de la masa sobre una hoja de col. Encima coloque un poco de relleno de carne con salsa de maní y adorne con una rodaja de tomate y perejil picadito. Haga doblez con la hoja de col para darle forma del tamal."@es .

<http://example.org/recipes/plato-principal/111/step/9fdfed39c924428dae202a3478f4dc35> a schema1:HowToStep ;
    schema1:text "Coloque los tamales en un sartén y coloque un poco del caldo de cerdo. Espolvoree un poco de hiervas encima y cocine tapado por unos 20 minutos."@es .

<http://example.org/recipes/plato-principal/111/step/db0b774c2dc746368190fc524f8254fa> a schema1:HowToStep ;
    schema1:text "Para preparar la salsa de maní, coloque en una sartén el aceite de achiote y sofría 2 cebollas en julianas hasta que transparenten. Añada el maní previamente licuado con leche y crema de leche. Condimenta con sal y pimienta. Deje enfriar."@es .

<http://example.org/recipes/plato-principal/112/step/2b1e314314a345dd9fd2ba5d4fe554dc> a schema1:HowToStep ;
    schema1:text "Servir incluyendo limón al gusto."@es .

<http://example.org/recipes/plato-principal/112/step/4baa31482a494362b8714e00be596f33> a schema1:HowToStep ;
    schema1:text "Picar la cebolla colorada, los pimiento y el tomate en brunoise o cuadrados muy pequeños."@es .

<http://example.org/recipes/plato-principal/112/step/7e48300b19f747bd9ad3d7cdf7f60764> a schema1:HowToStep ;
    schema1:text "Colocar el plátano verde y la longaniza y volver a mezclar."@es .

<http://example.org/recipes/plato-principal/112/step/92860ded85304a5f9322c616ab1b0766> a schema1:HowToStep ;
    schema1:text "Machacar el ajo y picar las hojas de chilangua o de albahaca."@es .

<http://example.org/recipes/plato-principal/112/step/9aaa33493b67470aab7b3a450d770ab9> a schema1:HowToStep ;
    schema1:text "Trocear la longaniza, separar sólo la carne de la pechuga de pollo y cortar en trozitos."@es .

<http://example.org/recipes/plato-principal/112/step/a5d9057f4f6e434f8f283601482dc2e8> a schema1:HowToStep ;
    schema1:text "Cortar los plátanos en laminas muy finas."@es .

<http://example.org/recipes/plato-principal/112/step/b530e843044c4f27b335a2155d986bc2> a schema1:HowToStep ;
    schema1:text "Tapar con hojas de verde hasta que termine de cocinarse."@es .

<http://example.org/recipes/plato-principal/112/step/d7ad4cb3749b4caa8e5c7f596255fc3b> a schema1:HowToStep ;
    schema1:text "Hechar las hojas picadas de chilangua o de albahaca."@es .

<http://example.org/recipes/plato-principal/112/step/db442c9db37f4de3a3d27017a6ba8585> a schema1:HowToStep ;
    schema1:text "Hechar las costillas de res (trozos) en el refrito, mezclar muy bien."@es .

<http://example.org/recipes/plato-principal/112/step/ec4303315ac94e4e9fd519458481b0cf> a schema1:HowToStep ;
    schema1:text "Hacer un refrito con el achiote, el ajo machacado, la cebolla, los pimientos y el tomate. Colocar sal y pimienta al gusto."@es .

<http://example.org/recipes/plato-principal/112/step/f25e4fda4426463cabb5895c468e5c29> a schema1:HowToStep ;
    schema1:text "Hechar la carne de cerdo (trozos)) y mezclar muy bien con el refrito."@es .

<http://example.org/recipes/plato-principal/113/step/09685a5afed748ef9c6f06e5b1c82890> a schema1:HowToStep ;
    schema1:text "Cortar los plátanos verdes y la longaniza y añadir al sofrito."@es .

<http://example.org/recipes/plato-principal/113/step/1ec1d218ae4c4859b6a6310873eff0e4> a schema1:HowToStep ;
    schema1:text "Colocar las carnes en el refrito y mezclar para integrar los ingredientes."@es .

<http://example.org/recipes/plato-principal/113/step/2e06a0a1ddfa471f8c909c00d554c3d5> a schema1:HowToStep ;
    schema1:text "Dejar cocinar hasta que se maceren todos los ingredientes."@es .

<http://example.org/recipes/plato-principal/113/step/627c78ab6e1b4187b0476b56fafa996d> a schema1:HowToStep ;
    schema1:text "Servir en cazuelas individuales con limón."@es .

<http://example.org/recipes/plato-principal/113/step/635a85ff6c2342c7a1f54749d335908a> a schema1:HowToStep ;
    schema1:text "Sofreír la pasta de ajo, los vegetales picados, salpimentar y colocar una pizca de achiote."@es .

<http://example.org/recipes/plato-principal/113/step/6b92259a432c4a57875df3ab9823085c> a schema1:HowToStep ;
    schema1:text "Comenzar cortando en trozos las carnes. Reservar."@es .

<http://example.org/recipes/plato-principal/113/step/70f5fe3aad524a5aa62e5c37307f06e3> a schema1:HowToStep ;
    schema1:text "Picar los vegetales en cubos bien pequeños."@es .

<http://example.org/recipes/plato-principal/113/step/ea1d1df6381d44548cefc61c0bbf317c> a schema1:HowToStep ;
    schema1:text "En un machete aplastar el ajo y la albahaca."@es .

<http://example.org/recipes/plato-principal/114/step/4df502722ae6412f8da14d5ee22746bb> a schema1:HowToStep ;
    schema1:text "Añada la cebolla, el tomate, el pimiento, el ajo y las hierbas. Agregue un poco de sal, comino, achiote y exprima el jugo de un limón. Tapar bien y deje que cocine a fuego medio por 25 minutos."@es .

<http://example.org/recipes/plato-principal/114/step/60d2448977be47e4b607093a76018553> a schema1:HowToStep ;
    schema1:text "Espere que repose un poco y sirva."@es .

<http://example.org/recipes/plato-principal/114/step/8d1b70907d5f4abc82eb162609bd38b1> a schema1:HowToStep ;
    schema1:text "Luego de este tiempo, revise la sazón y bañe el pescado con el caldo. Tape nuevamente y deje cocinar por unos 5 minutos."@es .

<http://example.org/recipes/plato-principal/114/step/a7e28f0d7a5c4e4892ee5b03a965627f> a schema1:HowToStep ;
    schema1:text "En una olla coloque los verdes y cubra por la mitad con agua. Coloque encima el pescado cortado en trozos."@es .

<http://example.org/recipes/plato-principal/114/step/d5fca631e6314b6fa6d8d8949098b853> a schema1:HowToStep ;
    schema1:text "Limpiar bien el pescado, lavarlo con agua y limón. Añada un poco de sal."@es .

<http://example.org/recipes/plato-principal/114/step/d9c18651afd04441be4bb4c872bb4112> a schema1:HowToStep ;
    schema1:text "Suele acompañarse con arroz y cebollas encurtidas y una buena agua de limoncillo."@es .

<http://example.org/recipes/plato-principal/115/step/0b9f9dc38d144c99a85820819ac83973> a schema1:HowToStep ;
    schema1:text "Batir el huevo en un plato y pasar los filetes de la tilapia."@es .

<http://example.org/recipes/plato-principal/115/step/2916376e43d14933aa4b41002fb6d822> a schema1:HowToStep ;
    schema1:text "En otro plato mezclar la harina y la pimienta, pasar el filete también por esta mezcla y empapar por ambos lados."@es .

<http://example.org/recipes/plato-principal/115/step/3aa11da5911146a489190977a4422b48> a schema1:HowToStep ;
    schema1:text "Servir acompañado con arroz blanco y/o ensalada."@es .

<http://example.org/recipes/plato-principal/115/step/3dea33c01bde4395824e4ba0a2a113dc> a schema1:HowToStep ;
    schema1:text "Lavar y secar el pescado y adobar los filetes con limón, ajo, paprika y sal, guardar por 1 o 2 horas."@es .

<http://example.org/recipes/plato-principal/115/step/d12adb2835674a03a45ef54b210f943b> a schema1:HowToStep ;
    schema1:text "Calentar un sartén con aceite y colocar los filetes hasta que se doren."@es .

<http://example.org/recipes/plato-principal/116/step/1c02121253fe4c599342524848a4b50f> a schema1:HowToStep ;
    schema1:text "Batir el huevo y dejar los filetes reposando media hora."@es .

<http://example.org/recipes/plato-principal/116/step/6ffd818380b8400290cb3895ae948490> a schema1:HowToStep ;
    schema1:text "Comenzar adobando el pescado con limón, ajo, pimienta y sal, dejar reposar por unas horas."@es .

<http://example.org/recipes/plato-principal/116/step/77c71f50d7e34a689d774bfea0fe6975> a schema1:HowToStep ;
    schema1:text "Servir caliente acompañado con arroz."@es .

<http://example.org/recipes/plato-principal/116/step/afafc0596aa843ec9cf2ff11e54aa52d> a schema1:HowToStep ;
    schema1:text "Colocar en un recipiente la harina tamizada, pasar los filetes por la misma y dar pequeños golpes de ambos lados."@es .

<http://example.org/recipes/plato-principal/116/step/cb61ce4945f148118f970b067c08d334> a schema1:HowToStep ;
    schema1:text "En una sartén precalentada con aceite a fuego medio, freír los filetes hasta que se doren."@es .

<http://example.org/recipes/plato-principal/117/step/3048cd24476541c3820487adbb0c44e4> a schema1:HowToStep ;
    schema1:text "Encender el fuego con leña o carbón hasta hacer brasas, recién allí colocar las tripas en trozos medianos y asarlas hasta que broten jugos."@es .

<http://example.org/recipes/plato-principal/117/step/56448478999d42ceb0000b01ed6d916b> a schema1:HowToStep ;
    schema1:text "Comenzar lavando muy bien la tripa, luego de esto hay que curarla con vinagre por una hora."@es .

<http://example.org/recipes/plato-principal/117/step/6219bb9fa54b4ab08072ac585dbb93f2> a schema1:HowToStep ;
    schema1:text "Una vez que las tripas estén asadas y secas, servir con papas y mote."@es .

<http://example.org/recipes/plato-principal/117/step/d05f89eed39a44b4a121505a22b5292e> a schema1:HowToStep ;
    schema1:text "Colocar las tripas en un recipiente con el limón, la hierba buena, el ajo, el comino, el achiote, salar y dejar reposar 2 horas."@es .

<http://example.org/recipes/plato-principal/118/step/2091e3b38c26460bbdb425819e2c743e> a schema1:HowToStep ;
    schema1:text "Encender previamente la brasa o la parrilla, cortar las tripas en trozos medianos y asarlas muy bien por ambos lados durante unos 10 minutos hasta que los jugos comiencen a brotar."@es .

<http://example.org/recipes/plato-principal/118/step/765bcf1ad11a4bb88859c43b9c3262ee> a schema1:HowToStep ;
    schema1:text "Lavar muy bien las tripas para que no queden residuos desagradables. Colocarlas en un tazón con el jugo de limón, la hierba buena, el ajo, el comino, el achiote y sal, mezclar bien y dejar reposar durante unos 45 minutos."@es .

<http://example.org/recipes/plato-principal/118/step/f744e4690bf14e469ac52b0fdd384c97> a schema1:HowToStep ;
    schema1:text "Una vez que las tripas estén asadas, cortar en trocitos y servir con mote y papas. Acompañarlas con ají criollo."@es .

<http://example.org/recipes/plato-principal/12/step/05bc8776b3dd432887f9f749cfa24aac> a schema1:HowToStep ;
    schema1:text "En una cacerola se colocan los filetes con la mitad del sofrito y la pasta de maní, se deja reposar fuera del fuego."@es .

<http://example.org/recipes/plato-principal/12/step/09f39d0ddaa940e3b05d34f0456cc652> a schema1:HowToStep ;
    schema1:text "Comenzar cortando la cebolla y el pimiento en finas rodajas, los tomates en cubos y los plátanos verdes rallados."@es .

<http://example.org/recipes/plato-principal/12/step/1672bc694030404392dfb5b19a6ae443> a schema1:HowToStep ;
    schema1:text "Se dejara a fuego lento hasta obtener una masa dorada."@es .

<http://example.org/recipes/plato-principal/12/step/5d141554914c47d99b83b0285c491f85> a schema1:HowToStep ;
    schema1:text "Con el sofrito restante cocinar los verdes que fueron rallados inicialmente e incorporarles el caldo y el agua."@es .

<http://example.org/recipes/plato-principal/12/step/78f2fe529ce94f24bbd3815fcd7930b0> a schema1:HowToStep ;
    schema1:text "Cocinar por 10 minutos y dividir la preparación en dos recipientes."@es .

<http://example.org/recipes/plato-principal/12/step/8acf9e4ddedd44f3bd9b96dd350468f4> a schema1:HowToStep ;
    schema1:text "Para el armado extender las hojas de plátano y colocar la masa y por encima el pescado, luego envolver y llevar a la vaporera por treinta minutos."@es .

<http://example.org/recipes/plato-principal/12/step/b645d77afcba4b9f8c23eab328017aa3> a schema1:HowToStep ;
    schema1:text "Condimentar los filetes de pescado agregándoles también jugo de los limones."@es .

<http://example.org/recipes/plato-principal/12/step/f232aa0a44434e91b37313b64b05d405> a schema1:HowToStep ;
    schema1:text "Sofreír las cebollas y el pimiento en aceite caliente, sumándole los ajos. Añadir posteriormente el tomate y condimentar con sal, pimienta y comino."@es .

<http://example.org/recipes/plato-principal/13/step/13e50523d1ce453a9a3268becc2f032d> a schema1:HowToStep ;
    schema1:text "Agregar todo el vino blanco y dejar que se reduzca por la mitad."@es .

<http://example.org/recipes/plato-principal/13/step/158fafff30b344eb8fa7694297de9d91> a schema1:HowToStep ;
    schema1:text "Espolvorear con perejil picado finamente."@es .

<http://example.org/recipes/plato-principal/13/step/5dea768ea01e497391897116d343e837> a schema1:HowToStep ;
    schema1:text "Agregar sal y pimienta al gusto a los camarones o langostinos."@es .

<http://example.org/recipes/plato-principal/13/step/92f2a9fe178a40a8ac492793d699e5e1> a schema1:HowToStep ;
    schema1:text "Derretir la mantequilla o calentar el aceite en una sartén."@es .

<http://example.org/recipes/plato-principal/13/step/c8c3818941a0475d814194f2c971ad73> a schema1:HowToStep ;
    schema1:text "Picar finamente o machacar el ajo y sofreír en el sartén por 1 minuto."@es .

<http://example.org/recipes/plato-principal/13/step/d779a9ab40dc44af947af080ddb12b2f> a schema1:HowToStep ;
    schema1:text "Agregar los camarones y colocarlos en el sartén y dejar cocinar por ambos lados."@es .

<http://example.org/recipes/plato-principal/13/step/e0f7663eeeb247e89ab6b91002b18b9d> a schema1:HowToStep ;
    schema1:text "Servir los camarones al ajillo con arroz blanco, patacones y/o ensalada de vegetales."@es .

<http://example.org/recipes/plato-principal/13/step/f5f9b11878b14425888a1f986d0ac56f> a schema1:HowToStep ;
    schema1:text "Añadir la crema de leche y dejar hervir hasta que los camarones o langostinos estén a su punto."@es .

<http://example.org/recipes/plato-principal/14/step/13f2ba9e722b4517a6d289df61530522> a schema1:HowToStep ;
    schema1:text "Servirlos con patacones, encurtidos y arroz."@es .

<http://example.org/recipes/plato-principal/14/step/cfea74915e7846a89602c11f0acbd168> a schema1:HowToStep ;
    schema1:text "Freír en aceite bien caliente."@es .

<http://example.org/recipes/plato-principal/14/step/ece25d239b4f45dcaebc1d8eb114aee3> a schema1:HowToStep ;
    schema1:text "En un bol colocar los camarones y bañarlos con jugo de limón, ajo, sal y pimienta. Se dejan marinando por unos minutos y luego se añade el huevo batido encima."@es .

<http://example.org/recipes/plato-principal/14/step/f362c6dccab64a00b5fbe20f214923ac> a schema1:HowToStep ;
    schema1:text "Sacar los camarones y pasarlos por harina."@es .

<http://example.org/recipes/plato-principal/15/step/0e7d9506bb524099b1c573fdfdfbedd0> a schema1:HowToStep ;
    schema1:text "Agregar los cangrejos uno a uno hasta que queden totalmente tapados con el agua. Añadir la cerveza y los plátanos cortados con cáscaras."@es .

<http://example.org/recipes/plato-principal/15/step/63d00507280e44f2916891046dcfa53b> a schema1:HowToStep ;
    schema1:text "Esperar a que los cangrejos se pongan de color rojo y dejar hervir unos 10 minutos más. Sacar los cangrejos de la olla y pasarlos rápidamente agua fría para que la carne se ablande."@es .

<http://example.org/recipes/plato-principal/15/step/6cd0f1950f124c5aac1c70f5f59a843c> a schema1:HowToStep ;
    schema1:text "Lavar muy bien los cangrejos con un cepillo de cerdas duras. Verificar que todos los cangrejos estén vivos, los muertos se desechan (aunque hay quienes les prefieren matarlos antes de meterlos a la olla y hay otras personas que los meten vivos)."@es .

<http://example.org/recipes/plato-principal/15/step/79b01f3f01894a98b525e01b1b85272c> a schema1:HowToStep ;
    schema1:text "Colocar las cebollas, el cilantro, el ajo, el orégano, el comino, la pimienta y la sal en una olla grande con agua y esperar hasta que el agua hierva."@es .

<http://example.org/recipes/plato-principal/15/step/a13a17189dae4686be366e8eca4e0748> a schema1:HowToStep ;
    schema1:text "Servir la cangrejada en bandejas grandes acompañada de los plátanos cocinados, salsa de cebollas, plátanos fritos y canguil."@es .

<http://example.org/recipes/plato-principal/16/step/1d9a5a0c13d546d58b7642aa5cbfe860> a schema1:HowToStep ;
    schema1:text "Servir en platos hondos acompañada de los plátanos fritos y una ensalada de canguil."@es .

<http://example.org/recipes/plato-principal/16/step/24f8a037ae1e4325b3e38970a2cbbd7b> a schema1:HowToStep ;
    schema1:text "Revolver la preparación esporádicamente y una vez que los cangrejos estén rojos hervir por unos 15 minutos más."@es .

<http://example.org/recipes/plato-principal/16/step/9e88422a4d744b6392c330238d56155e> a schema1:HowToStep ;
    schema1:text "Colocar en una cacerola con agua las cebollas, el ajo y los condimentos y esperar hasta que el agua hierva."@es .

<http://example.org/recipes/plato-principal/16/step/c1274b4f0ae84a9fafb5c24bfbcf5085> a schema1:HowToStep ;
    schema1:text "Lo fundamental para comenzar la preparación es lavar muy bien los cangrejos y desechar aquellos que estén muertos."@es .

<http://example.org/recipes/plato-principal/16/step/c59252d0e87645b29f16838e4ffb0440> a schema1:HowToStep ;
    schema1:text "Retirar los cangrejos de la olla y pasarlos por agua fría para ablandarlos."@es .

<http://example.org/recipes/plato-principal/16/step/ed7662e2eaa94a238f54a924e52c5d9d> a schema1:HowToStep ;
    schema1:text "Agregar los cangrejos hasta que queden cubiertos completamente y recién allí agregar la cerveza y los plátanos cortados en rodajas con sus cáscaras."@es .

<http://example.org/recipes/plato-principal/17/step/1804a9e5d0564be19126d3acbcb8479a> a schema1:HowToStep ;
    schema1:text "Comenzar la preparación cocinando los plátanos maduros a fuego bajo en una cacerola con agua y mantequilla, revolviendo continuamente para que no se pegue."@es .

<http://example.org/recipes/plato-principal/17/step/1c44353a0e2746a3bafa5238b3c64532> a schema1:HowToStep ;
    schema1:text "Para el armado lavar los carapachos y poner la preparación en su interior sobre una cama de hojas de lechuga y con unas aceitunas arriba."@es .

<http://example.org/recipes/plato-principal/17/step/701fb1b995bd4efdbe959aa17ade5813> a schema1:HowToStep ;
    schema1:text "Cuando estén cocidos los maduros, realizar con ellos un pure homogéneo, e ir agregándole el azúcar en forma de lluvia junto con la esencia de vainilla."@es .

<http://example.org/recipes/plato-principal/17/step/e50421e4d22b440eb100cdbc5c20a09f> a schema1:HowToStep ;
    schema1:text "A la preparación agregarle la carne de cangrejo."@es .

<http://example.org/recipes/plato-principal/18/step/306296c6b99a47b0b543d5ac4a5f9cb5> a schema1:HowToStep ;
    schema1:text "Cocinar los maduros a fuego lento con agua y mantequilla, mover continuamente la mezcla para que no se pegue."@es .

<http://example.org/recipes/plato-principal/18/step/3806db6da693472a9720d673c4ae73b2> a schema1:HowToStep ;
    schema1:text "Majar el maduro cuando este completamente cocinado, dejarlo sin grumos. Poco a poco se va agregando azúcar, al igual que la esencia de vainilla."@es .

<http://example.org/recipes/plato-principal/18/step/81b93b8ceeb24812b0a3df0f3c565793> a schema1:HowToStep ;
    schema1:text "Mezclar con la carne de cangrejo y agregar las pasas."@es .

<http://example.org/recipes/plato-principal/18/step/83fcdc8395004086a2b19533d940044a> a schema1:HowToStep ;
    schema1:text "Lavar los carapachos y poner la preparación en su interior, sobre una cama de lechuga y con una aceituna encima."@es .

<http://example.org/recipes/plato-principal/19/step/015be075c5e14389a3f0d177e53bd4c1> a schema1:HowToStep ;
    schema1:text "Licuar los dientes de ajo, la cebolla colorada, el achiote molido, el orégano, 2 cucharaditas de sal, el jugo de limón y la cerveza hasta obtener un puré."@es .

<http://example.org/recipes/plato-principal/19/step/6dcc3450f77848d596d648076e707c9d> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una sartén de buen tamaño, agregar las semillas de achiote y cocinar a fuego lento durante unos 15 minutos hasta que el color de las semillas se haya transferido al aceite. Retirar las semillas del aceite."@es .

<http://example.org/recipes/plato-principal/19/step/a6df2b49b1f04009b106057b02e7a215> a schema1:HowToStep ;
    schema1:text "Anadir la carne al mismo sartén con el aceite de achiote. Cocinar hasta que todo el líquido se haya reducido y la carne se empiece a dorar. Revolver con frecuencia y ajustar la sal."@es .

<http://example.org/recipes/plato-principal/19/step/c3cacf8c40574d97abbb3309345d6256> a schema1:HowToStep ;
    schema1:text "Servir la carne colorada acompañada con aguacate, curtido de cebolla, chulpi y otras guarniciones ecuatorianas."@es .

<http://example.org/recipes/plato-principal/19/step/f2b1f54e4bf148288153c36a5cc52a9c> a schema1:HowToStep ;
    schema1:text "Colocar los trozos de carne y el licuado en un tazón de vidrio o plástico, cubrir y dejar reposar en la refrigeradora durante unas 2 horas."@es .

<http://example.org/recipes/plato-principal/2/step/38db36bb330747929b6fe053381d1367> a schema1:HowToStep ;
    schema1:text "Servir el arroz con los camarones sin pelar como guarnición y acompañado de aguacate, curtido de cebolla, tomates y ají."@es .

<http://example.org/recipes/plato-principal/2/step/3f15e301b87b4a12b9fc34978067bdcb> a schema1:HowToStep ;
    schema1:text "Hervir suficiente agua en una olla grande, añadir los camarones y dejar hervir por 2 minutos. Sacar los camarones del agua y guarde 2½ tazas del agua que se cocinó."@es .

<http://example.org/recipes/plato-principal/2/step/782e47243b124ac787359463f58edb9d> a schema1:HowToStep ;
    schema1:text "Añadir el arroz y mezclar bien, agregar las 2½ tazas de agua donde se cocinaron los camarones. Esperar hasta que el agua hierva y reducir la temperatura."@es .

<http://example.org/recipes/plato-principal/2/step/a950c694fa7a4ab9b4a96eeacf7dc33c> a schema1:HowToStep ;
    schema1:text "Sazonar los camarones con sal, pimienta, 1 cucharadita de comino y el ajo machacado. Dejar reposar durante 1 hora en la refrigeradora."@es .

<http://example.org/recipes/plato-principal/2/step/bb0229e4ce7c47c3a43f14b6b7af55ec> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una olla para hacer el arroz, añadir el ajo picado y cocinar a fuego medio durante unos 3 minutos."@es .

<http://example.org/recipes/plato-principal/2/step/c147d52938e644b7b55fc5651f1bbe4d> a schema1:HowToStep ;
    schema1:text "Agregar el refrito y los camarones picados al arroz, que aún se está cocinando, y cocinar a fuego lento hasta que el arroz esté listo. Añadir los camarones enteros y mezclar bien. Rectificar la sal y espolvorear con perejil restante."@es .

<http://example.org/recipes/plato-principal/2/step/c41094d2f1d4411697e743ac690665a3> a schema1:HowToStep ;
    schema1:text "Derretir la mantequilla en un sartén de buen tamaño y agregar la cebolla, el pimiento, los tomates, la mitad del perejil, el achiote molido, la cucharadita restante de comino, sal y pimienta. Cocinar durante 10 minutos, revolviendo de vez en cuando. Añadir el vino blanco y cocinar durante 5 minutos más."@es .

<http://example.org/recipes/plato-principal/2/step/dd1c9b7b5c724d3fae6bc30ce2b21f20> a schema1:HowToStep ;
    schema1:text "Pelar los camarones, guardando algunos sin pelar para utilizar como guarnición. Picar la mitad de los camarones y dejar la otra mitad enteros."@es .

<http://example.org/recipes/plato-principal/20/step/01a2a4d0342d4a71b9d8fc5d4010f4d0> a schema1:HowToStep ;
    schema1:text "Seguido de que se coloca esta salsa en una olla o bol, se agrega a esta mezcla los trozos de carne, se deja marinar durante dos horas, también se puede durante un dia para que adquiera mas sabor."@es .

<http://example.org/recipes/plato-principal/20/step/241ea55af7054a39a0a9c81b916925df> a schema1:HowToStep ;
    schema1:text "Luego se pone otra olla a calentar cuando este caliente, se colocan los trozos de carne que están marinados en la cacerola caliente sin aceite, y se dejan para que doren por todos lados, luego ya dorados se le agrega todo el liquido para que se cocine. Lo dejamos tapado a fuego lento durante 45 minutos. Ya pasado los 45 minutos esta listo."@es .

<http://example.org/recipes/plato-principal/20/step/6e05e02c4a544df5acc9792978748ffb> a schema1:HowToStep ;
    schema1:text "Luego agregamos a este licuado sal y pimienta para sasonar y volvemos a licuar. Le vamos agregando un poquito de aceite a la licuadora para que se espese y apagamos. Se coloca esta salsa en un bol"@es .

<http://example.org/recipes/plato-principal/20/step/a20958ffea0d4de182ffc99a109410cd> a schema1:HowToStep ;
    schema1:text "Colocamos en la licuadora: El achiote, el comino, oregano, ajo, cebolla colorada, el jugo de un limón y bañamos todo esto con una cerveza. Lo licuamos muy bien."@es .

<http://example.org/recipes/plato-principal/20/step/e0d3a4861ba04ce1af4b9fb3407cd754> a schema1:HowToStep ;
    schema1:text "Este sabroso plato se acompaña con arroz, maduro y aguacate."@es .

<http://example.org/recipes/plato-principal/21/step/2607eadc995e4257a1edd3ee021a18a0> a schema1:HowToStep ;
    schema1:text "Agregar las papas con la mantequilla y el cilantro y cocinar hasta que estén tiernas."@es .

<http://example.org/recipes/plato-principal/21/step/26779722216e43f2a222ff2d3c6b7ae5> a schema1:HowToStep ;
    schema1:text "Servir caliente, en cazuelas individuales, espolvoreado con perejil."@es .

<http://example.org/recipes/plato-principal/21/step/2c364dbaca5e4206a57358c454511c0b> a schema1:HowToStep ;
    schema1:text "Procesar el choclo con la leche formando una pasta, colocar en el caldo."@es .

<http://example.org/recipes/plato-principal/21/step/cbfeb16921db48c280f623d2f5551da4> a schema1:HowToStep ;
    schema1:text "Colocar en una olla la carne con la cebolla picada, el tomate cortado en cubos, el ajo, las especias y cocinar a fuego bajo por una hora."@es .

<http://example.org/recipes/plato-principal/22/step/3961599c5e344d808864eca55e9f89cd> a schema1:HowToStep ;
    schema1:text "Retirar el refrito del fuego y mezclar con 4 cucharas de pasta de mani y reservar."@es .

<http://example.org/recipes/plato-principal/22/step/3ca7b1671cf54a9d958426dbce0a5c4a> a schema1:HowToStep ;
    schema1:text "Lavar, pelar y rayar lo plátanos verdes agregando un poquito de aceite o achiote para que no se oxide."@es .

<http://example.org/recipes/plato-principal/22/step/48f62b4c18f9460b902c9ed4bf15f8ba> a schema1:HowToStep ;
    schema1:text "Llevar al horno a 180ºc hasta que se dore."@es .

<http://example.org/recipes/plato-principal/22/step/708c478e60cd40a695879529ed8bb5a5> a schema1:HowToStep ;
    schema1:text "Agregar el maní restante cuando esté hirviendo y dejar por 30 minutos para que se cocine el verde y se mezclen los sabores. Revolver constantemente."@es .

<http://example.org/recipes/plato-principal/22/step/7f408a6025f3440cb4718b921a80a6c7> a schema1:HowToStep ;
    schema1:text "Retirar y agregar el cilantro picado"@es .

<http://example.org/recipes/plato-principal/22/step/a25093fc1865460598c8aac271bf85e9> a schema1:HowToStep ;
    schema1:text "Cortar las cebollas finamente en cubos pequeños y picar finamente los tomates y pimientos."@es .

<http://example.org/recipes/plato-principal/22/step/a2b3b60aedd64dda83dd324e2dbca3d0> a schema1:HowToStep ;
    schema1:text "Cocinar el verde rallado en el consomé de pescado o agua y un poco mas de la mitad del refrito (Condimentar con sal, comino y pimienta)."@es .

<http://example.org/recipes/plato-principal/22/step/c0d4e2bfa7be422cb4cb40fc96d2a412> a schema1:HowToStep ;
    schema1:text "Hacer un refrito en un sartén con aceite o achiote con las cebollas, los pimientos, el ajo, el tomate, sal, pimienta y comino."@es .

<http://example.org/recipes/plato-principal/22/step/e1d3d8a867a74139a439e5a1b66e9ac2> a schema1:HowToStep ;
    schema1:text "En una cazuela de barro colocar una porción de la masa de plátano verde, acomodar los filetes de pescado y agregar bastante salsa de maní bien esparcida y luego agregar la última capa de plátano verde."@es .

<http://example.org/recipes/plato-principal/22/step/ea4612b1384d45d492c5836888cd858e> a schema1:HowToStep ;
    schema1:text "Aliñar los filetes de pescado con comino, sal y pimienta."@es .

<http://example.org/recipes/plato-principal/23/step/3117e4d37e814f08aec33170b5d66f45> a schema1:HowToStep ;
    schema1:text "Preparar una ensalada con tomate, cebolla, jugo de limón, aceite y cilantro picadito."@es .

<http://example.org/recipes/plato-principal/23/step/5598938df9fa4285969e30624b35dd8a> a schema1:HowToStep ;
    schema1:text "Sirva la carne asada acompañada de yuca cocida y la ensalada."@es .

<http://example.org/recipes/plato-principal/23/step/5d8a9a5553da41689e8d076ad95f2504> a schema1:HowToStep ;
    schema1:text "Ase la carne sobre una grill con brasas."@es .

<http://example.org/recipes/plato-principal/23/step/6b18d775d2ec455cb6093d95bdeef752> a schema1:HowToStep ;
    schema1:text "En una fuente coloque los filetes de cerdo y adobe con sal, pimienta, ajo y comino al gusto. Añada el aceite de achiote, y deje secar al sol por unas horas."@es .

<http://example.org/recipes/plato-principal/23/step/dbd75d0d59e44a36b455fab8d350f53b> a schema1:HowToStep ;
    schema1:text "Con ayuda de un cuchillo bien filoso, filetee el lomo de cerdo."@es .

<http://example.org/recipes/plato-principal/24/step/0b46f8a7f61b4fb996e7e2919b884182> a schema1:HowToStep ;
    schema1:text "Coloque la pulpa de tamarindo con 1 taza de agua y mezclar. Hervir por cinco minutos."@es .

<http://example.org/recipes/plato-principal/24/step/8c80d22056924d2288412a7d79f3f092> a schema1:HowToStep ;
    schema1:text "Sazonar la carne con sal y pimienta y llevar a la parrilla dando la vuelta constantemente por 45 minutos."@es .

<http://example.org/recipes/plato-principal/24/step/8e980176e73f4ce79e124b64ab8dbc16> a schema1:HowToStep ;
    schema1:text "Cortar la zanahoria en trozos grandes."@es .

<http://example.org/recipes/plato-principal/24/step/c41aa3d71e014b2ca6c9b38557da92de> a schema1:HowToStep ;
    schema1:text "Añadir la salsa de tomate y cocinar por 10 minutos o hasta que quede un poco espesa."@es .

<http://example.org/recipes/plato-principal/24/step/cd28455bc11d47eea4bb2622dafe116a> a schema1:HowToStep ;
    schema1:text "Servir la carne acompañada de la salsa de tamarindo."@es .

<http://example.org/recipes/plato-principal/24/step/ce051b0ba8284142bcc08e4ee9695677> a schema1:HowToStep ;
    schema1:text "Colocar el azúcar en una olla junto con la zanahoria y el romero. Dejar hervir a fuego lento hasta que el caramelo se mezcle con los ingredientes."@es .

<http://example.org/recipes/plato-principal/25/step/3c26d9ebc7cc43c8a29a6ddb999d982a> a schema1:HowToStep ;
    schema1:text "Cortar la zanahoria en rodajas y colocarla en una cacerola junto al azúcar y el romero. Dejar hervir hasta caramelizar."@es .

<http://example.org/recipes/plato-principal/25/step/863f5c2765a54d1481b71b275b444d26> a schema1:HowToStep ;
    schema1:text "Comenzar salpimentando la carne y asándola en una parrilla o asadera por 30 minutos, a fuego medio."@es .

<http://example.org/recipes/plato-principal/25/step/a37ecf5a553545b1bd86836aae2dd27b> a schema1:HowToStep ;
    schema1:text "Servir la carne acompañada con la salsa de tamarindo."@es .

<http://example.org/recipes/plato-principal/25/step/cbdc68da9f4b40d08262a0f8060aa14d> a schema1:HowToStep ;
    schema1:text "Agregar por último la salsa de tomate y cocinar hasta espesar."@es .

<http://example.org/recipes/plato-principal/25/step/eda231d254a04a1785d06c4503410528> a schema1:HowToStep ;
    schema1:text "Agregar a la cacerola la pulpa de tamarindo junto con una taza de agua y dejar hervir por unos minutos."@es .

<http://example.org/recipes/plato-principal/26/step/0a984f7bac1540f7a80b4fe0ff76bc2e> a schema1:HowToStep ;
    schema1:text "Cuando la cebolla esté suave, agregar una taza de agua para dejar hervir."@es .

<http://example.org/recipes/plato-principal/26/step/0e845034606c4c408b3e23b23d4a6043> a schema1:HowToStep ;
    schema1:text "Agregar las papitas cortadas en dos, así como el arroz cocido y la cebolla blanca, revolviendo todo suavemente."@es .

<http://example.org/recipes/plato-principal/26/step/227cbcb0644e4e4b9845bd86d5ca438d> a schema1:HowToStep ;
    schema1:text "Añadir entonces el picadillo y revolverlo bien, manteniéndolo en fuego suave hasta que sazonen bien los ingredientes."@es .

<http://example.org/recipes/plato-principal/26/step/3975027d366e40e48d14fc729e8f528a> a schema1:HowToStep ;
    schema1:text "Picar todos los intestinos y las papitas en trocitos pequeños."@es .

<http://example.org/recipes/plato-principal/26/step/4c6d6520a05d4048843d69a45017f4d7> a schema1:HowToStep ;
    schema1:text "Hacer un refrito con la manteca de color, manteca de chancho, la cebolla picada en pluma, especias para sazonar, ajo y sal."@es .

<http://example.org/recipes/plato-principal/26/step/6d3df2a57b25460588acc6f99b845dde> a schema1:HowToStep ;
    schema1:text "Cocer las papitas con sal hasta que esten blandas."@es .

<http://example.org/recipes/plato-principal/26/step/ebbb3d78f1cc450cb0b15db0147cfa31> a schema1:HowToStep ;
    schema1:text "Agregar el perejil picado y retirar la chanfaina para servir."@es .

<http://example.org/recipes/plato-principal/27/step/2ebb789f3e35498a9d2bbb47873d57d9> a schema1:HowToStep ;
    schema1:text "Servir en pequeñas cazuelas decorando con perejil fresco."@es .

<http://example.org/recipes/plato-principal/27/step/2f44483c0adb44a987f5cc8eaaaaadb5> a schema1:HowToStep ;
    schema1:text "Comenzar hirviendo los papines en agua con sal hasta que estén tiernos."@es .

<http://example.org/recipes/plato-principal/27/step/4ad00fa0ad7c419381859255f36e4370> a schema1:HowToStep ;
    schema1:text "Cuando la cebolla se haya dorado agregar una taza de agua y dejar hervir."@es .

<http://example.org/recipes/plato-principal/27/step/8047a85990284bbc942dd64d2335da4e> a schema1:HowToStep ;
    schema1:text "Picar todas las vísceras y cortar los papines en trozos pequeños."@es .

<http://example.org/recipes/plato-principal/27/step/b7e38fb2ca7c49849359fe4e4bdff4f1> a schema1:HowToStep ;
    schema1:text "Agregar por ultimo los papines y el arroz cocido."@es .

<http://example.org/recipes/plato-principal/27/step/d204692edb6d4194ade854ff26d792b0> a schema1:HowToStep ;
    schema1:text "Agregar a la preparación el picadillo y revolver a fuego bajo."@es .

<http://example.org/recipes/plato-principal/27/step/dda85d28a59449eea8dbd23ca1bc8baa> a schema1:HowToStep ;
    schema1:text "En una sartén colocar ambas mantecas y sofreír la cebolla picada junto con el ajo y agregar las especias para sazonar."@es .

<http://example.org/recipes/plato-principal/28/step/1013eba1529a4307b2c559e0c064e698> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una sartén tipo wok y agregar la cebolla, el ajo, el tocino o panceta, 1 cucharada de salsa inglesa, 1 cucharada de salsa de soya, el comino, el cilantro, el ají y el achiote. Cocinar por durante unos 5 minutos hasta que las cebollas estén suaves."@es .

<http://example.org/recipes/plato-principal/28/step/1ee38a5096504a7da09e6e31dedb4b13> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y espolvorear con el cilantro o perejil picado y las cebolletas. Servir el chaulafán acompañado de aguacate, ají y la salsa de tomate."@es .

<http://example.org/recipes/plato-principal/28/step/232dab2adb7f4b37a643081e26822f9c> a schema1:HowToStep ;
    schema1:text "Agregar el resto de la salsa de soya y de la salsa inglesa, los huevos revueltos, los guisantes, las zanahorias y las pasas. Mezclar bien todos los ingredientes."@es .

<http://example.org/recipes/plato-principal/28/step/2eb301531fa84f13bb03269ed591dff5> a schema1:HowToStep ;
    schema1:text "Retirar el pollo del caldo, colar el caldo, dejar enfriar el pollo un poco y luego desmenuzarlo. Guardar el pollo desmenuzado y el caldo para más tarde."@es .

<http://example.org/recipes/plato-principal/28/step/5771e197679d4f2d941278503ca2b875> a schema1:HowToStep ;
    schema1:text "Reducir la temperatura, tapar el arroz y cocinar a fuego lento durante unos 20 minutos hasta que el arroz esté tierno."@es .

<http://example.org/recipes/plato-principal/28/step/7cad00c085b5480db4527f02e6de580d> a schema1:HowToStep ;
    schema1:text "Colocar el agua en una olla grande y agregar la zanahoria, la cebolla, el apio y el cilantro. Esperar hasta que el agua hierva."@es .

<http://example.org/recipes/plato-principal/28/step/828f5280790e41aa95671ae1ac2a69fd> a schema1:HowToStep ;
    schema1:text "Agregar el arroz cocido, el pollo desmenuzado y los pimientos. Mezclar bien y cocinar a fuego medio durante unos 5 minutos, revolviendo de vez en cuando."@es .

<http://example.org/recipes/plato-principal/28/step/8a15947042004be290effa51a1b4736b> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una olla, agregar la cebolla picada y el arroz y revolver durante 2 minutos. Añadir el caldo de pollo y dejar hervir hasta que el caldo se haya reducido."@es .

<http://example.org/recipes/plato-principal/28/step/d21e9d501486444d9334bf0c3338ec0f> a schema1:HowToStep ;
    schema1:text "Agregar el pollo y cocinar a fuego medio durante 1 hora hasta esté cocido."@es .

<http://example.org/recipes/plato-principal/29/step/41d47529d9a44a8f9bbf038b43ae55bf> a schema1:HowToStep ;
    schema1:text "Agregar al wok el arroz, el pollo y los pimientos cortados en cubos. Cocinar a fuego medio por 10 minutos cuidando que no se pegue."@es .

<http://example.org/recipes/plato-principal/29/step/5b1a83c5a8ef4546b8e6e05ca0b92fbb> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y espolvorear con perejil fresco y cebollas de verdeo."@es .

<http://example.org/recipes/plato-principal/29/step/96019cdc1e5144d8ace4f0ef4db522cf> a schema1:HowToStep ;
    schema1:text "Servir caliente en cazuelas."@es .

<http://example.org/recipes/plato-principal/29/step/af18738478de40a891c6e1e982fc9473> a schema1:HowToStep ;
    schema1:text "Con los huevos preparar un revuelvo y añadirlo al wok junto con las arvejas, las zanahorias cortadas en cubos e integrar bien."@es .

<http://example.org/recipes/plato-principal/29/step/e6f524a0b8434e6db89ce5a85ea710fd> a schema1:HowToStep ;
    schema1:text "Comenzar calentando en un wok la cebolla, el ajo, la panceta, las salsas y las especias. Cocinar hasta que la cebolla se dore."@es .

<http://example.org/recipes/plato-principal/3/step/09ddc76f529640d89d6f11ef4cb56f0e> a schema1:HowToStep ;
    schema1:text "Sirva acompañado de plátanos maduros fritos en rodajas."@es .

<http://example.org/recipes/plato-principal/3/step/5981abead4be4a30b00121b165937bee> a schema1:HowToStep ;
    schema1:text "En una sartén, se coloca un poco de aceite de achiote y se sofríen las cebollas coloradas, los pimientos verdes, el ajo y las ramas de cebolla finamente picadas. Se incorporan las conchas y se remueven todos los ingredientes por unos 3 minutos, hasta que se suelten los sabores."@es .

<http://example.org/recipes/plato-principal/3/step/d0c6e091d18b4c9c9b85ac1d27826485> a schema1:HowToStep ;
    schema1:text "Mezclar bien los ingredientes y añada el perejil y culantro finamente picados. Condimente con sal, pimienta y comino. Deje cocinar a fuego lento por unos 15 minutos."@es .

<http://example.org/recipes/plato-principal/3/step/dbec8649c48d4c4cb750cc806d86078e> a schema1:HowToStep ;
    schema1:text "En una cacerola, ponga a cocinar el arroz con la leche de coco a fuego bajo. Añada un punto de sal."@es .

<http://example.org/recipes/plato-principal/3/step/e01aadbc7a29470eb25f4651e8c9211c> a schema1:HowToStep ;
    schema1:text "Lave bien las conchas y deseche las que estén abiertas. Cocine al vapor para que se abran."@es .

<http://example.org/recipes/plato-principal/3/step/fa4443019db3485d8ac4d1f125ea57e8> a schema1:HowToStep ;
    schema1:text "Cuando el arroz esté cocido, llévelo al sartén con las conchas y el sofrito."@es .

<http://example.org/recipes/plato-principal/30/step/03287b3eb6e943d0be2570717de92e93> a schema1:HowToStep ;
    schema1:text "Tambien podemos cocinarla al grill por 5 minutos por cada lado."@es .

<http://example.org/recipes/plato-principal/30/step/1afd5d77d3844de49ba78283cf325bf2> a schema1:HowToStep ;
    schema1:text "En un sarten agregamos aceite de oliva a fuego medio y colocamos las chuletas. Luego agregamos una tacita de agua."@es .

<http://example.org/recipes/plato-principal/30/step/2868f0709c464e608b3c8003ca923a87> a schema1:HowToStep ;
    schema1:text "Cocinamos todo por 5 minutos y agregamos el arroz. Revolvemos bien y agregamos 6 tazas de agua, sal al gusto y aceite. Dejamos cocinar de 10 a 15 minutos."@es .

<http://example.org/recipes/plato-principal/30/step/4fd9d21148744126a4a4a5fdcacd41dd> a schema1:HowToStep ;
    schema1:text "Mientras preparamos la chuleta. Preparamos ajo machacado, agregamos agua por encima del ajo y lo machacamos."@es .

<http://example.org/recipes/plato-principal/30/step/91fd21be58384420a7ce185a69e82f9f> a schema1:HowToStep ;
    schema1:text "Una vez listo el moro agregamos queso por encima y servimos con la chuleta."@es .

<http://example.org/recipes/plato-principal/30/step/96a8fcc54f4d4590b8f80a41cf9381e9> a schema1:HowToStep ;
    schema1:text "Luego agregamos el achiote. Mientras enjuagamos la lenteja y la agregamos al refrito, agregamos 1 taza de agua."@es .

<http://example.org/recipes/plato-principal/30/step/a44a1ece0cb34721977c2eaffaf82070> a schema1:HowToStep ;
    schema1:text "Primero cortamos los vegelates en trozos pequeños ara hacer le refrito."@es .

<http://example.org/recipes/plato-principal/30/step/aeb1ee2c7a9a4196bed3cacc78d327ff> a schema1:HowToStep ;
    schema1:text "Luego tomamos las chuletas y le pasamos el ajo por encima y le agregamos la mostaza y agregamos un poquito mas de sal."@es .

<http://example.org/recipes/plato-principal/30/step/f5cac09d5d6548398678ec27ad9bcb65> a schema1:HowToStep ;
    schema1:text "La cebolla bien picadita la agregamos a una olla, luego agregamos el pimiento en pedacitos, trituramos los ajos y le agregamos una pizaca de sal y tambien los llevamos a la olla, agregamos mantequilla y revolvemos todo muy bien."@es .

<http://example.org/recipes/plato-principal/31/step/5bfddf48e30b4c4db234358f3c1116fb> a schema1:HowToStep ;
    schema1:text "Marinar las chuletas con el aliño y dejar reposar por 30 minutos."@es .

<http://example.org/recipes/plato-principal/31/step/7348c371fdbb4777af4bd7d8ab5e4ab4> a schema1:HowToStep ;
    schema1:text "Agregar el vino y dejar reducir a la mitad antes de añadir la crema de leche para espesar la salsa."@es .

<http://example.org/recipes/plato-principal/31/step/a967ea6042564278a516fe3a7ab0c01d> a schema1:HowToStep ;
    schema1:text "Preparar en un sartén con aceite la pasta de ajo y la cebolla, se debe cocinar hasta que la cebolla este cristalina."@es .

<http://example.org/recipes/plato-principal/31/step/ad99937a7f1d4de1badc2500c38e0733> a schema1:HowToStep ;
    schema1:text "Agregar sal y pimienta y condimentar con todo las piezas de chuleta."@es .

<http://example.org/recipes/plato-principal/31/step/bfdd6442a594419a9d89caab028643d1> a schema1:HowToStep ;
    schema1:text "Picar en cubitos la cebolla perla."@es .

<http://example.org/recipes/plato-principal/31/step/c62e527624a04e089c9a2c159f0255c9> a schema1:HowToStep ;
    schema1:text "Levar las chuletas a la parrilla de 5 a 8 minutos por cada lado a fuego medio."@es .

<http://example.org/recipes/plato-principal/31/step/dd70056ed2db41dfa95eeb38ca3e95b1> a schema1:HowToStep ;
    schema1:text "Cortar la acelga dejar cocer."@es .

<http://example.org/recipes/plato-principal/32/step/0a9fc4bb51934e48af3267bd0a02206e> a schema1:HowToStep ;
    schema1:text "Engrasar una fuente para horno, coloque una capa de papa, encima las chuletas y el resto de ingredientes."@es .

<http://example.org/recipes/plato-principal/32/step/37ef228d7da445458082e2dae9b2c4b2> a schema1:HowToStep ;
    schema1:text "Hornear por 40 minutos y voltear, luego dejar 40 minutos más o hasta que la papa esté dorada y crujiente."@es .

<http://example.org/recipes/plato-principal/32/step/37f86e87e38f4a2c889476b75321e4cb> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a 225 °C."@es .

<http://example.org/recipes/plato-principal/32/step/51de836dda0c46e7819e0a6a5036a166> a schema1:HowToStep ;
    schema1:text "Dorar las chuletas en un sarten con mantequilla, no dejar que se cocinen por completo."@es .

<http://example.org/recipes/plato-principal/32/step/7e991933e6b04f429111c4ce6e0c2746> a schema1:HowToStep ;
    schema1:text "Vertir la mantequilla derretida al momento de dorar las chuletas sobre las papas."@es .

<http://example.org/recipes/plato-principal/32/step/bef693cdf9b549e991eda1852a2c1975> a schema1:HowToStep ;
    schema1:text "Cubra la preparación con el resto de papas, reserve media taza del concentrado de res y añada el resto."@es .

<http://example.org/recipes/plato-principal/32/step/eaca0a055f2d4eb8bc412a0ba9c550a7> a schema1:HowToStep ;
    schema1:text "Pelar y cortar las papas en rodajas finas."@es .

<http://example.org/recipes/plato-principal/32/step/f3ecc5cf6ea84f83a8917386fe95fee4> a schema1:HowToStep ;
    schema1:text "Cortar las cebellas en rodajas muy finas."@es .

<http://example.org/recipes/plato-principal/33/step/19dd6f3ef5364aa08a2bc82a21dafcbd> a schema1:HowToStep ;
    schema1:text "Mezclar en un tazón el ajo machacado con el comino, la sal y la pimienta para preparar un aliño para la carne."@es .

<http://example.org/recipes/plato-principal/33/step/3838bc524e6549a4b1b2a1f9c21b04c9> a schema1:HowToStep ;
    schema1:text "Servir el churrasco con un huevo frito encima de cada bistec y acompañado con arroz, papas fritas, plátanos maduros fritos, curtido de cebolla y tomate, lechuga, aguacate o ají."@es .

<http://example.org/recipes/plato-principal/33/step/4c6254c2c0804d29bc78453576937ed1> a schema1:HowToStep ;
    schema1:text "Frotar los filetes de carne con el aliño y dejarlos reposar por un par de horas."@es .

<http://example.org/recipes/plato-principal/33/step/df48c09d1c8641bba7f602707d93e038> a schema1:HowToStep ;
    schema1:text "Asar o freír los filetes a la parrilla o en una sartén por cada lado hasta que estén cocidos a gusto. Dependiendo de la temperatura de la parrilla, esto tardará sólo unos minutos."@es .

<http://example.org/recipes/plato-principal/34/step/3a773e95b1d4429da9a6f7610ef054ca> a schema1:HowToStep ;
    schema1:text "Verter la salsa sobre la corvina y hornear a fuego mínimo por unos 5 minutos."@es .

<http://example.org/recipes/plato-principal/34/step/4cf1b88e94bd4ee8a037335a0001ca7c> a schema1:HowToStep ;
    schema1:text "En una olla, derrita un poco de mantequilla y saltee el tomate con sal, pimienta y una pizca de azúcar. Luego incorpore el vino, el perejil y la crema de leche."@es .

<http://example.org/recipes/plato-principal/34/step/6b079fb1a3af4eaea953f2600f117ca7> a schema1:HowToStep ;
    schema1:text "Coloque el pescado en una fuente engrasada y hornee por unos 15 minutos."@es .

<http://example.org/recipes/plato-principal/34/step/b5aaed90e4a640a8a856673a16466792> a schema1:HowToStep ;
    schema1:text "Cortar las corvinas en lonjas delgadas. Luego déjelas marinar con sal, pimienta y jugo de limón por una media hora."@es .

<http://example.org/recipes/plato-principal/34/step/e02edcd7ae7241209e2f409fef1c0e38> a schema1:HowToStep ;
    schema1:text "Servir el pescado y acompañe con papas al horno y patacones."@es .

<http://example.org/recipes/plato-principal/35/step/15df6c6d2dd6479998fd0155b204a402> a schema1:HowToStep ;
    schema1:text "En una sartén con aceite bien caliente, proceda a freír los filetes hasta que queden dorados. Reserve."@es .

<http://example.org/recipes/plato-principal/35/step/475746e8bd6246f183a2f5bb1dbfedd8> a schema1:HowToStep ;
    schema1:text "Para preparar la salsa, coloque una sartén al fuego y derrita la mantequilla con un poco de aceite. Haga un sofrito con la cebolla y el ajo, e incorpore los mariscos. Sazone con sal y pimienta, luego añada el vino y luego de unos minutos la crema de leche. Cocine por unos 7 minutos hasta que la preparación espese."@es .

<http://example.org/recipes/plato-principal/35/step/a302f581d6af480e8ee2a975b39cea57> a schema1:HowToStep ;
    schema1:text "Lavar los filetes de corvina y sazonarlos con sal, pimienta y jugo de limón. Pasarlos por un poco de harina."@es .

<http://example.org/recipes/plato-principal/35/step/a56f7a5efde84460817bdf7a5b8f2159> a schema1:HowToStep ;
    schema1:text "Limpiar bien los mariscos y lavarlos, reserve."@es .

<http://example.org/recipes/plato-principal/35/step/e48bd91318204430b067e2143bdde02f> a schema1:HowToStep ;
    schema1:text "Sirva los filetes de corvina, bañados con la salsa de mariscos y espolvoree perejil picadito. Acompañe con patacones y encurtido de cebollas y tomates."@es .

<http://example.org/recipes/plato-principal/36/step/18ba4adc23144e87a2576c29df3e4b3b> a schema1:HowToStep ;
    schema1:text "Para finalizar bañamos Trozos con la salsa que preparamos y disfrutamos."@es .

<http://example.org/recipes/plato-principal/36/step/291b65e0063b45daae67e10c8d94ac09> a schema1:HowToStep ;
    schema1:text "Agregamos a la olla un cuarto de cebolla y 1 cucharada sopera de sal. Luego lo ponemos durante 30 minutos en nuestra olla de presión. Una vez pasado el timepo esperaremos que el vapor salga."@es .

<http://example.org/recipes/plato-principal/36/step/2c70b76ccd45491ab1ab3b8c16684fda> a schema1:HowToStep ;
    schema1:text "Si se cocina en olla normal la colocaremos por 3 horas aproximadamente."@es .

<http://example.org/recipes/plato-principal/36/step/c3772fd0b5a844e5b57aa305a91569d8> a schema1:HowToStep ;
    schema1:text "Mientras en un sarten colocamos aceite y colocamos la carne a fuego medio. Al sarten le colocaremos tapa."@es .

<http://example.org/recipes/plato-principal/36/step/ce07f0832bfb4cebba52c03b11038ea6> a schema1:HowToStep ;
    schema1:text "1 taza salsa bbq, ¼ de taza de refresco y ½ tasa de caldo de cerdo. Mezclamos muy bien y lo dejamos hervir por 2 minutos. Agregamos un toque de Sal."@es .

<http://example.org/recipes/plato-principal/36/step/d4385ce71cfb4ad8916938bcef02471d> a schema1:HowToStep ;
    schema1:text "Una vez que pasen unos 3 minutos que este dorada la carne volteamos para que la carne se dore por el otro lado. Ya listo esperamos que se enfrie."@es .

<http://example.org/recipes/plato-principal/36/step/fa94a7bd2a254c9993d9a61af767eeb7> a schema1:HowToStep ;
    schema1:text "En un envase colocar:"@es .

<http://example.org/recipes/plato-principal/36/step/fd80a746656e4944ae839c88a7200852> a schema1:HowToStep ;
    schema1:text "Comenzaremos colocando en una olla agua. Una vez que este hirviendo agregamos la carne aproximadamente que el agua cubra la costilla."@es .

<http://example.org/recipes/plato-principal/37/step/0b6393f3647c435fa44b4ec6d9414d63> a schema1:HowToStep ;
    schema1:text "Llevar al horno por 30 minutos y retirar el papel aluminio y deje hornear otros 10 a 15 minutos."@es .

<http://example.org/recipes/plato-principal/37/step/13b3e2f5764d45e49610db9ffdedabb2> a schema1:HowToStep ;
    schema1:text "Colocar las costillas en un molde para horno y vertir encima el caldo y el refrito."@es .

<http://example.org/recipes/plato-principal/37/step/14bf42836a3648f384fa67dd58f49a9b> a schema1:HowToStep ;
    schema1:text "Separar las costillas individualmente y frotar el costillar con el curry."@es .

<http://example.org/recipes/plato-principal/37/step/477e279961664f38a993f62551accd35> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a 150 °C."@es .

<http://example.org/recipes/plato-principal/37/step/4bc07f058d3744f9a11cb6d67017d290> a schema1:HowToStep ;
    schema1:text "Pelar el ajo y el jengibre y picar finamente."@es .

<http://example.org/recipes/plato-principal/37/step/5ef0ce89eb5f47939c33d04b2abec9c7> a schema1:HowToStep ;
    schema1:text "Sofreír el ajo y el jengibre en aceite caliente a fuego lento durante 5 minutos, agregar pimienta y sal."@es .

<http://example.org/recipes/plato-principal/37/step/9c7ee596708d4abc8abb8debb879d3d1> a schema1:HowToStep ;
    schema1:text "Cortar las cebollas en rodajas y colocar sobre las costillas antes de tapar con papel aluminio."@es .

<http://example.org/recipes/plato-principal/38/step/08b0eaae51524a05a22bed150857193d> a schema1:HowToStep ;
    schema1:text "Colocar en una cacerola aceite y una pizca de achiote. Con este aceite condimentado pincelar el cuy y asarlo de ambos lados."@es .

<http://example.org/recipes/plato-principal/38/step/132ef329075f415f9093fc1a30447667> a schema1:HowToStep ;
    schema1:text "Añadir al sofrito las papas y cubrirlas de agua, cuando rompa el hervor bajar a fuego mínimo y cocinar hasta que estén tiernas."@es .

<http://example.org/recipes/plato-principal/38/step/228a723e024e45e89dee30f39c076dd4> a schema1:HowToStep ;
    schema1:text "Colocar en un recipiente el cuy con el ajo, el comino y sal. Dejar reposar unas horas en heladera."@es .

<http://example.org/recipes/plato-principal/38/step/4cd7804115b745218c43abb97d7553ec> a schema1:HowToStep ;
    schema1:text "En una sartén con aceite sofreír la cebolla, los ajos restantes, el verdeo y las especias por unos 5 minutos."@es .

<http://example.org/recipes/plato-principal/38/step/82cdb6787e5c4c82936de232f154afa2> a schema1:HowToStep ;
    schema1:text "Servir el cuy sobre un colchón de papas."@es .

<http://example.org/recipes/plato-principal/39/step/2e233c405918444c98dc9d5d395efa87> a schema1:HowToStep ;
    schema1:text "Aliñar el cuy con 5 dientes de ajo, el comino y sal. Dejarlo reposar hasta el día siguiente."@es .

<http://example.org/recipes/plato-principal/39/step/37a791f1eb27496ba2b40de647a5ea74> a schema1:HowToStep ;
    schema1:text "Asar el cuy en carbón, pinchándolo para que vaya cocinándose homogéneamente."@es .

<http://example.org/recipes/plato-principal/39/step/5ab8dd74d6e24160b959e535a4ee1fae> a schema1:HowToStep ;
    schema1:text "Calentar en una sartén 6 cucharadas de aceite con el achiote. Barnizar el cuy con el aceite de achiote."@es .

<http://example.org/recipes/plato-principal/39/step/90e533add78a4c3199b05aec77ce4e34> a schema1:HowToStep ;
    schema1:text "Agregar las papas y suficiente agua hasta cubrirlas. Esperar hasta que el agua hierva, reducir la temperatura y cocinar a fuego lento hasta que las papas estén blandas."@es .

<http://example.org/recipes/plato-principal/39/step/b0770eda56334bddb61972a705d21226> a schema1:HowToStep ;
    schema1:text "Calentar en una sartén 2 cucharadas de aceite y añadir la cebolla, los 3 dientes de ajo restantes, las cebolletas, el cilantro, el orégano, la pimienta y sal. Cocinar durante 5 minutos."@es .

<http://example.org/recipes/plato-principal/39/step/f4b8e918428049e5b1e1379f956b901d> a schema1:HowToStep ;
    schema1:text "Servir el cuy sobre las papas cocidas acompañado de hojas de lechuga, tomate y curtido de cebolla."@es .

<http://example.org/recipes/plato-principal/4/step/5580fd72ed424b84a34867ed7f74ab1b> a schema1:HowToStep ;
    schema1:text "Tomar las pechugas de pollo y condimentar con una mezcla realizada con todas las especias de la lista."@es .

<http://example.org/recipes/plato-principal/4/step/df21be138deb4873a4b1909915b70628> a schema1:HowToStep ;
    schema1:text "Agregar a la cacerola la cebolla, los tomates, el morrón y cocinar por unos 15 minutos."@es .

<http://example.org/recipes/plato-principal/4/step/e542c7eb4f3345febadb18c7513630da> a schema1:HowToStep ;
    schema1:text "Colocar el pollo con la piel hacia abajo en una sartén con aceite caliente y cocinar hasta dorar."@es .

<http://example.org/recipes/plato-principal/4/step/f2773849f96d4497a7315560f2f75314> a schema1:HowToStep ;
    schema1:text "Agregar el vino blanco y cocinar hasta que el líquido se reduzca a la mitad."@es .

<http://example.org/recipes/plato-principal/4/step/f5d0cc90ac2440f5ad852cb716ba5856> a schema1:HowToStep ;
    schema1:text "Servir el arroz con pollo acompañado con plátano maduro frito."@es .

<http://example.org/recipes/plato-principal/4/step/f63fa9e88f044c5ab379031bdde2a66a> a schema1:HowToStep ;
    schema1:text "Añadir ahora el agua con el arroz, los frijoles y las zanahorias y cocinar a fuego medio hasta que el arroz se haya cocido."@es .

<http://example.org/recipes/plato-principal/40/step/0818395c419d4d39bd25537eef2c4d13> a schema1:HowToStep ;
    schema1:text "Agregar el menudo picado, revolver y dejar fuera del fuego pero tapado para que se siga cociendo."@es .

<http://example.org/recipes/plato-principal/40/step/20cc9a35aa734f54b50923d1851e7550> a schema1:HowToStep ;
    schema1:text "Añadir las papas y la taza de maní licuado y dejar hervir por 15 minutos."@es .

<http://example.org/recipes/plato-principal/40/step/2cf06ad549094e7ca179753344ca3340> a schema1:HowToStep ;
    schema1:text "Lavar los menudos en agua con vinagre. Cambiar el agua y colocarle jugo de limón y sal. Dejar reposar durante unos 5minutos y lavar nuevamente con agua fría."@es .

<http://example.org/recipes/plato-principal/40/step/4ab966d45b324806b7fdd07af05652e4> a schema1:HowToStep ;
    schema1:text "En una sartén calentar el aceite y agregar la sangre desmenuzada, la pimienta, el perejil, una cebolla cortada, freír todo por 10 minutos."@es .

<http://example.org/recipes/plato-principal/40/step/788b80da06f649c8805b1306b9e28f90> a schema1:HowToStep ;
    schema1:text "Servir el yahuarlocro bien caliente con la sangre frita por encima."@es .

<http://example.org/recipes/plato-principal/40/step/938109cb6ddf4897a4c21ab666c0aa69> a schema1:HowToStep ;
    schema1:text "En olla aparte colocar la sangre con 2 litros de agua y sal. Cuando rompa en hervor cocinar por media hora."@es .

<http://example.org/recipes/plato-principal/40/step/b900e11c00e84f549274435ba40f6357> a schema1:HowToStep ;
    schema1:text "En una olla grande calentar el aceite con el achiote, el cilantro, el comino, pimienta y ajo y dorar la cebolla por 5 minutos."@es .

<http://example.org/recipes/plato-principal/40/step/c7460012286e41368e04868c440928d1> a schema1:HowToStep ;
    schema1:text "Colocar los menudos en una cacerola con agua y cocinar por media hora o hasta tiernizar, dejar enfriar y cortar en trozos pequeños."@es .

<http://example.org/recipes/plato-principal/41/step/1cfc284043224a3e9790618b44d362bc> a schema1:HowToStep ;
    schema1:text "Servir el encocado con arroz o ensalada."@es .

<http://example.org/recipes/plato-principal/41/step/3a28cc8bc89c40b78b8e825ee6fccaf3> a schema1:HowToStep ;
    schema1:text "En una olla con el coco rallado, el agua del coco, la mantequilla la crema y la sal, colocar los cangrejos."@es .

<http://example.org/recipes/plato-principal/41/step/a3be5a23c3c7479ba0fe9bcd9f7f874e> a schema1:HowToStep ;
    schema1:text "Agregar a la cacerola los plátanos partidos en dos y dejarlos cocinar en la salsa."@es .

<http://example.org/recipes/plato-principal/41/step/c7a28714365845ddab74d4887a4fb040> a schema1:HowToStep ;
    schema1:text "Colocar de a una las cucharadas de harina para espesar la preparación y cocinar a fuego bajo."@es .

<http://example.org/recipes/plato-principal/41/step/e8b48fcd20984db693bd759be3376be8> a schema1:HowToStep ;
    schema1:text "Comenzar limpiando los cangrejos, para esto separar el carapacho del resto."@es .

<http://example.org/recipes/plato-principal/42/step/0faf0d3d9aa94042aefa46f793e21419> a schema1:HowToStep ;
    schema1:text "En una sartén precalentada con aceite añadir la cebolla, los tomates, los morrones y sal a gusto. Cocinar por unos minutos a fuego bajo, agregar el coco licuado y cocinar por unos 15 minutos más."@es .

<http://example.org/recipes/plato-principal/42/step/4229c5356f9d4d61905ae29865efd0ad> a schema1:HowToStep ;
    schema1:text "Comenzar por colocar en un recipiente el jugo de las frutas, el ajo, la sal y las especias. Preparar una salsa y pintar abundantemente los trozos de pescado. Dejar reposar por al menos 4 horas en heladera."@es .

<http://example.org/recipes/plato-principal/42/step/a87ae98d73df4331a1d604355a01db53> a schema1:HowToStep ;
    schema1:text "Servir el encocado de pescado con el coco rallado y el cilantro espolvoreados y acompañados con arroz y plátanos maduros fritos."@es .

<http://example.org/recipes/plato-principal/42/step/ba3a556ddecc44c388b1d8abbbd39bec> a schema1:HowToStep ;
    schema1:text "Por ultimo agregar el pescado, y cocinar a fuego lento por 20 minutos más."@es .

<http://example.org/recipes/plato-principal/43/step/1fe620ff5185414d8a10499f3007af86> a schema1:HowToStep ;
    schema1:text "Diluir la harina en agua, para espesar la preparación, tapar la olla, cocinar a fuego lento."@es .

<http://example.org/recipes/plato-principal/43/step/20b3c28faf804eda870134f4f53912a4> a schema1:HowToStep ;
    schema1:text "Matar los cangrejos y limpiarlos. Separar las patas y el pecho del carapacho."@es .

<http://example.org/recipes/plato-principal/43/step/2cee7a4f8dec4a94b9f2f782e6608b7d> a schema1:HowToStep ;
    schema1:text "Agregar los maduros partidos por la mitad para que se cocinen en esta salsa."@es .

<http://example.org/recipes/plato-principal/43/step/5e67fd9493a541319263e93185908f56> a schema1:HowToStep ;
    schema1:text "Colocar los cangrejos en una olla y agregar el coco rallado con su agua, la crema de leche, la sal y la mantequilla."@es .

<http://example.org/recipes/plato-principal/43/step/e001acd1ff9944b38290fb80f03b8fac> a schema1:HowToStep ;
    schema1:text "Servir acompañado de arroz blanco y de ensalada."@es .

<http://example.org/recipes/plato-principal/44/step/47b95cff4d884fb1bc79075f0b10783e> a schema1:HowToStep ;
    schema1:text "Colocar en un tazón el jugo de limón, el jugo de naranja, el ajo, el comino, el achiote, las pepitas de cilantro y sal. Mezclar bien para preparar un aliño. Agregar los trozos de pescado, cubrirlos bien con el aliño y dejarlo reposar en la refrigeradora durante 2 horas."@es .

<http://example.org/recipes/plato-principal/44/step/ce49dd371e744258a9c7ce3076eb2fcf> a schema1:HowToStep ;
    schema1:text "Agregar los trozos de pescado, tapar parcialmente y dejar cocinar a fuego lento durante 20 minutos. Espolvorear con el coco rallado y el cilantro. Servir el encocado de pescado con arroz y plátanos maduros fritos."@es .

<http://example.org/recipes/plato-principal/44/step/dcdbf4bc25e14b47862937eb1479e9bb> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una sartén y agregue la cebolla, los tomates, los pimientos y sal. Cocinar a fuego medio durante 5 minutos. Agregar el coco licuado, mezclar bien y cocinar durante 10 minutos."@es .

<http://example.org/recipes/plato-principal/45/step/23db71b1d9654a1c92072e60e2364dd6> a schema1:HowToStep ;
    schema1:text "También agregue el maní licuado en leche, la leche de coco y un punto de sal. Dejar cocinar por unos 7 minutos."@es .

<http://example.org/recipes/plato-principal/45/step/ab0301d2ca574ac78e8153c8f02caaf4> a schema1:HowToStep ;
    schema1:text "Limpiar bien los camarones y cocinar aparte el pulpo y los pateburros para que ablanden un poco."@es .

<http://example.org/recipes/plato-principal/45/step/d037d84672704b6896e659a5636705b5> a schema1:HowToStep ;
    schema1:text "Por último añada la chillangua y rectifique los sabores."@es .

<http://example.org/recipes/plato-principal/45/step/dce31090db2d4011bdb17ec755793712> a schema1:HowToStep ;
    schema1:text "En una olla derretir la mantequilla con aceite de achiote, y haga un sofrito con cebollas, pimientos y ajo. Añada el caldo de camarones, el pescado, el pulpo, los pateburros, camarones y demás mariscos."@es .

<http://example.org/recipes/plato-principal/45/step/dfa6bd266ee44ae9add47840c1d3a0e0> a schema1:HowToStep ;
    schema1:text "Frotar el pescado con sal y limón y luego proceda a lavarlo."@es .

<http://example.org/recipes/plato-principal/45/step/e29d37c737a44147ba0a1c8d66454578> a schema1:HowToStep ;
    schema1:text "Servir acompañado con patacones, arroz, aguacate y limón."@es .

<http://example.org/recipes/plato-principal/46/step/068f42653fba455095184f31d36c8af4> a schema1:HowToStep ;
    schema1:text "Añadir por último la corvina cortada en trozos grandes y dejar cocinar por 10 minutos más a fuego bien bajo. Salpimentar."@es .

<http://example.org/recipes/plato-principal/46/step/44243320108f43bb9fda1678744e8fd6> a schema1:HowToStep ;
    schema1:text "Servir en cazuelas con arroz y cilantro fresco."@es .

<http://example.org/recipes/plato-principal/46/step/6f59120bc04249a0837a62cd726c5d86> a schema1:HowToStep ;
    schema1:text "Comenzar cortando la papa en cubos y la cebolla, el tomate y el pimiento en finas tiras."@es .

<http://example.org/recipes/plato-principal/46/step/a1593f891e3a482ca42787ae8dc365ea> a schema1:HowToStep ;
    schema1:text "Sofreír en sartén precalentada junto con achiote, ajo y comino."@es .

<http://example.org/recipes/plato-principal/46/step/c7d3f1ef190243a4ad556f846633e596> a schema1:HowToStep ;
    schema1:text "Agregar al sofrito una taza de agua y la papa y cocinar a fuego medio por 15 minutos."@es .

<http://example.org/recipes/plato-principal/47/step/3aa1f0e5803a4f39a057ad59707778ed> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y espolvorear con cilantro. Servir compañado de arroz blanco y patacones."@es .

<http://example.org/recipes/plato-principal/47/step/80503766d8fd46c087743615f8304d45> a schema1:HowToStep ;
    schema1:text "Agregar el pescado y dejar cocinar por 5 minutos, hechar sal y pimienta."@es .

<http://example.org/recipes/plato-principal/47/step/8985d915736240398d9a23aaffb39a6c> a schema1:HowToStep ;
    schema1:text "Cortar la papa en cubitos."@es .

<http://example.org/recipes/plato-principal/47/step/a4dfcfd9bd0f45b588e265c8eac05a80> a schema1:HowToStep ;
    schema1:text "Cortar finamente la cebolla, el tomate y el pimiento."@es .

<http://example.org/recipes/plato-principal/47/step/d18e16bcbb514eefa89d83cecbcd2c01> a schema1:HowToStep ;
    schema1:text "Cuando el sofrito este listo agregar 1 taza de agua y la papa y dejamos cocinar por 10 minutos."@es .

<http://example.org/recipes/plato-principal/47/step/f1a66538c0a947adbe018ad540eec584> a schema1:HowToStep ;
    schema1:text "Preparar un sofrito con el achiote, cebolla, pimiento, tomat, ajo y comino."@es .

<http://example.org/recipes/plato-principal/48/step/00bf2761aaff4decb3cf840b9c036ee3> a schema1:HowToStep ;
    schema1:text "Colocar el pimiento y la cebolla a asar en un sartén con unas gotas de aceite de oliva, por 10 minutos, a fuego medio."@es .

<http://example.org/recipes/plato-principal/48/step/492eeb0b5f8a41f2b09f841c0f10a304> a schema1:HowToStep ;
    schema1:text "Llevar los filetes condimentados con sal y pimienta a la parrilla durante 4 minutos por cada lado."@es .

<http://example.org/recipes/plato-principal/48/step/93af77a9b024479e8c95f027a15f60bb> a schema1:HowToStep ;
    schema1:text "En un recipiente colocar el ajo, orégano, pimientos, salsa de tomate y vinagre. Mezclar y condimentar."@es .

<http://example.org/recipes/plato-principal/48/step/d3f2e5b7414745aeb9c0259ebd145447> a schema1:HowToStep ;
    schema1:text "Servir acompañado de la salsa de pimientos"@es .

<http://example.org/recipes/plato-principal/48/step/f498a641ba894e0c9188148e799f74b5> a schema1:HowToStep ;
    schema1:text "Cortar el pimiento en dos para retirarle todas las semillas, volvemos a cortar en trozos. Hacer lo mismo con la cebolla"@es .

<http://example.org/recipes/plato-principal/49/step/0e3d729e98fe454f95897d592e39d1d6> a schema1:HowToStep ;
    schema1:text "Batir el huevo junto con la harina."@es .

<http://example.org/recipes/plato-principal/49/step/876f1788bdfd4473a37a713e666113a0> a schema1:HowToStep ;
    schema1:text "Agregar la mezcla al filete y freir hasta que quede dorado por ambos lados."@es .

<http://example.org/recipes/plato-principal/49/step/a4cf22e74a33487aa407985447e9a88a> a schema1:HowToStep ;
    schema1:text "Agregar un poco de sal dentro de un tazón que sea hondo y grande, hasta crear una pasta que esté bien mezclada."@es .

<http://example.org/recipes/plato-principal/49/step/e0e40abe4b394c3e93b129edb2d66153> a schema1:HowToStep ;
    schema1:text "Marinar el filete por 30 minutos con jugo de limón y sal."@es .

<http://example.org/recipes/plato-principal/5/step/3ab0a315084648a4b706c018f5147cba> a schema1:HowToStep ;
    schema1:text "Añadir el caldo de pollo o el agua, el arroz, los guisantes y las zanahorias, mezclar bien. Tapar y cocinar a fuego medio durante 20 minutos. Reducir la temperatura y cocinar a fuego lento durante unos 10 minutos hasta que el arroz esté tierno."@es .

<http://example.org/recipes/plato-principal/5/step/65333ee6d3794d819be7f671a7cea88f> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una sartén de buen tamaño y añadir las presas de pollo (con la piel hacia abajo) y cocinar hasta que las presas queden doradas por ambos lados."@es .

<http://example.org/recipes/plato-principal/5/step/c75a5002ed6943f3a0427c00a4145b86> a schema1:HowToStep ;
    schema1:text "Añadir la cerveza o vino blanco y cocinar durante 20 minutos a fuego medio hasta que el líquido se reduzca a la mitad, revolver con frecuencia."@es .

<http://example.org/recipes/plato-principal/5/step/c89f66d3fe2d466fa96965af5c9188d1> a schema1:HowToStep ;
    schema1:text "Espolvorear con el cilantro y servir el arroz con pollo acompañado con plátano maduro frito, una pequeña ensalada, cebollas encurtidas, rodajas de aguacate o ají criollo."@es .

<http://example.org/recipes/plato-principal/5/step/d05ea0bccce7488a8f0f204db49abfa4> a schema1:HowToStep ;
    schema1:text "Mezclar en un tazón el ajo machacado, el achiote, el comino, las pepas de cilantro, sal y pimienta. Aliñar las presas de pollo con esta mezcla."@es .

<http://example.org/recipes/plato-principal/5/step/e28971531d56462fa2f347ea82f25ae9> a schema1:HowToStep ;
    schema1:text "Agregar la cebolla, los tomates, el pimiento y las cebolletas, mezclar bien y cocinar durante 10 minutos, revolviendo de vez en cuando."@es .

<http://example.org/recipes/plato-principal/50/step/014021cb15814243ac96efda75fcc50a> a schema1:HowToStep ;
    schema1:text "Luego agarramos el pollo y lo pasamos huevo y escurrimos bien y pasamos el pan molido. Los aplastamos bien. Hacemos lo mismo con todos los pollos."@es .

<http://example.org/recipes/plato-principal/50/step/3c40b33f0c424616b09e180161a324dc> a schema1:HowToStep ;
    schema1:text "En un plato colocamos el pan molido. El italiano ya viene sazonado con hiervitas. A este plato le agregamos la mitad de la harina de trigo. Mezclamos bien."@es .

<http://example.org/recipes/plato-principal/50/step/419670d0af6a4d17b663bb060d4befa3> a schema1:HowToStep ;
    schema1:text "Comenzamos batiendo los dos huevos. Bien batidos se le agrega unas goticas de salsa china."@es .

<http://example.org/recipes/plato-principal/50/step/7fb44fc944f74f7d86762c3436c9772c> a schema1:HowToStep ;
    schema1:text "Aparte en un sarten agregamos aceite y colocamos las milanesas. No las tocamos hasta que esten doradas y crocantes por ambos lados."@es .

<http://example.org/recipes/plato-principal/50/step/dff81af8180b44da93d58ebab802d410> a schema1:HowToStep ;
    schema1:text "Una vez listas se sirven con ensalada, papas fritas o arroz blanco."@es .

<http://example.org/recipes/plato-principal/51/step/05010a8453f144abaadfd24c735e3851> a schema1:HowToStep ;
    schema1:text "Para finalizar incorporamos la salsa de champiñones y dejamos hervir por 1 minuto."@es .

<http://example.org/recipes/plato-principal/51/step/06510b2cb33e426887717107060ca108> a schema1:HowToStep ;
    schema1:text "Aparte en otro sartén colocamos las pechugas previamente salpimentadas hasta que estén bien doradas por ambos lados, Aproximadamente por 4 minutos."@es .

<http://example.org/recipes/plato-principal/51/step/0e2589034e294457bbcfc763535438bd> a schema1:HowToStep ;
    schema1:text "Listo para disfrutar y servir."@es .

<http://example.org/recipes/plato-principal/51/step/a3f8ea0580ab4b229b4cda4a9ccbf1d1> a schema1:HowToStep ;
    schema1:text "En un sartén colocamos el aceite a fuego medio."@es .

<http://example.org/recipes/plato-principal/51/step/c8cbad4f777e4b6ca2eec3e6411b3498> a schema1:HowToStep ;
    schema1:text "Luego agregamos el ajo y cebolla finamente picados por 3 minutos."@es .

<http://example.org/recipes/plato-principal/51/step/d2980f9bbe2343708bd31fd0755ded8c> a schema1:HowToStep ;
    schema1:text "Agregamos los champiñones y cocinamos por 2 minutos. Una vez pasado estos minutos agregamos la crema de leche y pimienta hasta que hierva."@es .

<http://example.org/recipes/plato-principal/51/step/dd1db97e9dde48c483601f1c8d9f6084> a schema1:HowToStep ;
    schema1:text "Agregamos el perejil y espesamos con harina en caso de ser necesario."@es .

<http://example.org/recipes/plato-principal/52/step/378ff796fb624c3f856bf87e8a115563> a schema1:HowToStep ;
    schema1:text "Sirva los filetes acompañados de arroz, papas fritas, ensaladas y algunas rodajas de limón."@es .

<http://example.org/recipes/plato-principal/52/step/3b931c303051489abddf013e1ee04bbc> a schema1:HowToStep ;
    schema1:text "Colocar los filetes de corvina en un bol y agregue el jugo de limón, sal y pimienta."@es .

<http://example.org/recipes/plato-principal/52/step/657b002cf7c8422ba11b5416a043de49> a schema1:HowToStep ;
    schema1:text "Cuando estén doradas por ambos lados, coloque sobre papel absorbente."@es .

<http://example.org/recipes/plato-principal/52/step/711660a5dcf8409cabb2c2e0a3af0466> a schema1:HowToStep ;
    schema1:text "Pase cada filete por harina de trigo, luego por huevo batido y por último por las migas de pan."@es .

<http://example.org/recipes/plato-principal/52/step/ffb6a6b2abf34a6baff75e2c3db98f4e> a schema1:HowToStep ;
    schema1:text "Freír los filetes en aceite bien caliente."@es .

<http://example.org/recipes/plato-principal/53/step/3546ff4513764227b553b49e8d85b35b> a schema1:HowToStep ;
    schema1:text "Agregar la cebolla, el ajo y la taza de cerveza o agua."@es .

<http://example.org/recipes/plato-principal/53/step/54f0925ca2574e2690879bea8161dced> a schema1:HowToStep ;
    schema1:text "Colocar en una cacerola a fuego medio, el cerdo condimentado."@es .

<http://example.org/recipes/plato-principal/53/step/5a1c23abd7b24388a9ca018ff45bc08f> a schema1:HowToStep ;
    schema1:text "Servir caliente sobre hojas de lechuga fresca."@es .

<http://example.org/recipes/plato-principal/53/step/6b6aeae951874c9db3cfcc9f50e5c370> a schema1:HowToStep ;
    schema1:text "Cocinar hasta que el líquido evapore, revolviendo esporádicamente."@es .

<http://example.org/recipes/plato-principal/54/step/67f4f98a60114e2bbf834d2607c8de2f> a schema1:HowToStep ;
    schema1:text "Servir la fritada de chancho con yuca, mote, plátanos maduros fritos, curtido de cebolla, aguacate y ají criollo."@es .

<http://example.org/recipes/plato-principal/54/step/8d6e738ce8d14f3a9ce1132660322546> a schema1:HowToStep ;
    schema1:text "Colocar la carne de chancho, la cebolla, el chalote, los dientes de ajo enteros y el agua en una sartén grande y cocinar hasta que se reduzca casi toda el agua."@es .

<http://example.org/recipes/plato-principal/54/step/a11e80be29284c458f00af31de2a9b7f> a schema1:HowToStep ;
    schema1:text "Sazonar la carne de chancho con el comino molido, ajo machacado, sal y pimienta. Dejar reposar en la refrigeradora un par de horas."@es .

<http://example.org/recipes/plato-principal/54/step/e4ad5d8ef2ea4e49af627574e8c68971> a schema1:HowToStep ;
    schema1:text "Añadir el jugo de naranja y cocinar, revolviendo de vez en cuando, hasta se reduzca todo el líquido y la carne esté dorada."@es .

<http://example.org/recipes/plato-principal/55/step/1e93a51ed610480cac076d04658e9936> a schema1:HowToStep ;
    schema1:text "Servir la gallareta asada acompañada de arroz y menestra."@es .

<http://example.org/recipes/plato-principal/55/step/31cbccfec62b4b80a00783ab9ad92370> a schema1:HowToStep ;
    schema1:text "Poner en remojo el frejol durante unos dos horas."@es .

<http://example.org/recipes/plato-principal/55/step/3d6cc4d6ccdc4b3dae8310dce52753be> a schema1:HowToStep ;
    schema1:text "Colar el fréjol y añadir al caldo cuando esté hirviendo. Se reduce la temperatura a fuego lento y se deja cocinar por una hora aproximadamente hasta que ablande el grano."@es .

<http://example.org/recipes/plato-principal/55/step/af838297f6f7437d95580a947eff7258> a schema1:HowToStep ;
    schema1:text "Colocar la gallareta sobre una parrilla bien caliente y asarla bien."@es .

<http://example.org/recipes/plato-principal/55/step/b0d93064bfb840e8be0763eeba677f23> a schema1:HowToStep ;
    schema1:text "En una olla colocar el aceite de achiote y sofreír la cebolla colorada, el pimiento, los tomates y el ajo triturado por unos 5 minutos. Añada sal, un poco de cilantro y el agua. Deje cocinar a fuego alto."@es .

<http://example.org/recipes/plato-principal/55/step/d4fd874af6cd4add824edfee11143449> a schema1:HowToStep ;
    schema1:text "Para preparar el aliño de la gallareta, licue la cebolla blanca, ajo, cilantro y sal. Se vierte este preparado sobre la gallareta troceada y deje reposar."@es .

<http://example.org/recipes/plato-principal/56/step/48ebb6ee801d48b187f74459db0cc10f> a schema1:HowToStep ;
    schema1:text "Sirva la gallina asada acompañada con papas salteadas en refrito y una rica ensalada de lechugas, zanahorias y tomates."@es .

<http://example.org/recipes/plato-principal/56/step/83759343664b41129140d8bb1c68dbda> a schema1:HowToStep ;
    schema1:text "Colocar la gallina con el cuy en una bandeja y marinar en una mezcla de cerveza, ajo, achiote, sal, pimienta y comino."@es .

<http://example.org/recipes/plato-principal/56/step/bb5c322eadd64cb6bd20216428385b97> a schema1:HowToStep ;
    schema1:text "Luego de marinar por unas horas, se procede a asar la gallina sobre las brasas."@es .

<http://example.org/recipes/plato-principal/57/step/4a00620faefa4e73bc754560f7d84739> a schema1:HowToStep ;
    schema1:text "Colocar en una olla el agua, el apio, la zanahoria, la cebolla, los ajos, sal y pimienta y preparar un caldo."@es .

<http://example.org/recipes/plato-principal/57/step/69a75cdd5e8c43b3b23c942e2f0594e8> a schema1:HowToStep ;
    schema1:text "Retirar las langostas y partirlas de manera longitudinal, retirar la carne y cortarla en trozos."@es .

<http://example.org/recipes/plato-principal/57/step/a8114e3969b846c7aebdc66fe4c1f87b> a schema1:HowToStep ;
    schema1:text "Cuando rompa en hervor introducir las langostas y cocinar por 5 minutos."@es .

<http://example.org/recipes/plato-principal/57/step/bc95a2f32939432eb8699c48a979c6af> a schema1:HowToStep ;
    schema1:text "Asar el ajo y formar un pure."@es .

<http://example.org/recipes/plato-principal/57/step/bcad2080783b4904bd7b11574bf4bc9b> a schema1:HowToStep ;
    schema1:text "Para el armado colocar los caparazones en una placa de horno, rellenar con la carne de la langosta, y cubrir con la salsa y la paprika."@es .

<http://example.org/recipes/plato-principal/57/step/ea3b8aa05d1b4ea39af13b8c9d8ec6ca> a schema1:HowToStep ;
    schema1:text "Meter al horno y gratinar, servir bien caliente."@es .

<http://example.org/recipes/plato-principal/57/step/f5f93e5481d34c68a2fa446edaa646e8> a schema1:HowToStep ;
    schema1:text "Añadir a la sartén las yemas de huevo, condimentar, retirar del fuego y sumar la pasta de ajo."@es .

<http://example.org/recipes/plato-principal/57/step/f601cafc15814e739a9c6beab6d8dd7a> a schema1:HowToStep ;
    schema1:text "Reservar los caparazones limpios."@es .

<http://example.org/recipes/plato-principal/57/step/ff7619756c4248ddb169b163e75a2850> a schema1:HowToStep ;
    schema1:text "En sartén con mantequilla y dorar la harina e incorporar el vino, la leche condensada, la crema de leche y cocinar revolviendo constantemente por 10 minutos."@es .

<http://example.org/recipes/plato-principal/58/step/65db96da52c745888eb27d35998d70c9> a schema1:HowToStep ;
    schema1:text "Servir la guatita con arroz, cebollas encurtidas, rodajas de tomate, aguacate, y ají."@es .

<http://example.org/recipes/plato-principal/58/step/6e975d9feaf84ba6b5c20e105d327818> a schema1:HowToStep ;
    schema1:text "Aparte diluir la mantequilla de maní con ½ taza de leche. Colocar esta mezcla en la licuadora con refrito y la leche restante. Licuarlos hasta obtener una salsa cremosa."@es .

<http://example.org/recipes/plato-principal/58/step/76b207cf1d3d4198b2ea0222917ed86d> a schema1:HowToStep ;
    schema1:text "En una olla grande, colocar el mondongo lavado con las 10 tazas de agua, las ramitas de cilantro, 4 dientes de ajo, una cucharadita de comino y sal. Esperar hasta que hierva, reducir la temperatura y cocinar a fuego lento durante 2 horas hasta que el mondongo esté suave."@es .

<http://example.org/recipes/plato-principal/58/step/76e744e429f04fbab2f67017fdd86132> a schema1:HowToStep ;
    schema1:text "Retirar la panza del agua y dejarlo enfriar un poco, reservar 2 tazas del caldo que se cocinó. Cuando el mondongo se haya enfriado, cortarlo en trozos muy pequeños."@es .

<http://example.org/recipes/plato-principal/58/step/ad616411e5444e758aa0713bcce44b4e> a schema1:HowToStep ;
    schema1:text "Cubrir el mondongo con agua, sal y la mitad del jugo de limón, dejarlo reposar durante 10 minutos, lavarlo y repetir el proceso otra vez. Lavarlo muy bien la segunda vez."@es .

<http://example.org/recipes/plato-principal/58/step/cea1322911b146b2988fed23d1a60b62> a schema1:HowToStep ;
    schema1:text "Tritura un poco las papas para espesar la salsa y rectificar la sal. Agregar pimienta al gusto."@es .

<http://example.org/recipes/plato-principal/58/step/dae2830b2cb442c0953e8971b2a73d25> a schema1:HowToStep ;
    schema1:text "Colocar en una sartén la mantequilla, el achiote, el orégano, la cebolla, el pimiento, el tomate, el comino y ajo restante y sal. Cocinar a fuego medio durante 5 minutos hasta que las cebollas estén suaves."@es .

<http://example.org/recipes/plato-principal/58/step/ec2c5e08adb84d32a227974e01a8e654> a schema1:HowToStep ;
    schema1:text "Colocar la salsa licuada, las 2 tazas de caldo del mondongo, las papas y el mondongo en una olla grande. Esperar hasta que hierva, reducir la temperatura y cocinar a fuego lento hasta que las papas estén suaves y el líquido comience a volverse espeso."@es .

<http://example.org/recipes/plato-principal/59/step/00cfd4fd49f44f07a63b796e6ac9fe12> a schema1:HowToStep ;
    schema1:text "En sartén precalentada colocar la mantequilla junto con el achiote, el orégano, la cebolla, el pimiento, el tomate, el comino y ajo restante y sal y dorar allí las cebollas hasta tiernizarlas."@es .

<http://example.org/recipes/plato-principal/59/step/042538b6715c427786ad8e32d7dae897> a schema1:HowToStep ;
    schema1:text "Servir la guatita caliente en cazuelas individuales."@es .

<http://example.org/recipes/plato-principal/59/step/1d729920be794a2b8a4388bef8c61d08> a schema1:HowToStep ;
    schema1:text "En una cacerola grande colocar la salsa licuada, el caldo del mondongo, las papas en cubos pequeños y el mondongo y cocinar a fuego lento hasta que las papas estén suaves y el líquido reduzca."@es .

<http://example.org/recipes/plato-principal/59/step/1da925229054499bb21f4f1e153a9485> a schema1:HowToStep ;
    schema1:text "Retirar la carne y cortar en pequeñas lonjas."@es .

<http://example.org/recipes/plato-principal/59/step/51cd19a6753c432587248a10df4f698a> a schema1:HowToStep ;
    schema1:text "Salpimentar de ser necesario."@es .

<http://example.org/recipes/plato-principal/59/step/534f79ee93b9419e87ea202c3c32aa55> a schema1:HowToStep ;
    schema1:text "Comenzar la receta colocando el mondongo en un recipiente con agua, sal y jugo de un limón, dejarlo por unos minutos y lavar muy bien, realizar este paso es de importancia para limpiar bien la víscera."@es .

<http://example.org/recipes/plato-principal/59/step/eb4b7e19269042a3840cdd1880f56cee> a schema1:HowToStep ;
    schema1:text "Mientras tanto diluir la mantequilla de maní con leche. Procesar este líquido junto con el sofrito de cebollas hasta obtener una salsa espesa."@es .

<http://example.org/recipes/plato-principal/59/step/ee7d0370dd5640618d219f3bc739678a> a schema1:HowToStep ;
    schema1:text "Colocar el mondongo en una olla honda con las tazas de agua, el cilantro, el ajo, comino y sal. Dejar hervir y bajar la temperatura para cocinar a fuego lento por 2 horas hasta tiernizar el mondongo."@es .

<http://example.org/recipes/plato-principal/6/step/18d905082b8b426e91bad32c84adfe41> a schema1:HowToStep ;
    schema1:text "Ahora agregamos el caldo de camaron, los camarones, los calamares, el pulpo, el cangrejo de Ecuador, salsa de soya, también le colocamos pimienta y hierbita, revolvemos y lo dejamos al fuego por cinco minutos."@es .

<http://example.org/recipes/plato-principal/6/step/37b6235c0197476ea49909ff2e383b54> a schema1:HowToStep ;
    schema1:text "Tenemos los mariscos; Para hacer el arroz marinero: el calamar, pulpo y el camaron, con las cabezas y cascaras del camaron hacemos un consomé y luego se lo agregamos al arroz."@es .

<http://example.org/recipes/plato-principal/6/step/3e339dec039d41c99dfaf37db179720e> a schema1:HowToStep ;
    schema1:text "Comenzamos agragando el arroz para que adquiera todos los sabores de los mariscos, al final agregamos un poquito de perejil y tapamos y dejamos cocinar tres minutos, apagamos el fuego y dejamos reposar."@es .

<http://example.org/recipes/plato-principal/6/step/48dc84dd1f58476a9211a99f5a005ed3> a schema1:HowToStep ;
    schema1:text "Ahora cortamos los calamares en cuadritos y ponemos en el sarten. Ya casi esta cocinado el arroz, lo movemos para que se unifique la cocción y agregamos 2 ramas de cebolla."@es .

<http://example.org/recipes/plato-principal/6/step/53903356fc8744df8ba0c8b92f7dd5ee> a schema1:HowToStep ;
    schema1:text "Agregamos comino, sal , y pizca de oregano y por ultimo cilantro para que mantenga jugosidad."@es .

<http://example.org/recipes/plato-principal/6/step/62aa558e777e4dedae1b0d6e9ba10689> a schema1:HowToStep ;
    schema1:text "Ahora hacemos el sofrito en una olla: agregamos bastante achiote y aceite. Cuando este caliente el aceite ponemos salsa de ajo y aceite, cuando este caliente el aceite agregamos salsa de ajo, cebolla roja y revolvemos. Despues colocamos el pimiento verde, pimiento rojo y seguimos revolviendo, para que se dore."@es .

<http://example.org/recipes/plato-principal/6/step/855cee48b35b4d499ceca61969bbc780> a schema1:HowToStep ;
    schema1:text "Hacer primeramente el arroz: 6 tazas de agua y 6 tazas de arroz. Colocarlo en una olla y cocinarlo."@es .

<http://example.org/recipes/plato-principal/6/step/b9fb1d5c3d484bceb29c8d66c172e427> a schema1:HowToStep ;
    schema1:text "Freiimos unos maduros para acompañar este lindo y sabroso plato."@es .

<http://example.org/recipes/plato-principal/6/step/bcf9b392fc0a46d18d1138a83d9fa0c8> a schema1:HowToStep ;
    schema1:text "Lavamos muybien los ingredientes y procedemos a cortar el cangrejo de Ecuador y el pulpo. Cortamos bien finitos un corte igual, y los ponemos que tengan un corte bien bonito en cuadritos."@es .

<http://example.org/recipes/plato-principal/60/step/16faa90a1e884b2492d09d72360e6ccc> a schema1:HowToStep ;
    schema1:text "Servir acompañado de arroz blanco y patacones."@es .

<http://example.org/recipes/plato-principal/60/step/40affe8aaa534e298efbe5f2dfeb8cf1> a schema1:HowToStep ;
    schema1:text "En ese punto, incorpore la leche de coco y la tableta de caldo. Rectifique el sabor y deje cocinar unos 5 minutos hasta que la salsa espese un poco."@es .

<http://example.org/recipes/plato-principal/60/step/9c4fe73e61fa497eae042ad461b1ae04> a schema1:HowToStep ;
    schema1:text "En una sartén, con aceite de achiote sofría las cebollas coloradas, las ramas de cebolla blanca y el ajo triturado. Coloque la carne de tatabra y remueva bien para integrar sabores. Deje cocinar a fuego bajo hasta que la carne suavice."@es .

<http://example.org/recipes/plato-principal/61/step/8933d56f0fa54df0aab432e177ad88d1> a schema1:HowToStep ;
    schema1:text "Sirva decorado con perejil picadito. Acompañe con arroz blanco y patacones."@es .

<http://example.org/recipes/plato-principal/61/step/bd72c6356fd748e7827e8b20a6cb545b> a schema1:HowToStep ;
    schema1:text "Coloque la carne de venado y añada el agua. Baje la temperatura y cocine durante 1 hora."@es .

<http://example.org/recipes/plato-principal/61/step/c00ade4bac374bea844ec43c37968e68> a schema1:HowToStep ;
    schema1:text "En una olla coloque el aceite de achiote, y sofría la cebolla colorada, el tomate y el ajo triturado."@es .

<http://example.org/recipes/plato-principal/61/step/c020bec032ba4242aa7677a5b9f0dd8f> a schema1:HowToStep ;
    schema1:text "Limpiar bien la carne, lavar y sazone con sal, pimienta y comino."@es .

<http://example.org/recipes/plato-principal/61/step/db1e5e9afe31487cacce5cbe3df6db60> a schema1:HowToStep ;
    schema1:text "Añada las yucas cocidas, la salsa de tomate y cocine por unos minutos más. Rectifique el sabor."@es .

<http://example.org/recipes/plato-principal/62/step/1f7127f636b24b64ba8f577340f5d733> a schema1:HowToStep ;
    schema1:text "Dejar reposar la pierna en la refrigeradora de 24 a 72 horas. Voltear la pierna de vez en cuando para que marine bien por todas partes. Mezclar el resto del aliño preparado con la chicha o cerveza y guardar."@es .

<http://example.org/recipes/plato-principal/62/step/28e9182f09b5473dbd6beb3b4f1ff448> a schema1:HowToStep ;
    schema1:text "Preparar el aliño con el ajo, el comino, 2 cucharadas de achiote, la sal y pimienta. Hacer varias incisiones de buen tamaño en la pierna de chancho y rellenar las incisiones con el aliño preparado."@es .

<http://example.org/recipes/plato-principal/62/step/519104b48e2840cda320b9edab78c70b> a schema1:HowToStep ;
    schema1:text "Pasada las primeras 3 horas, agregar las papas al horno y continuar horneando la pierna a 325F (160C) durante unas 3 a 4 horas adicionales. Si se cubrió la pierna con papel aluminio, retirar durante los últimos 30 minutos para que la piel se vuelva crujiente."@es .

<http://example.org/recipes/plato-principal/62/step/64d99878d28a4a1bb7d0277c7ce74c37> a schema1:HowToStep ;
    schema1:text "Si los jugos se empiezan a secar, calentar un poco de la chicha o cerveza adicional con un poco de la mezcla de mantequilla y achiote, agregar este líquido a la fuente de hornear. Usar una brocha para rociar la piel con la mezcla de mantequilla y achiote. Darle la vuelta a la fuente de hornear de vez en cuando para que la pierna se hornee de forma uniforme y si la piel se empieza a dorar demasiado se puede cubrir con papel aluminio (pero sin presionar la piel con el papel)."@es .

<http://example.org/recipes/plato-principal/62/step/69663a41a63842558551599f391d2683> a schema1:HowToStep ;
    schema1:text "En una olla pequeña derretir 4 onzas de mantequilla y mezclar con 1 cucharada de achiote. Bañar la pierna de chancho con esta mezcla. Guardar un poco para rociar la piel durante el proceso del hornearse. Hornear la pierna a 400F (200C) durante unos 30 a 45 minutos. Reducir la temperatura a 325F (160C) y seguir horneando durante 3 horas más."@es .

<http://example.org/recipes/plato-principal/62/step/d0ae60f32179472fa7561ddeedf05c77> a schema1:HowToStep ;
    schema1:text "Limpiar bien la pierna de chancho y colocar sobre una bandeja o un recipiente grande donde se pueda marinar. Rociar la pierna con el jugo de limón."@es .

<http://example.org/recipes/plato-principal/62/step/e71ff5373cf148ba8c8efaee3697b2bd> a schema1:HowToStep ;
    schema1:text "Pre-calentar el horno a 400F (200C). Colocar la pierna de chancho (con el lado de la piel hacia arriba) en la fuente de hornear con la mezcla guardada de la marinada."@es .

<http://example.org/recipes/plato-principal/62/step/f4b986aa93324631bfd0346132762f24> a schema1:HowToStep ;
    schema1:text "Cortar la pierna en rebanadas y sirva el hornado de chancho con las papas horneadas, mote refrito en la salsa del hornado, curtido de cebolla, aguacate, tomate, lechuga y ají criollo. Otros acompañantes pueden ser arroz blanco, yucas, habas, plátanos maduros fritos o llapingachos."@es .

<http://example.org/recipes/plato-principal/63/step/21bb41abd7584c9ba16c3fa4e7dce9aa> a schema1:HowToStep ;
    schema1:text "Introducir las langostas cuando empiece a hervir y dejar cocer por 5 minutos."@es .

<http://example.org/recipes/plato-principal/63/step/2290f097ba3642a1b5c8927af117dffc> a schema1:HowToStep ;
    schema1:text "Llevar al fuego una cacerola con la mantequilla y dorar la harina por 5 minutos."@es .

<http://example.org/recipes/plato-principal/63/step/2b936f6f1f204350888888ff896f04f8> a schema1:HowToStep ;
    schema1:text "Lavar los caparazones y reservarlos."@es .

<http://example.org/recipes/plato-principal/63/step/4bf5a363c2a6410287d6c6a0f6bfa3ad> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a temperatura alta (200 ºC – 400 ºF)"@es .

<http://example.org/recipes/plato-principal/63/step/59c57fb8680a4025b2bcdd24877a9480> a schema1:HowToStep ;
    schema1:text "Retirar las langostas del caldo y partirlas por la mitad de manera longitudinal empezando desde la cola."@es .

<http://example.org/recipes/plato-principal/63/step/a20c5fd36948426f9468dbd6ad8ecf51> a schema1:HowToStep ;
    schema1:text "Añadir las yemas de huevo y continuar cociendo por 1 minuto sin dejar de remover."@es .

<http://example.org/recipes/plato-principal/63/step/c9d908313dec4c8bb2f27cc8008187e8> a schema1:HowToStep ;
    schema1:text "Preparar un caldo con el agua, el apio, la zanahoria, la cebolla, los dientes de ajo, sal y pimienta al gusto."@es .

<http://example.org/recipes/plato-principal/63/step/ce9db3902b1b4866aeb49f739fd0e50b> a schema1:HowToStep ;
    schema1:text "Cortar un extremo de la cabeza de ajo y con un paño de cocina o limpión presione para sacar la pulpa del ajo y reservar."@es .

<http://example.org/recipes/plato-principal/63/step/e77cd1b597954ee49265efafba089959> a schema1:HowToStep ;
    schema1:text "Disponga el caparazón de las langostas en una lata de horno, coloque la carne de la langosta, bañe con la salsa y rocíe con el queso, la páprika, el eneldo y el tomillo."@es .

<http://example.org/recipes/plato-principal/63/step/ec5424416243473593e480061f7e5319> a schema1:HowToStep ;
    schema1:text "Azar la cabeza de ajo en el horno por 20 minutos."@es .

<http://example.org/recipes/plato-principal/63/step/f2ffa2aaed5b425aa87c7010c8e64130> a schema1:HowToStep ;
    schema1:text "Incorporar el vino, la leche evaporada, la crema de leche y dejar cocer por 5 minutos."@es .

<http://example.org/recipes/plato-principal/63/step/f7678937bf154edc9647f9e4f55d7fa5> a schema1:HowToStep ;
    schema1:text "Extraer con cuidado la carne y cortar en trozos."@es .

<http://example.org/recipes/plato-principal/63/step/f9302c399fe24577bf5d26d96f5d40cd> a schema1:HowToStep ;
    schema1:text "Salpimiente y retire del fuego, agregar la pasta de ajo y el licor, intégrarlo todo."@es .

<http://example.org/recipes/plato-principal/63/step/fb2961d5fee44c00affc8d9a7846be06> a schema1:HowToStep ;
    schema1:text "Meter al horno hasta que se gratine. Servir caliente"@es .

<http://example.org/recipes/plato-principal/64/step/07d2cc8d94ae44049105eaee374b5c48> a schema1:HowToStep ;
    schema1:text "Luego agregamos una taza de vino blanco, 1 ramita de romero, cocinamos y dejamos reducir. Seguido agregamos la sal, pimienta, 3 hojas de albahaca y revolvemos hasta que reduzca mas. Una vez lista retiramos del fuego."@es .

<http://example.org/recipes/plato-principal/64/step/3279f73b63794d88ad61f717671b57f8> a schema1:HowToStep ;
    schema1:text "En una bandeja colocamos la pasta, la salsa bechamel por encima, el queso mozarella, y la carne. Repetimos el proceso y por ultimo bastante queso. Cocinamos por 200 grados C por 40 minutos."@es .

<http://example.org/recipes/plato-principal/64/step/913d6cb8a196431daf769f4ef6ddf6b6> a schema1:HowToStep ;
    schema1:text "Comenzamos colocando la mantequilla en una olla. Una vez derretida agregamos el harina, la leche, la sal, pimienta y nuez moscada. Mezclamos bien hasta espesar. Dejamos reposar."@es .

<http://example.org/recipes/plato-principal/64/step/e9660648aebd4eaf851e9b7655c4d27c> a schema1:HowToStep ;
    schema1:text "Aparte en un sarten realizaremos la salsa boloñesa. Comenzaremos colocando 2 cucharadas de aceite, la carne molida de res y de cerdo. Revolvemos hasta que se cocine. Agregamos salsa para pizza y revolvemos hasta mezclar bien."@es .

<http://example.org/recipes/plato-principal/65/step/118acf917745443e888508b43e240720> a schema1:HowToStep ;
    schema1:text "Aparte en una olla de agua hirviendo agregamos la pechuga a cocinar. Que servira para desmecharla y hacer la lasaña."@es .

<http://example.org/recipes/plato-principal/65/step/38214614208b4599863f6c971d142594> a schema1:HowToStep ;
    schema1:text "Listo para disfrutar y servir."@es .

<http://example.org/recipes/plato-principal/65/step/8da1ed7c1fab461c9b1a2a679740ef98> a schema1:HowToStep ;
    schema1:text "Una vez cocinado el pollo lo sacamos y lo desmenuzamos. Aparte en un sarten colocamos un poco de achiote y agregamos la carne molida y aceite para sofreirla. Cuando ya a consumido el liquido agregamos la cebolla, los pimientos, el tomate y ajo. Mezclamos bien. Luego agregamos el pollo desmechado y revolvemos bien. Agregamos tomillo, albahaca, sal, pimienta , culantro y oregano. Mezclamos y agregamos un poco de liquido y lo tapamos. Dejamos cocinar por 15 minutos."@es .

<http://example.org/recipes/plato-principal/65/step/9847fbfa32024e70924a78e9a4506a86> a schema1:HowToStep ;
    schema1:text "Luego en una bandeja refractaria colocamos salsa bechamel, una capa de pasta, luego relleno de carne y pollo, por encima salsa bechamel, por encima queso mozarella. Seguimos colocando lamina de pasta, relleno y bechamel y al final abundante queso mozarella."@es .

<http://example.org/recipes/plato-principal/65/step/9c5e6195e1ff485e9549a584d17f9224> a schema1:HowToStep ;
    schema1:text "Colocamos el horno a 200 C. Esperamos de 30 a 40 minutos."@es .

<http://example.org/recipes/plato-principal/65/step/a53691cdb0354692931618354694a114> a schema1:HowToStep ;
    schema1:text "Primero en olla con agua agregamos las laminas de lasaña, aceite y sal."@es .

<http://example.org/recipes/plato-principal/65/step/bb28381b21a54f0d910a28e48bdf4e1b> a schema1:HowToStep ;
    schema1:text "Luego en un recipiente ponemos las 2 cucharaditas de mantequilla a derretir, agregamos encima la harina y mezclamos. Seguido agregamos la leche batiendo constantemente para que no se forme grumos. Luego mezclamos leche y harina y batimos. Para que se forme la salsa bechamel. Agregamos despues nuez moscada, pimienta y sal. Seguimos batiendo."@es .

<http://example.org/recipes/plato-principal/65/step/fcaa7e6fc61a49c096837ca08083438f> a schema1:HowToStep ;
    schema1:text "Antes de meter al horno espolvoreamos oregano."@es .

<http://example.org/recipes/plato-principal/66/step/043f6ced08d147db9cf3dc24ff7c7104> a schema1:HowToStep ;
    schema1:text "Con la mitad de esta mezcla sazone el lechón por dentro y por fuera, y déjelo reposar en la refrigeradora de 2 a 24 horas."@es .

<http://example.org/recipes/plato-principal/66/step/133fd26e93f949ea999ba1df709867e7> a schema1:HowToStep ;
    schema1:text "Lavar bien el lechón o la pierna de cerdo y secarla con papel toalla."@es .

<http://example.org/recipes/plato-principal/66/step/1b74a4694b17438fbf57af7fb805b6f1> a schema1:HowToStep ;
    schema1:text "Voltear la carne cada 45 minutos y rociarla con el jugo de la fuente o usar caldo de res o agua para evitar que se reseque o queme."@es .

<http://example.org/recipes/plato-principal/66/step/302a9cdfc4e94ce48825aebab17e01d0> a schema1:HowToStep ;
    schema1:text "Colocar el lechón o pierna de cerdo en una bandeja de horno profunda y hechar el coñac o brandy en el interior."@es .

<http://example.org/recipes/plato-principal/66/step/ae1d3fa1ac0c447c975f136d812d730b> a schema1:HowToStep ;
    schema1:text "Hornear por 30 minutos, voltear y agregar la salsa restante, continuar la cocción por 90 minutos."@es .

<http://example.org/recipes/plato-principal/66/step/c51497b5cad647eab28e76af7b45efa7> a schema1:HowToStep ;
    schema1:text "20 minutos antes de finalizar se debe cubrir la carne con papel aluminio en la parte superior para evitar que se queme."@es .

<http://example.org/recipes/plato-principal/66/step/c80fa53293154e91ac3d6c3c8915fa9a> a schema1:HowToStep ;
    schema1:text "Licuar el aceite, la sal, la pimienta, el ajo, la cebolla, el comino y el orégano hasta obtener una salsa."@es .

<http://example.org/recipes/plato-principal/66/step/ccfceb4f5e44442f8c2650ba95fc92e3> a schema1:HowToStep ;
    schema1:text "Usar un cuchillo para pinchar la carne profundamente para que el adobo penetre en ella."@es .

<http://example.org/recipes/plato-principal/66/step/d60c6755b8794a798c051cd21d09a3aa> a schema1:HowToStep ;
    schema1:text "Colocar la mezcla en un pocillo y añadir las hojas de laurel trituradas."@es .

<http://example.org/recipes/plato-principal/66/step/e70d8ac0003b45a4b4c55da0ba8cdcfa> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a temperatura media."@es .

<http://example.org/recipes/plato-principal/67/step/1d48103b48a0496e8c92c96b26f4bdf8> a schema1:HowToStep ;
    schema1:text "Sirva la lengua bañada en la salsa y acompáñela con arroz blanco, papas salteadas, ensalada y aguacate."@es .

<http://example.org/recipes/plato-principal/67/step/1da06622d6124187b26210357e22cd63> a schema1:HowToStep ;
    schema1:text "En una sartén, colocar aceite de achiote y sofría la cebolla con el ajo. Sazone con sal, pimienta y comino al gusto. Incorpore el maní licuado con la leche y el cilantro picadito. Continúe removiendo la salsa por unos minutos hasta que comience a espesar."@es .

<http://example.org/recipes/plato-principal/67/step/4d801612b6e8464c8c6a2eea8cbd4f16> a schema1:HowToStep ;
    schema1:text "En ese punto debe añadir los filetes de lengua a la salsa y se deja cocinar por unos 5 minutos."@es .

<http://example.org/recipes/plato-principal/67/step/5908331f17a64c6b8a183cc3c4b5a762> a schema1:HowToStep ;
    schema1:text "Lavar bien la lengua y colocarla en una olla de presión con suficiente agua, hojas de culantro y un poco de sal. Cocinarla por aproximadamente 40 minutos hasta que ablande."@es .

<http://example.org/recipes/plato-principal/67/step/ea0394c240c44aa89f8f164ee8154287> a schema1:HowToStep ;
    schema1:text "Una vez que esté blanda, deje enfriar y luego corte en lonjas finas."@es .

<http://example.org/recipes/plato-principal/68/step/22a8fa01e2844915bb48b7e3ee02f492> a schema1:HowToStep ;
    schema1:text "Realizar un pure rustico donde se sientan trocitos de papa."@es .

<http://example.org/recipes/plato-principal/68/step/287678a647334848bd4ab07192ead12b> a schema1:HowToStep ;
    schema1:text "Servir caliente y espolvorear con cilantro picado."@es .

<http://example.org/recipes/plato-principal/68/step/3871cf6b7a3e4597a96f77a78c556354> a schema1:HowToStep ;
    schema1:text "Pasado ese tiempo agregar el agua y hervir las papas hasta que se ablanden."@es .

<http://example.org/recipes/plato-principal/68/step/64f2d5dfcabc4368bcac36a4faaef47f> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, salar y esparcir el queso rallado."@es .

<http://example.org/recipes/plato-principal/68/step/9a6075c436954ca2a47cb322bbd7b105> a schema1:HowToStep ;
    schema1:text "Añadir la leche y cocinar por 5 minutos más."@es .

<http://example.org/recipes/plato-principal/68/step/bc2e3b2e8fe741b7b954441645fb84c2> a schema1:HowToStep ;
    schema1:text "En una olla precalentada colocar la mantequilla y dorar la cebolla, junto con el ajo, el comino y el achiote."@es .

<http://example.org/recipes/plato-principal/68/step/f99d1b8e887049f193aa46c2c5052dce> a schema1:HowToStep ;
    schema1:text "Agregar a la cacerola las papas cortadas en trozos grandes y cocinar por 5 minutos."@es .

<http://example.org/recipes/plato-principal/69/step/48cb5631855246e690859cb20fb33d57> a schema1:HowToStep ;
    schema1:text "Seguido de esto picamos la cebolla roja en pedacitos pequeños."@es .

<http://example.org/recipes/plato-principal/69/step/54ec42e239354903b19c3044b7bd801b> a schema1:HowToStep ;
    schema1:text "Luego la carne que sacamos la salamos bien y la agregamos al sarten para cocinarla con la salsa y agregamos el brandy."@es .

<http://example.org/recipes/plato-principal/69/step/62c18e67a89345a4abd9c9943e68bc15> a schema1:HowToStep ;
    schema1:text "Aparte en un sarten colocamos el aceite de oliva y lo ponemos a calentar. Mienstras vamos pasando la carne por ambos lados por la pimienta y quitamos el exceso."@es .

<http://example.org/recipes/plato-principal/69/step/6fa85cf06f474f0fadb86afe72c00321> a schema1:HowToStep ;
    schema1:text "Una vez lista la sacamos y Podemos acompañarla con ensalada."@es .

<http://example.org/recipes/plato-principal/69/step/79d3c1b7ee894fdaa7a4654f0ce2703d> a schema1:HowToStep ;
    schema1:text "Primero ponemos la pimienta en pepitas en el mortero para molerla ya agrre la textura. Solo la molemos un poco y luego la colocamos en un plato o recipiente."@es .

<http://example.org/recipes/plato-principal/69/step/9d44ad4267de4df4be6edb69cdbd9fbe> a schema1:HowToStep ;
    schema1:text "Seguido de esto colocamos en el sarten a sellar unos segundos por todos los lados. Solo la sellamos, incluyendo los lados delgaditos, al tenerla sellada la retiramos del sarten."@es .

<http://example.org/recipes/plato-principal/69/step/a76cbe5b1524400a97f6a27e27a6f748> a schema1:HowToStep ;
    schema1:text "En ese mismo sarten agregamos la mantequilla para derretirla, luego agregamos la crema de leche, aproximadamente 1 taza o al gusto. Revolvemos bien. Agregamos sal al gusto, luego la cebolla roja picada y mezclamos todo muy bien."@es .

<http://example.org/recipes/plato-principal/69/step/d4f9c7c95fb44749a455afcd21943b19> a schema1:HowToStep ;
    schema1:text "Luego picamos muy bien el ajo."@es .

<http://example.org/recipes/plato-principal/7/step/366384691b944fe480368300d93b5874> a schema1:HowToStep ;
    schema1:text "Luego agregamos 2 huevos fritos revueltos. Mezclamos por 2 minutos mas."@es .

<http://example.org/recipes/plato-principal/7/step/559d963bc2db4a2599a7267cb2f67cc6> a schema1:HowToStep ;
    schema1:text "Añadimos 5 tazas de arroz cocinado, 4 cucharadas de salsa de soya densa. Mezclamos por dos minutos mas hasta que todo se mezcle muy bien."@es .

<http://example.org/recipes/plato-principal/7/step/5cf0bc095f7b4bf19c5eb85110b0361e> a schema1:HowToStep ;
    schema1:text "En una sarten colocamos aceite y ponemos a freir 1/2 kg de carne de cerdo. Agregamos una pizca de sal y comino. Una vez dorada la sacamos y reservamos para despues."@es .

<http://example.org/recipes/plato-principal/7/step/8623d84fc6fc43d881a4c701c7996669> a schema1:HowToStep ;
    schema1:text "Una vez listo los reservamos. En el mismo sarten sofreimos 1/2 kg de pollo cocinado y de igual manera lo reservamos."@es .

<http://example.org/recipes/plato-principal/7/step/b604559c53124e8f872ab19f6c45bd7a> a schema1:HowToStep ;
    schema1:text "Luego agregamos 1/2 taza de cebolla china picadita y agregamos 3 dientes de ajo y un poquito de jenjibre rayado. Mezclamos bien y añadimos pimienta al gusto, comino y sal."@es .

<http://example.org/recipes/plato-principal/7/step/bdfbf5bbed9e4e378b31a7786e447f80> a schema1:HowToStep ;
    schema1:text "Mezclamos todo muy bien y añadimos 1/2 taza de arveja cocinada, 1/2 taza de zanahoria cocinada en cuadritos, mezclamos todo muy bien y agregamos la carne de cerdo, el pollo y el camaron. Mezclamo muy bien todos los ingredientes."@es .

<http://example.org/recipes/plato-principal/7/step/cae51d417a4a4a7ab9a0f12a2d95aa3e> a schema1:HowToStep ;
    schema1:text "Una vez listo disfrutar y servir."@es .

<http://example.org/recipes/plato-principal/7/step/ddce70c85cb04709847fb60c30adcaa4> a schema1:HowToStep ;
    schema1:text "Luego en el mismo aceite agregamos 1/2 kg de camarones, sofreimos hasta que cambien de color."@es .

<http://example.org/recipes/plato-principal/70/step/1625fef970664cb488e0e2b698c55b6b> a schema1:HowToStep ;
    schema1:text "Extender el lomo sobre un cuadrado de papel de aluminio, colocar las lonjas de jamón y el queso, enrollar y llevar al horno por 45 minutos o hasta que la carne esté cocida."@es .

<http://example.org/recipes/plato-principal/70/step/26d2816f6bf9449ca1d58e9a4ad0d738> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a 350ºF."@es .

<http://example.org/recipes/plato-principal/70/step/402a31b5d54542ac9c6f397636e5172f> a schema1:HowToStep ;
    schema1:text "Retirar del horno y dejar refrescar deja refrescar."@es .

<http://example.org/recipes/plato-principal/70/step/4dbda77535014892a36095671f7ac712> a schema1:HowToStep ;
    schema1:text "Cocinar sin dejar de mover hasta espesar."@es .

<http://example.org/recipes/plato-principal/70/step/8e8778bb475e42598b15d0611ec51fcb> a schema1:HowToStep ;
    schema1:text "Retira del fuego y cortar el lomo y servir con la salsa."@es .

<http://example.org/recipes/plato-principal/70/step/af4b232f3aa84d29b414e872ac5841c3> a schema1:HowToStep ;
    schema1:text "En un recipiente aparte hervir la leche evaporada restante, junto con la harina, la cebolla, el vino."@es .

<http://example.org/recipes/plato-principal/70/step/b7226e208a95499895be52ac03735b54> a schema1:HowToStep ;
    schema1:text "Abrir el lomo en forma de sábana, sazonarlo con la sazón, el tomillo, la mantequilla y 2 cucharadas de leche evaporada."@es .

<http://example.org/recipes/plato-principal/71/step/2a974f1671b04c3394d190714e63b832> a schema1:HowToStep ;
    schema1:text "Lavar las carachamas y condimentarlas con ajo y sal."@es .

<http://example.org/recipes/plato-principal/71/step/6b337ed404a74a8088edf1d3aa125847> a schema1:HowToStep ;
    schema1:text "Para el armado colocar 3 hojas de achira en forma de asterisco, colocar una cucharada de la preparación y por encima una carachama, agregar una cucharada de agua y cerrar en forma de bolsa."@es .

<http://example.org/recipes/plato-principal/71/step/7ee3182c758d40ac8919ea89af6b88eb> a schema1:HowToStep ;
    schema1:text "Comenzar por cocinar la yuca. Una vez que este tierna, reservar."@es .

<http://example.org/recipes/plato-principal/71/step/c9cb3a87dc0f48d5a291889e79fe818c> a schema1:HowToStep ;
    schema1:text "Picar la cebolla colorada el tomate y agregar limón, mezclar todo."@es .

<http://example.org/recipes/plato-principal/71/step/d7c46a78996148d4873b81dca660d68b> a schema1:HowToStep ;
    schema1:text "Cocinar los paquetes en una parrilla por unos 25 a 30 minutos."@es .

<http://example.org/recipes/plato-principal/71/step/ea4f6b3e3d024d85818663817b719a5b> a schema1:HowToStep ;
    schema1:text "Picar la cebolla blanca y mezclar con el palmito y el cilantro."@es .

<http://example.org/recipes/plato-principal/72/step/2d4b4043dd614f949cb6019fabf68724> a schema1:HowToStep ;
    schema1:text "Cocinar la yuca."@es .

<http://example.org/recipes/plato-principal/72/step/36cf15f36cc940cb92bdfeeb831613a3> a schema1:HowToStep ;
    schema1:text "Colocar 3 hojas de bijao en forma de asterisco, agregar la preparación anterior y sobre ésta las carachamas."@es .

<http://example.org/recipes/plato-principal/72/step/654c328ebddc47ac83002f9ef6eb52b2> a schema1:HowToStep ;
    schema1:text "Picar la cebolla blanca finamente en rodajas y mezclar con el palmito y el cilantro, condimentar con poca sal."@es .

<http://example.org/recipes/plato-principal/72/step/9ee1052dbb084ef8bae15dc1fc0d3c33> a schema1:HowToStep ;
    schema1:text "Agregar 3 cucharadas de agua y cerrar en forma de bolsa junto a los tallos y las puntas de las hojas, amarrar con bejuco o lianas."@es .

<http://example.org/recipes/plato-principal/72/step/a96b590372274272913ba6a3153fdb02> a schema1:HowToStep ;
    schema1:text "Condimentar con sal y ajo picado finamente."@es .

<http://example.org/recipes/plato-principal/72/step/cf6ffdd31db348c19db512eea75e75b3> a schema1:HowToStep ;
    schema1:text "Retirar las vísceras de la carachama y lavar minuciosamente."@es .

<http://example.org/recipes/plato-principal/72/step/d78fa92b2079457cb39d40d47d19a6ad> a schema1:HowToStep ;
    schema1:text "Cocinar en una parrilla con brasas de carbón o leña, de 25 a 30 minutos o hasta que deje de gotear líquido."@es .

<http://example.org/recipes/plato-principal/72/step/e55805d2b5404f93900fc5bfe6465f99> a schema1:HowToStep ;
    schema1:text "Realizar un encurtido con la cebolla colorada finamente picada, el tomate y agregar limón."@es .

<http://example.org/recipes/plato-principal/73/step/1e044d59ba7243e3958623c85883eed0> a schema1:HowToStep ;
    schema1:text "Añadir el litro de agua y esperar a que rompa en hervor, añadir las lentejas lavadas y cocinar por una hora a fuego lento."@es .

<http://example.org/recipes/plato-principal/73/step/6cc91a6d612d43d989d9a8eb9c1d3552> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y servir en cazuelas individuales acompañado con arroz y plátanos maduros fritos."@es .

<http://example.org/recipes/plato-principal/73/step/81ccdacd95ed4ae4a422eed00ffc46df> a schema1:HowToStep ;
    schema1:text "En una olla grande calentar aceite y agregar la cebolla, el pimiento, el tomate, el ajo,las especias y sal. Cocinar hasta que los ingredientes esten tiernos."@es .

<http://example.org/recipes/plato-principal/74/step/73c881ad774f4a1b8c6115b08e3250ed> a schema1:HowToStep ;
    schema1:text "Condimentar la carne y asarla de ambos lados."@es .

<http://example.org/recipes/plato-principal/74/step/8857a5a32cc64adc80fd474847359125> a schema1:HowToStep ;
    schema1:text "Colocar en una olla con agua y sal el arroz blanco y dejar hervir."@es .

<http://example.org/recipes/plato-principal/74/step/9d9f70b307014dee8958a484b23a296d> a schema1:HowToStep ;
    schema1:text "En una sartén precalentada sofreír la cebolla, el tomate, el pimiento y el ajo cortados en cubos pequeños y salar a gusto."@es .

<http://example.org/recipes/plato-principal/74/step/cebcf4bd95a7426ea38e3b3e43b5e4c2> a schema1:HowToStep ;
    schema1:text "En cacerola aparte lavar y hervir los frejoles hasta que estén blandos."@es .

<http://example.org/recipes/plato-principal/74/step/d8dd2789c88c496aade3a9b0149fe4d8> a schema1:HowToStep ;
    schema1:text "Añadir los frejoles al sofrito y cocinar integrando por un par de minutos."@es .

<http://example.org/recipes/plato-principal/74/step/ed9b1f98072b4b4b98f056bf0be31bf9> a schema1:HowToStep ;
    schema1:text "Servir el lomo junto a una porción de arroz blanco."@es .

<http://example.org/recipes/plato-principal/75/step/1431b2d756b6404b936b35052a044746> a schema1:HowToStep ;
    schema1:text "Revolver el refrito con el fréjol y dejarlo hervir unos 5 minutos."@es .

<http://example.org/recipes/plato-principal/75/step/2c1a82bcdeee4525baba6d6befeb97f1> a schema1:HowToStep ;
    schema1:text "Condimentar al gusto la carne, se puede usar ajo molido, comino, pimienta y sal."@es .

<http://example.org/recipes/plato-principal/75/step/5fac814c46c64672afeee81fb922174e> a schema1:HowToStep ;
    schema1:text "Lavar y hervir los frejoles hasta que estén blandos."@es .

<http://example.org/recipes/plato-principal/75/step/7e09f7d15868432f85d7648e4fa18183> a schema1:HowToStep ;
    schema1:text "Remojar los frejoles en agua. Dejar remojando desde la noche anterior."@es .

<http://example.org/recipes/plato-principal/75/step/aa6444a420484eff906f7344e0c07154> a schema1:HowToStep ;
    schema1:text "Acompañar con patacones."@es .

<http://example.org/recipes/plato-principal/75/step/aafa7a944cda45459fb2014b9fb6a839> a schema1:HowToStep ;
    schema1:text "Agregar cuero de chancho cortado en cuadritos."@es .

<http://example.org/recipes/plato-principal/75/step/b268facff2d944a2875f25e4d6f75759> a schema1:HowToStep ;
    schema1:text "Asar la carne y servir junto a una porción de arroz blanco."@es .

<http://example.org/recipes/plato-principal/75/step/e5cc1f1c8d424308bc7ddf314ebaa90f> a schema1:HowToStep ;
    schema1:text "Preparar un refrito con la cebolla colorada, el tomate, el pimiento, el ajo y sal al gusto."@es .

<http://example.org/recipes/plato-principal/75/step/ffe8eae6b6fa41b6a175914562a8494c> a schema1:HowToStep ;
    schema1:text "Poner a cocinar el arroz blanco."@es .

<http://example.org/recipes/plato-principal/76/step/245d8509e45c4e27a2808a6b8397c4cc> a schema1:HowToStep ;
    schema1:text "Mezclar el cilantro restante con la menestra y servir acompañado con arroz, carne asada o frita, patacones o plátanos maduros fritos, una pequeña ensalada o rodajas de aguacate."@es .

<http://example.org/recipes/plato-principal/76/step/4f220c225af84c799077cc965580f400> a schema1:HowToStep ;
    schema1:text "Calentar el aceite a fuego medio en una olla grande y agregar la cebolla, el pimiento, el tomate, el ajo, el comino, el achiote, 2 cucharadas del cilantro picado y sal. Cocinar durante unos 5 minutos hasta que los ingredientes se hayan ablandado, revolviendo de vez en cuando."@es .

<http://example.org/recipes/plato-principal/76/step/e42209ba4ee94a5888ca18750c0503da> a schema1:HowToStep ;
    schema1:text "Añadir el agua e incrementar la temperatura hasta que comience a hervir. Agregar las lentejas y reducir la temperatura, tapar parcialmente la olla y cocinar a fuego lento durante 1 hora hasta que las lentejas estén tiernas."@es .

<http://example.org/recipes/plato-principal/77/step/162a8ca399004b5591e7efa5823d3e04> a schema1:HowToStep ;
    schema1:text "En una olla colocaremos 1 cucharada de achiote, 1 taza de cebolla picada en cubo, 3 dientes de ajo, 1 unidad de pimiento verde en trocitos pequeños, 2 cucharadas de hiervita o cilantro, pimienta y comino al gusto. Revolvemos muy bien y agregamos las lentejas."@es .

<http://example.org/recipes/plato-principal/77/step/4b3c136fe4ee4029b1ea678e85a386d3> a schema1:HowToStep ;
    schema1:text "Sazonamos con sal al gusto y agregamos 2 tazas de agua. Dejamos cocinar por 15 minutos."@es .

<http://example.org/recipes/plato-principal/77/step/60b7d4f2d64d4fa8ad413f889da58782> a schema1:HowToStep ;
    schema1:text "Añadimos 2 cucharadas de mantequilla y servimos al gusto."@es .

<http://example.org/recipes/plato-principal/77/step/9aa62bddd4d944fc9be5d8b93d7f665f> a schema1:HowToStep ;
    schema1:text "Agregamos el arroz y revolvemos muy bien. Añadimos 1 taza de agua y tapamos."@es .

<http://example.org/recipes/plato-principal/77/step/f4e96ea9b1ff40928544748d0d4f40d0> a schema1:HowToStep ;
    schema1:text "Aparte en un sarten perparamos unas papas una vez lista se las colocamos al arroz y añadimos un poco de queso. Mezclamos bien."@es .

<http://example.org/recipes/plato-principal/77/step/fa3df22190f44f15ba562b4bdbef575a> a schema1:HowToStep ;
    schema1:text "Listo para disfrutar."@es .

<http://example.org/recipes/plato-principal/78/step/1aad3deff5a9426895554b5058123c87> a schema1:HowToStep ;
    schema1:text "Tome las hojas de bijao y páselas por el fuego para suavizarla. Luego se lavan y se cortan."@es .

<http://example.org/recipes/plato-principal/78/step/70d5416c40ac4fad9c9cfa67458782ee> a schema1:HowToStep ;
    schema1:text "Servir el pescado con patacones, ensalada y rodajas de limón."@es .

<http://example.org/recipes/plato-principal/78/step/797227165bae48959daaaa2be11109f4> a schema1:HowToStep ;
    schema1:text "En una sartén con aceite de achiote, prepare un sofrito con cebolla, ajo, oreganón, chirarán y una pizca de sal y pimienta. Añada la leche de coco, la chillangua y deje cocinar por unos 10 minutos hasta que reduzca la salsa."@es .

<http://example.org/recipes/plato-principal/78/step/9cea5b62a8c04196808865e65e6f1de9> a schema1:HowToStep ;
    schema1:text "Retirar del agua y dejar que escurra un rato. Luego colocar encima en la parrilla y asar."@es .

<http://example.org/recipes/plato-principal/78/step/e2fd8377cd104caa87384c43e8d6bd7c> a schema1:HowToStep ;
    schema1:text "En la hoja limpia, coloque el pescado aliñado y encima el sofrito preparado. Se envuelve bien en las hojas y se amarran con hilo para luego cocinarlos en agua hirviendo por pocos minutos."@es .

<http://example.org/recipes/plato-principal/78/step/e3f7c0f4d96f42eabb78a03bd26e6ac0> a schema1:HowToStep ;
    schema1:text "En un bol, coloque los filetes de pescado y aliñe con jugo de limón, jugo de naranja, un poco de aceite, sal y comino."@es .

<http://example.org/recipes/plato-principal/79/step/1ef8b88b8ab84fdca0387dcd1472df0a> a schema1:HowToStep ;
    schema1:text "Enrollar con el plástico film y cubrir con papel aluminio."@es .

<http://example.org/recipes/plato-principal/79/step/23a5e755322947aa85cea9639135bdc2> a schema1:HowToStep ;
    schema1:text "Colocar en el medio el jamón y la espinaca."@es .

<http://example.org/recipes/plato-principal/79/step/34e744368bca4732a29d1dc918ad0334> a schema1:HowToStep ;
    schema1:text "Cortar el pastel en medallones y servir acompañado de la salsa."@es .

<http://example.org/recipes/plato-principal/79/step/4fcd3a1d14b0426e8c7bc5e40b2e7239> a schema1:HowToStep ;
    schema1:text "Hornear por 45 minutos."@es .

<http://example.org/recipes/plato-principal/79/step/5b3cb8f66d904b6180e3391758fa912a> a schema1:HowToStep ;
    schema1:text "Estirar el plástico film y colocar la carne bien estirada para poder envolverla."@es .

<http://example.org/recipes/plato-principal/79/step/8b142f356f384da19e0b1c69232933cb> a schema1:HowToStep ;
    schema1:text "Agregar el ajo, la cebolla y el tomate."@es .

<http://example.org/recipes/plato-principal/79/step/9fd23ec90aef499cb9ef258ba928023c> a schema1:HowToStep ;
    schema1:text "Mezclar bien, cueza durante pocos minutos y añadir la pasta de tomate."@es .

<http://example.org/recipes/plato-principal/79/step/bc90a9f0619c4621a2f75f6f58466ea6> a schema1:HowToStep ;
    schema1:text "Preparar la salsa, en una cacerola, calentar el aceite y añadir el tocino, el laurel y dejar cocer durante 3 minutos."@es .

<http://example.org/recipes/plato-principal/79/step/bfe9225cb288492b8329016f0f307458> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a 250 °C."@es .

<http://example.org/recipes/plato-principal/79/step/d05ae2365735404e9bdbb424067e5770> a schema1:HowToStep ;
    schema1:text "Mezclar la carne molida con la miga de pan y los huevos, agregar sal y pimienta."@es .

<http://example.org/recipes/plato-principal/79/step/f164d3bbba464635bfd65bf2e9df74ef> a schema1:HowToStep ;
    schema1:text "Incorporar el concentrado de carne y el vino, dejar reducir hasta la mitad y condimentar."@es .

<http://example.org/recipes/plato-principal/8/step/18660d693e2e48438df98b800f88437a> a schema1:HowToStep ;
    schema1:text "Coloque el bacalao sobre papel absorbente, reserve."@es .

<http://example.org/recipes/plato-principal/8/step/3796e722d8594e94a6572a7ff9282cd3> a schema1:HowToStep ;
    schema1:text "Pase los trozos por harina y luego fría en aceite bien caliente."@es .

<http://example.org/recipes/plato-principal/8/step/68f1fcfe33b446adba0cfd3fa3b6119e> a schema1:HowToStep ;
    schema1:text "Sirva el bacalao frito y bañe con la salsa de vino. Acompáñelo con arroz o papas y curtidos de cebollas."@es .

<http://example.org/recipes/plato-principal/8/step/9a6fd38ea4f64d98a5e0d6135a5570fd> a schema1:HowToStep ;
    schema1:text "Lavar bien el bacalao y proceda a cortarlos en trozos. Sazone con sal, pimienta y jugo de limón."@es .

<http://example.org/recipes/plato-principal/8/step/ea657bce7b4246858fac9d98ecab542a> a schema1:HowToStep ;
    schema1:text "En la misma sartén donde cocino el bacalao, sofría las cebollitas con el tomate y los pimientos cortados en julianas. Añada el vino, el tomillo y rectifique el sabor."@es .

<http://example.org/recipes/plato-principal/80/step/0190bea010ea4279950ccc9ef7813489> a schema1:HowToStep ;
    schema1:text "Luego Agregamos un poco de achiote a la mezcla del procesador, agregamos tambien 2 cucharaditas de comino, 1 cucharadita de oregano seco, 1 cucharadita de tomillo, 12 oz de cerveza rubia, 2 cucharaditas de sal, 1 cucharadita de pimienta negra. Licuamos todo muy bien."@es .

<http://example.org/recipes/plato-principal/80/step/81172e117a5340e19f449c5c8908b951> a schema1:HowToStep ;
    schema1:text "Una vez marinado lo colocamos en una bandeja para horno por aproximadamente 2 horas."@es .

<http://example.org/recipes/plato-principal/80/step/9a939820440b43ec830519267c09fac5> a schema1:HowToStep ;
    schema1:text "Una vez listo podemos disfrutar y servir."@es .

<http://example.org/recipes/plato-principal/80/step/a94a0723c4aa4118bac879bd2b4bb3be> a schema1:HowToStep ;
    schema1:text "En un procesador colocaremos la cebolla blanca, la cebolla verde, 6 dientes de ajo y 2 cucharadas de vinagre blanco. Trituramos bien."@es .

<http://example.org/recipes/plato-principal/80/step/ad087883848b49289be93cc865e516bc> a schema1:HowToStep ;
    schema1:text "Procedemos a agujerear la pierna de puerco con la ayuda de un cuchillo para que entre la marinada. Sumergimos el pernil en la marinada y dejamos en la nevera pro 8 horas."@es .

<http://example.org/recipes/plato-principal/80/step/d3a096e4530d42aabc90c3fee8d85770> a schema1:HowToStep ;
    schema1:text "Para que el cuero quede crujiente lo rociamos con achiote por encima y lo dejamos descubierto."@es .

<http://example.org/recipes/plato-principal/81/step/2743e23b83ef47df86fdf78e0edd0e32> a schema1:HowToStep ;
    schema1:text "Licuar los dientes de ajos, las ramitas de perejirl, sal, mostaza y media taza de agua."@es .

<http://example.org/recipes/plato-principal/81/step/31329936d96a404eb0bebed5e7825648> a schema1:HowToStep ;
    schema1:text "Acompañar con un curtido elaborado con la cebolla paiteña que nos sobró y el tomate riñón con un poco de limón"@es .

<http://example.org/recipes/plato-principal/81/step/325fe6bb164a4b6caff183b71bb8152e> a schema1:HowToStep ;
    schema1:text "Cocinar el arroz en una olla con agua y poca sal, puedes añadirle media cebolla para darle mejor sabor."@es .

<http://example.org/recipes/plato-principal/81/step/39f5a577445640af81129274d383d65d> a schema1:HowToStep ;
    schema1:text "Poner tomatelicuado sin semillas y 1/4 de cebolla picada al frejól ya cocinado, sal al gusto y un poco de ajo machacado, dejar hervir y revolver por 10 minutos."@es .

<http://example.org/recipes/plato-principal/81/step/89556662300343e5b806a98df52be8a6> a schema1:HowToStep ;
    schema1:text "Lavar y aliñar el pescado. Poner el aliño sobre el pescado carita y los vamos frotando por todas sus partes."@es .

<http://example.org/recipes/plato-principal/81/step/ccc37182ebce499d9fbef274ec9a6df3> a schema1:HowToStep ;
    schema1:text """Poner a cada pescado sobre una plato con huevo batido y luego pasarlo sobre harina e inmediatamente colocarlo sobre la sartén con aceite
	bien fuerte."""@es .

<http://example.org/recipes/plato-principal/81/step/d7e94f8a8c004c09959259d9d8dbf113> a schema1:HowToStep ;
    schema1:text "Cocinar el frejól en una olla de presión con agua hasta que esté muy blando, o comprar fréjol ya cocinado."@es .

<http://example.org/recipes/plato-principal/82/step/03c4af7432064800be95fe269fed423c> a schema1:HowToStep ;
    schema1:text "Luego al envase donde tenemos el pollo agregaremos un poco de mostaza, un chorrito de salsa de soya (Un poquito a cada pieza) y el aliño casero que preparamos. Luego repetimos el procedimiento por el otro lado del pollo. Mezclamos todo muy bien."@es .

<http://example.org/recipes/plato-principal/82/step/06473934e3544542b79b1d4e206b5dbe> a schema1:HowToStep ;
    schema1:text "Al estar listo si nos gusta más espeso agregamos ½ taza de agua con 1 cucharadita de maicena y se lo agregamos al pollo y lo dejamos saltear un rato para que espese."@es .

<http://example.org/recipes/plato-principal/82/step/5a7f6fb3427940948558f13075903e4f> a schema1:HowToStep ;
    schema1:text "Una vez listo podemos acompañar con papas fritas o ensalada"@es .

<http://example.org/recipes/plato-principal/82/step/8b923716ab1b4174bb2b34e2d5dd507e> a schema1:HowToStep ;
    schema1:text "Si se hace en el sartén se deja por 25 minutos y con 1 taza de agua."@es .

<http://example.org/recipes/plato-principal/82/step/a30ddf0d046540ffa71b8d5eb314c234> a schema1:HowToStep ;
    schema1:text "Luego de estar sellado por ambos lados agregamos 8,5 oz de cocacola y media taza de agua. En este momento este paso nos gusta cocinarlo en una olla de presión eléctrica. Así que sacamos el pollo del sartén y lo agregamos a la olla de presión junto con la coca cola y el agua. La tapamos y la colocamos por 15 minutos."@es .

<http://example.org/recipes/plato-principal/82/step/c093d1659bed47449fdf355c1894ddcc> a schema1:HowToStep ;
    schema1:text "En un sartén agregamos aceite, dejamos calentar y agregamos las piezas de pollo a freír un poco. Las dejamos sellar por 7 minutos más o menos y volteamos al otro lado."@es .

<http://example.org/recipes/plato-principal/82/step/dd1903906c2c44f3a0167964fcc5027c> a schema1:HowToStep ;
    schema1:text "Lo primero que vamos hacer es hacerle unos huecos al pollo para que entre bien el aliño casero."@es .

<http://example.org/recipes/plato-principal/82/step/e2de2f6d4c5e421ab61686b3b07592bc> a schema1:HowToStep ;
    schema1:text "Luego en un envase haremos el aliño para el pollo: Agregamos 5 dientes de ajo, 1 cucharadita comino molido, 1/8 de cucharadita pimienta negra, 1 cucharadita de sal y un poquito de agua. Esto lo podemos hacer en mortero o en la licuadora. Molemos bien y estaría listo el aliño casero."@es .

<http://example.org/recipes/plato-principal/83/step/2c819ba17b4e459ba3c784ee5f9f2e62> a schema1:HowToStep ;
    schema1:text "Luego a la salsa le agregamos el queso parmesano y una cucharadita de jugo de limon y una cucharadita de la ralladura de concha de limon."@es .

<http://example.org/recipes/plato-principal/83/step/35e1b1864ed54ef7b21ce1015cb5faac> a schema1:HowToStep ;
    schema1:text "Una vez listo lo retiramos y dejamos reducir la salsa a la mitad. Aproximadamente 10 minutos mas. Al pasar el tiempo lo apagamos y retiramos del sarten."@es .

<http://example.org/recipes/plato-principal/83/step/439d4652065b4dedbe07df2cc4a39d9a> a schema1:HowToStep ;
    schema1:text "Precionamos con una cuchara para sacarle el liquido. Luego las colocamos a un lado para dejarlas descansar."@es .

<http://example.org/recipes/plato-principal/83/step/8ce286928757414da3cd1f4e1cb522d0> a schema1:HowToStep ;
    schema1:text "En el mismo sarten agregamos una cucharada de aceite y colocamos las pechugas de pollo sasonadas con sal y pimienta. Dejamos que doren de 5 a 7 minutos por ambos lados."@es .

<http://example.org/recipes/plato-principal/83/step/94c6052f690d496f801fe60d5bc4768d> a schema1:HowToStep ;
    schema1:text "Una vez listo lo servimos y disfrutamos."@es .

<http://example.org/recipes/plato-principal/83/step/a1b0c52a0e884877b73a7736190ca384> a schema1:HowToStep ;
    schema1:text "Lista la salsa cortamos el pollo el pollo en trocitos y lo colocamos en un molde encima de el colocamos la espinaca y por encima agregamos la salsa. Al final colocamos el queso parmesano restante y llevamos al horno hasta que dore."@es .

<http://example.org/recipes/plato-principal/83/step/c79371937bbd45f2bdec85cf10db6a3f> a schema1:HowToStep ;
    schema1:text "En un sarten colocaremos un poco de aceite al calentar colocamos las espinacas y revolvemos por 3 minutos. Cocinar a fuego medio."@es .

<http://example.org/recipes/plato-principal/83/step/e32a530fdd85441abe2ae06ea16463b4> a schema1:HowToStep ;
    schema1:text "Pasado el tiempo agregamos cebolla y ajo picaditos. Seguido de esto añadimos 1 1/4 de tazas de agua, 1 1/4 taza de caldo pollo, 1 taza de nata para montar y 1/2 taza de jamon picado en cuadritos. Ya agregado todo lo dejamos cocinar a fuego medio o bajo por 15 minutos."@es .

<http://example.org/recipes/plato-principal/83/step/f38da5dba358432b851c2c70521c2f27> a schema1:HowToStep ;
    schema1:text "Ya pasado el tiempo nos aseguramos que este bien cocinado el pollo. Revisamos el centro a ver si esta bien cocido."@es .

<http://example.org/recipes/plato-principal/83/step/fdbc8fb5df014cc2b60f95382387e307> a schema1:HowToStep ;
    schema1:text "Una vez pasado el tiempo se ha reducido las espinacas. Procedemos a retirarlas y las colocamos en un colador."@es .

<http://example.org/recipes/plato-principal/84/step/41d4e8d64b1a42c9b99c5681ec5c8231> a schema1:HowToStep ;
    schema1:text "En un sarten colocamos aceite y agregamos los pollos para sofreirlo."@es .

<http://example.org/recipes/plato-principal/84/step/7e82237a457848aeaf24f8eb285fa160> a schema1:HowToStep ;
    schema1:text "Pasado unos minutos agregamos el zumo de la naranja y lo tenemos 10 minutos revolviendo."@es .

<http://example.org/recipes/plato-principal/84/step/8405daf254764b9ab6375dd190e305eb> a schema1:HowToStep ;
    schema1:text "Primero salpimentamos el pollo con sal y pimienta por todos lados con la ayuda de las manos."@es .

<http://example.org/recipes/plato-principal/84/step/8ded6757c0304935a7a777531c49a89b> a schema1:HowToStep ;
    schema1:text "Una vez que ha reducido lo podemos servir y disfrutar."@es .

<http://example.org/recipes/plato-principal/84/step/b4f2e10b83bc41e48ba03b194bea7b0f> a schema1:HowToStep ;
    schema1:text "Luego de sofrito agregamos la cebolla picadita en cuadritos."@es .

<http://example.org/recipes/plato-principal/85/step/0db84294c341480aa1167e6a3e20fa73> a schema1:HowToStep ;
    schema1:text "Luego agregamos 3 cucharadas de tomate frito y revolvemos todo muy bien. Seguido agregamos 1 taza de nata para montar. Mezclamos y dejamos cocinar."@es .

<http://example.org/recipes/plato-principal/85/step/1349a8cce2574a0083317e5d1b310697> a schema1:HowToStep ;
    schema1:text "Agregamos un poco de sal y luego 1 kg de pechugas de pollo. Mezclamos bien y agregamos cúrcuma al gusto, un poquito de jengibre, un toque de canela, 1 cucharada de curry y mezclamos muy bien."@es .

<http://example.org/recipes/plato-principal/85/step/2e7d773e674b4cca8268a8d98cb9fcea> a schema1:HowToStep ;
    schema1:text "En un sartén colocamos 2 cucharadas de aceite, media cucharada de mantequilla y 2 dientes de ajo picadito. Sofreímos un poco y añadimos 1 cebolla. Revolvemos todo muy bien."@es .

<http://example.org/recipes/plato-principal/85/step/dbf58b529304449981e6eda7ee8dbef4> a schema1:HowToStep ;
    schema1:text "Una vez listo servimos con arroz."@es .

<http://example.org/recipes/plato-principal/86/step/273d206d9cd940e3878142f3d296e586> a schema1:HowToStep ;
    schema1:text "En una bandeja se coloca el pollo con la piel hacia arriba. Cubrir la bandeja con papel de aluminio y hornear por una hora a fuego medio. Retira la bandeja del horno, destape y proceda a untar un aceite de achiote encima de cada pieza de pollo. Luego lleve nuevamente bandeja destapada al horno por unos 30 minutos, hasta que el pollo quede dorado."@es .

<http://example.org/recipes/plato-principal/86/step/2e03c98c33cc4d869e618f60f39b5ef3> a schema1:HowToStep ;
    schema1:text "Servir el pollo acompañado de unas suculentas papas en crema, arroz y encurtido de cebollas. Decore con cebolla verde finamente picada."@es .

<http://example.org/recipes/plato-principal/86/step/48580178d475425b86dd31078cabc3ec> a schema1:HowToStep ;
    schema1:text "Colocar en una fuente las presas de pollo y adobarlo con el aliño. Guarde la fuente tapada en el refrigerador por unas 4 horas para que el pollo absorba bien los sabores."@es .

<http://example.org/recipes/plato-principal/86/step/a7a8d88df43943fba4e659feb59399e3> a schema1:HowToStep ;
    schema1:text "Preparar el aliño para el pollo mezclando el agua con 1 cucharadita de sal, 1 cucharadita de comino, pasta de ajo y una pizca de pimienta."@es .

<http://example.org/recipes/plato-principal/87/step/06bffea7ff91492eaf7468771bdc3eb7> a schema1:HowToStep ;
    schema1:text "En una olla colocamos las piezas de pollo y le agregamos la sal, 1 cucharada de ajo en polvo, pimienta al gusto, 1 pizca de comino, el jugo de un limon y mezclamos todo con las manos y dejamos reposar por 2 horas para que penetre el sabor."@es .

<http://example.org/recipes/plato-principal/87/step/26e334c740a043d4a3907a6d1789fe82> a schema1:HowToStep ;
    schema1:text "Luego de reposado el pollo lo untamos primero en la mezcla de maicena y luego en la de harina, retiramos el exceso y hacemos asi con todas hasta terminar el pollo."@es .

<http://example.org/recipes/plato-principal/87/step/2fc9543eaf6e4cd090c035c3ff9170b1> a schema1:HowToStep ;
    schema1:text "Una vez listo lo ponemos a freir en una olla con acite muy caliente."@es .

<http://example.org/recipes/plato-principal/87/step/7b7aa414c10e48b887633b80602ff3bc> a schema1:HowToStep ;
    schema1:text "Despues de colocado el pollo lo bajamos a fuego medio y colocamos una tapa para que se cocine por 13 minutos. Para retirarlo subimos el fuego para que no absorba el aceite."@es .

<http://example.org/recipes/plato-principal/87/step/84bae253ffa24b9eb0ad3b728b1ff54e> a schema1:HowToStep ;
    schema1:text "Listo para disfrutar con papas fritas."@es .

<http://example.org/recipes/plato-principal/87/step/a0c9396a65da400b962b39f2bb7e727b> a schema1:HowToStep ;
    schema1:text "En otro recipiente aparte colocamos 1/2 kg de harina, 1 cucharadita de sal y pimienta al gusto.Mezclamos todo."@es .

<http://example.org/recipes/plato-principal/87/step/f2d52a9611a64ee798cf113e0a6dd7e6> a schema1:HowToStep ;
    schema1:text "Aparte en un recipiente colocamos una taza de agua y 6 cucharadas de maicena mezclamos bien."@es .

<http://example.org/recipes/plato-principal/88/step/1d8a5001d4984f1faac940e0bd8edf59> a schema1:HowToStep ;
    schema1:text "En un recipiente colocar aceite de achiote cantidad al gusto, luego las especias, el jugo de limón, la cebolla y el cilantro. Mezclamos muy bien."@es .

<http://example.org/recipes/plato-principal/88/step/585f5fae60a24a40be41119c4bd409fc> a schema1:HowToStep ;
    schema1:text "Luego le hacemos unos cortes al pollo para que penetre el sabor de la salsa por dentro."@es .

<http://example.org/recipes/plato-principal/88/step/71355c6192294d6681b71ca7a578485b> a schema1:HowToStep ;
    schema1:text "Una vez listo colocamos el pollo en una bandeja para horno y añadimos nuestra salsa por encima y por todos los lados. Luego por dentro de la piel y por debajo del pollo."@es .

<http://example.org/recipes/plato-principal/88/step/a5ee5d5e050f47d39fa91d0798b44848> a schema1:HowToStep ;
    schema1:text "Seguido de esto, podemos agregar un poco de cerveza y continuamos adobando."@es .

<http://example.org/recipes/plato-principal/88/step/f1c89b3af0ae4bcfa623d83871b5f849> a schema1:HowToStep ;
    schema1:text "Luego cubrimos la bandeja con papel films y refrigeramos en la nevera. Llevamos al horno por 20 o 30 minutos. Pasado el tiempo lo volteamos por el otro lado y lo cocinamos otro par de minutos hasta que la piel este asada."@es .

<http://example.org/recipes/plato-principal/89/step/0b993d92fccc413aa27d8a1001cf9cf4> a schema1:HowToStep ;
    schema1:text "Picar el ají finamente para incorporar a las papas, agregaar sal y pimienta."@es .

<http://example.org/recipes/plato-principal/89/step/4fd039e66eba452ca8743c509b6346c0> a schema1:HowToStep ;
    schema1:text "Meter al horno a temperatura baja 160°C, seguir untando el pollo con el adobo por los próximos 30 minutos."@es .

<http://example.org/recipes/plato-principal/89/step/827db5dbd725461d9aede7e0f1da925f> a schema1:HowToStep ;
    schema1:text "Procesar el ajo, achiote, ají de seco, cerveza, jugo de limón, sal y pimienta para formar un adobo y bañar al pollo con este adobo."@es .

<http://example.org/recipes/plato-principal/89/step/91ceaf5424664f0a892117162467f02e> a schema1:HowToStep ;
    schema1:text "Pelar, lavar y cortar las papas al estilo allumette, la cebolla debe ser cortada en finas tiras."@es .

<http://example.org/recipes/plato-principal/89/step/c9c220b00db5452b89cd7caca03c7d63> a schema1:HowToStep ;
    schema1:text "Despresar el pollo y acompañar con las papitas picantes."@es .

<http://example.org/recipes/plato-principal/89/step/d132ca78594f489281b7d84d47b46717> a schema1:HowToStep ;
    schema1:text "Colocar aceite en un sartén y dorar la cebolla, luego incorporar las papas y dejar freír por todos sus lados."@es .

<http://example.org/recipes/plato-principal/89/step/d887741e4c5e432abda0b45343d3c5a2> a schema1:HowToStep ;
    schema1:text "Dejar el pollo en el horno hasta que dore completamente."@es .

<http://example.org/recipes/plato-principal/89/step/e28747e929d94ce8a5bafb58f6365035> a schema1:HowToStep ;
    schema1:text "Meter el pollo en la refrigeradora de 2 a 4 horas."@es .

<http://example.org/recipes/plato-principal/9/step/02f6006b9bb74ca1ac6fb22a4de66645> a schema1:HowToStep ;
    schema1:text "Precalentar el horno para asar y engrasar ligeramente una bandeja de hornear."@es .

<http://example.org/recipes/plato-principal/9/step/148d3016ecc74b8c9871418b974365c5> a schema1:HowToStep ;
    schema1:text "Hacer un refrito con ajo, cebolla, pimientos y dejar cocinar durante 2 minutos."@es .

<http://example.org/recipes/plato-principal/9/step/2660eda774f5422cb378a7eda4ee0c6b> a schema1:HowToStep ;
    schema1:text "Tapar con papel aluminio y llevar al horno por 30 minutos."@es .

<http://example.org/recipes/plato-principal/9/step/67019687051c4771a036d949d2b77a38> a schema1:HowToStep ;
    schema1:text "Hechar sal y pimienta a los filetes y séllelos en una sartén caliente con un poco de aceite."@es .

<http://example.org/recipes/plato-principal/9/step/67eb8aababde441b83897d7765021005> a schema1:HowToStep ;
    schema1:text "Incorporar al refrito el tomate, concentrado de res, culantro y dejar cocinar durante 4 minutos."@es .

<http://example.org/recipes/plato-principal/9/step/99b04de9504d41f0804f4da126481f27> a schema1:HowToStep ;
    schema1:text "Cortar la cebolla y los pimientos en juliana y los tomates en media luna."@es .

<http://example.org/recipes/plato-principal/9/step/f8988e210b764b028cb964366be4fff0> a schema1:HowToStep ;
    schema1:text "Colocar un poco de agua, la pasta de tomate, sal, pimienta y mezclar."@es .

<http://example.org/recipes/plato-principal/90/step/0eb0d7ddd2b64dcca9e74fef71e50d9a> a schema1:HowToStep ;
    schema1:text "Servir el pollo en su salsa y acompáñelo con arroz y rodajas de plátano."@es .

<http://example.org/recipes/plato-principal/90/step/7c20b636bc7f42c29dddf4ce0787afe0> a schema1:HowToStep ;
    schema1:text "En la misma sartén donde cocino el pollo, añada la cebolla, el ajo y el ají molido. Remueva bien y coloque las piezas de pollo nuevamente, sazone con sal y pimienta. Incorpore el agua y deje cocinar tapado por unos 20 minutos."@es .

<http://example.org/recipes/plato-principal/90/step/b0b7124161f44ac0a540cc1974bd571d> a schema1:HowToStep ;
    schema1:text "Luego de este tiempo añada el maní molido, se remueven todos los ingredientes y se deja cocinar a fuego bajo por otros 5 minutos."@es .

<http://example.org/recipes/plato-principal/90/step/d97aed426811433b9a56b1fe9bd75d71> a schema1:HowToStep ;
    schema1:text "En una sartén con aceite de achiote, proceda a sellar los muslos de pollo y resérvelos en una fuente."@es .

<http://example.org/recipes/plato-principal/91/step/03142b123f764692845ae40b2486eb17> a schema1:HowToStep ;
    schema1:text "Cocinar el cuero de chancho con agua, sal, ajo y las ramas de cebolla blanca. Se cocina hasta que el cuero suavice. Retire del fuego, cuele y corte el cuero en trozos medianos. Reserve el caldo."@es .

<http://example.org/recipes/plato-principal/91/step/1146428e526a4f8c8d48b4529dad4fe8> a schema1:HowToStep ;
    schema1:text "Limpiar el cuero de chancho y retire el exceso de grasa."@es .

<http://example.org/recipes/plato-principal/91/step/1fe008f443ea4f98a0a204142acf0446> a schema1:HowToStep ;
    schema1:text "Luego añada la yuca y los cueros al caldo. Deje cocinar hasta que reduzca un poco el líquido y agregue la cebolla en ramas y el perejil finamente picados."@es .

<http://example.org/recipes/plato-principal/91/step/2f53226cbeb243168c6b028ff152e2b1> a schema1:HowToStep ;
    schema1:text "En una olla coloque la manteca a derretir y proceda a sofreír las cebollas, ajo, sal, pimienta y comino. Agregue el caldo con el que cocinó el cuero."@es .

<http://example.org/recipes/plato-principal/91/step/8b1b0edd1a0c41d6beee377b8b12d248> a schema1:HowToStep ;
    schema1:text "Sirva bien caliente acompañado de una ensalada de legumbres."@es .

<http://example.org/recipes/plato-principal/91/step/ca57df9f852d45538d25d072ae65d652> a schema1:HowToStep ;
    schema1:text "Pelar las yucas y cortarlas en trozos medianos."@es .

<http://example.org/recipes/plato-principal/92/step/2e1a8c09b56f494a8342ed1ff8bd3463> a schema1:HowToStep ;
    schema1:text "Cocinar el frejol en agua hasta que ablanden, reserve."@es .

<http://example.org/recipes/plato-principal/92/step/48a323d322c84068aa81bbacbbc35e54> a schema1:HowToStep ;
    schema1:text "Cortar la carne en trozos pequeños, reserve."@es .

<http://example.org/recipes/plato-principal/92/step/5a18b67a19904d7a99b596e988c81632> a schema1:HowToStep ;
    schema1:text "Sirva bien caliente."@es .

<http://example.org/recipes/plato-principal/92/step/613531594dc542febb41eb1f1386e930> a schema1:HowToStep ;
    schema1:text "Añada el agua, el frejol y deje cocinar a fuego medio."@es .

<http://example.org/recipes/plato-principal/92/step/7589599243da49218276ff8f9c4f54af> a schema1:HowToStep ;
    schema1:text "En una sartén, prepare un sofrito con el aceite de achiote, la cebolla, el tomate, el pimiento, ajo, sal, pimienta comino, y laurel. Incorpore la carne de cerdo y mezcle todos los ingredientes por unos 5 minutos."@es .

<http://example.org/recipes/plato-principal/92/step/e82d36340d5245758db6a316d0b40e79> a schema1:HowToStep ;
    schema1:text "Agregue el verde, las hierbas y revise la sazón. Cocine por unos 20 minutos hasta que todo esté bien cocido."@es .

<http://example.org/recipes/plato-principal/93/step/4a840f52059b4a71b5c5d8036affb031> a schema1:HowToStep ;
    schema1:text "En una sartén haga un sofrito con 1 cucharada de aceite de achiote, cebolla picadita y un poco de ajo. Incorpore el caldo de camarones y la quinua lavada, deje cocinando por unos 15 minutos a fuego lento."@es .

<http://example.org/recipes/plato-principal/93/step/803cfc4a749246df8c7f2eea9086687c> a schema1:HowToStep ;
    schema1:text "Lave bien los mariscos y déjelos dispuestos para la preparación."@es .

<http://example.org/recipes/plato-principal/93/step/ab5970507cbe41dd9ff8f7cd1bf902fa> a schema1:HowToStep ;
    schema1:text "En una sartén coloque un poco de aceite de achiote, y sofría 2 cebollas picaditas con 1 cucharada de ajo Añada el pimiento y condimente con sal, pimienta y comino."@es .

<http://example.org/recipes/plato-principal/93/step/b12699e4950b4316b0de0a207db26598> a schema1:HowToStep ;
    schema1:text "Añada el cilantro picadito y rectifique los sabores."@es .

<http://example.org/recipes/plato-principal/93/step/b1ecfe9d39ec4bfcbe35a34c84ac63c3> a schema1:HowToStep ;
    schema1:text "Añada los camarones y las almejas, y saltee todos los ingredientes por unos 3 minutos. Incorpore la quinua cocida, las arvejas, los calamares cortados y las vieiras. Remueva todo y siga cocinando por 5 minutos más."@es .

<http://example.org/recipes/plato-principal/93/step/f6ce272c934e47b2b2038c430dbc7c82> a schema1:HowToStep ;
    schema1:text "Sirva el plato acompañado de aguacate, patacones, limón y curtido de cebollas y tomates."@es .

<http://example.org/recipes/plato-principal/94/step/087395931b6d4d6f853915cb8eea101d> a schema1:HowToStep ;
    schema1:text "Pelar y rallar los verdes crudos, amasar con achiote y un poco de agua. Reservar."@es .

<http://example.org/recipes/plato-principal/94/step/37f05cc7f7e54722af47e164d8c6da25> a schema1:HowToStep ;
    schema1:text "Agregar sal y pimienta y servir acompañado de limón."@es .

<http://example.org/recipes/plato-principal/94/step/cdd0a717a02a4b8ab78b724e7ec6f9ec> a schema1:HowToStep ;
    schema1:text "Hervir a fuego lento hasta que la mezcla este cocida y espesa."@es .

<http://example.org/recipes/plato-principal/94/step/e97c839853b94e5d9d43118097352c29> a schema1:HowToStep ;
    schema1:text "Agregar el refrito junto con el maní licuado, dejar hervir y añadir el verde previamente rallado y amasado, sazonar con sal, pimienta y comino."@es .

<http://example.org/recipes/plato-principal/94/step/f56fe80882484dea8dbce1f579e3c7b2> a schema1:HowToStep ;
    schema1:text "Agregar el pescado cortado en trozos, y el cilantro picado, dejar cocer por unos minutos."@es .

<http://example.org/recipes/plato-principal/94/step/fab9893015c940d3b9c8015a620d5e5a> a schema1:HowToStep ;
    schema1:text "Preparar un refrito con la cebolla colorada, el ajo y el tomate."@es .

<http://example.org/recipes/plato-principal/95/step/022b8f081d074612912666348a53d196> a schema1:HowToStep ;
    schema1:text "Agregar por último el pescado cortado en trozos."@es .

<http://example.org/recipes/plato-principal/95/step/682e9f0177bd45b88eb7a26d4a4024ec> a schema1:HowToStep ;
    schema1:text "Sofreír la cebolla, el ajo y el tomate, integrar los ingredientes y sumar la pasta de maní."@es .

<http://example.org/recipes/plato-principal/95/step/a7aa9d53e2a443fd8a0bfc918438494c> a schema1:HowToStep ;
    schema1:text "Servir con cilantro fresco y limón."@es .

<http://example.org/recipes/plato-principal/95/step/b423e706357745c59be278f078c57a70> a schema1:HowToStep ;
    schema1:text "Una vez que el sofrito rompe el hervor agregar los verdes reservados y condimentar."@es .

<http://example.org/recipes/plato-principal/95/step/c3566284e785420f8cfc9eac7f7087a6> a schema1:HowToStep ;
    schema1:text "Cocinar a fuego bajo hasta que la preparación espese."@es .

<http://example.org/recipes/plato-principal/95/step/fd053645ef364383ace421b1ffa2acde> a schema1:HowToStep ;
    schema1:text "Comenzar rallando los verdes, condimentar con achiote y unas gotas de agua y reservar."@es .

<http://example.org/recipes/plato-principal/96/step/478ff07bcb05471f8652658a8e055087> a schema1:HowToStep ;
    schema1:text "En una cacerola aparte colocamos 1/4 de taza de achiote y la carne. Sofreimos por 5 minutos y retiramos la carne."@es .

<http://example.org/recipes/plato-principal/96/step/73cf7eafb5e54547a35a83442302745a> a schema1:HowToStep ;
    schema1:text "Apagamos y en una licuadora colocaremos el refrito mas 1 cervesa."@es .

<http://example.org/recipes/plato-principal/96/step/d0adb145a08c4367b42bc07081811748> a schema1:HowToStep ;
    schema1:text "Luego en ese mismo sarten agregamos 1 cebolla colorada, 2 ajos picados, 1/2 pimiento rojo, 1/2 aji, 1/2 cucharada de cilantro picado, tomate en cuadritos, 2 cucharaditas de sal y comino al gusto."@es .

<http://example.org/recipes/plato-principal/96/step/ec0ff08e775249b79f913ecb59e8d1ea> a schema1:HowToStep ;
    schema1:text "En un envase colocamos 2 kg de carne de cordero y encima colocamos pimienta al gusto, comino al gusto, sal y 1/2 taza de harina. Mezclamos bien con las manos."@es .

<http://example.org/recipes/plato-principal/96/step/fd3f955f2d6c40fab6c91ffe073b68a6> a schema1:HowToStep ;
    schema1:text "Luego tomamos la mezcla y se agrega la carne por un a hora. Agregamos el resto de ingredientes y una vez listo servimos con papas o arroz."@es .

<http://example.org/recipes/plato-principal/97/step/48bb76fd9fc64400b5043659fde128ab> a schema1:HowToStep ;
    schema1:text "Cortar la zanahoría en tiras y la cebolla a la pluma."@es .

<http://example.org/recipes/plato-principal/97/step/5557309c27664a6999b975e1b36fa75d> a schema1:HowToStep ;
    schema1:text "Tapar la olla y cocinra a fuego medio para evitar que se consuma el jugo."@es .

<http://example.org/recipes/plato-principal/97/step/5aeaf912ab9b4ea485fc1abbe9147d1c> a schema1:HowToStep ;
    schema1:text "Freír la cebolla y el ají, luego agregar el cabrito para sofreírlo."@es .

<http://example.org/recipes/plato-principal/97/step/802746f53d7949139f0a6b9f7a14a780> a schema1:HowToStep ;
    schema1:text "Agregue el vino donde se maceró, el cilantro, la zanahoria y las arvejas."@es .

<http://example.org/recipes/plato-principal/97/step/d3c7b70c969f446aa0ecc7c7d8a9b9b2> a schema1:HowToStep ;
    schema1:text "Despresar el cabrito o el cordero en presas grandes y ponerlo en una vasija con sal, el vino blanco y pimienta, desde el día anterior para que se macere."@es .

<http://example.org/recipes/plato-principal/97/step/eb879f493ee448c489c5d8e4ef79e144> a schema1:HowToStep ;
    schema1:text "Retirar cuando las presas estén suaves. Servir acompañado de arroz blanco."@es .

<http://example.org/recipes/plato-principal/98/step/07523f86446e44c186d87f469f256f5b> a schema1:HowToStep ;
    schema1:text "Comenzar colocando la carne de guanta en un bol, cubrir con un litro de chicha y dejar reposar por 4 horas."@es .

<http://example.org/recipes/plato-principal/98/step/6143933146d442a79f142748801e1555> a schema1:HowToStep ;
    schema1:text "Incorporar la carne a la cacerola revolver y cocinar a fuego lento por una hora."@es .

<http://example.org/recipes/plato-principal/98/step/a8ff64ccbc32460193e98a79da2b573b> a schema1:HowToStep ;
    schema1:text "Colocar en una cacerola todos los ingredientes restantes picados en cubos pequeños y sofreír por 10 minutos."@es .

<http://example.org/recipes/plato-principal/98/step/e6b12f830c104260b6a558c49d17af85> a schema1:HowToStep ;
    schema1:text "Servir caliente acompañado de papas hervidas o arroz."@es .

<http://example.org/recipes/plato-principal/99/step/18504f9f069844e9b4002b174069debe> a schema1:HowToStep ;
    schema1:text "Agregamos la carne y 2 naranjillas licuadas. Mezclamos bien. Encima agregamos el cilantro y revolvemos."@es .

<http://example.org/recipes/plato-principal/99/step/1f41e5faae194ccc9d9a8f3c2999c6ab> a schema1:HowToStep ;
    schema1:text "Luego colocamos la tapa y dejamos cocinar por 15 minutos."@es .

<http://example.org/recipes/plato-principal/99/step/509376fd847c4b5483834a028a480442> a schema1:HowToStep ;
    schema1:text "Luego agregamos 1 cucharadita de sal y los tomates cortados en trocitos y revolvemos. Dejamos por 2 minutos que se sofria bien."@es .

<http://example.org/recipes/plato-principal/99/step/b0b687cec4a54bb5a5ed46a881d3e16d> a schema1:HowToStep ;
    schema1:text "En una olla de presion colocamos la cebolla, el achiote, el aceite, 2 dientes de ajos bien cortados, 1/4 cucharadita de comino y comenzamos a sofreir. Agregamos aceite y revolvemos."@es .

<http://example.org/recipes/plato-principal/99/step/f22f320c9c3f4ee1b163149b3c62ad5b> a schema1:HowToStep ;
    schema1:text "Pasado el tiempo lo prendemos nuevamente pero en saltear para que seque un poco."@es .

<http://example.org/recipes/postre/1/step/3b866ab6f5de4e80a984a3c1b686bd69> a schema1:HowToStep ;
    schema1:text "Incorporar la harina, la maicena y el azúcar impalpable, hasta obtener una masa suave y homogénea."@es .

<http://example.org/recipes/postre/1/step/64de92cc1ee6463e80255d64903f8e12> a schema1:HowToStep ;
    schema1:text "Hornear a temperatura moderada por unos 10 minutos o hasta que estén ligeramente dorados."@es .

<http://example.org/recipes/postre/1/step/d37b6104a4ac46c0a803db0cb0920b62> a schema1:HowToStep ;
    schema1:text "Batir por 3 minutos a velocidad media la margarina con la yema de huevo y la esencia de vainilla."@es .

<http://example.org/recipes/postre/1/step/d8ef2e97b01346c2b7e84947e3bceb94> a schema1:HowToStep ;
    schema1:text "Cernir y mezclar la harina, el polvo de hornear y la maicena."@es .

<http://example.org/recipes/postre/1/step/ebc63549505442cdb772dc0bf5cf4e26> a schema1:HowToStep ;
    schema1:text "Dejar enfriar y unirlos con manjar y luego espolvorear cada alfajor con azúcar impalpable."@es .

<http://example.org/recipes/postre/1/step/f7fdd8e024d04ce88a83317ee21746dd> a schema1:HowToStep ;
    schema1:text "Extender sobre la mesa la masa con un rodillo y cortar círculos (puede hacerlo con cortadores de galletas)."@es .

<http://example.org/recipes/postre/10/step/032eba2365b6486a9076d5ed4efa007f> a schema1:HowToStep ;
    schema1:text "Listo para disfrutar."@es .

<http://example.org/recipes/postre/10/step/5f35675538014303b0d23fa6f8a26e32> a schema1:HowToStep ;
    schema1:text "Calentamos durante 3 a 5 minutos."@es .

<http://example.org/recipes/postre/10/step/a2595277a2df445ca36e484394e9c7f5> a schema1:HowToStep ;
    schema1:text "Luego revolvemos muy bien la mezcla. Dejamos reposar un minuto para que no suba y cocinamos durante 8 minutos mas,."@es .

<http://example.org/recipes/postre/10/step/ad13d6ebca284326a4c31b47a437fb48> a schema1:HowToStep ;
    schema1:text "Seguido de esto quitamos las especies, servimos y agregamos un trozo de queso."@es .

<http://example.org/recipes/postre/10/step/c824de3e931e4db58f3a059a9eb38fe0> a schema1:HowToStep ;
    schema1:text "En una olla colocamos la leche 1 lts, 1 trozo de canela, 1 ½ tableta de chocolate y 5 clavitos de olor."@es .

<http://example.org/recipes/postre/11/step/15d78ac86e9a41d492e07c3493755f0f> a schema1:HowToStep ;
    schema1:text "Batir las yemas y agregar a la preparación, manteniéndola a fuego muy bajo."@es .

<http://example.org/recipes/postre/11/step/6b65198b18cd4aedb73bf5a18d15cbf5> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y dejar entibiar, con las manos húmedas formar bolitas."@es .

<http://example.org/recipes/postre/11/step/6f78064e71eb4951a40eb95a6a1c4ccb> a schema1:HowToStep ;
    schema1:text "Dejar enfriar y servir."@es .

<http://example.org/recipes/postre/11/step/75d3d0f58c564a8a8b3a4c475f32d88e> a schema1:HowToStep ;
    schema1:text "Comenzar por hervir la leche con el azúcar hasta notar que espese."@es .

<http://example.org/recipes/postre/11/step/b405ed9dc5e5449d8554965d7db070ea> a schema1:HowToStep ;
    schema1:text "Agregar el coco a la cacerola y revolver hasta que se evapore el exceso de leche. Colocar la manteca."@es .

<http://example.org/recipes/postre/12/step/4945ed41b8184f6698d7111bc3f0fbcb> a schema1:HowToStep ;
    schema1:text "Formar bolitas pequeñas, colocar sobre en una bandeja y espolvorear con azúcar impalpable. Servir las cocadas frías."@es .

<http://example.org/recipes/postre/12/step/57743cd41db244bea783e49489ec6bb8> a schema1:HowToStep ;
    schema1:text "Colocar en una olla la leche, la panela y el azúcar. Cocinar a fuego lento, revolviendo constantemente, hasta que el dulce esté espeso. Añadir el coco y hervir. Agregar la mantequilla y retirar del fuego."@es .

<http://example.org/recipes/postre/12/step/d25bff0c8cc748f9a9fae3428bfe7947> a schema1:HowToStep ;
    schema1:text "Batir las yemas de huevo con el jugo de limón y verter sobre la cocada. Llevar nuevamente al fuego, sin dejar de batir, hasta que el dulce se desprenda de la olla. Verter la mezcla en un tazón y seguir batiendo hasta que enfríe."@es .

<http://example.org/recipes/postre/13/step/19c6b7c1c7864333913f669ca365ee36> a schema1:HowToStep ;
    schema1:text "Agregar el jugo de naranja y mezclar bien."@es .

<http://example.org/recipes/postre/13/step/30b2b12414104edfb3887ea601b55cd7> a schema1:HowToStep ;
    schema1:text "Probar y, si se desea, agregar azúcar o miel a gusto."@es .

<http://example.org/recipes/postre/13/step/352a960f91c64f53999be97a009850b7> a schema1:HowToStep ;
    schema1:text "Pelar, limpiar y cortar en cubos pequeños la papaya, la piña (sin el centro), los bananos y los mangos."@es .

<http://example.org/recipes/postre/13/step/79db7587f3484e5f9d17375a76afea2b> a schema1:HowToStep ;
    schema1:text "Refrigerar por unos 30 minutos (si se prefiere frío) o servir el come y bebe inmediatamente en copas de postres."@es .

<http://example.org/recipes/postre/13/step/8e09f17b590241358a7ada786a660b66> a schema1:HowToStep ;
    schema1:text "Mezclar todas las frutas en un tazón grande."@es .

<http://example.org/recipes/postre/14/step/25c91ec84a5b4d0b9267e8336493959f> a schema1:HowToStep ;
    schema1:text "Preparar en la taza de agua tibia la gelatina sin sabor."@es .

<http://example.org/recipes/postre/14/step/3fc509a6c94d4d538ccc4d07abab8944> a schema1:HowToStep ;
    schema1:text "Comenzar la receta refrigerando la leche condensada por unas horas."@es .

<http://example.org/recipes/postre/14/step/5625f7ba5e8a4c469fc7c311b7324430> a schema1:HowToStep ;
    schema1:text "Tomar la leche condensada y batir por 3 a 5 minutos."@es .

<http://example.org/recipes/postre/14/step/653408dc69f64e03a300999963684eb8> a schema1:HowToStep ;
    schema1:text "Procesar la pulpa de chirimoya junto con el azúcar."@es .

<http://example.org/recipes/postre/14/step/794ec4fbc6b941aca96dde8d39881062> a schema1:HowToStep ;
    schema1:text "Mezclar la pulpa con la leche condensada y por último la gelatina, revolviendo hasta que la consistencia de la preparación sea homogénea."@es .

<http://example.org/recipes/postre/14/step/8f540b1349a646429189aa5daaa3f9ea> a schema1:HowToStep ;
    schema1:text "Sin que llegue a hervor calentar en una cacerola la gelatina para disolver los grumos que hayan quedado."@es .

<http://example.org/recipes/postre/14/step/8fa0ec5c1c3a4ac08d97058bbe533a3b> a schema1:HowToStep ;
    schema1:text "Colocar en molde de aluminio o silicona y refrigerar."@es .

<http://example.org/recipes/postre/15/step/181a0044e11c44fe84f43e52b7c6c1c3> a schema1:HowToStep ;
    schema1:text "Licuar la pulpa de la chirimoya con el azúcar."@es .

<http://example.org/recipes/postre/15/step/900ecb91c77a4726b7ba3315a5c973e6> a schema1:HowToStep ;
    schema1:text "Batir la leche evaporada que ha estado en refrigeración."@es .

<http://example.org/recipes/postre/15/step/947ec14f8a6a42b291ffddc7f3b0ae39> a schema1:HowToStep ;
    schema1:text "Vertir un molde,húmedo y llevar a refrigeración hasta que endurezca."@es .

<http://example.org/recipes/postre/15/step/9612706f09914075a6dde14ae3102631> a schema1:HowToStep ;
    schema1:text "Remojar la gelatina en agua fría."@es .

<http://example.org/recipes/postre/15/step/97a2bdee8ee04c4f970126eb41a85d58> a schema1:HowToStep ;
    schema1:text "Refrigerar con un día de anticipación la leche evaporada."@es .

<http://example.org/recipes/postre/15/step/b5e8cd64d17742f7b2d77caf4593383b> a schema1:HowToStep ;
    schema1:text "Mezclar todos los ingredientes (la gelatina debe ser agregada de último) hasta obtener una mezcla homogénea."@es .

<http://example.org/recipes/postre/15/step/e43055985ab44259b90adf56fddf247f> a schema1:HowToStep ;
    schema1:text "Llevar a fuego medio la gelatina hasta que se disuelva cuidando que no hierva."@es .

<http://example.org/recipes/postre/16/step/03dd79e547dc4571b3b131dfc3872b73> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y dejar enfriar durante 2 horas."@es .

<http://example.org/recipes/postre/16/step/529a5006b2c14f19aa8b237bb06dc85d> a schema1:HowToStep ;
    schema1:text "Pelar el babaco y cortarlo en pedazos pequeños."@es .

<http://example.org/recipes/postre/16/step/6222409fa2d74b6ebf4818567272e518> a schema1:HowToStep ;
    schema1:text "Hervir 2 tazas de agua con el azúcar, la canela, los clavos de olor y el limón."@es .

<http://example.org/recipes/postre/16/step/d582ec9be91a4fc58b5dcfc0f2f30998> a schema1:HowToStep ;
    schema1:text "Añadir el babaco y cocinar a fuego lento hasta que la fruta esté transparente."@es .

<http://example.org/recipes/postre/16/step/df872387210246c496e6e0138b92ca3c> a schema1:HowToStep ;
    schema1:text "Servir el dulce de babaco en copas de helado."@es .

<http://example.org/recipes/postre/16/step/f727f7d2341e4c25bf00a04fc78e3669> a schema1:HowToStep ;
    schema1:text "Espolvorear un poco de azúcar en los pedazos de babaco y dejar reposar."@es .

<http://example.org/recipes/postre/17/step/1f95d62dfebe4401a5ffb8952f139670> a schema1:HowToStep ;
    schema1:text "Retirar y dejar enfriar en heladera."@es .

<http://example.org/recipes/postre/17/step/425a2489fba44b6eb9e5d1897765e25c> a schema1:HowToStep ;
    schema1:text "Comenzar por pelar las frutas y cortarlas en trozos pequeños."@es .

<http://example.org/recipes/postre/17/step/4b6b7c0bb2024f438bf3581605a368d7> a schema1:HowToStep ;
    schema1:text "Servir en copas de postre."@es .

<http://example.org/recipes/postre/17/step/af12cf9bce2643349a540a2b33a902f7> a schema1:HowToStep ;
    schema1:text "Agregar por último el babaco y cocinar a fuego lento por 2 horas."@es .

<http://example.org/recipes/postre/17/step/f62746ae5510485b8f31b040a6b019e6> a schema1:HowToStep ;
    schema1:text "Espolvorear con azúcar las frutas y dejar reposar por unas 4 horas."@es .

<http://example.org/recipes/postre/17/step/fe08f3612255484294f1f237e75fb385> a schema1:HowToStep ;
    schema1:text "Hervir 2 tazas de agua con azúcar, limón, canela y clavos de olor."@es .

<http://example.org/recipes/postre/18/step/104201cba61a474cb08f94a9807adc7c> a schema1:HowToStep ;
    schema1:text "Luego que estén listos los higos los escurrimos y los pasamos por la miel durante 15 minutos. Los sacamos y acompañamos con queso fresco en tiritas."@es .

<http://example.org/recipes/postre/18/step/1badc821933b4120bad1b4466cfe0c34> a schema1:HowToStep ;
    schema1:text "Luego los cocinamos en agua hirviendo por aproximadamente 40 minutos hasta que se hagan pequeños y suaves."@es .

<http://example.org/recipes/postre/18/step/59d67385e93546acb44fe50b5a592a9e> a schema1:HowToStep ;
    schema1:text "Colocamos al fuego hasta que se espese la miel."@es .

<http://example.org/recipes/postre/18/step/8d03b23ee6754ddba67d5c56f6b117ef> a schema1:HowToStep ;
    schema1:text "Primero cortamos las puntas de los higos para que boten el liquido blanco. Los metemos en un envase con agua durante 4 horas aproximadamente."@es .

<http://example.org/recipes/postre/18/step/b8542e1aacf74c3a877fa8233328763e> a schema1:HowToStep ;
    schema1:text "Mientras preparamos la miel. Para ella utilizaremos panela, agua, canela y clavos de olor."@es .

<http://example.org/recipes/postre/19/step/1237ae81278f41549333832d5a3d930f> a schema1:HowToStep ;
    schema1:text "Colocar en una olla grande la panela o piloncillo, las especias y 6 tazas de agua. Cocinar a fuego lento hasta que la panela esté completamente disuelta y convertida en almíbar."@es .

<http://example.org/recipes/postre/19/step/219eec1ddb414f5889e6d9665bb793fd> a schema1:HowToStep ;
    schema1:text "Añadir los higos y continuar cocinando a fuego lento durante unas 2 horas hasta que el almíbar esté espeso."@es .

<http://example.org/recipes/postre/19/step/24f78f3ea0b04d739bd9be6d32059774> a schema1:HowToStep ;
    schema1:text "Añadir el bicarbonato y hervir el agua con los higos. Cocinarlos durante unos 20 minutos hasta que estén suaves."@es .

<http://example.org/recipes/postre/19/step/31bfe28bb90742aca830088cf3c6e78b> a schema1:HowToStep ;
    schema1:text "Colar el agua y escurrir cada higo con delicadeza hasta sacarle la mayor cantidad de agua."@es .

<http://example.org/recipes/postre/19/step/379bda9a3b9c456081748e1282e0a2b9> a schema1:HowToStep ;
    schema1:text "Servir el dulce de higos (caliente o frío) acompañado con rodajas de quesillo o queso."@es .

<http://example.org/recipes/postre/19/step/39fe4927fa9a4bbab17d02949f2ddd7f> a schema1:HowToStep ;
    schema1:text "Hacer una incisión en forma de cruz en la parte superior (o parte más angosta) de cada higo."@es .

<http://example.org/recipes/postre/19/step/5b022f9dc9574668bb1dcaa3bffe0456> a schema1:HowToStep ;
    schema1:text "Colar los higos, colocarlos en una olla y cubrirlos con 8 tazas de agua aproximadamente."@es .

<http://example.org/recipes/postre/19/step/b0fb9d1e82454a119473da9d08926707> a schema1:HowToStep ;
    schema1:text "Colocar los higos en un tazón, cubrirlos con agua y dejarlos remojar durante un día entero."@es .

<http://example.org/recipes/postre/19/step/c74b3b789ae349bb91570dc9d04877c3> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y dejar los higos en el agua en el que se cocinaron durante otro día entero."@es .

<http://example.org/recipes/postre/2/step/00415774a06b4dfa8aa2111eb57601ae> a schema1:HowToStep ;
    schema1:text "Procedemos a amazar muy bien de adentro hacia afuera. Amasamos y amasamos hasta que este todo bien mezclado con la palma de la mano para que no se maltrate la masa y salgan migas."@es .

<http://example.org/recipes/postre/2/step/2abe4300858248849ca9663441321cb6> a schema1:HowToStep ;
    schema1:text "Al estar listos rellenamos con manjar o dulce de leche y colocamos otra tapita de alfajor encima."@es .

<http://example.org/recipes/postre/2/step/2f014df4f17547e69e37aaeaa5886208> a schema1:HowToStep ;
    schema1:text "Listos para disfrutar."@es .

<http://example.org/recipes/postre/2/step/6d7f8da1046c4ac9bb058b4a88196391> a schema1:HowToStep ;
    schema1:text "Luego la vamos enrrollando a lo largo como un rodillo, luego por debajo agregamos harina y por encima. Con la ayuda de un rodillo la aplastamos pero no mucho . Nuestra masa tendrá una forma rectangular con un grosor de ½ milímetro."@es .

<http://example.org/recipes/postre/2/step/8d2bfef129034812b6eeee25d0b57483> a schema1:HowToStep ;
    schema1:text "Una vez estirado utilizaremos cortadores de la forma que prefieras ,circulo o corazones. Y cortamos todas las que vayan saliendo de la masa, hasta terminarla. Cada una la vamos colocando en una badeja plana donde cocinaremos."@es .

<http://example.org/recipes/postre/2/step/dfe29040dca940148850332112de67b7> a schema1:HowToStep ;
    schema1:text "En una mesa agregamos 375 gramos de harina, encima la maicena, luego 250 gramos de azúcar impalpable. Mezclamos con la ayuda de las manos en el centro agregaos un huevo y un chorrito de limón y margarina."@es .

<http://example.org/recipes/postre/20/step/13cb8141cecc444aae26cdddbfe551b1> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y dejar que repose un poco."@es .

<http://example.org/recipes/postre/20/step/5d4eb419a191431e9d41dd069339fda3> a schema1:HowToStep ;
    schema1:text "En una cacerola, colocar la leche, el azúcar, la mantequilla y la vainilla."@es .

<http://example.org/recipes/postre/20/step/773b72c8e9754f0bb9b98662433468fa> a schema1:HowToStep ;
    schema1:text "Conservar en el refrigerador."@es .

<http://example.org/recipes/postre/20/step/bf74c00e3a1242389d25f153b02d5a25> a schema1:HowToStep ;
    schema1:text "Puede guardar el dulce en un envase de vidrio esterilizado."@es .

<http://example.org/recipes/postre/20/step/efb4f37a0c5e41519f56f291702eea4c> a schema1:HowToStep ;
    schema1:text "El proceso de cocción se realiza hasta que la preparación espese y obtenga una consistencia cremosa. Cuando la mezcla se despegue del fondo de la olla, indica que está lista."@es .

<http://example.org/recipes/postre/20/step/fe09a210d5234b4c9fe75617648ae093> a schema1:HowToStep ;
    schema1:text "Llevar a fuego mediano y remover constantemente con una cuchara de madera por unas dos horas."@es .

<http://example.org/recipes/postre/21/step/67b31924c44c4b63b7dc335a820f277e> a schema1:HowToStep ;
    schema1:text "Incorporar las nueces o las almendras y la ralladura de naranja cuando adquiera un color rubio."@es .

<http://example.org/recipes/postre/21/step/862c723e5c7a4c77bac88bc8d91b5145> a schema1:HowToStep ;
    schema1:text "Servir frío."@es .

<http://example.org/recipes/postre/21/step/9b71fdf10f3842bcb953b8ed996143a3> a schema1:HowToStep ;
    schema1:text "Dejar macerar (reposar) en el azúcar morena toda la noche."@es .

<http://example.org/recipes/postre/21/step/b8e61d396ad549a387aaeb09b44e6d1e> a schema1:HowToStep ;
    schema1:text "Cocinar a fuego lento con clavos de olor y canela durante 1 hora y media sin permitir que hierva."@es .

<http://example.org/recipes/postre/21/step/de37f18d8c424077b35082d4c6522d02> a schema1:HowToStep ;
    schema1:text "Pelar el sambo, sacar las semillas y luego cortar en cubitos pequeños."@es .

<http://example.org/recipes/postre/22/step/08199fa6f9a3444193e0f842e711dded> a schema1:HowToStep ;
    schema1:text "Espolvorear el azúcar morena y dejar macerando toda la noche."@es .

<http://example.org/recipes/postre/22/step/1c0103728e6f48be8e8ee66d7acba9c9> a schema1:HowToStep ;
    schema1:text "Por ultimo incorporar las nueces la ralladura de la naranja cuando se torne translucido."@es .

<http://example.org/recipes/postre/22/step/5a7d8c469be94d70a7affced4b53d806> a schema1:HowToStep ;
    schema1:text "Cocinar a fuego lento con la canela y los clavos de olor por dos horas, evitando que rompa en hervor."@es .

<http://example.org/recipes/postre/22/step/6c4e3222b0bc4cf4a312b23b13afb2b2> a schema1:HowToStep ;
    schema1:text "Comenzar por pelar las frutas y cortarlas en trozos pequeños."@es .

<http://example.org/recipes/postre/22/step/c7600e44bb0f4079b179171c22a1c97d> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y dejar enfriar, servir ya frio."@es .

<http://example.org/recipes/postre/23/step/085043e7f78d405e97ff7357364dd36b> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y servir el dulce de zapallo (caliente o frío) con una rodaja de quesillo o queso fresco."@es .

<http://example.org/recipes/postre/23/step/16c5306c8b744951bc75f0503ebb9116> a schema1:HowToStep ;
    schema1:text "Destapar y cocinar a fuego lento durante aproximadamente 1 hora hasta que el almíbar espese y los pedazos de zapallo estén confitados."@es .

<http://example.org/recipes/postre/23/step/8a4f58b190e84148ba55bc33a2ae1ec4> a schema1:HowToStep ;
    schema1:text "Lavar bien el zapallo, cortarlo a la mitad, quitarle las semillas y las membranas, y cortarlo en trozos medianos."@es .

<http://example.org/recipes/postre/23/step/df31529d0cd94e1baa96664613265156> a schema1:HowToStep ;
    schema1:text "Colocar en una olla grande el zapallo, la panela, la canela, el clavo de olor, la pimienta dulce y el agua. Hervir a fuego medio durante 30 minutos con la tapa puesta."@es .

<http://example.org/recipes/postre/24/step/5b8dfc58a98346cabe630a352c288790> a schema1:HowToStep ;
    schema1:text "Hornear en horno precalentado por unos 45 a 60 minutos hasta que esté dorado."@es .

<http://example.org/recipes/postre/24/step/67cba265edd74f4cb7ba651ba1d32e6d> a schema1:HowToStep ;
    schema1:text "En una paila, coloque media taza de azúcar y cocine a fuego bajo, de manera que se forme un caramelo. Se añade la leche y 1 ½ taza de azúcar. Remover y dejar que hierva. Luego se baja el fuego y se comienza a remover constantemente por unos 40 minutos, hasta que la preparación adquiera una contextura espesa. Retire y deje enfriar."@es .

<http://example.org/recipes/postre/24/step/6db6fb339fa04d3f8bf092a444ab93af> a schema1:HowToStep ;
    schema1:text "Rayar la piña y se pasa por un colador para eliminar el jugo."@es .

<http://example.org/recipes/postre/24/step/7cda226868344bf69764b9ba2b23d531> a schema1:HowToStep ;
    schema1:text "Colocar la pulpa de la piña con media taza de azúcar en una olla y llevar a fuego medio. Cocinar hasta que se obtenga una mermelada."@es .

<http://example.org/recipes/postre/24/step/a6d0eb90841444e0b7c8f6b05880326b> a schema1:HowToStep ;
    schema1:text "Colocamos el pastel en una fuente, vertemos encima la mermelada de piña y sobre esta la crema de leche."@es .

<http://example.org/recipes/postre/24/step/ba5ebadb4b2048328460a4d4ffca7011> a schema1:HowToStep ;
    schema1:text "En un bol se baten la mantequilla y el azúcar hasta obtener una mezcla cremosa."@es .

<http://example.org/recipes/postre/24/step/c52d3cc9b95b4bc19070fcc4bea4c2ce> a schema1:HowToStep ;
    schema1:text "Añada los huevos y la harina junto con 2 tazas de leche. Incorpore la vainilla y el polvo de hornear."@es .

<http://example.org/recipes/postre/24/step/cbc96ea9e1eb4e62baee8435315f723a> a schema1:HowToStep ;
    schema1:text "Disfrute este rico postre."@es .

<http://example.org/recipes/postre/24/step/d036b98cd4ba4c71a22525778d3fa35a> a schema1:HowToStep ;
    schema1:text "Verter en un molde, previamente engrasado y espolvoreado de harina."@es .

<http://example.org/recipes/postre/25/step/52fbe6e485674a89b27c9d38be6acdea> a schema1:HowToStep ;
    schema1:text "Mezclar y colocar la mezcla en las hojas de achira o plátano."@es .

<http://example.org/recipes/postre/25/step/5bd2935be6274a53ba56ebcb87504bae> a schema1:HowToStep ;
    schema1:text "Doblar las hojas y cocinar al vapor por 30 minutos aproximadamente."@es .

<http://example.org/recipes/postre/25/step/c6129e7957534929b98f415df593622c> a schema1:HowToStep ;
    schema1:text "Licuar los plátanos, el azúcar, la mantequilla, los huevos y el queso."@es .

<http://example.org/recipes/postre/25/step/f2b081a8ad1f4d0189ed1b018110c451> a schema1:HowToStep ;
    schema1:text "Colocar en un tazón y añadir la maicena, el polvo de hornear, la vainilla, la copa de licor anisado y las pasas."@es .

<http://example.org/recipes/postre/26/step/2308ee5baa4642a6a095e1074e58fbee> a schema1:HowToStep ;
    schema1:text "Agregar las claras de huevo al puré de guayaba y azúcar y usar la batidora eléctrica para batir la mezcla hasta que obtener una textura cremosa y firme."@es .

<http://example.org/recipes/postre/26/step/6272ad9c3394457a9d97c4c07ad2cff2> a schema1:HowToStep ;
    schema1:text "Pelar las guayabas, retirar la parte del centro con las semillas y colocar los pedazos de pulpa en un tazón grande, agregar el azúcar, mezclar y triturar hasta hacerlo puré."@es .

<http://example.org/recipes/postre/26/step/dcced127c9044604a9d16f1eabee4a54> a schema1:HowToStep ;
    schema1:text "Servir la espumilla inmediatamente en copas o conos de helado, acompañada con la salsa de mora, grajeas y coco rallado."@es .

<http://example.org/recipes/postre/27/step/071bfa2ea9074aefbed1a67c7db88fd8> a schema1:HowToStep ;
    schema1:text "Calentar el agua y 1 taza de azúcar en una olla pequeña a fuego alto, esperar hasta que hierva y cocinar hasta que el caramelo comience a tomar un color dorado. Colocar el caramelo en el molde donde se preparará el flan."@es .

<http://example.org/recipes/postre/27/step/39d071fececc4866b6e4bd13fb9d8aea> a schema1:HowToStep ;
    schema1:text "Dejar que el flan se enfríe en la refrigeradora, retirar del molde y servir con coco rallado encima."@es .

<http://example.org/recipes/postre/27/step/b3c39982b2624ed2b80197250ef46992> a schema1:HowToStep ;
    schema1:text "Licuar la leche, la leche condensada, los huevos, ¼ de azúcar y el coco rallado. Colocar la mezcla en el molde con el caramelo."@es .

<http://example.org/recipes/postre/27/step/b4b43a4680744d1c99daf9943b02278c> a schema1:HowToStep ;
    schema1:text "Cocinar a baño de maría a fuego medio, tapado, durante 1 hora y media hasta que la mezcla cuaje y retirar del fuego."@es .

<http://example.org/recipes/postre/28/step/2b534b95f66c41b586ad571fed35f52f> a schema1:HowToStep ;
    schema1:text "Añada el huevo y mezcle bien los ingredientes."@es .

<http://example.org/recipes/postre/28/step/3c3a98ac712743bb94a22313174c8c79> a schema1:HowToStep ;
    schema1:text "Hornear por unos 10 a 15 minutos hasta que se observen los bordes dorados."@es .

<http://example.org/recipes/postre/28/step/5aaecfa6b3d44900a63ab5589c593e17> a schema1:HowToStep ;
    schema1:text "Luego añada el coco rallado y la harina."@es .

<http://example.org/recipes/postre/28/step/93596134d8a84c53a3b5e7f3945a44e3> a schema1:HowToStep ;
    schema1:text "En una bandeja engrasada, debe colocar porciones de la mezcla y darle forma aplanada."@es .

<http://example.org/recipes/postre/28/step/99c4ded057c94167bf703341bda4bb7c> a schema1:HowToStep ;
    schema1:text "Tamice la harina junto con el polvo de hornear."@es .

<http://example.org/recipes/postre/28/step/b82fc3eded8c4417a23b8ce148a72399> a schema1:HowToStep ;
    schema1:text "Debe refrigerar la mezcla unas horas antes de hornear."@es .

<http://example.org/recipes/postre/28/step/ba5ba5f5d3174a2ba64206b13ae654f8> a schema1:HowToStep ;
    schema1:text "En un bol, mezcle la mantequilla con el azúcar hasta obtener una consistencia cremosa."@es .

<http://example.org/recipes/postre/28/step/f33d70ab4e2d4392b4e3ac4d2d7b8d50> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a unos 180 °C."@es .

<http://example.org/recipes/postre/29/step/10ef4323a0024a32ab712ef06235848a> a schema1:HowToStep ;
    schema1:text "Amasar hasta lograr una masa elástica, dejar reposar cubierta con film hasta que duplique su tamaño."@es .

<http://example.org/recipes/postre/29/step/26799fe656ba45829bc9e8843c761c00> a schema1:HowToStep ;
    schema1:text "Formar una corona y agregar los huevos batidos y el fermento."@es .

<http://example.org/recipes/postre/29/step/2ed152c6933e4941842295e059527de0> a schema1:HowToStep ;
    schema1:text "Estirar los bollitos formando rectángulos, colocar el relleno y enrollar, el cierre se colocara hacia abajo. Dar forma a los guaguas haciéndole la cabeza, luego pincelar con huevo batido y dejar descansar por media hora."@es .

<http://example.org/recipes/postre/29/step/53ca70b73a884751823b2646bab5e741> a schema1:HowToStep ;
    schema1:text "Para la masa, batir los huevos con el azúcar, la vainilla y la pizca de sal."@es .

<http://example.org/recipes/postre/29/step/57605a409cc54f5e86c6d03a5c9a01b3> a schema1:HowToStep ;
    schema1:text "En un recipiente colocar la harina y agregar la mantequilla a temperatura ambiente integrando todo con las manos."@es .

<http://example.org/recipes/postre/29/step/7129251a8b324687b48137d8b905ddf2> a schema1:HowToStep ;
    schema1:text "Desgasificar la masa estirándola en la mesada y dividir bollos de unos 100 gramos."@es .

<http://example.org/recipes/postre/29/step/8f5758a50b3643fab69511652fcd80aa> a schema1:HowToStep ;
    schema1:text "Comenzar preparando el fermento, para esto agregar en un recipiente la levadura y el azúcar, mezclar y agregar la leche unir todos los ingredientes y tapar con film dejando reposar en un lugar templado por una hora."@es .

<http://example.org/recipes/postre/29/step/923fbedf0855449693434c402ba81211> a schema1:HowToStep ;
    schema1:text "Dejar enfriar y decorar con glasé o chips de chocolate."@es .

<http://example.org/recipes/postre/29/step/96cd7d6ec4b04ff2982dfcfce11e8cbc> a schema1:HowToStep ;
    schema1:text "Hornear en horno precalentado a 200 grados por 15 minutos."@es .

<http://example.org/recipes/postre/3/step/24c1c3316ea84498a5bc988bfeb6deb4> a schema1:HowToStep ;
    schema1:text "Mientras tanto mezclar el azúcar impalpable con el jugo de naranja y formando un glasé."@es .

<http://example.org/recipes/postre/3/step/2c2e557e5ca34768ba73ec6eec326a12> a schema1:HowToStep ;
    schema1:text "Estirar la masa con palote hasta dejarla de 5 mm de espesor y colocarla sobre una placa enmantecada. Cortar cuadrados de unos 5 centímetros y hornear a 180 grados por unos 15 minutos o hasta que se doren."@es .

<http://example.org/recipes/postre/3/step/746a0a6fc1b84447970f05b49210e8fc> a schema1:HowToStep ;
    schema1:text "Servir los aplanchados fríos."@es .

<http://example.org/recipes/postre/3/step/b942a659b32749a08a63f701c7861582> a schema1:HowToStep ;
    schema1:text "Sacar los cuadrados del horno y cubrirlos con el glaseado."@es .

<http://example.org/recipes/postre/3/step/e5a115b5d120467bbf7ff412e19e1a43> a schema1:HowToStep ;
    schema1:text "Agregar a la preparación el aceite sin dejar de integrar hasta formar una masa, dejar reposar envuelta en papel manteca por una media hora."@es .

<http://example.org/recipes/postre/3/step/fc132f6d80554c1bba660ab2eb3b901e> a schema1:HowToStep ;
    schema1:text "Comenzar mezclando la harina, el polvo de hornear, la sal y el azúcar, formar una corona y colocar en el centro el huevo, las yemas, la esencia de vainilla y la mantequilla e integrar bien todos los ingredientes."@es .

<http://example.org/recipes/postre/30/step/2224d8c7961b4a89bbeb1ffc9b2ef7a7> a schema1:HowToStep ;
    schema1:text "En una batidora agregamos la harina, el azúcar, una cucharadita de canela y la sal. Mezclamos bien y agregamos la mantequilla, batimos y luego agregamos los huevos."@es .

<http://example.org/recipes/postre/30/step/2482f3c33d4b4d2fa6f3626578463e8b> a schema1:HowToStep ;
    schema1:text "Hornemos a 175 grados hasta que estén dorados. Luego envolvemos y dejamos reposar para que no se endurezcan. AL final decoramos con glaseado."@es .

<http://example.org/recipes/postre/30/step/55048a24bf4d407db87c27c84a8a81fe> a schema1:HowToStep ;
    schema1:text "Si los deseamos rellenos estiramos la masa y le colocamos un poco de la mezcla en un extremo y vamos enrrollando. Una vez listo le damos la formita deseada y pintamos por encima con una yema de huevo."@es .

<http://example.org/recipes/postre/30/step/6fffd889131c494494087105cfa7764a> a schema1:HowToStep ;
    schema1:text "Primero en un envase diluimos la levadura en leche tibia, mezclamos bien y agregamos un poco de harina, batimos con un batidor manual y dejamos leudar por 1 hora."@es .

<http://example.org/recipes/postre/30/step/cfc719e8966240beb4fcc58194f53817> a schema1:HowToStep ;
    schema1:text "Una vez listo aplastamos o rompemos la masa amasamos bien y trabajamos la masa."@es .

<http://example.org/recipes/postre/30/step/e91f9a64bdbb43f39b9657f0cd742422> a schema1:HowToStep ;
    schema1:text "Luego estiramos la masa con la ayuda de un rodillo y hacemos los moldes con la ayuda de un molde de cartulina y un cortador. Y le vamos dando la forma"@es .

<http://example.org/recipes/postre/30/step/f408293aae6e4367b9776c2a24146539> a schema1:HowToStep ;
    schema1:text "Una vez mezclado agregamos a la batidora la mezla de levadura y vainilla. Batimos bien hasta tener una masa suave. Formamos una bola y la colocamos en un envase. Cubrimos esta masa y dejamos leudar por 2 horas."@es .

<http://example.org/recipes/postre/31/step/018b6ab15a7b43ab9405420c4402cd01> a schema1:HowToStep ;
    schema1:text "El helado se almacena en un envase y se refrigera para mantenerlo."@es .

<http://example.org/recipes/postre/31/step/18fb2f79ede14f3798ff0dacb61af890> a schema1:HowToStep ;
    schema1:text "Prepara una base en una especie de batea y coloque la paja con el hielo y la sal en granos. Encima ubique la paila de bronce."@es .

<http://example.org/recipes/postre/31/step/7935d8acbb854d8382faf999b2c77a89> a schema1:HowToStep ;
    schema1:text "La mezcla a medida que se va enfriando, adquiere una contextura homogénea."@es .

<http://example.org/recipes/postre/31/step/8417aa0a925047d0b47b2b8f5136de01> a schema1:HowToStep ;
    schema1:text "Disfrute de un delicioso y cremoso helado de paila."@es .

<http://example.org/recipes/postre/31/step/960bca0edb2c428b994978863f7a0458> a schema1:HowToStep ;
    schema1:text "Batir el jugo de moras con el azúcar."@es .

<http://example.org/recipes/postre/31/step/a223ebabf32f45d79cbc3ad6ef927c18> a schema1:HowToStep ;
    schema1:text "Añada el jugo de frutas en la paila."@es .

<http://example.org/recipes/postre/31/step/cda2ab425ca9491898d5212ff67dbfbc> a schema1:HowToStep ;
    schema1:text "La técnica de elaboración implica que a la paila se le den constantemente vueltas y con una paleta se va desprendiendo el líquido cuando se va solidificando de las paredes de la paila."@es .

<http://example.org/recipes/postre/32/step/246051052133474c870400ce68ccf2e0> a schema1:HowToStep ;
    schema1:text "Luego tomamos de nuevo la licuadora y agregamos el mango, 3 cucharadas de azúcar, resto de crema de leche y un toque de agua y licuamos. Despues de licuar y cernir tenemos tambien el jugo de mango."@es .

<http://example.org/recipes/postre/32/step/2cf21704c289465abf3d7dc5b85adf91> a schema1:HowToStep ;
    schema1:text "Para comenzar a preparal el helado de molde colocamos encima de un envace el yute y encima de el el hielo picado . lo picamos un poco mas con la ayuda de un cuchillo y sobre el colocamos la sal en grano (la mitad, para que se concerve mas el hielo) sobre esto ponemos la paila pequeña por 10 minutos ."@es .

<http://example.org/recipes/postre/32/step/44bf0985220f42b694b1701d78105e51> a schema1:HowToStep ;
    schema1:text "En una licuadora colocar la mora, junto con el azúcar, el agua y la mitad de la crema de leche. Procedemos a licuar y cernir."@es .

<http://example.org/recipes/postre/32/step/588f60b333d2411cacb27e59dacdde38> a schema1:HowToStep ;
    schema1:text "Luego dentro de la paila agregamos la mezcla de mora y comenzamos a dar vuelta. Cuando llevemos como 10 minutos comenzamos a despegar con la pala lo que se va pegando."@es .

<http://example.org/recipes/postre/32/step/59a21b229200401788867252504eb59d> a schema1:HowToStep ;
    schema1:text "Seguimos dando vuelta hasta que se haga la cosistencia del helado. Y listo. Queda como un helado."@es .

<http://example.org/recipes/postre/32/step/c1f7541c733340068443fbff3bdfb742> a schema1:HowToStep ;
    schema1:text "Después de cernir rectificamos el dulce. Se le puede agregar mas al gusto."@es .

<http://example.org/recipes/postre/33/step/52f10331630a48ef99e4cb3f59919c3b> a schema1:HowToStep ;
    schema1:text "Colocar las bolas sobre una rebanada de pan, envolver dándole forma con las manos. Cubrir con otra rebanada de pan, repitiendo el proceso. El pan debe adherirse a la bola."@es .

<http://example.org/recipes/postre/33/step/81b307ea0fb843ce8ba2e90fe23e77b7> a schema1:HowToStep ;
    schema1:text "Bañar las bolas de helado y pan con la mezcla preparada anteriormente. Cubrirla cuidadosamente, dejándola bien impregnada."@es .

<http://example.org/recipes/postre/33/step/822335a6dcab4848a019b2d850b3cb34> a schema1:HowToStep ;
    schema1:text "Freír las bolas hasta que estén de un tono dorado, servirlas cubiertas con sirope de chocolate, miel o nata."@es .

<http://example.org/recipes/postre/33/step/a9ef8b869ae84f8c9777d2fa7cae120c> a schema1:HowToStep ;
    schema1:text "Congelar las bolas un par de horas antes de freírlas para que no se deshagan."@es .

<http://example.org/recipes/postre/33/step/b4aeeec375274505931d6153a65e6c21> a schema1:HowToStep ;
    schema1:text "Mezclar en una taza un huevo, la leche y la harina, batir hasta conseguir una mezcla espesa."@es .

<http://example.org/recipes/postre/34/step/202265d5bdc545eda8a5a0a93dc7d7e9> a schema1:HowToStep ;
    schema1:text "Realizar el mismo procedimiento con las otras frutas, intercalando los sabores y colores."@es .

<http://example.org/recipes/postre/34/step/28209e5558ab4ab4968b6d902a7866b0> a schema1:HowToStep ;
    schema1:text "Tomar un poco de la preparación anterior y mezclarlo con la glucosa."@es .

<http://example.org/recipes/postre/34/step/2904162c64ad41a182e06bfc9eefd0ea> a schema1:HowToStep ;
    schema1:text "Mezclar la glucosa con el resto del batido de leche y la crema. Incorporarle el azúcar y batir enérgicamente. Refrigerar por unas dos horas."@es .

<http://example.org/recipes/postre/34/step/519868eac2254d3bae0248844b4326fa> a schema1:HowToStep ;
    schema1:text "Disfrute de estos exquisitos helados."@es .

<http://example.org/recipes/postre/34/step/80ee3d8fe2a546a6ac8755e88c3a94b5> a schema1:HowToStep ;
    schema1:text "Por separado se debe batir cada zumo de frutas con parte del helado base."@es .

<http://example.org/recipes/postre/34/step/9cbd29a5ba7e480789a843a22f932137> a schema1:HowToStep ;
    schema1:text "En un molde para helados, verter cada porción de helado con frutas y congelar."@es .

<http://example.org/recipes/postre/34/step/a2021db27e6d4d6088d47ceaa5ab919a> a schema1:HowToStep ;
    schema1:text "En una licuadora, preparar un batido con el agua, la leche y la crema de leche."@es .

<http://example.org/recipes/postre/35/step/089339827c204e36bf1af9645d9942a6> a schema1:HowToStep ;
    schema1:text "Llevar al horno durante 15 minutos o hasta que quede bastante firme al tacto.."@es .

<http://example.org/recipes/postre/35/step/25c8cf4753f6440691bbb4c5cc27846e> a schema1:HowToStep ;
    schema1:text "Untar una fuente con la crema y desmolde sobre ella el flan."@es .

<http://example.org/recipes/postre/35/step/6f98e0997de8404886032ed6aef034b2> a schema1:HowToStep ;
    schema1:text "Poner en un molde savarín acaramelado a baño María tratando de que no queden huecos de aire."@es .

<http://example.org/recipes/postre/35/step/8e61b2f1a49b4d8383fae41d9212bd4c> a schema1:HowToStep ;
    schema1:text "Bañar el flan con la crema restante y servir."@es .

<http://example.org/recipes/postre/35/step/a07edf5474c34b9f88a081d81f24a330> a schema1:HowToStep ;
    schema1:text "Dejar enfriar."@es .

<http://example.org/recipes/postre/35/step/ad70cf7a78eb4fbdb62b2cbfde89f2ce> a schema1:HowToStep ;
    schema1:text "Batir las claras de huevo a punto de nieve."@es .

<http://example.org/recipes/postre/35/step/c71fdc1bbb794665baf43a6e8b9c1170> a schema1:HowToStep ;
    schema1:text "Mezclar la mermelada con las claras de huevo."@es .

<http://example.org/recipes/postre/35/step/fdf845187a0c4113bf8f769389ef3df8> a schema1:HowToStep ;
    schema1:text "Hacer una crema con las yemas, la leche, la maicena (previamente disuelta en un poco de agua fría ), la vainilla y el azúcar."@es .

<http://example.org/recipes/postre/36/step/31d4f2ac66c140eda6ff3f73abf6c42e> a schema1:HowToStep ;
    schema1:text "Colocar en una olla el licuado con la canela y el anis y cocinar a fuego lento por unos minutos."@es .

<http://example.org/recipes/postre/36/step/3528f387e3cb42eebe9937728f08316d> a schema1:HowToStep ;
    schema1:text "Cuando el zapallo entibie, licuar junto con la leche."@es .

<http://example.org/recipes/postre/36/step/588cf937556d4521820133c431f62603> a schema1:HowToStep ;
    schema1:text "Servir caliente."@es .

<http://example.org/recipes/postre/36/step/a4af8ef9c97c450fb0dce6935014ef78> a schema1:HowToStep ;
    schema1:text "Cortar el zapallo en cubos pequeños y hervir hasta que este blando."@es .

<http://example.org/recipes/postre/36/step/d7e9ff13f46f4ef18c8ae85cee67f5ac> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y espolvorear con panela rallada."@es .

<http://example.org/recipes/postre/37/step/1c6e782258914bc7a3bab917c3060617> a schema1:HowToStep ;
    schema1:text "Tomar las hojas de achira, colocarle una porción de la masa y añadirle las pasas previamente remojadas en una copa de licor."@es .

<http://example.org/recipes/postre/37/step/1eaef12cae1d4939aab7b26887a40ef1> a schema1:HowToStep ;
    schema1:text "Servirlos acompañados de una taza de café."@es .

<http://example.org/recipes/postre/37/step/407268d2249043b9955d206b6d4387ae> a schema1:HowToStep ;
    schema1:text "Incorporar el azúcar, las yemas de huevo y la harina poco a poco. Debe obtenerse una masa homogénea."@es .

<http://example.org/recipes/postre/37/step/4110f90a0aeb49e0a7beee258784e104> a schema1:HowToStep ;
    schema1:text "Incorpore el queso, el ron anisado, la vainilla y la ralladura de limón. Por último añada las claras batidas a punto de nieve."@es .

<http://example.org/recipes/postre/37/step/4f5cd53f28024e148d5f716995c62863> a schema1:HowToStep ;
    schema1:text "En un bol, batir las mantequilla junto con la manteca hasta obtener cremosidad."@es .

<http://example.org/recipes/postre/37/step/965f66f5865544c488045bcc9aea3451> a schema1:HowToStep ;
    schema1:text "Doblar las hojas sobre la masa, cuidando de cerrar los extremos."@es .

<http://example.org/recipes/postre/37/step/c7f0cfefe884419e974435b4308d674f> a schema1:HowToStep ;
    schema1:text "Colocar en una vaporera y cocinarlos por unos 20 minutos."@es .

<http://example.org/recipes/postre/38/step/883548dbcb01441584ede85537feb48d> a schema1:HowToStep ;
    schema1:text "Luego agregamos 2 cucharaditas de harina y revolvemos lentamente, luego comenzamos a colocarla al fuego para que comience a hervir."@es .

<http://example.org/recipes/postre/38/step/91c051194cb04f7f83703453419e0fb2> a schema1:HowToStep ;
    schema1:text "Una vez listo dejamos enfriar y servimos."@es .

<http://example.org/recipes/postre/38/step/9fadfc318313485181a4d9df38ed3e05> a schema1:HowToStep ;
    schema1:text "Esta mezcla dura como 1 hora en la hornilla para que de la consistencia deseada."@es .

<http://example.org/recipes/postre/38/step/bf6a747c546d4f2d8a58b36f3d81293b> a schema1:HowToStep ;
    schema1:text "Seguir revolviendo constantemente para que no se pegue."@es .

<http://example.org/recipes/postre/38/step/da76f9b109154d6399c20a9309154c21> a schema1:HowToStep ;
    schema1:text "Se debe seguir revolviendo hasta el final para que no se pegue."@es .

<http://example.org/recipes/postre/38/step/e4b9424fce9846638a08e8886c2fc86d> a schema1:HowToStep ;
    schema1:text "En una olla colocamos 1 litro de leche y agregamos 1 taza de azucar y canela al gusto."@es .

<http://example.org/recipes/postre/38/step/f0c7cf738a9c40d79603d1b746b8a208> a schema1:HowToStep ;
    schema1:text "Para saber cuando esta listo se revuelve a un costado de la olla y miramos si se ve el fondo de la olla. Seguimos batiendo hasta que tenga un color bronceado y se pueda ver el fondo de la olla al revolver."@es .

<http://example.org/recipes/postre/39/step/05bf7b2a338c498b8d65e9944477beae> a schema1:HowToStep ;
    schema1:text "Mezclar con la harina y la maicena cernidas y las nueces hasta tener una masa manejable."@es .

<http://example.org/recipes/postre/39/step/1ca7601308164ec9baf26c566900e843> a schema1:HowToStep ;
    schema1:text "Dejar que las galletas se enfríen un poco y revolverlas en azúcar glass."@es .

<http://example.org/recipes/postre/39/step/30dc2585bd6146668c86759ecef9fac2> a schema1:HowToStep ;
    schema1:text "Formar las medias lunas utilizando 1 cucharadita de masa."@es .

<http://example.org/recipes/postre/39/step/6dd3e3d28d0041658af02c751aa5fd06> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a 170 ºC (325 ºF)."@es .

<http://example.org/recipes/postre/39/step/7a482b27166f4b59894ef427be6b8cf7> a schema1:HowToStep ;
    schema1:text "Acomodar en charolas para hornear sin engrasar y hornear entre 15 y 30 minutos, sin dejar que se doren."@es .

<http://example.org/recipes/postre/39/step/d661f058add64567a7abf83e3d3fa8bf> a schema1:HowToStep ;
    schema1:text "Batir la mantequilla con el azúcar hasta que esté cremosa, añádir la vainilla."@es .

<http://example.org/recipes/postre/4/step/06ea26f4c80a4f8984cca9f5bfdf93c7> a schema1:HowToStep ;
    schema1:text "Extender la masa con el rodillo hasta dejarla de ½ centímetro de espesor. Colocar la masa sobre una bandeja cubierta con papel encerado. Cortar en cubos de 8 cms de ancho y largo y hornear hasta que se doren."@es .

<http://example.org/recipes/postre/4/step/2db74693cf494b5e994346599953bf40> a schema1:HowToStep ;
    schema1:text "Añadir el aceite y amasar ligeramente con la mano sin calentar la masa. Formar una bola, envolver en papel encerado y dejar reposar durante 30 minutos."@es .

<http://example.org/recipes/postre/4/step/a6d22adf848541c3ab856b46d71b93f9> a schema1:HowToStep ;
    schema1:text "Aparte, mezclar el azúcar impalpable con el jugo de naranja y ½ cucharadita de esencia de vainilla formando una pasta suave. Sacar los cubos del horno e inmediatamente cubrirlos con la pasta de azúcar."@es .

<http://example.org/recipes/postre/4/step/c61a219d516b43a992c755e0c5c249be> a schema1:HowToStep ;
    schema1:text "Mezclar la harina con el polvo de hornear, la sal y el azúcar. En el centro, poner el huevo, las yemas, 1 cucharadita de esencia de vainilla y la mantequilla e integrar bien los ingredientes."@es .

<http://example.org/recipes/postre/4/step/f86d7655a22b477c91e661c8798b8d2e> a schema1:HowToStep ;
    schema1:text "Servir los aplanchados fríos."@es .

<http://example.org/recipes/postre/40/step/56598d9b9ca24652b811f1016570e3fe> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y dejar enfriar durante 2 horas."@es .

<http://example.org/recipes/postre/40/step/86663c75571a4f928666eaa49d095dda> a schema1:HowToStep ;
    schema1:text "Añadir los cubitos de piña, el puré licuado y el jugo de limón y hervir nuevamente."@es .

<http://example.org/recipes/postre/40/step/88020bc95cfe448f94d73d6c822ac2be> a schema1:HowToStep ;
    schema1:text "Pelar y descorazonar la piña. Cortar la mitad de la piña en cubitos y licuar la otra mitad hasta obtener un puré."@es .

<http://example.org/recipes/postre/40/step/cc468bafc7ea46bbbbe2b7ccbb884430> a schema1:HowToStep ;
    schema1:text "Reducir la temperatura y cocinar a fuego lento, revolviendo de vez en cuando, hasta que el líquido se haya reducido y esté espeso."@es .

<http://example.org/recipes/postre/40/step/e8235a8bda8e4ecfadf3c62c0420471c> a schema1:HowToStep ;
    schema1:text "La mermelada de piña se puede servir con pan, crepas, helado o con queso."@es .

<http://example.org/recipes/postre/40/step/ef5a9d5bfb2849fe91f55779b282706e> a schema1:HowToStep ;
    schema1:text "En una olla mediana hervir el agua, el azúcar, la canela y los clavos de olor."@es .

<http://example.org/recipes/postre/41/step/2a3dc2c659bb42569c00af39223c0515> a schema1:HowToStep ;
    schema1:text "Siga cocinando hasta que la mermelada tenga una consistencia espesa y se despegue del fondo de la olla."@es .

<http://example.org/recipes/postre/41/step/7385e118ec18456383b1b2c0a2f507b3> a schema1:HowToStep ;
    schema1:text "Añada el jugo de limón y mezcle todo muy bien."@es .

<http://example.org/recipes/postre/41/step/808f6ef1cc484df09e0a6be97c061b06> a schema1:HowToStep ;
    schema1:text "Pasar la mezcla por un colador para retirar las semillas."@es .

<http://example.org/recipes/postre/41/step/833176de7bb64c2dbc7aa1800fda6afb> a schema1:HowToStep ;
    schema1:text "Vierta la preparación en frascos esterilizados y deje enfriar."@es .

<http://example.org/recipes/postre/41/step/a48e6041294845dbbe37a6f6fcf563d3> a schema1:HowToStep ;
    schema1:text "Triturar la fruta y realice un puré con la ayuda de una licuadora o batidora. Puede añadir un poco del agua donde se cocinaron los tomates."@es .

<http://example.org/recipes/postre/41/step/c5810038b1b44dae8f8ca7ac02d8ce18> a schema1:HowToStep ;
    schema1:text "Lavar bien los tomates."@es .

<http://example.org/recipes/postre/41/step/d257bcb424134de99c09568f0a5366d6> a schema1:HowToStep ;
    schema1:text "Colocar la pulpa en una olla, agregue el azúcar y lleve a cocción a fuego moderado por unos 30 minutos."@es .

<http://example.org/recipes/postre/41/step/dfe42c6141b243959ea82fd7c7dccc79> a schema1:HowToStep ;
    schema1:text "Tápelos y conserve en el refrigerador."@es .

<http://example.org/recipes/postre/41/step/ea3a8f052c6349e393500c7844da5d1e> a schema1:HowToStep ;
    schema1:text "Pasar los tomates por agua caliente por 2 minutos y luego por agua fría. Esto permitirá retirarles fácilmente la piel."@es .

<http://example.org/recipes/postre/42/step/0207ba7820ca4ab6ab3586cb26c74cdc> a schema1:HowToStep ;
    schema1:text "Luego cortamos con la ayuda de un cuchillo cortamos varias tiritas en forma de orejita. Colocamos en una bandaja y cocinamos en horno por 20 minutos a 180 grados."@es .

<http://example.org/recipes/postre/42/step/0757d99b14744997bad0c436f7f480e8> a schema1:HowToStep ;
    schema1:text "Luego con la ayuda de los dedos la undimos en la bandeja y dejamos reposar por 20 minutos."@es .

<http://example.org/recipes/postre/42/step/501b3a5a920442b0b05ee565fb6fdfdf> a schema1:HowToStep ;
    schema1:text "Seguido de esto estiramos la otra parte y tomamos un huevo batido y le extendemos a la masa y luego el azúcar con la canela por encima luego la enrollamos y volvemos a desenrollar y colocamos huevo batido y por encima la azucar con la canela y le pasamos un rodillo por encima para que se pegue a la masa."@es .

<http://example.org/recipes/postre/42/step/63710a2bbe2a439a813fd214f405a2f3> a schema1:HowToStep ;
    schema1:text "Si las deseamos en forma de milhojas solo cocinamos la masa completa al horno y al salir la cortamos y rellenamos con dulce de leche."@es .

<http://example.org/recipes/postre/42/step/64a285a1dbae4f05b3400466ee359200> a schema1:HowToStep ;
    schema1:text "Luego comenzamos como a doblar la masa, la doblamos como 4 veces hacia adentro y extendemos con un rodillo una vez doblado todo."@es .

<http://example.org/recipes/postre/42/step/b4aff6db2fa9466498d060f2a48b326d> a schema1:HowToStep ;
    schema1:text "Estan listas para disfrutar."@es .

<http://example.org/recipes/postre/42/step/ff4faa9563004da5ba3f624e3b0deeca> a schema1:HowToStep ;
    schema1:text "Preparamos la masa y agarramos la mitad para una bandeja y luego la otra la estiramos con la ayuda de un rodillo hasta que tenga como 5milimetros de espesor y la colocamos en una bandeja."@es .

<http://example.org/recipes/postre/43/step/30b5c54f82384b3697797b059df6f888> a schema1:HowToStep ;
    schema1:text "Luego agregamos 4 tazas de agua caliente. Lo cocinamos en una olla de presión de preferencia por 1 hora y 30 minutos."@es .

<http://example.org/recipes/postre/43/step/37deb3aa78c14ece817be3f89fbf1013> a schema1:HowToStep ;
    schema1:text "Luego agregamos esta mezcla a la olla. Junto con 5 bolitas pimienta dulce entera, 3 clavos de olor, 1 ramita canela y una media taza de pasas. Lo dejamos hervir, moviéndolo constantemente."@es .

<http://example.org/recipes/postre/43/step/4e450affd89b4f7db6959ed79f5b3c6c> a schema1:HowToStep ;
    schema1:text "Aparte en un licuadora colocamos: 4 cucharadas del morocho con 1 taza de leche ."@es .

<http://example.org/recipes/postre/43/step/8984bc998a2b4219b79bb4326a4d70e4> a schema1:HowToStep ;
    schema1:text "Una vez listo sacamos las bolitas de pimienta y canela y servimos."@es .

<http://example.org/recipes/postre/43/step/9bf4ca2667134318927d128e786ec881> a schema1:HowToStep ;
    schema1:text "Seguido de esto agregamos el azúcar, solo media taza, luego agregamos la leche condensada para comenzar. Revolvemos bien y dejamos cocinar."@es .

<http://example.org/recipes/postre/43/step/b66fcc20d6eb4108bc300624a209d747> a schema1:HowToStep ;
    schema1:text "Una vez cocinado se deja enfriar por una hora y agregamos 4 tazas de leche."@es .

<http://example.org/recipes/postre/43/step/de785d778f8549aa8779d745fddbc31f> a schema1:HowToStep ;
    schema1:text "Dejaremos remojado el morocho durante toda la noche, aproximadamente una taza de morocho."@es .

<http://example.org/recipes/postre/44/step/21a3db8c058946edba6f08e34ca8c6e9> a schema1:HowToStep ;
    schema1:text "Incorporar la crema de dulce de leche. Hacerlo con movimientos suaves y envolventes, para que no se pierda demasiado aire."@es .

<http://example.org/recipes/postre/44/step/3edad540863b4db5ae30f75dd95380b5> a schema1:HowToStep ;
    schema1:text "Dividir el mousse en 6 vasos individuales o en una fuente grande."@es .

<http://example.org/recipes/postre/44/step/828d6d3ab22546b3888c8e3783f3adac> a schema1:HowToStep ;
    schema1:text "Decorar con dulce de leche, frutos secos, praliné, o lo que se desee."@es .

<http://example.org/recipes/postre/44/step/85a06336f24e45fcba7f13519484cc1b> a schema1:HowToStep ;
    schema1:text "Batir la crema de leche, e incorporarle el dulce de leche con movimientos envolventes."@es .

<http://example.org/recipes/postre/44/step/9f0e52ec28d24906a449af1713c0f291> a schema1:HowToStep ;
    schema1:text "Usar galletitas en el fondo, romper las que se consideren necesarias para cubrirlo."@es .

<http://example.org/recipes/postre/44/step/b2ecef5bf15e45b9893313c935491504> a schema1:HowToStep ;
    schema1:text "Separar las claras de huevos y batir a punto nieve con una batidora agregando azúcar poco a poco."@es .

<http://example.org/recipes/postre/45/step/0b72bdaa2301449e9fae1a218181464f> a schema1:HowToStep ;
    schema1:text "Por último agregue la gelatina disuelta."@es .

<http://example.org/recipes/postre/45/step/0d9f45ff4b334387958b4550536a40bd> a schema1:HowToStep ;
    schema1:text "Con la ayuda de una espátula, incorpore la leche evaporada, la pulpa de taxo y la leche condesada. Mezcle los ingredientes con movimientos suaves y envolventes."@es .

<http://example.org/recipes/postre/45/step/29dbcfa4c0a74370974b920c1a02f06a> a schema1:HowToStep ;
    schema1:text "Verter la mezcla en una molde para mousse y llevar al refrigerador por unas horas."@es .

<http://example.org/recipes/postre/45/step/4672d8803c6a47e497aa49fa897d413d> a schema1:HowToStep ;
    schema1:text "Sirva decorado con una salsa de taxo o con crema chantilly."@es .

<http://example.org/recipes/postre/45/step/842aa60cbf2a4a2f8e725b1fa3b69763> a schema1:HowToStep ;
    schema1:text "En un bol, se deben batir las claras de punto de nieve."@es .

<http://example.org/recipes/postre/45/step/c0facfb3ee6b4b65b71c3efbc7a970a7> a schema1:HowToStep ;
    schema1:text "Disolver la gelatina sin sabor en el agua fría. Reservar."@es .

<http://example.org/recipes/postre/46/step/0049e7a1c152410da94baf7618ad1d41> a schema1:HowToStep ;
    schema1:text "Mezclar las dos preparaciones e incorporar las manzanas y vertir todo en moldes para muffins o en pirotines y llenar cada espacio hasta la mitad."@es .

<http://example.org/recipes/postre/46/step/1be651cf2e974a6eba381174a4f95289> a schema1:HowToStep ;
    schema1:text "Batir aparte en otro bol el huevo, leche y agregar aceite de oliva o manteca hasta obtener una crema suave."@es .

<http://example.org/recipes/postre/46/step/87a1f9a38bcd47688d24a072c75c08eb> a schema1:HowToStep ;
    schema1:text "Hornear a temperatura media (180 °C) por 20 minutos aproximadamente."@es .

<http://example.org/recipes/postre/46/step/8fd3d6d2f0fa44f2850a27e3c219c619> a schema1:HowToStep ;
    schema1:text "Rocíar con esta preparación los muffins."@es .

<http://example.org/recipes/postre/46/step/a489d130e5bd4c928c24ed900f7e5143> a schema1:HowToStep ;
    schema1:text "Dejar enfriar por cinco minutos y desmoldar."@es .

<http://example.org/recipes/postre/46/step/b70126a6902f4379b83972b2f315bec3> a schema1:HowToStep ;
    schema1:text "Meclar en otro bol el azúcar morena, 1 cucharada de harina y la mantequilla."@es .

<http://example.org/recipes/postre/46/step/d08f309959c54cecbb81298c1f6008ec> a schema1:HowToStep ;
    schema1:text "Mezclar en un bol harina, azúcar, polvo de hornear, sal y la canela molida."@es .

<http://example.org/recipes/postre/46/step/fe0bad852db94352b7aac06819aeab3c> a schema1:HowToStep ;
    schema1:text "Remover hasta que tome una textura arenosa."@es .

<http://example.org/recipes/postre/47/step/13bb1f6760b8473399baefb236e31461> a schema1:HowToStep ;
    schema1:text "Desgranar los choclo usando un cuchillo. Luego licuar (con un poco de leche) o moler para extraer el jugo del choclo."@es .

<http://example.org/recipes/postre/47/step/2f155c8d9afa45559b8a1133e026d8a6> a schema1:HowToStep ;
    schema1:text "Servir en envases individuales y espolvorear canela en polvo."@es .

<http://example.org/recipes/postre/47/step/628519e531394a788a615419057d1076> a schema1:HowToStep ;
    schema1:text "Colar el jugo y revolver con la leche"@es .

<http://example.org/recipes/postre/47/step/7e2f23c8a0cf44cca6d78328ca4d57ce> a schema1:HowToStep ;
    schema1:text "Hervir hasta que se logre la consistencia deseada, luego sacar del fuego y dejajr enfriar un poco."@es .

<http://example.org/recipes/postre/47/step/edc0c83e34c34a8bbff9746e036a1627> a schema1:HowToStep ;
    schema1:text "Cocinar a fuego mediano revolviendo continuamente hasta que espese. Por último se agrega la vainilla."@es .

<http://example.org/recipes/postre/47/step/f368e44b42db4a34bef05832bd8cb06e> a schema1:HowToStep ;
    schema1:text "Colocar el jugo del choclo en una olla y juntar los demás ingredientes a excepci{on de la vainilla y la canela en polvo."@es .

<http://example.org/recipes/postre/48/step/1a6a032b9cbd489d8270b27fab5694d7> a schema1:HowToStep ;
    schema1:text "Levantar las claras a punto de nieve e incorpore batiendo con cuidado en forma envolvente."@es .

<http://example.org/recipes/postre/48/step/2d7bb13888514e8eaf97b8d1280f0a3b> a schema1:HowToStep ;
    schema1:text "Agregar la harina cernida."@es .

<http://example.org/recipes/postre/48/step/89a409fad0b14de18419c67badf3a85b> a schema1:HowToStep ;
    schema1:text "Agregar las yemas de huevo y continuar removiendo enérgicamente."@es .

<http://example.org/recipes/postre/48/step/9ef54300719c417ebb1aebdc341890f7> a schema1:HowToStep ;
    schema1:text "Colocar en una olla de baño maría ½ taza de leche, disolver el chocolate, y agregar la mantequilla derretida, moviendo constantemente, agregar la azúcar sin dejar de remover."@es .

<http://example.org/recipes/postre/48/step/deea7ddf37054ff8af5617cf7f574128> a schema1:HowToStep ;
    schema1:text "Hornear a 350º en un molde alto hasta que introduzca un palillo en el medio y salga limpio."@es .

<http://example.org/recipes/postre/48/step/f3329977c0824b28a0dc8aa2c0ed4bd4> a schema1:HowToStep ;
    schema1:text "No dejar hervir el chocolate para que mantenga su aroma, debe darse tiempo."@es .

<http://example.org/recipes/postre/49/step/1dd60e320e80464b9b4a6c12789a98b6> a schema1:HowToStep ;
    schema1:text "Retire del fuego y deje enfriar."@es .

<http://example.org/recipes/postre/49/step/618bfc9849c64bd5a3fbe1a133e1eaa7> a schema1:HowToStep ;
    schema1:text "Añada la mitad de los tocte y la manteca. Continúe removiendo a fuego mediano por unos minutos."@es .

<http://example.org/recipes/postre/49/step/71980acb624641fdad6a2acef792bbef> a schema1:HowToStep ;
    schema1:text "En una paila, coloque la panela troceada junto con el agua."@es .

<http://example.org/recipes/postre/49/step/aaa7a831b77646f9a53ecaf22080441a> a schema1:HowToStep ;
    schema1:text "Cuando la miel haya reposado agregue el huevo y remueva bien, evitando que la clara se solidifique."@es .

<http://example.org/recipes/postre/49/step/b1a51853ee514a11b379ee0ce5dc24a2> a schema1:HowToStep ;
    schema1:text "Coloque nuevamente la miel en la paila y lleve al fuego. Debe remover constantemente hasta que la preparación comience a espesar y obtenga el punto de bola."@es .

<http://example.org/recipes/postre/49/step/d23e8716d1d64fe7b64036a01a9100b1> a schema1:HowToStep ;
    schema1:text "Incorpore el resto de los tocte y mezcle muy bien."@es .

<http://example.org/recipes/postre/49/step/f5c77f650e574518ad6af0caf347ea1f> a schema1:HowToStep ;
    schema1:text "Coloque la preparación en cajas artesanales y decore a su gusto."@es .

<http://example.org/recipes/postre/49/step/fdff0f92e7b4457da3bd2c96cd6049c0> a schema1:HowToStep ;
    schema1:text "Deje cocinar hasta que se derrita la panela. Retire del fuego y pase la miel por un tamiz."@es .

<http://example.org/recipes/postre/5/step/0684efac34d84934b8ef4709da1d1ba0> a schema1:HowToStep ;
    schema1:text "Retirar del fuego cuando la leche tenga el sabor de la canela. Retirar las canelas, los clavos de olor y las pimientas."@es .

<http://example.org/recipes/postre/5/step/08a18c0ce463498ca7eaa6d77e4b2cc6> a schema1:HowToStep ;
    schema1:text "Agregar la leche y las pasas y dejar hervir por unos 15 minutos más."@es .

<http://example.org/recipes/postre/5/step/60e8a1f59ff84d4cbe7f3008ac8c1a9d> a schema1:HowToStep ;
    schema1:text "Lavar bien el arroz y cocinar hirviendo durante 20 minutos, hasta que ablande, batiendo constantemente."@es .

<http://example.org/recipes/postre/5/step/826fea9c3c08488a9434b04b44f1611b> a schema1:HowToStep ;
    schema1:text "Poner la leche o los huevos batidos, el azúcar, los clavos de olor y la canela."@es .

<http://example.org/recipes/postre/5/step/9a22dced555041208e503f9f8d3fb507> a schema1:HowToStep ;
    schema1:text "Servir frío o caliente, adornado con canela en polvo o canela en rama."@es .

<http://example.org/recipes/postre/50/step/187cc9690ea7411699f340374690acef> a schema1:HowToStep ;
    schema1:text "En un recipiente colocar el almidón de maíz junto con el polvo de hornear, la esencia y las pasas."@es .

<http://example.org/recipes/postre/50/step/1e91e125f7784988acdb3bce701d9c2f> a schema1:HowToStep ;
    schema1:text "Comenzar por procesar los plátanos junto con los huevos, el azúcar, la mantequilla y el queso."@es .

<http://example.org/recipes/postre/50/step/35b9585f63f64217b7cc84ae6a135f9b> a schema1:HowToStep ;
    schema1:text "Colocar la mezcla por cucharadas abundantes en las hojas de achira."@es .

<http://example.org/recipes/postre/50/step/38edf4a9c4eb4e949bc3c672c54f8fdc> a schema1:HowToStep ;
    schema1:text "Agregar la mezcla de los plátanos al recipiente, integrar todos los ingredientes."@es .

<http://example.org/recipes/postre/50/step/4af227dcc45e4301a9b2d0b43ebf27a7> a schema1:HowToStep ;
    schema1:text "Servir tibios."@es .

<http://example.org/recipes/postre/50/step/a45f16e5427941aaae1dbdb2f6bf97f9> a schema1:HowToStep ;
    schema1:text "Doblar y cerrar las hojas y cocinar en vaporera por media hora."@es .

<http://example.org/recipes/postre/51/step/0979d40d9b1e449e8dfc728f9ccdb31f> a schema1:HowToStep ;
    schema1:text "Cortar la masa hasta que la preparación parezca visualmente arena mojada. Llevar la masa a la mesa, estirarla y compactarla 2 veces. Envolver en papel film y dejar reposar 1 día."@es .

<http://example.org/recipes/postre/51/step/09a753b9f6314d3f86c1abab9ddd33c9> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a 350 F (180 C). Sacar la masa de la refrigeradora y estirarla dentro del papel film hasta 3 mm de grosor."@es .

<http://example.org/recipes/postre/51/step/0c6a0ae5708f4de6a313ec76246880d7> a schema1:HowToStep ;
    schema1:text "Colocar en una olla el azúcar panela y el agua. Cocinar durante 10 minutos, revolviendo frecuentemente, hasta formar un almíbar. Agregar los maduros y caramelizarlos a fuego medio durante 45 min."@es .

<http://example.org/recipes/postre/51/step/25c79aef04bf4fde8356e5270520ce42> a schema1:HowToStep ;
    schema1:text "Servir el pie de maduro en porciones individuales con acompañado de una taza de café."@es .

<http://example.org/recipes/postre/51/step/3fbe373e2abc41d390e80ce2f5cc999c> a schema1:HowToStep ;
    schema1:text "Una vez que la masa de tarta se cocinó lo suficiente para que las paredes se sostengan y no se derritan, quitar el peso de las piedras y terminar de cocinar la masa hasta que se separe de la tartera por sí sola (si se forma globos, pincharlos). Retirar del horno y dejar enfriar la masa."@es .

<http://example.org/recipes/postre/51/step/b33127210a8f482baac5d0cf568e7c1d> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, agregar el queso y mezclar. Verter la mezcla en el molde, ya con la masa de tarta, y hornear a 150 C por 20 min."@es .

<http://example.org/recipes/postre/51/step/c77abe173853488986356130c30b7a5a> a schema1:HowToStep ;
    schema1:text "Forrar con la masa una tartera desmontable (esta masa sirve para 2 tarteras de 24 cm). Cortar papel aluminio del largo casi doble de la tartera y forrar la misma. Sobre el papel aluminio colocar piedras y meter al horno."@es .

<http://example.org/recipes/postre/51/step/c8a337ea1d924f9f96423e94122f1575> a schema1:HowToStep ;
    schema1:text "En un tazón, batir la mantequilla con el azúcar, hasta blanquear. Agregar 2 huevos y batir hasta formar una mezcla unida y esponjosa. Tamizar la harina sobre la masa, agregar la sal y mezclar nuevamente."@es .

<http://example.org/recipes/postre/52/step/40f9b9d4d07b4212bfd33ee94d3796b5> a schema1:HowToStep ;
    schema1:text "Servir los pristiños y bañarlos en miel."@es .

<http://example.org/recipes/postre/52/step/5223681d660a4f9e8a9ca775f39fec52> a schema1:HowToStep ;
    schema1:text "Preparar la miel ubicando en un recipiente pequeño las 2 tazas de agua con la panela rayada, la ramita de canela, el jugo de limón haciendo que se disuelva totalmente la panela, realizar este proceso a fuego lento, cernir cuando se encuentre listo."@es .

<http://example.org/recipes/postre/52/step/563dab0d8547463d927b94ab9d411407> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en un sartén un poco hondo y lanzar los pristiños a freír cuidadosamente, retirar cuando se encuentren dorados completamente."@es .

<http://example.org/recipes/postre/52/step/7bb98137bb0340f186558ad8bcee7198> a schema1:HowToStep ;
    schema1:text "Formar un circulo con flecos hacia afuera dándole molde de roscas."@es .

<http://example.org/recipes/postre/52/step/7f19b41b88d3411eb8553f75e3d87434> a schema1:HowToStep ;
    schema1:text "Cortar la masa de forma rectangular de 15 cm de largo y 3 de ancho utilizando un cuchillo."@es .

<http://example.org/recipes/postre/52/step/a287714751d5445a88c984e9f65e14f3> a schema1:HowToStep ;
    schema1:text "Ubicar en un recipiente las 2 tazas de harina incorporando la mantequilla, mezcla los huevos y la cucharadita de polvo de hornear, agrega leche y la pizca de sal y amasa hasta formar un resultado homogéneo."@es .

<http://example.org/recipes/postre/52/step/f0f93ba500dd4437aa69f1e3048428a5> a schema1:HowToStep ;
    schema1:text "Estirar la masa con un rodillo sobre una superficie plana y que se encuentre con harina, repetir el proceso hasta obtener una masa delgada."@es .

<http://example.org/recipes/postre/53/step/29566642fb264454838532ee31c316a4> a schema1:HowToStep ;
    schema1:text "Cortar rectángulos de 10 por 3 cm y formar un círculo con pequeños cortes externos formando una rosca."@es .

<http://example.org/recipes/postre/53/step/4edbed06f7d140849ed19859f13e7ce1> a schema1:HowToStep ;
    schema1:text "Colocar en un bol la harina, el polvo de hornear, la manteca, y los huevos."@es .

<http://example.org/recipes/postre/53/step/6ff23c7eac43450783861cced91b6940> a schema1:HowToStep ;
    schema1:text "Para preparar la miel de panela colocar en una olla pequeña partes iguales de panela y agua junto con una ramita de canela, colocar a fuego lento y dejar cocinar por media hora."@es .

<http://example.org/recipes/postre/53/step/77aa60fa16d14d85bc525791b81fece5> a schema1:HowToStep ;
    schema1:text "Precalentar el aceite y freír los pristiños hasta que se encuentren dorados."@es .

<http://example.org/recipes/postre/53/step/88edcb1915814d2d934ac3c325fd006d> a schema1:HowToStep ;
    schema1:text "Integrar los ingredientes y agregar de a poco leche y sal y amasar hasta lograr una preparación suave."@es .

<http://example.org/recipes/postre/53/step/9fdb68a3ccf14f40ba65e6364e57e9a3> a schema1:HowToStep ;
    schema1:text "Estirar sobre la mesada con palote hasta conseguir una masa fina."@es .

<http://example.org/recipes/postre/53/step/a3fbad086c5742cc8fcf4da150820107> a schema1:HowToStep ;
    schema1:text "Servir los pristiños tibios y bañados en miel."@es .

<http://example.org/recipes/postre/54/step/037885fe169c481b983fb561eb4eda7f> a schema1:HowToStep ;
    schema1:text "Colocar las quesadillas en el horno y esperar hasta que se doren. Retirar del horno y dejar enfriar durante 2 horas. Servir acompañado de un salpicón de naranjilla, un helado o un té."@es .

<http://example.org/recipes/postre/54/step/706fd3b7478e4543b62ea3f0d30b6662> a schema1:HowToStep ;
    schema1:text "Extender la masa lo más fino posible y cortar en 10 pedazos. Colocar 2 cucharadas de relleno en el centro y doblar los bordes, observando que el relleno quede al descubierto."@es .

<http://example.org/recipes/postre/54/step/757436c91ef64d21a7c1f0828718d910> a schema1:HowToStep ;
    schema1:text "Para el preparar el relleno, batir ágilmente las yemas con el azúcar hasta que se derrita, luego añadir la maicena y cuando la preparación esté muy esponjosa agregar el queso."@es .

<http://example.org/recipes/postre/54/step/86e5bea332ae421ca8bc1240951798ac> a schema1:HowToStep ;
    schema1:text "Pre-calentar el horno a 350 F (180 C). En un tazón, batir el huevo fuertemente, agregar la mantequilla derretida y luego añadir el agua con la sal poco a poco. Amasar hasta lograr una masa suave y homogénea, dejar reposar."@es .

<http://example.org/recipes/postre/55/step/1b373d29ee1e44b1a1e9908491860681> a schema1:HowToStep ;
    schema1:text "Colocar en una olla pequeña el agua con 1 taza de azúcar y hervir a fuego alto, sin revolver, durante 10 minutos hasta que el caramelo comience a tomar un color dorado. Retirar el caramelo del fuego y distribuirlo rápidamente en los moldes de flan."@es .

<http://example.org/recipes/postre/55/step/846a78c419774216a0a407eea546ccc4> a schema1:HowToStep ;
    schema1:text "Aparte, colocar una cucharada de azúcar morena sobre cada rodaja de piña y asarlas debajo del broiler o parilla superior del horno, esperar hasta que el azúcar comience a burbujear y a caramelizarse."@es .

<http://example.org/recipes/postre/55/step/8b403e5958534d308cd47c64c1efcfa2> a schema1:HowToStep ;
    schema1:text "Pre-calentar el horno a 350 F. Batir los huevos con una batidora eléctrica a velocidad baja y lentamente agregar el almíbar de piña, la vainilla, la leche y el ron hasta que todos los ingredientes estén bien mezclados. Colar la mezcla y llenar los moldes de flan con esta mezcla."@es .

<http://example.org/recipes/postre/55/step/a4905a1440674f4497943ede9d1a1f2c> a schema1:HowToStep ;
    schema1:text "Mezclar el jugo de piña con la maicena y la taza de azúcar restante en una olla pequeña a fuego bajo, hervir y cocinar a fuego lento durante 5 minutos hasta que comience a espesar. Retirar del fuego y dejar enfriar completamente."@es .

<http://example.org/recipes/postre/55/step/e266d11f77d44b31af8d6e4fe17284bb> a schema1:HowToStep ;
    schema1:text "Para sacar los flanes de los moldes, colocarlos en un recipiente con agua tibia durante unos minutos, esto ayuda a derretir el caramelo y a desprenderse fácilmente. Servir cada flan acompañado de una rodaja de piña caramelizada."@es .

<http://example.org/recipes/postre/55/step/fa6b83c4815f47879717999e07950b11> a schema1:HowToStep ;
    schema1:text "Hornear los flanes a baño de maría durante 45 minutos hasta que cuajen. Retirarlos del horno, dejar enfriar y refrigerarlos un par de horas antes de servirlos."@es .

<http://example.org/recipes/postre/56/step/0c8f4fde38bf4f4b837830f657de590d> a schema1:HowToStep ;
    schema1:text "Cocinar a vapor, en una tamalera, por 30 minutos o hasta que esten firmes."@es .

<http://example.org/recipes/postre/56/step/253a700f2b0d41fbaf9a6ad3bcde619a> a schema1:HowToStep ;
    schema1:text "Agregar las claras batidas a punta de nieve en el paso 1."@es .

<http://example.org/recipes/postre/56/step/25eba6bee46d46889aa6c93256ea6ef4> a schema1:HowToStep ;
    schema1:text "Rallar el queso de mesa finamente."@es .

<http://example.org/recipes/postre/56/step/4e833ec082c04ebe8d02e0dae6f892c3> a schema1:HowToStep ;
    schema1:text "Batir la margarina agregando alternadamente el azúcar y las yemas de huevo hasta obtener una mezcla cremosa."@es .

<http://example.org/recipes/postre/56/step/7e44176b0d6545dda9dec889d522d1d3> a schema1:HowToStep ;
    schema1:text "Servir con café caliente."@es .

<http://example.org/recipes/postre/56/step/8a4b116dbc39403b814152e7aa48cea0> a schema1:HowToStep ;
    schema1:text "Batir las claras de huevo a punto de nieve."@es .

<http://example.org/recipes/postre/56/step/8ac901cfd69740178cad90dae15db273> a schema1:HowToStep ;
    schema1:text "Añadir pasas encima para decorar, doblar la hoja de achira y cerrar."@es .

<http://example.org/recipes/postre/56/step/9762fe241a684ca0b517ad0338b5b0fc> a schema1:HowToStep ;
    schema1:text "Agregar el queso, el licor, la ralladura de limón, las pasas y la harina y batir hasta obtener una mezcla uniforme."@es .

<http://example.org/recipes/postre/56/step/9e471ed6085549d7895beaa6f3c2a598> a schema1:HowToStep ;
    schema1:text "Colocar varias cucharadas de la masa en el centro de cada hoja de achira."@es .

<http://example.org/recipes/postre/56/step/c82a6d3c1f234c7f838aea297ec04663> a schema1:HowToStep ;
    schema1:text "Tamizar las harinas con el polvo de hornear."@es .

<http://example.org/recipes/postre/57/step/33559231813548cda08de063b9f6ba99> a schema1:HowToStep ;
    schema1:text "Para el armado, colocar una cucharada abundante de la masa en el centro de cada hoja de achira, agregar pasas por encima y doblar la hoja cerrándola."@es .

<http://example.org/recipes/postre/57/step/75387be7fa6049f0a5b2d37c11460fc4> a schema1:HowToStep ;
    schema1:text "A las yemas batidas agregarles el queso rallado, el licor, la ralladura de limón, las pasas y la harina tamizada. Mezclar hasta integrar todos los ingredientes."@es .

<http://example.org/recipes/postre/57/step/7e589c015b2143fb9ce3fd6661182067> a schema1:HowToStep ;
    schema1:text "Comenzar separando yemas de claras, batir las claras a punto nieve y rallar el queso."@es .

<http://example.org/recipes/postre/57/step/96e23333435e4cedabbb0fba376f69c3> a schema1:HowToStep ;
    schema1:text "En un recipiente mezclar las harinas con el polvo de hornear y pasarlas por el tamiz."@es .

<http://example.org/recipes/postre/57/step/97f2657f133c4de784a4c80efb5af379> a schema1:HowToStep ;
    schema1:text "Cocinar en vaporera por una media hora, servir tibios acompañados de café negro."@es .

<http://example.org/recipes/postre/57/step/bab9b97d02ad4a1e9a66c2d81c16fab7> a schema1:HowToStep ;
    schema1:text "Batir la margarina pomada y añadir lentamente el azúcar y las yemas hasta obtener una mezcla homogénea."@es .

<http://example.org/recipes/postre/57/step/dd7b999e476c44219e9d560bec6dc9de> a schema1:HowToStep ;
    schema1:text "Añadir a toda la preparación las claras batidas a punto nieve."@es .

<http://example.org/recipes/postre/58/step/0bbe32283ab74c87b4c34133ba1dab3a> a schema1:HowToStep ;
    schema1:text "Una vez hecha todas las rosquitas, colocarlas sobre una bandeja engrasada o cubierta con papel de horno. Hornear a temperatura de 350 F durante 20 minutos hasta que las rosquitas estén doradas."@es .

<http://example.org/recipes/postre/58/step/1c862f6f00bd4e7e8a998b74be83d756> a schema1:HowToStep ;
    schema1:text "Retirar del horno y dejar enfriar sobre una rejilla. Servir las rosquitas de mantequilla con Nutella o mermelada y acompañar con té o café."@es .

<http://example.org/recipes/postre/58/step/5697b32ab33740d7b4bab6dbca4562e3> a schema1:HowToStep ;
    schema1:text "Agregar la mezcla de la harina a la mezcla de la mantequilla y yemas. Amasar con las manos dentro del tazón e ir agregando poco a poco la leche, atendiendo la consistencia de la masa. Mover bien la masa hasta que quede suave y densa."@es .

<http://example.org/recipes/postre/58/step/dcf7fd848dd747d7a9a5520f1c72ca2e> a schema1:HowToStep ;
    schema1:text "En un tazón aparte, batir la mantequilla hasta que esté cremosa. Agregar las yemas y continuar batiendo a velocidad media hasta que los ingredientes estén incorporados."@es .

<http://example.org/recipes/postre/58/step/dda54a594cd247b1873efe187b34988a> a schema1:HowToStep ;
    schema1:text "Pre-calentar el horno a 350 F. Colocar en un tazón grande la harina, sal, polvo de hornear y azúcar. Mezclar bien y dejar reposar para después."@es .

<http://example.org/recipes/postre/58/step/fac6307f1d2846e9bf609f3c6c3f3dc5> a schema1:HowToStep ;
    schema1:text "Colocar la masa en la mesa de trabajo y espolvorear con harina. Dividir la masa en bolas pequeñas. Estirar la masa, formando tiras de 10 centímetros de largo. Entrenzar dos tiras, formar una rosquita (círculo) y pinchar ambos extremos para cerrar el círculo."@es .

<http://example.org/recipes/postre/59/step/0f8f04a3c8484e5fb59e2cba802e8896> a schema1:HowToStep ;
    schema1:text "Colocar en la mesada y estirar a mano, envolver en film y conservar en heladera como mínimo 12 horas."@es .

<http://example.org/recipes/postre/59/step/171be78cee6e48de901c8d6322f9fbd4> a schema1:HowToStep ;
    schema1:text "Verter la mezcla sobre la masa de tarta, y hornear a 160 C por 20 minutos."@es .

<http://example.org/recipes/postre/59/step/21d307c69fdc4505ab0e9b54fe71ea03> a schema1:HowToStep ;
    schema1:text "Pasados 10 minutos de horneado retirar los porotos y el papel aluminio, y terminar de cocinar hasta dorar levemente, retirar y dejar enfriar."@es .

<http://example.org/recipes/postre/59/step/2d2eb01f4f974e7db5a69c3f40a26119> a schema1:HowToStep ;
    schema1:text "Colocar en tartera desmontable y cubrir con papel aluminio colocando unos porotos por encima para que la masa no se eleve."@es .

<http://example.org/recipes/postre/59/step/4cdbc6201ed14b84bf76406e58a537cd> a schema1:HowToStep ;
    schema1:text "Servir la tarta acompañada de café negro ecuatoriano."@es .

<http://example.org/recipes/postre/59/step/4d1feba8a98541269a528c10a416f6fb> a schema1:HowToStep ;
    schema1:text "En una cacerola colocar la panela y el agua y cocinar hasta formar un almíbar. Añadir los maduros pisados y caramelizarlos por media hora."@es .

<http://example.org/recipes/postre/59/step/91c9322d9b954a41abb530bc9079e79f> a schema1:HowToStep ;
    schema1:text "Agregar a la mezcla la harina tamizada junto con la sal y mezclar hasta lograr una masa arenosa."@es .

<http://example.org/recipes/postre/59/step/965647c7fa7349928470885835dae2cb> a schema1:HowToStep ;
    schema1:text "Comenzar la preparación blanqueando la manteca con el azúcar, luego sumar dos huevos y batir hasta lograr una mezcla homogénea."@es .

<http://example.org/recipes/postre/59/step/b01e8d57fe164d9ca97182d411b6e1df> a schema1:HowToStep ;
    schema1:text "Retirar la mezcla del fuego y dejar entibiar, añadir el queso e integrar."@es .

<http://example.org/recipes/postre/59/step/c7266d68d9f3419c86738bfc37926c78> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a temperatura media y mientras tanto estirar la masa fría."@es .

<http://example.org/recipes/postre/6/step/74cfd029b6d34f4dba2308eb8262d789> a schema1:HowToStep ;
    schema1:text "Colocar en placa para horno previamente enmantecada."@es .

<http://example.org/recipes/postre/6/step/a5c76fc8592d4ed683a092628dc77f49> a schema1:HowToStep ;
    schema1:text "Rallar el o los quesos que haya escogido."@es .

<http://example.org/recipes/postre/6/step/b54c283077c641f1b26594b2b605aea7> a schema1:HowToStep ;
    schema1:text "Comenzar la preparación colocando sobre la mesada los ingredientes ya pesados."@es .

<http://example.org/recipes/postre/6/step/c07da8be96fc4cd08393762a2ae4fdd8> a schema1:HowToStep ;
    schema1:text "Hornear a 200 grados hasta notar que se abre la corteza."@es .

<http://example.org/recipes/postre/6/step/c1c7edbc7511401a9da89e5a932e4c8f> a schema1:HowToStep ;
    schema1:text "Retirar y servir tibios."@es .

<http://example.org/recipes/postre/6/step/ce24d5592ab24f70917e94ef2587ab7b> a schema1:HowToStep ;
    schema1:text "En la mesada mezclar todos los ingredientes secos formar una corona y agregar el huevo y el agua de manera gradual, amasando bien la masa hasta lograr una preparación suave."@es .

<http://example.org/recipes/postre/6/step/e710b7d8431d4e89b8678109425b34c5> a schema1:HowToStep ;
    schema1:text "Formar bollitos de aproximadamente 60 gramos."@es .

<http://example.org/recipes/postre/60/step/1d679cdebb2b4b8390b7f1c6d00d7987> a schema1:HowToStep ;
    schema1:text "Reservar en la refrigeradora mientras realizamos el resto de la receta."@es .

<http://example.org/recipes/postre/60/step/2b0b9470155d4cd8bbada70d9e34ed6f> a schema1:HowToStep ;
    schema1:text "Incorporar las claras batidas a punto de nieve y vertir en el molde."@es .

<http://example.org/recipes/postre/60/step/3f6c0e1f2b02491e883ca2e891237775> a schema1:HowToStep ;
    schema1:text "Pelar las mandarinas y desprender los gajos (ñejos)."@es .

<http://example.org/recipes/postre/60/step/587cce8305404c1fba5958a89504c50c> a schema1:HowToStep ;
    schema1:text "Mezclar las galletas con la mantequilla y el vino dulce, colocar esta preparación en la base de un molde de tarta."@es .

<http://example.org/recipes/postre/60/step/68b02c5a7e6e49b7b0a00b0fb8b4a991> a schema1:HowToStep ;
    schema1:text "Colocar en una cacerola con el azúcar y llevar al fuego hasta formar un jarabe. Retirar del fuego y dejar enfriar."@es .

<http://example.org/recipes/postre/60/step/8be20d6fc1544638a41ba93da0066f2f> a schema1:HowToStep ;
    schema1:text "Llevar al horno precalentado a temperatura media, y dejar cocer por aproximadamente 25 minutos."@es .

<http://example.org/recipes/postre/60/step/8d36206fb1f84a65a14d976f5652a362> a schema1:HowToStep ;
    schema1:text "Retirar con cuidado la membrana y la semilla."@es .

<http://example.org/recipes/postre/60/step/9979ca5d8e7140928984f367b0af1255> a schema1:HowToStep ;
    schema1:text "Retirar del horno, dejar enfriar y adornar con gajos de mandarina."@es .

<http://example.org/recipes/postre/60/step/c189abea17ef4addbb5969000cd3e1f9> a schema1:HowToStep ;
    schema1:text "Batir las yemas de huevo hasta que estén cremosas y mezclar con la leche condensada, la corteza y el jugo de la mandarina."@es .

<http://example.org/recipes/postre/60/step/ce06b343cf304d3aabddb3ebba9c195f> a schema1:HowToStep ;
    schema1:text "Triturar las galletas hasta convertirlas en polvo de galleta."@es .

<http://example.org/recipes/postre/61/step/4c3a39ef233442d6a462fc36b0ebd876> a schema1:HowToStep ;
    schema1:text "Batir en otro recipiente las claras de huevo hasta que estén a punto de nieve."@es .

<http://example.org/recipes/postre/61/step/5d3da58250734ee3b198400eae3c011b> a schema1:HowToStep ;
    schema1:text "Batir las yemas de huevo hasta que estén espumosas y agregar azúcar."@es .

<http://example.org/recipes/postre/61/step/860c4af55e934b23834276e468680ae6> a schema1:HowToStep ;
    schema1:text "Colocar otra capa de bizcochos remojadas en café. Repetir este proceso hasta terminar con una capa final del mascarpone."@es .

<http://example.org/recipes/postre/61/step/9668137cb8ae4064a6de21937635bfc1> a schema1:HowToStep ;
    schema1:text "Mezclar con una espátula en forma envolvente el queso mascarpone con las claras batidas hasta que formar una mezcla homogénea."@es .

<http://example.org/recipes/postre/61/step/a47b1000877b4856adffa54cb0782e91> a schema1:HowToStep ;
    schema1:text "Separar las claras de las yemas de huevo."@es .

<http://example.org/recipes/postre/61/step/b1bde25eaca44606903e7b99af7eb274> a schema1:HowToStep ;
    schema1:text "Sumergir los bizcochos en el café sin dejar que salgan demasiado húmedas, colocarlos en un molde hasta formar una capa completa."@es .

<http://example.org/recipes/postre/61/step/b1e15720379e4289b3e02be830684a2b> a schema1:HowToStep ;
    schema1:text "Agregar la preparación de las yemas de huevo y mezclar delicadamente."@es .

<http://example.org/recipes/postre/61/step/cd4958c9d4f345d09aa4f691d3a0d5d8> a schema1:HowToStep ;
    schema1:text "Espolvorear la parte superior del tiramisú con el cacao en polvo y decorar con la ralladura de chocolate."@es .

<http://example.org/recipes/postre/61/step/dc0b65e7f8b142a099f6df864f4da72d> a schema1:HowToStep ;
    schema1:text "Cubrir la primera capa de bizcochos con una capa de la crema de mascarpone."@es .

<http://example.org/recipes/postre/61/step/e818ad9855274c509aef205fa792c826> a schema1:HowToStep ;
    schema1:text "Refrigerar el tiramisú por lo menos dos horas."@es .

<http://example.org/recipes/postre/62/step/1108c179a5e74ee5b5ca78845db22a6c> a schema1:HowToStep ;
    schema1:text "Servir la torta de choclo opcionalmente bañada con crema o coco rallado y acompañada con una taza de café."@es .

<http://example.org/recipes/postre/62/step/293d2270de9842a381deac01a1e2f368> a schema1:HowToStep ;
    schema1:text "Colocar en una licuadora la leche condensada, los huevos, la esencia de vainilla, la mantequilla y el choclo poco a poco, licuar bien hasta que quede una mezcla esponjada."@es .

<http://example.org/recipes/postre/62/step/4e9a1556ae2d49b286834abd3419d0cf> a schema1:HowToStep ;
    schema1:text "Agregar la mezcla en un tazón, añadir el coco y el polvo para hornear, y mezclar bien."@es .

<http://example.org/recipes/postre/62/step/687ba14edc8b4852a282752d4a896e5a> a schema1:HowToStep ;
    schema1:text "Pre-calentar a 350 F (180 C). Engrasar y enharinar un molde para hornear la torta."@es .

<http://example.org/recipes/postre/62/step/838935c1727d4c798881dc51061eea9d> a schema1:HowToStep ;
    schema1:text "Vaciar la mezcla en el molde engrasado y enharinado y hornear durante 45 minutos hasta que esté dorado."@es .

<http://example.org/recipes/postre/63/step/0a85aa9202f5409c8aa98b002b36487c> a schema1:HowToStep ;
    schema1:text "Separar las yemas de las claras de los huevos, batir las claras a punto de nieve y reservar aparte."@es .

<http://example.org/recipes/postre/63/step/1031d710ef7441a0a9a8f4231a6b3ac1> a schema1:HowToStep ;
    schema1:text "Agregar el polvo de hornear y la harina poco a poco. Incorporar las claras batidas a punto de nieve, con movimientos envolventes con una espátula para mantener el aire de la claras."@es .

<http://example.org/recipes/postre/63/step/1d8b46f8a93b435f927bbdcb0e48eaaa> a schema1:HowToStep ;
    schema1:text "Pre-calentar a 350 F (180 C). Engrasar y enharinar un molde para hornear la torta."@es .

<http://example.org/recipes/postre/63/step/40996a880a7541cd8b125170c2056110> a schema1:HowToStep ;
    schema1:text "Colocar en un tazón el aceite, el azúcar y las yemas. Batir hasta que la mezcla esté homogénea. Agregar la ralladura y el jugo de naranja y mezclar bien."@es .

<http://example.org/recipes/postre/63/step/436b579122c14466bb614e7d9e93e99e> a schema1:HowToStep ;
    schema1:text "Verter la mezcla en el molde engrasado y enharinado y hornear durante 40 minutos. Servir la torta de naranja acompañada de té o café."@es .

<http://example.org/recipes/postre/64/step/23b4bff640be4bfead44efa3f0d6d281> a schema1:HowToStep ;
    schema1:text "Retirar y realizar un puré con el zapallo."@es .

<http://example.org/recipes/postre/64/step/3069b8c48db84ffe91186b40c6cd6181> a schema1:HowToStep ;
    schema1:text "Agregar la leche, los huevos batidos y mezclar."@es .

<http://example.org/recipes/postre/64/step/39dd548188404041935a414608981bd6> a schema1:HowToStep ;
    schema1:text "Agregar las pasas, el ron, la sal, el polvo de hornear y el queso y colocar en un molde engrasado con mantequilla y enharinado."@es .

<http://example.org/recipes/postre/64/step/85f53979bb3841149716f157426a2fce> a schema1:HowToStep ;
    schema1:text "Hornear moderado por una hora o hasta que esté dorado encima."@es .

<http://example.org/recipes/postre/64/step/9c9ca623ba994ddd85819a3b81a3a44d> a schema1:HowToStep ;
    schema1:text "Cocinar el zapallo en agua con la canela y el azúcar apróximadamente 20 minutos hasta que esté blando."@es .

<http://example.org/recipes/postre/65/step/36b4217471104e5a94346b12c382f391> a schema1:HowToStep ;
    schema1:text "Tomar una cucharada de masa y hacer un hueco, colocarle la mozzarella rallada."@es .

<http://example.org/recipes/postre/65/step/7598207bdded4003a03afdfa745d5606> a schema1:HowToStep ;
    schema1:text "Pisar los plátanos con tenedor y agregar a la cebolla, salar a gusto."@es .

<http://example.org/recipes/postre/65/step/a0a19e367d9249aca2f3534700cbf170> a schema1:HowToStep ;
    schema1:text "Cocinar los verdes cortados en mitades hasta que estén tiernos."@es .

<http://example.org/recipes/postre/65/step/c23fa22680e34792a1d02baa447997d9> a schema1:HowToStep ;
    schema1:text "Sofreír la cebolla picada junto con el achiote."@es .

<http://example.org/recipes/postre/65/step/cb5cfe66ac6c4758b03df3642f929ee9> a schema1:HowToStep ;
    schema1:text "Freír hasta dorar y servir tibias."@es .

<http://example.org/recipes/postre/65/step/d141b59991304e30aff423abf78ec027> a schema1:HowToStep ;
    schema1:text "Cerrar y aplastar formando tortillas."@es .

<http://example.org/recipes/postre/66/step/04ff442fba524910a7fad3c481cd227c> a schema1:HowToStep ;
    schema1:text "Luego agregamos la harina previamente cernida y mezclamos con movimientos envolventes."@es .

<http://example.org/recipes/postre/66/step/21aadfed2a874f8bb1d76a37deeb56f1> a schema1:HowToStep ;
    schema1:text "Luego decoramos con nuestra mezcla de chantilly y la ayuda de una manga pastelera."@es .

<http://example.org/recipes/postre/66/step/41eb741f040b4941a9797596074548b8> a schema1:HowToStep ;
    schema1:text "Una vez listo el biscocho lo dejamos enfriar y le colocamos el liquido de las tres leches puedes hacerle huequitos con un palillo para que se moje mas rápido."@es .

<http://example.org/recipes/postre/66/step/7378f4c54ca340cea30f171e9eb1fddc> a schema1:HowToStep ;
    schema1:text "Luego en la batidora agregamos crema chantilly royal y se añade una taza de leche fresca. Comenzamos a mezclar a velocidad baja y luego alta. Por 4 minutos. Se verifica que forme picos."@es .

<http://example.org/recipes/postre/66/step/b56145e6a78b470aa52d231b4ea684a1> a schema1:HowToStep ;
    schema1:text "Y dejamos en la nevera."@es .

<http://example.org/recipes/postre/66/step/d98bf440909e4b08bfe1d7baf3333eea> a schema1:HowToStep ;
    schema1:text "Colocamos en un molde previamente enharinado y enmantequilaldo hasta que este dorado."@es .

<http://example.org/recipes/postre/66/step/e6ef432eb50e44ef8c20f2b6606b9499> a schema1:HowToStep ;
    schema1:text "Mientras se cocina hacemos nuestra mezcla en un envase con las tres leches y revolvemos bien."@es .

<http://example.org/recipes/postre/66/step/ef2292f3b40842ffb786debf41e6d9b4> a schema1:HowToStep ;
    schema1:text "Comenzamos batiendo los huevos, el azúcar y vainilla por 8 minutos velocidad alta."@es .

<http://example.org/recipes/postre/67/step/12ca0f1fe9f34c77b81decad610bc909> a schema1:HowToStep ;
    schema1:text "Vertir la mezcla en las obleas, esparcir de forma homogénea y tapar con otra oblea . Dejar enfriar."@es .

<http://example.org/recipes/postre/67/step/15be3a15a87d48599681b942661a5913> a schema1:HowToStep ;
    schema1:text "Añadir el merengue y batir."@es .

<http://example.org/recipes/postre/67/step/2d7bce3e7b8b47b0a406e8ea4a6aa229> a schema1:HowToStep ;
    schema1:text "Hierva el agua con el azúcar hasta que el azúcar se haya disuelto y las burbujas sean uniformes."@es .

<http://example.org/recipes/postre/67/step/2fab74277d9f456885e371dd06a96a74> a schema1:HowToStep ;
    schema1:text "En un recipiente colocar las claras de huevo y batir a punto de nieve para formar un meregue."@es .

<http://example.org/recipes/postre/67/step/67378c27da004fcfb5214624c4460714> a schema1:HowToStep ;
    schema1:text "Colocar en una olla de fondo grueso la miel de abeja y dejar hervir a fuego medio."@es .

<http://example.org/recipes/postre/67/step/6d1fa770974a4cd08283a63130a6c325> a schema1:HowToStep ;
    schema1:text "Colocar este almíbar en forma de hilo en el merengue inicial. Debe hacerlo antes de que el recipiente se enfríe."@es .

<http://example.org/recipes/postre/67/step/ba355cd72511416a912c2b563c9ebd0d> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y añada las almendras o avellanas picadas."@es .

<http://example.org/recipes/postre/67/step/e54513e25aaa4c97a01b422e95729eff> a schema1:HowToStep ;
    schema1:text "Continuar batiendo y añadir poco a poco el azúcar impalpable hasta que la mezcla se despegue totalmente de la olla."@es .

<http://example.org/recipes/postre/68/step/1b0d0f841e0042b583f8d072cb5242f1> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y agregar las almendras tostadas y picadas."@es .

<http://example.org/recipes/postre/68/step/23018213f7eb420792e63193e2d7eb15> a schema1:HowToStep ;
    schema1:text "Agregar en forma de hilo el almíbar a las claras formando un merengue."@es .

<http://example.org/recipes/postre/68/step/778d285bc63b42598fce33de7952758c> a schema1:HowToStep ;
    schema1:text "En una cacerola colocar la miel y dejar hervir a fuego bajo."@es .

<http://example.org/recipes/postre/68/step/8d37a00eebf8438f987f40b1bf9e14dd> a schema1:HowToStep ;
    schema1:text "Añadir el merengue a la cacerola sin dejar de mezclar."@es .

<http://example.org/recipes/postre/68/step/9caf36838b1d4448adefecb8e3857da0> a schema1:HowToStep ;
    schema1:text "Comenzar batiendo las claras a punto nieve, mientras tanto hervir el agua con el azúcar para formar un almíbar y esperar a que las burbujas sean pequeñas y uniformes."@es .

<http://example.org/recipes/postre/68/step/c7518bcdf93a471487f6c1521b09e18d> a schema1:HowToStep ;
    schema1:text "Continuar batiendo y poco a poco agregar en forma de lluvia el azúcar impalpable hasta que la mezcla se despegue de la cacerola."@es .

<http://example.org/recipes/postre/68/step/cd2cd39f9bb34f2e88a2a1d6859e5efa> a schema1:HowToStep ;
    schema1:text "Esparcir la mezcla aún caliente sobre las obleas cubriendo de manera pareja y tapar con obleas."@es .

<http://example.org/recipes/postre/68/step/f3c8366c890a4a2db4e0ea59a8bc9c9c> a schema1:HowToStep ;
    schema1:text "Dejar enfriar, cortar y servir."@es .

<http://example.org/recipes/postre/69/step/0a19c07cf1aa4f478acae074cc425b42> a schema1:HowToStep ;
    schema1:text "Incorpore uno a uno los huevos."@es .

<http://example.org/recipes/postre/69/step/0d2102b6a3344940876216a4bce28a54> a schema1:HowToStep ;
    schema1:text "Vierta la mezcla en la fuente preparada con las rebanadas de piña."@es .

<http://example.org/recipes/postre/69/step/17ca11670cd44978b411fbba42de81f2> a schema1:HowToStep ;
    schema1:text "Con la batidora a velocidad mínima, añada de manera alternada, la harina y el yogurt."@es .

<http://example.org/recipes/postre/69/step/1d1e1563aef24ec6a157b7768ba09500> a schema1:HowToStep ;
    schema1:text "Retire del horno y deje enfriar."@es .

<http://example.org/recipes/postre/69/step/3f546423b71a48fab34fb129b23ea484> a schema1:HowToStep ;
    schema1:text "Agregue el ron."@es .

<http://example.org/recipes/postre/69/step/a5ff51cccb844390a41d72963bad48b4> a schema1:HowToStep ;
    schema1:text "Precalentar el horno a 200°C."@es .

<http://example.org/recipes/postre/69/step/b8434ac66eb84e61bdc5a3246d339cb6> a schema1:HowToStep ;
    schema1:text "Hornear por unos 40 minutos hasta que el pastel dore."@es .

<http://example.org/recipes/postre/69/step/cbe85ed9cdf64fcf8e98f9a4d69f0a66> a schema1:HowToStep ;
    schema1:text "En una cacerola derrita 2 cucharadas de mantequilla y luego agregue ½ taza de azúcar. Deje que se vuelva caramelo. Coloque las rebanadas de piña. Retire del fuego y reserve."@es .

<http://example.org/recipes/postre/69/step/db98f8ac246c4114bf3688cb81d9471b> a schema1:HowToStep ;
    schema1:text "Desmolde cuidadosamente y disfrute."@es .

<http://example.org/recipes/postre/69/step/ea28c6d3ce83408ab23e4be08473fd88> a schema1:HowToStep ;
    schema1:text "En un bol, con la batidora eléctrica, mezcle la mantequilla con ¾ tazas de azúcar hasta obtener una consistencia cremosa."@es .

<http://example.org/recipes/postre/7/step/0248e452bde84276a869ee53bab3eb6b> a schema1:HowToStep ;
    schema1:text "Verter la preparación en un molde previamente engrasado con mantequilla (debe quedar máximo hasta la mitad)."@es .

<http://example.org/recipes/postre/7/step/328276e730b24523bdfab0d27e6857ce> a schema1:HowToStep ;
    schema1:text "Agregar la mantequilla derretida y volver a batir con fuerza."@es .

<http://example.org/recipes/postre/7/step/3abd8bfe299f47baac21758c85cf0cb4> a schema1:HowToStep ;
    schema1:text "Colocar en un tazón el pan y la leche, remojar un rato luego desmenuzar el pan hasta deshacerlo."@es .

<http://example.org/recipes/postre/7/step/3b9c9d007678429fada430cdfacfbcd2> a schema1:HowToStep ;
    schema1:text "Dejar enfriar antes de servir."@es .

<http://example.org/recipes/postre/7/step/4be32a939a924fcd8aca23fb6e84f901> a schema1:HowToStep ;
    schema1:text "Añadir los huevos, la vainilla, el licor y las pasas."@es .

<http://example.org/recipes/postre/7/step/ad7ad1774ffc40379b825ac707def928> a schema1:HowToStep ;
    schema1:text "Agregar azúcar y dejar reposar hasta que se disuelva."@es .

<http://example.org/recipes/postre/7/step/d0a695a527544ddf969774cc3be1b84b> a schema1:HowToStep ;
    schema1:text "Hornear el budín en un horno precalentado a 180 ºC durante una hora, o hasta que se dore."@es .

<http://example.org/recipes/postre/7/step/ea7b6f790c16407f95cf3d3283ef2192> a schema1:HowToStep ;
    schema1:text "Batir con una cuchara de madera hasta que todo se incorpore bien."@es .

<http://example.org/recipes/postre/8/step/10f64b136215485e96ba796f3bf5f3fa> a schema1:HowToStep ;
    schema1:text "Colocar en una cacerola la mandioca cocida, la manteca, los huevos, el queso y la sal y mezclar hasta que la preparación quede homogénea."@es .

<http://example.org/recipes/postre/8/step/38b754e16fcd4c95897bbd3ce0c064ff> a schema1:HowToStep ;
    schema1:text "Servir los buñuelos con la miel."@es .

<http://example.org/recipes/postre/8/step/7960996169534ea09f994838c153bf69> a schema1:HowToStep ;
    schema1:text "En una olla colocar la panela rallada, el agua y la naranja y cocinar a fuego lento hasta que se disuelva totalmente."@es .

<http://example.org/recipes/postre/8/step/83388e9c22eb41aa8fcc1236bb578bfe> a schema1:HowToStep ;
    schema1:text "En una cacerola calentar el fuego alto, freír los buñuelos y retirarlos cuando se encuentren dorados de ambos lados colocándolos sobre un papel de cocina."@es .

<http://example.org/recipes/postre/8/step/d6d1c03879c34e69b502fba55a38f39a> a schema1:HowToStep ;
    schema1:text "Formar pequeños bollos de igual tamaño."@es .

<http://example.org/recipes/postre/9/step/2434dec6bce5490ab2968ed553014559> a schema1:HowToStep ;
    schema1:text "Cernir la mezcla realizada."@es .

<http://example.org/recipes/postre/9/step/71f1879682704aa0a673d3de69c00f15> a schema1:HowToStep ;
    schema1:text "Pelar la yuca y ponerla a cocinar una vez que se hayan quitado las venas."@es .

<http://example.org/recipes/postre/9/step/83b93c46d59b412abc2fbc86522b0be5> a schema1:HowToStep ;
    schema1:text "Ubicar en un recipiente la yuca cocida, el polvo para hornear, la mantequilla, los huevos, la taza de queso y la pizca de sal, mezclar hasta obtener una masa homogénea."@es .

<http://example.org/recipes/postre/9/step/9377b61329674ad1a56bb3514e63931b> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una olla para freir a fuego medio alto, luego lanzar las bolitas de manera cuidadosa, cuando estén doradas totalmente retirarlos y ubicarlos en un papel de cocina para retirar el exceso de aceite."@es .

<http://example.org/recipes/postre/9/step/b2cea0d7fc274b428bb5fc4c5b6e311e> a schema1:HowToStep ;
    schema1:text "Preparar la miel, ubicando en una olla pequeña la panela rayada, la taza de agua y el jugo de naranjilla, cocinar a fuego lento hasta que se disuelva totalmente la panela y quedando de manera dorada y las gotas cayendo lentamente."@es .

<http://example.org/recipes/postre/9/step/b8a507fa49df4cc9872c53f93595a8c7> a schema1:HowToStep ;
    schema1:text "Realizar bolitas formando así los buñuelos, deben quedar del mismo tamaño."@es .

<http://example.org/recipes/postre/9/step/fef494f278cf4251a918bc3fc2a4c9f9> a schema1:HowToStep ;
    schema1:text "Servir los buñuelos con la miel preparada."@es .

<http://example.org/recipes/sopa/1/step/287aee8d4d6549ea80458624b9038dd2> a schema1:HowToStep ;
    schema1:text "Calentar el aceite o mantequilla en una olla grande y agregar la cebolla, el ajo, el pimiento, el perejil, el orégano, el comino, el achiote, la sal y pimienta. Cocinar durante 10 minutos, revolviendo frecuentemente."@es .

<http://example.org/recipes/sopa/1/step/3f42508a663f4891b6c2bacb2efda8f4> a schema1:HowToStep ;
    schema1:text "Agregar las zanahorias y cocinar durante 10 minutos hasta que estén tiernas."@es .

<http://example.org/recipes/sopa/1/step/4538d01a0bca453797bfab831f7ad0a3> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y agregar el cilantro. Servir el aguado acompañado de aguacate y ají."@es .

<http://example.org/recipes/sopa/1/step/bbb4a978a8a24d83bf406ca105ddc8b0> a schema1:HowToStep ;
    schema1:text "Añadir el agua y esperar hasta que hierva. Agregar las presas de gallina y cocinar a fuego medio durante 30 minutos."@es .

<http://example.org/recipes/sopa/1/step/d237a868fdd042bebabe5a69060d124c> a schema1:HowToStep ;
    schema1:text "Remojar el arroz en agua durante 30 minutos."@es .

<http://example.org/recipes/sopa/1/step/f9b90f2257af412da6decd84b18f3f1c> a schema1:HowToStep ;
    schema1:text "Agregar el arroz remojado y las papas. Cocinar durante 45 minutos a fuego bajo, revolviendo de vez de en cuando."@es .

<http://example.org/recipes/sopa/10/step/0cf807643c4340b999202ef9b00d0e84> a schema1:HowToStep ;
    schema1:text "Para servir, colocar una o dos bolas de verde en cada plato, añadir un poco de caldo y verduras. Acompañar con rodajas de limón, ají criollo y cebollas encurtidas."@es .

<http://example.org/recipes/sopa/10/step/512045ed38da4183a718688b8e85bfac> a schema1:HowToStep ;
    schema1:text "Cortar la carne, la zanahoria, la yuca y la col en trozos pequeños y cortar los choclos en rodajas pequeñas. Guardar estos ingredientes cortados para más adelante."@es .

<http://example.org/recipes/sopa/10/step/6accc2fcdf9e487d94b2e580ff74e74a> a schema1:HowToStep ;
    schema1:text "Agregar las 10 tazas de agua, los huesos de res, los trozos de carne, y los 4 plátanos cortados por la mitad."@es .

<http://example.org/recipes/sopa/10/step/9d39d14c023f4a588f6de71a3053247b> a schema1:HowToStep ;
    schema1:text "Añadir la mezcla de maní y 4 cucharadas del caldo de carne. Mezclar bien y guardar el relleno hasta que se necesite."@es .

<http://example.org/recipes/sopa/10/step/b4c14d23159345a9941bbfdeda5130d2> a schema1:HowToStep ;
    schema1:text "Colar el caldo de carne y esperar hasta que hierva, reducir a fuego lento y agregar las bolas de verde rellenas. Cocinar a fuego lento durante unos 15 minutos."@es .

<http://example.org/recipes/sopa/10/step/bd55c920c13c45808cbb4cbc827cb1f8> a schema1:HowToStep ;
    schema1:text "Para preparar la masa de las bolas de verde, sacar los plátanos cocidos del caldo de carne y triturarlos hasta obtener una masa uniforme. Agregar los plátanos crudos rallados, los huevos y un poco de sal y pimienta a la masa."@es .

<http://example.org/recipes/sopa/10/step/ca6e1851a45f4bab9a9dc57b02e07664> a schema1:HowToStep ;
    schema1:text "Retirar las bolas de verde cocidas del caldo y colocarlas en un plato aparte. Añadir los pedazos de yuca, de col, las rodajas de choclo y cocinar hasta que todos los ingredientes estén calientes. Agregar el cilantro al caldo."@es .

<http://example.org/recipes/sopa/10/step/e70cb7ecd8e04acf82c8c2e7ff3b34dd> a schema1:HowToStep ;
    schema1:text "Para preparar el relleno de carne para las bolas de verde, calentar en una sartén las otras 2 cucharadas de aceite a fuego medio y agregar la ½ cebolla colorada, el tomate restante, los dos dientes de ajo, el pimiento verde, la cucharadita de comino y de achiote restante y un poco de sal. Añadir la carne, las zanahorias, las arvejas y el cilantro."@es .

<http://example.org/recipes/sopa/10/step/e751d73d718b4055b75c83c07e561233> a schema1:HowToStep ;
    schema1:text "Retirar el caldo del fuego y dejar enfriar. Luego retirar los huesos del caldo y desecharlos. Retirar los trozos de carne, las zanahorias, los choclos y yucas del caldo. Dejar reposar los plátanos en el caldo hasta que se vayan a usar para evitar que se sequen y poder aplastarlos para hacer la masa de las bolas."@es .

<http://example.org/recipes/sopa/10/step/f02d543ae1194819872647cddc9686bb> a schema1:HowToStep ;
    schema1:text "Formar bolas de tamaño mediano o grande con la masa de plátano. Hacer un hueco en la mitad de cada bola y llenarlas con el relleno de carne. Para evitar que se sellen mejor, dejar reposar unos 30 minutos en la refrigeradora."@es .

<http://example.org/recipes/sopa/10/step/f112f19af9ec4beba242f8dbd4996f9d> a schema1:HowToStep ;
    schema1:text "Esperar hasta que hierva, reducir la temperatura y cocinar a fuego lento durante 30 minutos. Añadir los trozos de yuca y cocinar durante unos 30 minutos hasta que la carne esté tierna. Agregar la zanahoria, el choclo, la col y cocinar por otros 15 minutos hasta que todos los ingredientes estén completamente cocidos."@es .

<http://example.org/recipes/sopa/10/step/f4bf20b6284344a9893a2001bdbd0ccb> a schema1:HowToStep ;
    schema1:text "Calentar en una olla 2 cucharadas de aceite a fuego medio y añadir la cebolla blanca, 6 dientes de ajo, 3 tomates cortados, el pimiento verde, 2 cucharaditas de comino, 1 cucharadita de achiote, 2 cucharadas de cilantro, el orégano, una pizca de sal y pimienta."@es .

<http://example.org/recipes/sopa/11/step/1908c60a89a746e0ac88a034a633957b> a schema1:HowToStep ;
    schema1:text "Sofreir la cebolla y el ajo, agregar el tomate pelado y picado. Vertir esta preparación en el agua en que se cocinó la costilla y agregar la zanahoria, las papas y la vainita."@es .

<http://example.org/recipes/sopa/11/step/2e95d2454ce6455a8ba4287ad6222176> a schema1:HowToStep ;
    schema1:text "Pelar las papas y cortarlas en cuadritos. Ponerlas a cocinar."@es .

<http://example.org/recipes/sopa/11/step/32077dbde9df4a86b6eb08092cc80be4> a schema1:HowToStep ;
    schema1:text "Cocinar la costilla en una olla grande hasta que este suave (reservar)."@es .

<http://example.org/recipes/sopa/11/step/4bb5cf0480a54b57be3d1e1b62389435> a schema1:HowToStep ;
    schema1:text "Condimentar con sal, pimienta, orégano."@es .

<http://example.org/recipes/sopa/11/step/d4e6c0af8e4c4e10a6262bfb31596450> a schema1:HowToStep ;
    schema1:text "Cocinar por 10 minutos y agregar la coliflor y el brócoli."@es .

<http://example.org/recipes/sopa/11/step/d5ebdac16437442c9d69963e18730ea4> a schema1:HowToStep ;
    schema1:text "Añadir la carne y cocinar 20 minutos o hasta que este bien cocido."@es .

<http://example.org/recipes/sopa/12/step/4a6509c567d247afb6120602ba5382c1> a schema1:HowToStep ;
    schema1:text "Retirar la olla del fuego y agregar la cebolla blanca y el culantro picados finamente."@es .

<http://example.org/recipes/sopa/12/step/734abbf898ef4046a219a518f80bc410> a schema1:HowToStep ;
    schema1:text "Retirar la cebolla y pimiento cuando estén cocidos, cocinar a fuego lento, con la olla tapada hasta que la carne de la gallina esté blanda."@es .

<http://example.org/recipes/sopa/12/step/8b529f4b952d4ca6853ca782c20d0989> a schema1:HowToStep ;
    schema1:text "Agregar sal, cebolla, pimiento, ajo y los aliños."@es .

<http://example.org/recipes/sopa/12/step/cc027d68ad25425ba505e96c67705497> a schema1:HowToStep ;
    schema1:text "Ubicar las presas de la gallina en una olla profunda con el agua ir retirando la espuma que se vaya formando."@es .

<http://example.org/recipes/sopa/12/step/d57f2f20271f4a8ba3f6539c62a1f3ff> a schema1:HowToStep ;
    schema1:text "Agregar agua caliente si el caldo se evapora y probar que este bien de sal."@es .

<http://example.org/recipes/sopa/12/step/dde73b3fb506483b8c966998c8cc3216> a schema1:HowToStep ;
    schema1:text "Agregar la yuca cuando la carne de la gallina esté completamente suave."@es .

<http://example.org/recipes/sopa/13/step/05d0231a6a7f4217a56d06e093a5655e> a schema1:HowToStep ;
    schema1:text "Déjar enfriar el arroz y mezclarlo con la 1/2 col cocinada y con la sangre de chancho."@es .

<http://example.org/recipes/sopa/13/step/14f4bd16c58b4f4d8d9e19ecb190e04a> a schema1:HowToStep ;
    schema1:text "Cocinar por una hora o hasta que las tripas ya no sangren."@es .

<http://example.org/recipes/sopa/13/step/2586e957e4ac42af8879487169d96bf4> a schema1:HowToStep ;
    schema1:text "Preparar un refrito, calentar el achiote y freir la cebolla, el pimiento y dos ajos machacados, el orégano, culantro y hierbabuena."@es .

<http://example.org/recipes/sopa/13/step/286ad5d44641442a9fe508749a9fab7d> a schema1:HowToStep ;
    schema1:text "Servir el caldo(preferiblemente caliente) en un plato."@es .

<http://example.org/recipes/sopa/13/step/3350102a080f4f688ed6e575d0e4d55f> a schema1:HowToStep ;
    schema1:text "Condimentar con sal, pimienta, ajinomoto, comino y 3 pepas de ajo."@es .

<http://example.org/recipes/sopa/13/step/373699ecbd5542f884167b7cdc1d8db0> a schema1:HowToStep ;
    schema1:text "Condimentar con sal, pimienta y comino. Una vez que este cocinado júntelo con el arroz."@es .

<http://example.org/recipes/sopa/13/step/a166dae3062b4c9e9ffc2de4ab3c4a7f> a schema1:HowToStep ;
    schema1:text "Cortar las salchichas en pequeñas porciones y servir como acompañante del caldo."@es .

<http://example.org/recipes/sopa/13/step/a18c6f7868e04077a815c225e91dfda8> a schema1:HowToStep ;
    schema1:text "Rallar 2 verdes y mezclarlo con un poco de refrito, achiote, culantro y rellene algunas tripas con esto."@es .

<http://example.org/recipes/sopa/13/step/ae59f95a5bf9416b864d3a367b2676ee> a schema1:HowToStep ;
    schema1:text "Cocinar hasta que las vísceras estén cocinadas (1 hora aprox.). Luego colocar las tripas rellenas con cuidado para que no se rompan."@es .

<http://example.org/recipes/sopa/13/step/d72f88347a014953b063729a222c7b8c> a schema1:HowToStep ;
    schema1:text "En un recipiente aparte colocar 4 o 5 litros de agua, colocar las menudencias del cerdo, los verdes cortados en rodajas y la 1/2 col cruda, si sobró condumio después de rellenar las tripas échelo también."@es .

<http://example.org/recipes/sopa/13/step/db2d92c4d2f94259aa98aa12d6df0191> a schema1:HowToStep ;
    schema1:text "Lavar las tripas de chancho con bastante agua y sal, frotarlas con cascaras de verde y dejarlo remojando en limón, hierbabuena y agua por 20 minutos, repita esto las veces necesarias hasta sacar el mal olor de las tripas."@es .

<http://example.org/recipes/sopa/13/step/db8b53aac3674a20975762ba6b5037e0> a schema1:HowToStep ;
    schema1:text "Sacar las salchichas en una bandeja y dejar enfriar."@es .

<http://example.org/recipes/sopa/13/step/e955a44bbeb54a8c952f2a828c588679> a schema1:HowToStep ;
    schema1:text "Cocinar el arroz para que quede sopudo (esponjoso) pero un poco crudo."@es .

<http://example.org/recipes/sopa/14/step/0cffc53e41664dd9b917dc4235a741e1> a schema1:HowToStep ;
    schema1:text "Cocinar el mondongo en agua con hierbabuena y sal, hasta que ablande."@es .

<http://example.org/recipes/sopa/14/step/0d15649753a34e5b975aa08cbc121653> a schema1:HowToStep ;
    schema1:text "Servir y espolvoree un poco de cilantro, cebolla en ramas o ají rocoto picaditos."@es .

<http://example.org/recipes/sopa/14/step/103aeefae9a249ab8dd2318fc031aee0> a schema1:HowToStep ;
    schema1:text "Lavar bien el mondongo y frotarlo con limón. Cortarlos en pedazos."@es .

<http://example.org/recipes/sopa/14/step/52bef57bfd73447aae608811195d4b30> a schema1:HowToStep ;
    schema1:text "Añada el culantro y sazone con sal y pimienta. Cocine por unos 10 minutos aproximadamente."@es .

<http://example.org/recipes/sopa/14/step/f0374292910142dfb710ea8a52987d4b> a schema1:HowToStep ;
    schema1:text "En una cacerola coloque aceite y sofría cebolla y ajo picaditos. Añada el caldo con el mondongo cocido."@es .

<http://example.org/recipes/sopa/15/step/0858c29571a34d37add68b09ebfaa221> a schema1:HowToStep ;
    schema1:text "Colocar las patas de res en una olla grande y añadir los dientes de ajo enteros, la cebolla colorada, las ramitas de cilantro y perejil, una pizca de comino, sal, pimienta y el agua."@es .

<http://example.org/recipes/sopa/15/step/20c7e326593349049dc04a8a2ead684a> a schema1:HowToStep ;
    schema1:text "Añadir al caldo, los trocitos de carne de las patas de res, la yuca y el mote cocido. Cocinar a fuego lento durante unos 25 minutos."@es .

<http://example.org/recipes/sopa/15/step/42dfef05aac94db69b02a7c7ca2227b0> a schema1:HowToStep ;
    schema1:text "Esperar hasta que hierva, reducir el fuego y cocinar a fuego lento durante 3 horas."@es .

<http://example.org/recipes/sopa/15/step/6f0fe3394f2a4908b5534850647beaab> a schema1:HowToStep ;
    schema1:text "Cortar la yuca en trozos medianos. Retirar los huesos de las patas y cortar la carne en trozos pequeños."@es .

<http://example.org/recipes/sopa/15/step/720259ef1d8d4826a5dbf944c2147f42> a schema1:HowToStep ;
    schema1:text "Calentar en una olla el aceite a fuego medio, agregar la cebolla blanca, el ajo machacado, el orégano, el achiote, comino, sal y pimienta."@es .

<http://example.org/recipes/sopa/15/step/782c03e634624be6b8bb0b2e2083dcab> a schema1:HowToStep ;
    schema1:text "Agregar la yuca y cocine durante unos 30 minutos hasta que la yuca y los patas de res estén suaves. Retirar del fuego, colar el caldo y guardarlo para después."@es .

<http://example.org/recipes/sopa/15/step/d7b6e261abcb4879adfe3aaa7520c6c3> a schema1:HowToStep ;
    schema1:text "Servir el caldo de pata espolvoreando el cilantro y cebolleta cortados, acompañado con arroz blanco, aguacate y ají."@es .

<http://example.org/recipes/sopa/15/step/e951d9bb38ab43db8846f00037905756> a schema1:HowToStep ;
    schema1:text "Mezclar aparte la mantequilla de maní con la leche y agregarla a la olla, revolver hasta que esté disuelta."@es .

<http://example.org/recipes/sopa/16/step/3293a53ddafb440da3b3d4a7b1358f0a> a schema1:HowToStep ;
    schema1:text "Cocinar aparte el mote y las papas."@es .

<http://example.org/recipes/sopa/16/step/3d2aa9651dcb45038ea6fbc2e8d421bf> a schema1:HowToStep ;
    schema1:text "Servir bien caliente, con el mote y las papas y un poco de cilantro espolvoreado."@es .

<http://example.org/recipes/sopa/16/step/4ce35053281844818dc96edacff09771> a schema1:HowToStep ;
    schema1:text "Batir en la licuadora, la leche con el maní. Reservar."@es .

<http://example.org/recipes/sopa/16/step/705a6f5a77ea4e2ea688c2eaea8626f7> a schema1:HowToStep ;
    schema1:text "En una sartén, colocar un poco de aceite y sofreír, una cebolla y el ajo picaditos. Añadir un punto de sal y la preparación de maní. Dejar hervir unos 5 minutos."@es .

<http://example.org/recipes/sopa/16/step/8806c657e7bf4fdf9ab12ae4c7b82e8c> a schema1:HowToStep ;
    schema1:text "En el caldo con las patas, agregar el sofrito. Rectificar el sabor."@es .

<http://example.org/recipes/sopa/16/step/9b74f6919d5d453183711d11e51c7e0e> a schema1:HowToStep ;
    schema1:text "Llevar las patas al fuego en una olla de presión, añadir una cebolla troceada. Dejar cocinar hasta que ablanden las patas."@es .

<http://example.org/recipes/sopa/16/step/a16e966f010c49af849d80a5f25a4a86> a schema1:HowToStep ;
    schema1:text "Una vez blandas, se sacan y se parten en pedazos. Incorporarlas nuevamente al caldo junto con las ramas de cebolla y el culantro picadito."@es .

<http://example.org/recipes/sopa/17/step/3761c92e714f42b39bd5573ba5c6d787> a schema1:HowToStep ;
    schema1:text "Servir en un plato hondo, el caldo con la yuca y una porción del pescado. Colocar encima curtido de cebolla y tomate."@es .

<http://example.org/recipes/sopa/17/step/61771ff19154491b9d166778dc82ba7e> a schema1:HowToStep ;
    schema1:text "Cocinar el pescado en una cacerola con tres tazas de agua, ají, culantro, sal, pimienta y comino."@es .

<http://example.org/recipes/sopa/17/step/73eefbadff3241f5b37bceb260c438f1> a schema1:HowToStep ;
    schema1:text "Cuando el pescado esté listo se debe retirar y colar el caldo."@es .

<http://example.org/recipes/sopa/17/step/7b0bd876fa6a40a79a221f2ff8d43eb5> a schema1:HowToStep ;
    schema1:text "Al ablandar la yuca se añade el pescado y se rectifica el sabor. Cocinar por unos minutos."@es .

<http://example.org/recipes/sopa/17/step/a515749744b047dd99049c10edc1cf2f> a schema1:HowToStep ;
    schema1:text "Limpiar el pescado y cortarlo en trozos."@es .

<http://example.org/recipes/sopa/17/step/c21e1780c6c4463080764d18dafeadfb> a schema1:HowToStep ;
    schema1:text "Se cocina la yuca pelada y en trozos con el caldo de pescado."@es .

<http://example.org/recipes/sopa/17/step/fe2eb9b549444e4297eb5e0a809b1ab3> a schema1:HowToStep ;
    schema1:text "Puede agregar un poco de ají, limón y un toque de aceite."@es .

<http://example.org/recipes/sopa/18/step/2dd473fafa424faabe6aced99f25d406> a schema1:HowToStep ;
    schema1:text "En un bold colocamos el aceite y agregamos las costillas condimentadas con sal y pimenta para sellarlo. Cuando estén cogiendo color se procede a retirarlas."@es .

<http://example.org/recipes/sopa/18/step/40c179d22d094c8790b3df1d2a4a7e13> a schema1:HowToStep ;
    schema1:text "EN un bandeja agregamos el pan en trocitos, la leche, la carne y el sofrito que acabamos de hcer para ir haciendo una masa, luego agregamos 1 huevo, sal , cilantro."@es .

<http://example.org/recipes/sopa/18/step/495b6e3f1b0a48369cdb7e81525ed827> a schema1:HowToStep ;
    schema1:text "En la misma olla donde retiramos la carne agregamos mas aceite y achiote, con cebolla, pimiento verde, pasta de ajo, comino y cilantro. Esperemos que se sofría bien."@es .

<http://example.org/recipes/sopa/18/step/731199a9cbff43ce974ab656983f56c8> a schema1:HowToStep ;
    schema1:text "Luego que la carne este blanda la saca mos de la olla y la cortamos en trocitos pequeños"@es .

<http://example.org/recipes/sopa/18/step/c67a25feac5f44689d37e169808698f4> a schema1:HowToStep ;
    schema1:text "Procedemos a cortar las costillas en trozos, luego se pelan las papas y se pican. Seguido se condimentan las costillas con sal pimienta."@es .

<http://example.org/recipes/sopa/18/step/d939230be08c4f42af612805ffb95b68> a schema1:HowToStep ;
    schema1:text "Luego agregamos la col picada cuando se deshidraten lso vegetales se introduce nuevamente la costilla. La zanahoria, el choclo y suficiente agua para que lo cubra todo. Y dejamos cocinar entre 30 y 40 minutos."@es .

<http://example.org/recipes/sopa/18/step/e5580025531f4432bc29cc9d7635955f> a schema1:HowToStep ;
    schema1:text "Luego agregamos las torrejas al caldo y le colocamos cilantro picadito."@es .

<http://example.org/recipes/sopa/18/step/e9c18fb9d2f64788a6a3aa2070ec2510> a schema1:HowToStep ;
    schema1:text "Luego hacemos las torrejas y las freimos por ambos lados. Una vez que estén listas las retiramos y las colocamos en un recipiente."@es .

<http://example.org/recipes/sopa/18/step/efb5e13e37d24b7eb8db073cdd7103cc> a schema1:HowToStep ;
    schema1:text "En un sarten aparte agregamos achiote, cebolla colorada, pimiento verde y rojo. Condimentamos co n sal y pomienta. Dejamos que se sofría."@es .

<http://example.org/recipes/sopa/19/step/141b07e7c1234da7911e5f3260b323e1> a schema1:HowToStep ;
    schema1:text "Agregar entonces la mantequilla y el cilantro."@es .

<http://example.org/recipes/sopa/19/step/448dd3c31e85414ead4c7028d17c8ea8> a schema1:HowToStep ;
    schema1:text "Cocinar en una olla la carne con la cebolla, el perejil, el tomate, el ajo y los aliños, hasta que esté suave."@es .

<http://example.org/recipes/sopa/19/step/569bb2de61ea4635aec814c93f87bdc9> a schema1:HowToStep ;
    schema1:text "Cocinar, revolviendo hasta que las papas estén suaves."@es .

<http://example.org/recipes/sopa/19/step/9374eacf179942a2bc598d49b743a80c> a schema1:HowToStep ;
    schema1:text "Licuar el choclo con la leche, ciérnalo y agréguelo al caldo."@es .

<http://example.org/recipes/sopa/19/step/bcc7d54b60474cf7a75a17da50c300e9> a schema1:HowToStep ;
    schema1:text "Cernir el caldo, picar la carne y lleve al fuego el caldo, la carne y las papas. Cocinar durante 20 minutos."@es .

<http://example.org/recipes/sopa/19/step/d30239dd783341baa9760dd614cc4bc9> a schema1:HowToStep ;
    schema1:text "Servir caliente, puede acomparñarlo de papas fritas."@es .

<http://example.org/recipes/sopa/2/step/4ecd2e829e26413a96b2d776976b6f8e> a schema1:HowToStep ;
    schema1:text "Se pone a remojar el arroz previamente lavado."@es .

<http://example.org/recipes/sopa/2/step/7243129c424a411ebfb67dafa31511a6> a schema1:HowToStep ;
    schema1:text "Luego agregamos el arroz, alverjitas, una zanahoria picadas. Revolvemos y dejamos que hierva unos 35 minutos. Le colocamos sal, cilantro picado, cebolla blanca de rama finamente picada y listo para servir y disfrutar."@es .

<http://example.org/recipes/sopa/2/step/79f0ee811c694bd2adcb211ff7666174> a schema1:HowToStep ;
    schema1:text "En una ollita ondita se agrega el aceite de achiote, la cebolla picadita, el tomate, los ajos, los pimientos. Sofrimos todo por dos minutos, luego se agrega una cucharadita de ajo picadito."@es .

<http://example.org/recipes/sopa/2/step/bf427778903c4360b930046aaad5ef82> a schema1:HowToStep ;
    schema1:text "Una vez que este todo sofrito agregamos un sobresito de sazón Goya, el cilantro y achote."@es .

<http://example.org/recipes/sopa/2/step/fe43b020701d41d69720a38cd2a7790f> a schema1:HowToStep ;
    schema1:text "En 4 litros de agua se colocan 2 pechugas picadas en trozos. Luego colocamos la sal y comino. Tapamos por 30 minutos."@es .

<http://example.org/recipes/sopa/20/step/00d34019f8af47b488cc150f8b38343c> a schema1:HowToStep ;
    schema1:text "Retirar la espuma y la grasa que se vaya formando, quitar el ajo, la cebolla y las hierbas."@es .

<http://example.org/recipes/sopa/20/step/1aa335efda3a4b968f4e771bb72a3e45> a schema1:HowToStep ;
    schema1:text "Añadir el agua, dejar hervir hasta que la carne esté blanda."@es .

<http://example.org/recipes/sopa/20/step/1fab145fc65d464e912d6b65a0585420> a schema1:HowToStep ;
    schema1:text "Añadir las papas y dejar que se cocine por 10 minutos más."@es .

<http://example.org/recipes/sopa/20/step/2edc47a74de546a1813e4b1f59e6685a> a schema1:HowToStep ;
    schema1:text "Agregar el resto de verduras en la olla, lanzar la sal, dejar cocinar por 10 minutos más y revisar que las verduras no estén sobre cocidas. Antes de apagar echar las 4 partes de col dejar cocinar unos segundos y retirar del fuego."@es .

<http://example.org/recipes/sopa/20/step/d376b560c80a4d0bb83361ba3d81f186> a schema1:HowToStep ;
    schema1:text "Agregar las zanahorias y dejar cocinar por 15 minutos."@es .

<http://example.org/recipes/sopa/20/step/f79910f294da42eeaf80178efb0b1644> a schema1:HowToStep ;
    schema1:text "Colocar la carne, el choclo, la cebolla, el ajo y las hierbas en una olla profunda."@es .

<http://example.org/recipes/sopa/21/step/219f815a317442ac932d8cdc38eefe7e> a schema1:HowToStep ;
    schema1:text "Cuando el aderezo esté bien cocido añadir las arvejas y el caldo preparado."@es .

<http://example.org/recipes/sopa/21/step/50445abc72f5499393d96eff55c4904e> a schema1:HowToStep ;
    schema1:text "Derretir la mantequilla y dore en estas las cebollas, el ajo, el ají y la salsa de tomate"@es .

<http://example.org/recipes/sopa/21/step/a9d6132007874c1fae6c308cd3111888> a schema1:HowToStep ;
    schema1:text "Esperar a que rompa el hervor e incorporar el arroz y las papas."@es .

<http://example.org/recipes/sopa/21/step/bb9af02a381f4e65ba32b07ee063295a> a schema1:HowToStep ;
    schema1:text "Enharinar los camarones y freirlos."@es .

<http://example.org/recipes/sopa/21/step/beb671f2c2cd488ba8d450966e4b82f2> a schema1:HowToStep ;
    schema1:text "Hacer un caldo con el agua y el pescado sazonado a su gusto."@es .

<http://example.org/recipes/sopa/21/step/cf52e7329d9d44a5ad4c50df09422e19> a schema1:HowToStep ;
    schema1:text "Antes de servir, agregar los huevos ligeramente mezclados, la leche evaporada, el queso parmesano, cilantro picado y por último los camarones."@es .

<http://example.org/recipes/sopa/22/step/22020600ad0740808bf81b02f6f4c844> a schema1:HowToStep ;
    schema1:text "Cortar la zanahoría en cubitos y la cebolla blanca bien fina."@es .

<http://example.org/recipes/sopa/22/step/3f93718d15d64359bb9bf0ccefc3d11f> a schema1:HowToStep ;
    schema1:text "Agregar el pescado frito a la sopa junto a la col, el queso, la leche, el cilantro y una rodaja de pimiento."@es .

<http://example.org/recipes/sopa/22/step/6695f754540f49679c05854a01d2a290> a schema1:HowToStep ;
    schema1:text "Freir la cebolla blanca con achiote, mantequilla y media cucharada de ajo, junto a 2 papas cortadas en cuadritos."@es .

<http://example.org/recipes/sopa/22/step/74313956f5334462a7bb5b222b465315> a schema1:HowToStep ;
    schema1:text "Añadir sal al gusto y servir."@es .

<http://example.org/recipes/sopa/22/step/7474e9258a39447b9b70c5dd0fba94b8> a schema1:HowToStep ;
    schema1:text "Cortar la mazorca de choclo en trozos y la cola en trozitos."@es .

<http://example.org/recipes/sopa/22/step/763e853b35314cff804ede47a7345b09> a schema1:HowToStep ;
    schema1:text "Aliñar el pescado con ajo y sal al gusto. Cubrir de harina y lo freímos en una sartén con aceite hasta que se dore."@es .

<http://example.org/recipes/sopa/22/step/8eca0f836a764d7d91dadf2759e35d97> a schema1:HowToStep ;
    schema1:text "Picar el resto de papas en cuadritos más grandes para que no se deshagan y las añadimos a la sopa junto a la zanahoria."@es .

<http://example.org/recipes/sopa/22/step/e9696d2721b84ca381f45ea369eb789d> a schema1:HowToStep ;
    schema1:text "Añadir un litro y medio de agua cuando la cebolla blanca este transparente ."@es .

<http://example.org/recipes/sopa/23/step/1c91eb7efc3f44dab1ccbb88b6c33ca2> a schema1:HowToStep ;
    schema1:text "Servir en cazuelas individuales y espolvorear con cilantro."@es .

<http://example.org/recipes/sopa/23/step/8e243660b75440a181cab8b0f0c7a81a> a schema1:HowToStep ;
    schema1:text "En una cacerola freír la cebolla en mantequilla y cuando este dorada agregar las papas cortadas en cubos, cubrir con un litro y medio de agua."@es .

<http://example.org/recipes/sopa/23/step/a7b339d7d37746bb8975737b78e3e95e> a schema1:HowToStep ;
    schema1:text "Comenzar la preparación cortando todos los vegetales en cubos y trozos pequeños"@es .

<http://example.org/recipes/sopa/23/step/b5d7fb39ea4c49929f3c37115400edd9> a schema1:HowToStep ;
    schema1:text "Luego de 5 minutos de cocción agregar las zanahorias y bajar el fuego."@es .

<http://example.org/recipes/sopa/23/step/d136d1cc4c4c419498e18ba02c5920a6> a schema1:HowToStep ;
    schema1:text "Agregar a la sopa la col, la leche con el queso y por último el pescado frito."@es .

<http://example.org/recipes/sopa/23/step/f8d9fd86186647cc8f9a63365e29f257> a schema1:HowToStep ;
    schema1:text "Pincelar el pescado escogido con ajo machacado y sal a gusto. con ajo y sal al gusto, pasar por harina y freír de ambos lados hasta dorar."@es .

<http://example.org/recipes/sopa/24/step/08a22d2910d84f9fb6972ccbc0b4f6a9> a schema1:HowToStep ;
    schema1:text "Licuamos, para hacer la crema. Luego en una olla agregamos mantequilla y cuando caliente un poco agregamos la crema licuada y cocinamos."@es .

<http://example.org/recipes/sopa/24/step/3ff2ae26e564403ba298f6420fb7e1da> a schema1:HowToStep ;
    schema1:text "En una olla se coloca agua y luego las acelgas bien lavadas. Se deja hervir por tres minutos."@es .

<http://example.org/recipes/sopa/24/step/70a7128187134e3a80911b2f64a9360f> a schema1:HowToStep ;
    schema1:text "Dejamos que hierva unos 3 minutos y listo!"@es .

<http://example.org/recipes/sopa/24/step/e034f175134a48a79821b7e0ddd01c01> a schema1:HowToStep ;
    schema1:text "Pasado los 3 minutos. Se sacan las acelgas y se escurren bien. Luego se colocan en la licuadora y se agrega el queso, en trocitos, la cebolla, leche , ajo, sal y pimienta al gusto."@es .

<http://example.org/recipes/sopa/25/step/106bfc68f7644330865b45089bbd2335> a schema1:HowToStep ;
    schema1:text "Añadir el caldo de pollo y mezclar hasta se combine totalmente con el refrito."@es .

<http://example.org/recipes/sopa/25/step/18f3e628e3ea49928e947a7814bb84b4> a schema1:HowToStep ;
    schema1:text "Agregar el queso y retirar del fuego, sirva caliente."@es .

<http://example.org/recipes/sopa/25/step/507030b9190c4197b4849bd1a507e7ce> a schema1:HowToStep ;
    schema1:text "Agregar la mantequilla a una olla, añadir la cebolla, el ajo y las zanahorias, remueva hasta que las cebollas se vuelvan transparente."@es .

<http://example.org/recipes/sopa/25/step/76502fdbaf03420d91d0fc24a20c255f> a schema1:HowToStep ;
    schema1:text "Verificar que el brócoli esté cocido retirar del fuego y dejar enfriar, luego llevarlo a la licuadora para formar una especie de puré, ir haciendo de a poco."@es .

<http://example.org/recipes/sopa/25/step/c8fcc2b04d504090a3d684dd9e72f9e1> a schema1:HowToStep ;
    schema1:text "Llevar el puré a la olla nuevamente, cocer a fuego lento, agregar la leche, sal y pimienta."@es .

<http://example.org/recipes/sopa/25/step/d2a4a0d10cf241d9adeb4340914fad6f> a schema1:HowToStep ;
    schema1:text "Agregar el brócoli y remover dejando que hierva a fuego lento."@es .

<http://example.org/recipes/sopa/26/step/2f807761750a4198ba3783650b8b5940> a schema1:HowToStep ;
    schema1:text "Luego que se licue lo hechamos de nuevo a la olla y lo unimos con el caldo que quedo, la crema de leche y el queso desmenuzado. Debe durar en el fuego hasta que la crema se espese."@es .

<http://example.org/recipes/sopa/26/step/36638431c14e493193bf5f4a97d6136d> a schema1:HowToStep ;
    schema1:text "Primero haremos un sofrito con la manteca de color , cebolla picada, pimienta, comino y sal. Colocamos en una olla con agua."@es .

<http://example.org/recipes/sopa/26/step/61b04485aca24eb48d614bbfa7791c48> a schema1:HowToStep ;
    schema1:text "Al hervir agregamos la zanahoria y las papas. Una vez cocinada se llevan a la licuadora y agregamos leche hasta formar pure."@es .

<http://example.org/recipes/sopa/26/step/d0f633868d504fbf91b104bb493e8e9f> a schema1:HowToStep ;
    schema1:text "Listo para disfrutar."@es .

<http://example.org/recipes/sopa/27/step/03ecc9e2469d4e47bd8e7e99a766356d> a schema1:HowToStep ;
    schema1:text "Servir la crema de zapallo caliente con queso desmenuzado, cebolletas cortadas, chorizo o chicharrones."@es .

<http://example.org/recipes/sopa/27/step/4da278557c4a4f88bde8ba58a80e8035> a schema1:HowToStep ;
    schema1:text "Pelar el zapallo, retirarle las semillas y cortarlo en trozos pequeños. Pelar y cortar finamente la cebolla y los tomates."@es .

<http://example.org/recipes/sopa/27/step/a5e6cca24ea845d0a00d57edff1847f1> a schema1:HowToStep ;
    schema1:text "Licuar hasta obtener un puré o una mezcla espesa. Añadir sal y pimienta al gusto. Recalentar la crema de ser necesario."@es .

<http://example.org/recipes/sopa/27/step/ac992ffb852d4956a255c6448e54d0c0> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una olla y añadir la cebolla, el ajo, el comino y los tomates. Sofreír durante unos 5 minutos hasta que las cebollas estén suaves. Añadir el caldo de pollo o de verduras y esperar hasta que hierva."@es .

<http://example.org/recipes/sopa/27/step/f68001956da04e6fbb0659f36ee66e19> a schema1:HowToStep ;
    schema1:text "Añadir los trozos de zapallo a la olla y esperar hasta que hierva nuevamente. Reducir la temperatura y cocinar a fuego lento durante unos 30 minutos hasta que los trozos de zapallo estén suaves. Retirar del fuego y esperar que se enfríe lo suficiente para licuar."@es .

<http://example.org/recipes/sopa/28/step/18692f17e71247feb1933035232e5499> a schema1:HowToStep ;
    schema1:text "Luego de esto lo ponemos nuevamente en la olla, junto con la yuca que se licuo. Mezclamos bien y dejamos cocinar por 5 minutos mas."@es .

<http://example.org/recipes/sopa/28/step/29097825680e4375bc1c9857ee4c520a> a schema1:HowToStep ;
    schema1:text "En una olla con agua colocamos la yuca con la sal. Dejamos cocinar"@es .

<http://example.org/recipes/sopa/28/step/653e86f09326486e97290b4c9355e217> a schema1:HowToStep ;
    schema1:text "Tapamos y dejamos hervir."@es .

<http://example.org/recipes/sopa/28/step/8d35ab9407484cafb3ace60588bd9a38> a schema1:HowToStep ;
    schema1:text "Servimos los platos con el caldo, la albacora y encima la ensalada del encebollado."@es .

<http://example.org/recipes/sopa/28/step/9724ae261f134cbfa142c4c476581be2> a schema1:HowToStep ;
    schema1:text "Pasado 10 minutos. Sacamos la Albacora y el resto dejamos tapado para que continue cocinandose por 30 minutos mas."@es .

<http://example.org/recipes/sopa/28/step/b5d97fb211934e6ebea8bbfb2b8bdd64> a schema1:HowToStep ;
    schema1:text "Luego licuamos una tasa de yuca, con una taza de agua donde se cocino y reservamos."@es .

<http://example.org/recipes/sopa/28/step/d39de2599e9a455382625717328d1898> a schema1:HowToStep ;
    schema1:text "En una olla aparte colocamos 2 litros de agua y agregamos el apio, los tomates, la cebolla mediana, cilantro, perejil, los ajos triturados, sal y pimienta al gusto. Revolemos y agregamos la albacora."@es .

<http://example.org/recipes/sopa/28/step/d84e9b9f03ff4d28bcf1f4a4c528fe95> a schema1:HowToStep ;
    schema1:text "Luego en otra cacerola colocamos la cebolla previamente lavada y picada, le agregamos cilantro, 3 cucharadas de aceite y el jugo de 6 limones. Revolvemos muy bien."@es .

<http://example.org/recipes/sopa/28/step/e4ad33bfe00148659ede0004ad232ebd> a schema1:HowToStep ;
    schema1:text "Seguido que pase el tiempo se sacan las verduras y los vegetales. Lo colocamos en una licuadora con algo del caldo y lo licuamos."@es .

<http://example.org/recipes/sopa/29/step/0fd0bee2a2aa4987883323380b219953> a schema1:HowToStep ;
    schema1:text "Se cocina la yuca pelada y en trozos con el caldo de pescado."@es .

<http://example.org/recipes/sopa/29/step/1a549bfeaae244daa002269a891bc7cc> a schema1:HowToStep ;
    schema1:text "Cuando el pescado esté listo se debe retirar y colar el caldo."@es .

<http://example.org/recipes/sopa/29/step/46ec4edbc38b498887b39e0d34c10ed0> a schema1:HowToStep ;
    schema1:text "Al ablandar la yuca se añade el pescado y se rectifica el sabor. Cocinar por unos minutos."@es .

<http://example.org/recipes/sopa/29/step/656591ba9a474b6781dcddc4cb3f6222> a schema1:HowToStep ;
    schema1:text "Puede agregar un poco de ají, limón y un toque de aceite."@es .

<http://example.org/recipes/sopa/29/step/90b9c42edad44074b03287e44e4edc2f> a schema1:HowToStep ;
    schema1:text "Cocinar el pescado en una cacerola con tres tazas de agua, ají, culantro, sal, pimienta y comino."@es .

<http://example.org/recipes/sopa/29/step/b6675aea69f6449ab198f270a2f448e3> a schema1:HowToStep ;
    schema1:text "Servir en un plato hondo, el caldo con la yuca y una porción del pescado. Colocar encima curtido de cebolla y tomate."@es .

<http://example.org/recipes/sopa/29/step/fc396cc4566a4ff69f32311f418a36a0> a schema1:HowToStep ;
    schema1:text "Limpiar el pescado y cortarlo en trozos."@es .

<http://example.org/recipes/sopa/3/step/11b6df5ebb864bf8ac9e77879b558c2a> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y añadir el ají."@es .

<http://example.org/recipes/sopa/3/step/6f6908ca9c604178add07c6149d62c1d> a schema1:HowToStep ;
    schema1:text "Licuar la leche semidescremada con maní, agregar a la olla y revolver."@es .

<http://example.org/recipes/sopa/3/step/7e8e7008b82e4e20afff5861f55c6397> a schema1:HowToStep ;
    schema1:text "Realizar el refrito con el aceite de achiote, la cebolla blanca, cebolla paiteña, ajo y comino. Una vez que las cebollas estén doradas, agregar mantequilla."@es .

<http://example.org/recipes/sopa/3/step/c214f2c3908f42fd9d76f0ecd92dda7c> a schema1:HowToStep ;
    schema1:text "Freír los plátanos cortados en trozos y luego lanzarlos a la olla."@es .

<http://example.org/recipes/sopa/3/step/cbc216ff6b6d4acea9f3ff33e3168413> a schema1:HowToStep ;
    schema1:text "Añadir el refrito a la olla, agua, la carne cocida y cilantro."@es .

<http://example.org/recipes/sopa/3/step/f4019790da5a47af8cb031e486f9464d> a schema1:HowToStep ;
    schema1:text "Agregar la carne y sazonar en la olla donde se preparará la sopa, refreír la carne con aceite caliente hasta que se dore completamente, luego retirar la carne."@es .

<http://example.org/recipes/sopa/30/step/255bc00ad4134f80a32788a370982828> a schema1:HowToStep ;
    schema1:text "Servir el encebollado manaba se pone con curtido de cebolla y tomate encima de cada plato de sopa."@es .

<http://example.org/recipes/sopa/30/step/30840e03664b417aa313049b60bea729> a schema1:HowToStep ;
    schema1:text "Colocar la yuca cortada y las lonjas de atún nuevamente en el caldo, rectificar la sal y calentar hasta que esté listo para servir."@es .

<http://example.org/recipes/sopa/30/step/7c05477fe33f45c3b74a08ca62573300> a schema1:HowToStep ;
    schema1:text "Cuando el agua comience a hervir, añadir el atún o albacora y cocinar durante unos 15 minutos hasta que el atún esté listo."@es .

<http://example.org/recipes/sopa/30/step/90299267dff54f618e2ef522a759aa62> a schema1:HowToStep ;
    schema1:text "Separar el atún en lonjas y guardarlo para añadir más tarde."@es .

<http://example.org/recipes/sopa/30/step/a1aa0c7e86cb4f08b9c23db41de3cbe5> a schema1:HowToStep ;
    schema1:text "Colar el caldo que se cocinó y guardarlo para cocinar la yuca."@es .

<http://example.org/recipes/sopa/30/step/a1c40b70c1a147a5843bd6409282b53a> a schema1:HowToStep ;
    schema1:text "Sofreír la cebolla, los tomates, el comino, el ají y la sal. Añadir el agua y el cilantro."@es .

<http://example.org/recipes/sopa/30/step/dcc60d49c59040b094e5485deb89eef0> a schema1:HowToStep ;
    schema1:text "Sacar la yuca y cortarla en pedazos pequeños."@es .

<http://example.org/recipes/sopa/30/step/e1d931e8bee84603b692b1dddb93ed55> a schema1:HowToStep ;
    schema1:text "Hervir el caldo de atún, añadir la yuca y cocinar hasta que esté suave."@es .

<http://example.org/recipes/sopa/31/step/209eb6a6872c44af865a0bf390615e34> a schema1:HowToStep ;
    schema1:text "En una olla grande realizar un sofrito con la cebolla, el tomate, las especias y una vez que haya dorado añadir el agua y subir el fuego."@es .

<http://example.org/recipes/sopa/31/step/2e2293bd58cd4983bb0722e82c978ab5> a schema1:HowToStep ;
    schema1:text "En el caldo cocinar la yuca hasta suavizarla y que esté blanda."@es .

<http://example.org/recipes/sopa/31/step/7e7858d511ee46228bee88604ecffc6f> a schema1:HowToStep ;
    schema1:text "Retirarla del caldo y cortar en trozos pequeños, hacer lo mismo con el atún, salpimentar."@es .

<http://example.org/recipes/sopa/31/step/98a3f446394646eea725fd988f7803d6> a schema1:HowToStep ;
    schema1:text "Servir en un plato hondo con lonjas de cebolla encurtida."@es .

<http://example.org/recipes/sopa/31/step/b2afb1c1de9c40ac82a41ed5465b9af8> a schema1:HowToStep ;
    schema1:text "Cuando rompa en hervor añadir el atún y cocinar hasta que esté suave. Retirar del fuego y reservar el caldo."@es .

<http://example.org/recipes/sopa/32/step/3cce6a3d36b34efc9aa9ccf30d2d1f98> a schema1:HowToStep ;
    schema1:text "Sumar a la cacerola 2 tazas de leche junto con las legumbres, y cocinar a fuego lento por 20 minutos."@es .

<http://example.org/recipes/sopa/32/step/523f50dbd7f24f759b1d7b2cf243f5b0> a schema1:HowToStep ;
    schema1:text "Retirar la cacerola del fuego y agregar la crema de leche y los quesos y esperar a que se disuelvan."@es .

<http://example.org/recipes/sopa/32/step/5fb23f3b6dda4d91bb82261a81044438> a schema1:HowToStep ;
    schema1:text "Añadir a la cacerola el arroz cocido, agregar el puré de sambo y zapallo y mezclar bien para integrar."@es .

<http://example.org/recipes/sopa/32/step/705b95a50609487e9d3b8fb5a5a99e82> a schema1:HowToStep ;
    schema1:text "En una cacerola colocar la manteca y dorar allí la cebolla junto con el ajo, el achiote, el comino, el orégano y pimienta al gusto."@es .

<http://example.org/recipes/sopa/32/step/92ef306f09e34885b54e4c30bcddad07> a schema1:HowToStep ;
    schema1:text "Servir caliente en cazuelas y con rodajas de huevo cocido y plátanos fritos."@es .

<http://example.org/recipes/sopa/32/step/d0d97a5297014968984d822d0ab61274> a schema1:HowToStep ;
    schema1:text "Con la leche restante procesar el maní y sumarlo a la sopa, cocinar todo junto por 10 minutos."@es .

<http://example.org/recipes/sopa/32/step/d5aaaf40cf0e42b9a2893002dff24278> a schema1:HowToStep ;
    schema1:text "Con una taza de leche y en una cacerola aparte hervir el bacalao y añadírselo a la sopa."@es .

<http://example.org/recipes/sopa/32/step/edd3d742fcb74245b6f1b88044c03db2> a schema1:HowToStep ;
    schema1:text "Comenzar la preparación cortando el bacalao en trozos y cocinando el sambo y el zapallo un poco de agua hasta que queden tiernos, dejar enfriar, escurrir y hacer un puré."@es .

<http://example.org/recipes/sopa/33/step/089320f1c3894ec4ba440331fc68e876> a schema1:HowToStep ;
    schema1:text "Licuar el maní tostado con 2 tazas de leche y agregar esto a la sopa. Cocinar durante 10 minutos, revolviendo con frecuencia."@es .

<http://example.org/recipes/sopa/33/step/0df97541d1cf4fff9caeaed21b7899d5> a schema1:HowToStep ;
    schema1:text "Remojar el bacalao seco durante 24 horas, cambiar al agua cada 6 a 8 horas, el agua de remojo debe ir quedando cada vez menos salada, al final del remojo cortar el bacalao en pedazos medianos."@es .

<http://example.org/recipes/sopa/33/step/3a7b48ed07c1434aade4a7c3937478a5> a schema1:HowToStep ;
    schema1:text "Cocinar el sambo y el zapallo por separado, con sólo un poco de agua. Cocinar hasta que estén suaves y tiernos, colar el agua y licuarlos hasta obtener un puré."@es .

<http://example.org/recipes/sopa/33/step/485ea46d8da449e0bb6ddd4fd3b4e7e4> a schema1:HowToStep ;
    schema1:text "Añadir el arroz y triturarlo hasta que se haga un puré o una salsa espesa. Agregar el puré de sambo, zapallo y col y mezclar bien."@es .

<http://example.org/recipes/sopa/33/step/563a9b5795b54579adc90b323738dfb3> a schema1:HowToStep ;
    schema1:text "Agregar 4 tazas de leche y las habas, los choclos, las habitas y las alubias, mezclar bien y dejar cocinar a fuego lento durante 15 minutos, removiendo de vez en cuando."@es .

<http://example.org/recipes/sopa/33/step/7cba5d3591074a63ba1e37c67e1c16a2> a schema1:HowToStep ;
    schema1:text "Derretir la mantequilla en una olla grande y agregar la cebolla, el ajo, el achiote, el comino, el orégano y pimienta. Cocinar durante unos 5 minutos hasta que las cebollas estén tiernas."@es .

<http://example.org/recipes/sopa/33/step/9f6280ab006e4adfbd6c6f965cf5839b> a schema1:HowToStep ;
    schema1:text "Antes de servir la fanesca, añadir los chochos, la crema de leche y los quesos y mezcle bien para que los quesos se disuelvan. Agregar el cilantro o perejil y rectificar la sal."@es .

<http://example.org/recipes/sopa/33/step/b8b4f23bc6f14088b12c49fe4c20d467> a schema1:HowToStep ;
    schema1:text "Aparte hervir durante 10 minutos 6 tazas de leche con el bacalao y añadir esta mezcla a la sopa."@es .

<http://example.org/recipes/sopa/33/step/eabd5effa0044895b91b0d5a36c87651> a schema1:HowToStep ;
    schema1:text "Hervir un poco de agua con la col durante 3 minutos, colar y añadir la col al puré de sambo y zapallo."@es .

<http://example.org/recipes/sopa/33/step/f5602718f4864f67a8eade2a56696dc0> a schema1:HowToStep ;
    schema1:text "Sirva la fanesca con pedazos de bacalao frito, rodajas de huevo duro, plátanos maduros fritos, queso fresco, un ají criollo y cebollas blancas encurtidas."@es .

<http://example.org/recipes/sopa/34/step/3fbc9aae53a949b88675b3cf640ab98b> a schema1:HowToStep ;
    schema1:text "Una vez que la carne esta suave, agregar las zanahorias cortadas en rodajas y cocinar hasta que estén tiernas, recién allí añadir las papas y cocinar a fuego medio por 15 minutos más."@es .

<http://example.org/recipes/sopa/34/step/5d7c632be2ed47ab9ee9dcebca5d7e9e> a schema1:HowToStep ;
    schema1:text "Agregar por ultimo las legumbres, rectificar los condimentos y la sal y recién 5 minutos antes de apagar el fuego, añadir la col."@es .

<http://example.org/recipes/sopa/34/step/7727473b788b4ce79ec933a8d5d39fe0> a schema1:HowToStep ;
    schema1:text "Colocar en una cacerola abundante agua, la carne, el choclo cortado en rodajas, la cebolla cortada en trozos pequeños y el ajo machacado y dejar hervir hasta tiernizar la carne."@es .

<http://example.org/recipes/sopa/34/step/f23e952fb7a4464084156e7058ae5a8c> a schema1:HowToStep ;
    schema1:text "Servir caliente en cazuelas individuales."@es .

<http://example.org/recipes/sopa/35/step/4799cf0137a3494cb409075431f540af> a schema1:HowToStep ;
    schema1:text "Calentar en una sartén el aceite y añadir la cebolla. Cocinar durante 5 minutos y colocar el sofrito en el caldo anterior. Dejar hervir hasta que las papas estén muy suaves."@es .

<http://example.org/recipes/sopa/35/step/84b6308333b24a6d96bba597f1fb76a4> a schema1:HowToStep ;
    schema1:text "Colocar la costilla, la zanahoria, la ramita de cilantro, el ajo y la sal en una olla con el agua hirviendo. Dejar hervir hasta que la carne de la costilla esté suave. Agregar las papas y la acelga."@es .

<http://example.org/recipes/sopa/35/step/941adc67fb07403fbc5368b7ffa5ed42> a schema1:HowToStep ;
    schema1:text "Agregar la cucharada de cilantro y la leche. Hervir por 5 minutos, rectificar sal y retirar del fuego."@es .

<http://example.org/recipes/sopa/35/step/c72ed7e656c2424d9739dad335497dc6> a schema1:HowToStep ;
    schema1:text "Servir el locro de acelga bien caliente acompañado de rodajas de pan."@es .

<http://example.org/recipes/sopa/36/step/3be39c5bad8e4f0fb8fc915069543c55> a schema1:HowToStep ;
    schema1:text "Listo para disfrutar y servir con ruedas de aguacate y cilantro picadito."@es .

<http://example.org/recipes/sopa/36/step/8a0d5a375beb4df68930dd394b9376ef> a schema1:HowToStep ;
    schema1:text "Dejamos hervir y colocamos un toque de achiote, cilantro o perejil picado, sal y pimienta al gusto y dejamos que se cocine hasta que se desbaraten las papas."@es .

<http://example.org/recipes/sopa/36/step/9c991045524841f88415b7c6b60754b4> a schema1:HowToStep ;
    schema1:text "En una olla agregamos la mantequilla, el ajo, la cebolla blanca. Sofreimos un poco hasta que este transparente la cebolla."@es .

<http://example.org/recipes/sopa/36/step/aa76586348844a9189c8aa4166b99859> a schema1:HowToStep ;
    schema1:text "Luego agregamos las papas y revolvemos bien. Seguido agregamos las zanahorias, el choclo, sal y pimienta al gusto. Mezclamos bien por 5 minutos."@es .

<http://example.org/recipes/sopa/36/step/b7b09a9c388c43d4b63a848b3b8e4202> a schema1:HowToStep ;
    schema1:text "Cuando ya esten las papas un poco transparentes agregamos la leche y agua hasta cubrir las papas."@es .

<http://example.org/recipes/sopa/36/step/d89b9ac6c4d7499aab96399f41057d77> a schema1:HowToStep ;
    schema1:text "Al estar espeso se agrega el queso y se apaga."@es .

<http://example.org/recipes/sopa/37/step/1d009b6d8b3742baad664f03821decd9> a schema1:HowToStep ;
    schema1:text "Agregar los tomates picados, el comino, el ají, el achiote y la sal. Mezclar bien y cocinar durante 3 minutos."@es .

<http://example.org/recipes/sopa/37/step/7ec353bd67224d84aa520c1e8e0a60c3> a schema1:HowToStep ;
    schema1:text "Agregar las papas y el agua o el caldo y esperar que hierva."@es .

<http://example.org/recipes/sopa/37/step/82b6695134114f2cbe0f2ed8d027630e> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una sartén grande, agregar la cebolla y cocinar durante 5 minutos."@es .

<http://example.org/recipes/sopa/37/step/8fcd316a0a504e669998c4d6b2960ec6> a schema1:HowToStep ;
    schema1:text "Añadir 2 tazas de habas, reducir la temperatura y cocinar a fuego lento durante unos 25 minutos hasta que las papas estén suaves."@es .

<http://example.org/recipes/sopa/37/step/a01fcd2f519941a18c1fc8077e6dd72b> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, espolvorear con el cilantro y servir el locro de habas acompañado de ají criollo y rodajas de aguacate."@es .

<http://example.org/recipes/sopa/37/step/a2e25634c9d847e98ba80d64316b6969> a schema1:HowToStep ;
    schema1:text "Usar un mortero o machacador para suavizar y ligeramente triturar las papas y las habas."@es .

<http://example.org/recipes/sopa/37/step/b5f48319e57543a9977342f283c61e0e> a schema1:HowToStep ;
    schema1:text "Añadir el ajo machacado y cocinar durante 2 minutos."@es .

<http://example.org/recipes/sopa/37/step/ecfe7581e6e34178912e6cd4804e5cf6> a schema1:HowToStep ;
    schema1:text "Batir la leche y los huevos y añadir esta mezcla a la sopa. Agregar el queso y mezclar bien."@es .

<http://example.org/recipes/sopa/37/step/f17cd7e777894261b66db243d0552400> a schema1:HowToStep ;
    schema1:text "Agregar el resto de las habas, cocinar durante 5 minutos, revolviendo de vez en cuando."@es .

<http://example.org/recipes/sopa/38/step/53dcac7e1e0349068eea46b080eb8b72> a schema1:HowToStep ;
    schema1:text "Se le agrega él orégano molido y listo."@es .

<http://example.org/recipes/sopa/38/step/5fb11e86114c4e29bdd8efa8104ad63a> a schema1:HowToStep ;
    schema1:text "Luego se agrega cilantro, 1/4 cucharadita de orégano y se revuelve todo."@es .

<http://example.org/recipes/sopa/38/step/865aed4f6211487ca89a90f24ae20715> a schema1:HowToStep ;
    schema1:text "Luego se agrega la leche, el queso y se revuelve. Se deja unos 3 minutos. Con cuidado por que puede subir."@es .

<http://example.org/recipes/sopa/38/step/8c9fa7b674954addadfd4263146c0fa4> a schema1:HowToStep ;
    schema1:text "Se cocina por unos 5 minutos."@es .

<http://example.org/recipes/sopa/38/step/904fcd7ff69f403898336dbfe27475ce> a schema1:HowToStep ;
    schema1:text "Seguido de sofrito se agrega 2 litros de agua caliente para cocinar mas rápido; Se ponen las papas, las habas, la calabaza y se cocina con la olla tapada por 20 minutos."@es .

<http://example.org/recipes/sopa/38/step/90c957c575714696876fe93eab5a92fd> a schema1:HowToStep ;
    schema1:text "Se puede servir y disfrutar."@es .

<http://example.org/recipes/sopa/38/step/c43d0d5c7f4b4566884bbe5ed61a01fb> a schema1:HowToStep ;
    schema1:text "Se agrega el Nabo sólo por 3 minutos por que si se cocina mas tiempo pierde lo nutritivo."@es .

<http://example.org/recipes/sopa/38/step/c4757fb130c64a2b990b0a936096f81b> a schema1:HowToStep ;
    schema1:text "Primeramente en una olla se pone a freír la cebolla blanca sola unos segundos, un poquito de achiote para que no quede tan blanca. Sofreimos y revolvemos."@es .

<http://example.org/recipes/sopa/38/step/c84d2fc7f9ba4893a7e26908588b7dc6> a schema1:HowToStep ;
    schema1:text "Cuando las papas estén listas, se agregan los choclos y la sal al gusto."@es .

<http://example.org/recipes/sopa/39/step/0c8458749f9b49bea2b85698c7e15f94> a schema1:HowToStep ;
    schema1:text "Agregar en una olla agua y cocinar el zapallo hasta que se encuentre suave."@es .

<http://example.org/recipes/sopa/39/step/83f9b66cb8cf4b5bae6a4199a2478198> a schema1:HowToStep ;
    schema1:text "Realizar el refrito con la mantequilla, la cebolla y el achiote cocinar a fuego lento hasta que las cebollas se vuelvan transparentes."@es .

<http://example.org/recipes/sopa/39/step/bc78c4fd80244c6e8886a4ceb89ef06a> a schema1:HowToStep ;
    schema1:text "Licuar la leche con el refrito y agregar a la olla que contiene el zapallo."@es .

<http://example.org/recipes/sopa/39/step/c0e43040e4a04c49bb4108ffba1550b5> a schema1:HowToStep ;
    schema1:text "Hervir el locro a fuego lento y cocer por otros 20 minutos, revolver el locro para disolver el zapallo y espesar. Cuidar que las papas queden enteras."@es .

<http://example.org/recipes/sopa/39/step/ce5f288a85934996a6584fcdaadbc902> a schema1:HowToStep ;
    schema1:text "Agregar las papas, sal y pimienta al gusto."@es .

<http://example.org/recipes/sopa/39/step/f65a8fb03c1d41ec932304486bc485b6> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y servir lanzando el queso al plato."@es .

<http://example.org/recipes/sopa/39/step/fcbf6f2ed0b044029606e4c47ddd85d3> a schema1:HowToStep ;
    schema1:text "Agregar los choclos a la olla y cocer por 20 minutos."@es .

<http://example.org/recipes/sopa/4/step/139697d0a3af4971a466882d3918b33d> a schema1:HowToStep ;
    schema1:text "Espolvorear el biche con cilantro o perejil y servir caliente con rodajas de limón y ají."@es .

<http://example.org/recipes/sopa/4/step/8f57c37f76f141468adb455d92ac01cd> a schema1:HowToStep ;
    schema1:text "Agregar el plátano y los filetes de pescado y cocinar a fuego lento durante unos 10 minutos hasta que el pescado esté listo."@es .

<http://example.org/recipes/sopa/4/step/a26129aa4d6943b79d0b41d4975b916f> a schema1:HowToStep ;
    schema1:text "Licuar el maní tostado con el refrito, la leche y 2 tazas de el caldo de pescado, hasta que estén bien triturados. Colar la mezcla licuada y combinarlo con el resto del caldo. Agregar 2 tazas más de agua."@es .

<http://example.org/recipes/sopa/4/step/a9cf237d0e9a428a91f94ba5543c8b46> a schema1:HowToStep ;
    schema1:text "Calentar las 2 cucharadas de aceite y agregar 1 taza de cebolla, 4 dientes ajo, 1 cucharadita de comino y sal. Cocinar durante unos 5 minutos hasta que las cebollas estén suaves."@es .

<http://example.org/recipes/sopa/4/step/ba9a9a01a1464f9f8c56c90057e8b6f7> a schema1:HowToStep ;
    schema1:text "Hervir 8 tazas de agua, ligeramente salada, agregar las cabezas y huesos de pescado y dejar hervir durante 30 minutos. Colar y guardar el caldo."@es .

<http://example.org/recipes/sopa/4/step/e3eef20d6e314faf8962179223e1daeb> a schema1:HowToStep ;
    schema1:text "Calentar en una olla las 2 cucharadas de aceite restantes y agregar las 2 tazas de cebolla, los 6 dientes de ajo, el pimiento, el achiote, la cucharadita de comino, orégano y sal. Cocinar a fuego lento durante unos 10 minutos hasta que las cebollas estén suaves."@es .

<http://example.org/recipes/sopa/4/step/f659bfda3acc44b3a360d4fc0992a3ab> a schema1:HowToStep ;
    schema1:text "Añadir la mezcla que se licuó con el caldo de pescado y hervir a fuego lento. Agregar el choclo y la yuca y cocinar a fuego lento durante unos 40 minutos hasta que la yuca esté tierna."@es .

<http://example.org/recipes/sopa/40/step/36f0805126ca4626a1b3d33e245f4bdd> a schema1:HowToStep ;
    schema1:text "Añadir sal al gusto, el queso y el cilantro. Servir el locro de papas caliente con aguacates, cebolletas o ají."@es .

<http://example.org/recipes/sopa/40/step/632fcc0f543c48fab1a4b45d1777b6e1> a schema1:HowToStep ;
    schema1:text "Reducir la temperatura, añadir la leche, mezclar bien y cocinar durante unos 5 minutos adicionales. Añadir más leche o agua si la sopa está muy espesa."@es .

<http://example.org/recipes/sopa/40/step/eef73d731c06495aaf0f571f3bcf1518> a schema1:HowToStep ;
    schema1:text "Añadir las papas a la olla, mezclar bien y continuar cocinando durante unos 5 minutos."@es .

<http://example.org/recipes/sopa/40/step/f512eea6ea91423a9e5cc91bf5c4ceb1> a schema1:HowToStep ;
    schema1:text "Calentar el aceite o la mantequilla a fuego medio en una olla y añadir la cebolla, el ajo, el comino y el achiote molido. Cocinar durante 5 minutos hasta que las cebollas estén suaves."@es .

<http://example.org/recipes/sopa/40/step/f8df89dcdbf34d759a6eff3bd349038d> a schema1:HowToStep ;
    schema1:text "Agregar el agua y hervir hasta que las papas se ablanden. Aplastar las papas, pero no todas, la consistencia del locro debe ser cremosa pero con trocitos de papa."@es .

<http://example.org/recipes/sopa/41/step/11e81924572148b885587b0617d2342b> a schema1:HowToStep ;
    schema1:text "Agregar el fideo, las papas y la zanahoria."@es .

<http://example.org/recipes/sopa/41/step/3472e47dc5674f2db83133ea6004ea6d> a schema1:HowToStep ;
    schema1:text "Ubicar el resultado del refrito en la olla donde se va a realizar el caldo, poner litro y medio de agua a hervir."@es .

<http://example.org/recipes/sopa/41/step/672bf637eb7c45c99b658c04f058023e> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y servir caliente."@es .

<http://example.org/recipes/sopa/41/step/86aa502126ef4b55aaa3687e72d44d55> a schema1:HowToStep ;
    schema1:text "Ubicar el hueso carnudo con los fréjoles cuando haya hervido el agua, dejar hervir por una hora."@es .

<http://example.org/recipes/sopa/41/step/a0085f0c603a4817af14da119d1fb0d9> a schema1:HowToStep ;
    schema1:text "Realizar el refrito con el ajo, la cebolla, el pimiento, la albahaca y el achiote, dejar enfriar y luego licuarlo."@es .

<http://example.org/recipes/sopa/41/step/a3ad99e8ff3a4d04a5ace8c9085aa768> a schema1:HowToStep ;
    schema1:text "Verificar que los fideos y las papas estén bien cocidos y lanzar el queso dejar cocinar solo unos minutos."@es .

<http://example.org/recipes/sopa/41/step/a48a4b2a7bff425290f370e34b63ba6f> a schema1:HowToStep ;
    schema1:text "Dejar remojando los fréjoles un día anterior."@es .

<http://example.org/recipes/sopa/42/step/23ade1676fac4699871298fbe0637cee> a schema1:HowToStep ;
    schema1:text "Luego agregamos la carne y revolvemos hasta que la carne este sofrita. Agregamos el frijol junto con el agua caliente. Lo sificiente para dejarlo hervir 40 minutos."@es .

<http://example.org/recipes/sopa/42/step/328a6eb7c04847bfaa7f0037d32e2623> a schema1:HowToStep ;
    schema1:text "Luego agregamos las papas y dejamos cocinar."@es .

<http://example.org/recipes/sopa/42/step/79d70131eb9545909b21fd90a929815f> a schema1:HowToStep ;
    schema1:text "Lista para servir y disfrutar."@es .

<http://example.org/recipes/sopa/42/step/842e85e9ecdc44d2b2296ae1e286708e> a schema1:HowToStep ;
    schema1:text "Pasado este tiempo se agrega los fideos y la zanahoria. Tapamos por 25 minutos."@es .

<http://example.org/recipes/sopa/42/step/b021a4a5ec854285baca6f8a71a0d59c> a schema1:HowToStep ;
    schema1:text "Seguido de esto se licue la albahaca con aceite y se le agrega al guiso."@es .

<http://example.org/recipes/sopa/42/step/b25c232c997a4ade9062798be3f6025a> a schema1:HowToStep ;
    schema1:text "En una olla hacemos el sofrito con: Aceite, pasta de achiote, pasta de ajo y cebolla en cuadritos. Revolemos bien. Al pasar unos minutos se coloca pimienta y sal al gusto."@es .

<http://example.org/recipes/sopa/43/step/45e9e51dca1741ff850443fd11c9bca0> a schema1:HowToStep ;
    schema1:text "Añadir las carnes y cocinar durante 5 minutos y retirar del fuego."@es .

<http://example.org/recipes/sopa/43/step/5d2e7624c42140a388ac1317a2fa38e7> a schema1:HowToStep ;
    schema1:text "Retirar la carne, el chorizo y el tocino del caldo, dejar enfriar."@es .

<http://example.org/recipes/sopa/43/step/6f23b0c9f08a4a9cb2b171f2b3eace64> a schema1:HowToStep ;
    schema1:text "Cocinar revolviendo hasta que espese, si se consume la preparación, ir agregando agua caliente."@es .

<http://example.org/recipes/sopa/43/step/766a24e6955e460584afb2aadcf41626> a schema1:HowToStep ;
    schema1:text "Agregar el refrito en el caldo en que se cocinó la carne."@es .

<http://example.org/recipes/sopa/43/step/a711acb7858945afb6ea25c0b6d94044> a schema1:HowToStep ;
    schema1:text "Cocinar en una olla la carne de cerdo, el chorizo y el tocino."@es .

<http://example.org/recipes/sopa/43/step/e805f1c983554a6b987ed8de106f7691> a schema1:HowToStep ;
    schema1:text "Realizar un refrito con el aceite de achiote, el ajo, la cebolla blanca y sal."@es .

<http://example.org/recipes/sopa/43/step/f0777fe32d994f8bb402e100308a5259> a schema1:HowToStep ;
    schema1:text "Añadir el mote, el maní y la leche."@es .

<http://example.org/recipes/sopa/44/step/11ea9b5b303944e297446282936dede0> a schema1:HowToStep ;
    schema1:text "Agregar las papas y dejarla cocinar por 15 minutos."@es .

<http://example.org/recipes/sopa/44/step/480178182ecb41a08f609eb5d04a82c4> a schema1:HowToStep ;
    schema1:text "Revolver el caldo con sus mezclas hasta que las papas estén completamente blandas."@es .

<http://example.org/recipes/sopa/44/step/54f12a7662674d2c9d77aad0cd652475> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y servir la sopa caliente."@es .

<http://example.org/recipes/sopa/44/step/6d70958ee17e498f8c43fd56dbe24205> a schema1:HowToStep ;
    schema1:text "Tomar la harina de trigo en un recipiente y disolver totalmente con agua fría, cernir sobre el caldo."@es .

<http://example.org/recipes/sopa/44/step/7ea471cb362346fea8b63a26a03e2476> a schema1:HowToStep ;
    schema1:text "Refreír la cebolla, el ajo molido, el achiote y la carne de cerdo, echar agua hasta formar un caldo."@es .

<http://example.org/recipes/sopa/45/step/0e45c0050e0a4c0499eef57ee01be0ab> a schema1:HowToStep ;
    schema1:text "Hacer un refrito de cebolla blanca picada, ajo, mantequilla y orégano."@es .

<http://example.org/recipes/sopa/45/step/6a511fa981f640119368bc11602afb23> a schema1:HowToStep ;
    schema1:text "Agregar el queso, la leche y el cilantro y dejar durante 5 minutos."@es .

<http://example.org/recipes/sopa/45/step/b45e7928120c4af980effcb54c3f4d2a> a schema1:HowToStep ;
    schema1:text "Hervir el agua junto al refrito durante 10 minutos."@es .

<http://example.org/recipes/sopa/45/step/d9c93add463449c3a75f2fd7022f0afb> a schema1:HowToStep ;
    schema1:text "Batir la yema de huevo con un poco de liquido de la sopa y luego agregarla."@es .

<http://example.org/recipes/sopa/45/step/f4cee55c54eb48a484589e1729a6d756> a schema1:HowToStep ;
    schema1:text "Raspar el platano con una cuchara de mesa y agregar al agua hirviendo, cocinar durante 15 minutos."@es .

<http://example.org/recipes/sopa/46/step/4785f26bd0a4456c9cc4201b0dddf6d7> a schema1:HowToStep ;
    schema1:text "Raspar los plátano con una cuchara o tenedor y agregar al agua hirviendo, dejar a fuego medio por 15 minutos más."@es .

<http://example.org/recipes/sopa/46/step/6dbb8bbc656f4035955a95b1d35247d7> a schema1:HowToStep ;
    schema1:text "Agregar el queso y la leche y cocinar por 10 minutos."@es .

<http://example.org/recipes/sopa/46/step/c2e1cc8598934bd9b822dc6b10cad022> a schema1:HowToStep ;
    schema1:text "Por ultimo batir la yema y agregar al raspado antes de servir."@es .

<http://example.org/recipes/sopa/46/step/d1ac04b79a3e4b9eba3a5297abcbf144> a schema1:HowToStep ;
    schema1:text "Colocar al refrito los dos litros de agua y cuando rompa en hervor cocinar por 10 minutos."@es .

<http://example.org/recipes/sopa/46/step/dbaa514cbfbc4d47b7bb4cfe3a5af4f5> a schema1:HowToStep ;
    schema1:text "En una sartén sofreír en mantequilla la cebolla con el ajo y el orégano."@es .

<http://example.org/recipes/sopa/47/step/874f8520b6834825907b13d20ae2e143> a schema1:HowToStep ;
    schema1:text "Servir el repe en cazuelas individuales espolvoreadas con cilantro fresco."@es .

<http://example.org/recipes/sopa/47/step/b69fef2c9d484fe59a9c12cef231baf3> a schema1:HowToStep ;
    schema1:text "Comenzar por sofreír en una cacerola precalentada con aceite, la cebolla junto con el ajo, una vez que estén dorados agregar el agua."@es .

<http://example.org/recipes/sopa/47/step/ce2fced474e448dfa609608ed2d44858> a schema1:HowToStep ;
    schema1:text "Mixear levemente las verduras para espesar la preparación, agregar el queso lojano junto con la leche y salar."@es .

<http://example.org/recipes/sopa/47/step/f06126cd255d43238e2f8f07f09867ff> a schema1:HowToStep ;
    schema1:text "Cuando rompa en hervor agregar el plátano y cocinar a fuego lento por media hora."@es .

<http://example.org/recipes/sopa/48/step/569c37f760d44c528b646edb526e354f> a schema1:HowToStep ;
    schema1:text "Triturar un poco las verduras para que espese el caldo. Añadir el quesillo desmenuzado, luego la leche, el cilantro y la sal."@es .

<http://example.org/recipes/sopa/48/step/b83c409c823248bab538dbcf50e5ea4d> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una olla y sofreír el ajo y la cebolla. Agregar las 8 tazas de agua y dejar hervir."@es .

<http://example.org/recipes/sopa/48/step/eb8696a1d0344afdbad651a4efb10e72> a schema1:HowToStep ;
    schema1:text "Agregar el plátano y cocinar a temperatura media alta durante 20 minutos, revolviendo de vez en cuando, hasta que se suavice el plátano."@es .

<http://example.org/recipes/sopa/48/step/ec396f3ab58448c69552b20335f4f201> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y servir el repe acompañado con aguacate, queso y ají."@es .

<http://example.org/recipes/sopa/49/step/22d8d8c68f24465b9beb3e5edaa7edad> a schema1:HowToStep ;
    schema1:text "Procesar los chochos limpios con la leche tibia, volcar la preparación en una olla y calentar a fuego bajo hasta espesar."@es .

<http://example.org/recipes/sopa/49/step/6a8167ea4e4a45be99be23aac8d266a0> a schema1:HowToStep ;
    schema1:text "Comenzar por tomar una sartén, calentar la mantequilla y dorar la cebolla."@es .

<http://example.org/recipes/sopa/49/step/763c3b9a804f4a818eea0cae24b7567a> a schema1:HowToStep ;
    schema1:text "Hervir la leche, retirar y dejar entibiar."@es .

<http://example.org/recipes/sopa/49/step/c4d382ab91c740be95461739e7d44f58> a schema1:HowToStep ;
    schema1:text "Agregar el queso, el jugo de limón, el ajo y salpimentar"@es .

<http://example.org/recipes/sopa/49/step/de072e345395487cb31bd7c832486e18> a schema1:HowToStep ;
    schema1:text "Servir espolvoreando con cilantro fresco."@es .

<http://example.org/recipes/sopa/5/step/59f00dd232c04efa95567caa3c55017e> a schema1:HowToStep ;
    schema1:text "Limpiar bien la carne, eliminando los rastros de grasa."@es .

<http://example.org/recipes/sopa/5/step/90a1a9cb7c4642fba21481734af8d2fa> a schema1:HowToStep ;
    schema1:text "Rectificar el sazón."@es .

<http://example.org/recipes/sopa/5/step/aee0f81097824cbeba265ff7d382f70b> a schema1:HowToStep ;
    schema1:text "Sirva y espolvoree con cilantro y la cebolla en ramas finamente picadas. También puede añadir rodajas de ají."@es .

<http://example.org/recipes/sopa/5/step/d35191d743334c44983c0a849fcc5a7d> a schema1:HowToStep ;
    schema1:text "Añadimos la zanahoria picada en cuadros, el choclo, la yuca y la col troceada."@es .

<http://example.org/recipes/sopa/5/step/d786bd8b78d5419f881a7d7ee372d63e> a schema1:HowToStep ;
    schema1:text "Una vez que las verduras ablanden, se retira el pimiento y la cebolla."@es .

<http://example.org/recipes/sopa/5/step/ed12d3ac26004372938eb267bec9491b> a schema1:HowToStep ;
    schema1:text "Llevar al fuego una cacerola con suficiente agua y los huesos. Se cocinan hasta que la carne quede suave pero se va retirando la espuma que forma arriba. Agregar la cebolla cortada a la mitad, el pimiento sin semillas y el ajo."@es .

<http://example.org/recipes/sopa/50/step/1cb0ea1084a647a8a444612c8935c543> a schema1:HowToStep ;
    schema1:text "Retirar la espuma que se forma en la superficie."@es .

<http://example.org/recipes/sopa/50/step/5d6188182e0d4fd681d2f1693accd946> a schema1:HowToStep ;
    schema1:text "Puede servir acompañado con un picadillo de cebolla y perejil."@es .

<http://example.org/recipes/sopa/50/step/75bcde225e9d4bf0aafef374e0d497d4> a schema1:HowToStep ;
    schema1:text "Poner el hueso en una olla con el agua. Agregar sal, tapar y dejar hasta que esté a punto de hervir."@es .

<http://example.org/recipes/sopa/50/step/874e78cc2c674cf7a246f0a559362c3a> a schema1:HowToStep ;
    schema1:text "Agregar la yuca partida cuando el choclo esté casi cocido y continuar con la cocción hasta que esté blanda."@es .

<http://example.org/recipes/sopa/50/step/a9c8b6761ee44ab692b33d56334d02b4> a schema1:HowToStep ;
    schema1:text "Agregar los choclos y dejar cocinar durante 30 minutos aproximadamente."@es .

<http://example.org/recipes/sopa/50/step/ae0a808f9ba342278f32adb8b63ff72b> a schema1:HowToStep ;
    schema1:text "Añadir las ramas de cebolla blanca troceada, el perejil y el tomate sin semillas y rallado."@es .

<http://example.org/recipes/sopa/50/step/c476e45ed45e4ca88938a7096d291796> a schema1:HowToStep ;
    schema1:text "Poner el plátano verde previamente rociado con limón."@es .

<http://example.org/recipes/sopa/50/step/c76f1768d34c4c3c860af37c528034a0> a schema1:HowToStep ;
    schema1:text "Para finalizar rectifique la sazón y agregue el orégano."@es .

<http://example.org/recipes/sopa/51/step/291779e17f5f46d19988ff897b6d7c59> a schema1:HowToStep ;
    schema1:text "Pasado este tiempo agregamos la papa, yuca, platanos y choclos. Todos picados en trozos."@es .

<http://example.org/recipes/sopa/51/step/4a32a9ce72874a8abc5d2c9f8682a12c> a schema1:HowToStep ;
    schema1:text "En un sarten pequeño agregamos aceite, ajo, cebolla blanca y larga, achiote y sofreimos. Cuando este listo el sofrito lo agregamos a la olla."@es .

<http://example.org/recipes/sopa/51/step/4e72ae886bee4f62bbfb0401ef3fb730> a schema1:HowToStep ;
    schema1:text "Luego para que agarre sabor, agregamos aceite, pimienta, sal, y comino. Dejamos que hierva 30 minutos."@es .

<http://example.org/recipes/sopa/51/step/e646061416b84ff7b16a653454d5f379> a schema1:HowToStep ;
    schema1:text "En una olla agregamos 2 litros de agua, el cilantro, pimiento verde, apio en trocitos, 5 dientes Ajo y la cebolla picada en cuadros."@es .

<http://example.org/recipes/sopa/51/step/fb2a0153853344b6996e9a9bb70d5185> a schema1:HowToStep ;
    schema1:text "Listo para servir y disfrutar."@es .

<http://example.org/recipes/sopa/52/step/25bbdfd3bfdd4d9c9bf189a021578ca1> a schema1:HowToStep ;
    schema1:text "No tape la olla y deje que se cuezan a término medio; incorpore los fideos, la leche y continúe la cocción hasta que las bolas floten y el fideo esté suave."@es .

<http://example.org/recipes/sopa/52/step/666531268aa5463c95bf2bfa1b2596de> a schema1:HowToStep ;
    schema1:text "Incorpore el agua y deje hervir por 15 minutos."@es .

<http://example.org/recipes/sopa/52/step/69eaadac467045fd9717ca2cef565d7b> a schema1:HowToStep ;
    schema1:text "Apague el fuego y reserve en caliente."@es .

<http://example.org/recipes/sopa/52/step/7358ffb47be24ac9a65c0c4243007ab0> a schema1:HowToStep ;
    schema1:text "Rectifique la sazón y sirva de inmediato."@es .

<http://example.org/recipes/sopa/52/step/ba6b1948fba742978a6964046fa3c908> a schema1:HowToStep ;
    schema1:text "Incorpore el aceite de color restante, salpimiente; agregue los camarones picados, las dos cucharadas de refrito que reservó, la albahaca picada fino; intégrelo todo hasta obtener una pasta muy bien amalgamada."@es .

<http://example.org/recipes/sopa/52/step/c11f4a3bec9d4fde8b7619502d89546a> a schema1:HowToStep ;
    schema1:text "Tome porciones del tamaño de un limón sutil y forme bolitas; agréguelas al caldo hirviendo."@es .

<http://example.org/recipes/sopa/52/step/de9c13b0a9584ebf8e5e023046cdb34e> a schema1:HowToStep ;
    schema1:text "Lleve una olla al fuego y haga un refrito con una cucharada de aceite de color, la cebolla, el cilantro picado y el orégano; reserve 2 cucharadas del refrito."@es .

<http://example.org/recipes/sopa/52/step/f2844b930a4c493d8927e6608373755e> a schema1:HowToStep ;
    schema1:text "Pele los verdes y rállelos, colóquelos en un bol."@es .

<http://example.org/recipes/sopa/53/step/2ae90c5aa50044dcbc0d0af0eae7c9ec> a schema1:HowToStep ;
    schema1:text "Retire del fuego, deje reposar unos minutos, reserve una taza de ingredientes sólidos para la decoración y licúe."@es .

<http://example.org/recipes/sopa/53/step/2c8520f431084ac48f95bf9f06814b68> a schema1:HowToStep ;
    schema1:text "Atraviese los camarones con palillos para que mantengan su forma, salpimiente; fríalos en aceite con achiote 2 minutos por lado."@es .

<http://example.org/recipes/sopa/53/step/5ed69f18632a4bb8aeb03cc95b7a0d0b> a schema1:HowToStep ;
    schema1:text "En 4 litros de agua fría empiece la cocción de las cabezas de pescado con el apio, una cebolla troceada, un ajo picado, la sal y la pimienta."@es .

<http://example.org/recipes/sopa/53/step/6dd1f10606e6488fbb28bbe0b2e07fb5> a schema1:HowToStep ;
    schema1:text "Sirva la crema disponiendo en cada plato una porción de sólidos y llenando el resto con la crema."@es .

<http://example.org/recipes/sopa/53/step/7081ab6c968443b6875eb780a50e8976> a schema1:HowToStep ;
    schema1:text "Añada el caldo reservado, el perejil, el tomillo, remueva y deje cocer por 15 minutos."@es .

<http://example.org/recipes/sopa/53/step/718b65ee44b84a39898dcf7e283b8d96> a schema1:HowToStep ;
    schema1:text "Incorpore el zapallo, la yuca, el verde y el mote, deje cocer por 5 minutos más."@es .

<http://example.org/recipes/sopa/53/step/9086fb90675246f3a51c6bcb7a1b73fa> a schema1:HowToStep ;
    schema1:text "Cueza por 30 minutos espumando de vez en cuando; retire del fuego, cuele y reserve el caldo."@es .

<http://example.org/recipes/sopa/53/step/94902a54a9dc4a05af66120ea660f03e> a schema1:HowToStep ;
    schema1:text "Regrese la crema al fuego y añada la leche de coco, la arveja y la tilapia cortada en cubos, deje hervir por 5 minutos más; sazone con la sal y la pimienta, retire del fuego."@es .

<http://example.org/recipes/sopa/53/step/a77ad5e05e1145deb4d32f21a161d6d1> a schema1:HowToStep ;
    schema1:text "En una olla caliente la mantequilla y el aceite, sofría la cebolla y el ajo restante picados fino, hasta que estén transparentes."@es .

<http://example.org/recipes/sopa/53/step/d8c57cba9498421fa0662fa065cd6c93> a schema1:HowToStep ;
    schema1:text "Decore con los camarones y la tilapia."@es .

<http://example.org/recipes/sopa/54/step/9cc59e80946842b981300e828ddab788> a schema1:HowToStep ;
    schema1:text "Decore con crema y acompañe con papas fritas."@es .

<http://example.org/recipes/sopa/54/step/a429375a7a1e4333ab511fa64ecd96af> a schema1:HowToStep ;
    schema1:text "Vuelva a agregar la carne bien picadita al consomé. Rectifique el sabor con sal y pimienta y cocine por unos 5 minutos. Retire del fuego y deje reposar."@es .

<http://example.org/recipes/sopa/54/step/a5ef74ecc87b4539b11e16a3916f3e18> a schema1:HowToStep ;
    schema1:text "Lleve al fuego una olla con agua, sal, el ajo, la rama de culantro, la cebolla blanca y la carne."@es .

<http://example.org/recipes/sopa/54/step/b2378c7828c24a00b2b7bb3b01982025> a schema1:HowToStep ;
    schema1:text "Sirva el consomé tibio y coloque una porción de la crema de aguacate."@es .

<http://example.org/recipes/sopa/54/step/e84c3e2ebede42279b8c6d095fb810fd> a schema1:HowToStep ;
    schema1:text "Coloque en el vaso de la licuadora el aguacate pelado y en trozos con un poco de leche, para batirlo y formar una crema."@es .

<http://example.org/recipes/sopa/54/step/e9c27028eeec4e65b8fb7117b45db2e7> a schema1:HowToStep ;
    schema1:text "Cocine hasta que la carne esté suave. En ese punto retire la carne y proceda a picarla sacando los huesos."@es .

<http://example.org/recipes/sopa/55/step/23ab2d8607824a299c01816ebb057cd8> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, añadir el cilantro y rectificar la sal. Servir la sopa con aguacate y ají."@es .

<http://example.org/recipes/sopa/55/step/3de03d99862e4adeaac4a1109ae37ec2> a schema1:HowToStep ;
    schema1:text "Calentar el aceite en una olla grande, añadir la cebolla, el ajo, el comino, el achiote y la sal. Cocinar las cebollas durante unos 5 minutos hasta que estén suaves."@es .

<http://example.org/recipes/sopa/55/step/5604a6ba63834ccea14203ccc811389b> a schema1:HowToStep ;
    schema1:text "Agregar el agua a la preparación anterior y esperar hasta que hierva. Añadir los guineos verdes, reducir la temperatura y cocinar a fuego lento durante unos 25 minutos hasta que los guineos estén suaves."@es .

<http://example.org/recipes/sopa/55/step/9b8c6307e5854b2bbfa914cfbe239dd6> a schema1:HowToStep ;
    schema1:text "Añadir las arvejas cocinadas, mezclar bien y cocinar durante 5 minutos. Agregar el queso y la leche y cocinar durante 5 minutos adicionales, revolviendo de vez en cuando."@es .

<http://example.org/recipes/sopa/55/step/d223e1aee8c942f7a90c8f6014a28341> a schema1:HowToStep ;
    schema1:text "Cocinar previamente las arvejas en agua y sal hasta que estén tiernas."@es .

<http://example.org/recipes/sopa/56/step/0d4f05edd34c4efa9784ebee57f4de9f> a schema1:HowToStep ;
    schema1:text "Se hechan los fideos por 15 minutos, pendiente de la olla por que puede subir."@es .

<http://example.org/recipes/sopa/56/step/15ecec1d14db47de9e2a5b44cb069a76> a schema1:HowToStep ;
    schema1:text "Luego agregamos el achiote, la cebolla, el ajo triturado, comino, sal, pimienta al gusto y se revuelve bien."@es .

<http://example.org/recipes/sopa/56/step/246c1798cac6426cbed0a1ca6fbecb35> a schema1:HowToStep ;
    schema1:text "Ya pasados los 15 minutos probamos qué estén las papas y los fideos."@es .

<http://example.org/recipes/sopa/56/step/613bb0c0664c4a8e945c40e23dd304de> a schema1:HowToStep ;
    schema1:text "Una vez listo agregamos cilantro picadito y servimos."@es .

<http://example.org/recipes/sopa/56/step/7da993bc0dd34ac4ba812b535c80a2f7> a schema1:HowToStep ;
    schema1:text "En una olla se coloca el aceite que venía en la lata de atún, para hacer el sofrito."@es .

<http://example.org/recipes/sopa/56/step/926cce8aa7fd48409bdb6feb8c52c5a5> a schema1:HowToStep ;
    schema1:text "Se le incorpora el pimiento y cilantro picado."@es .

<http://example.org/recipes/sopa/56/step/adff920ad33a4185bd29426ac1390b66> a schema1:HowToStep ;
    schema1:text "Mientras se sofríe se van agregando las papas, los choclos y se dejan 3 minutos."@es .

<http://example.org/recipes/sopa/56/step/b84fad3a49ed42369ea10e71e809a0b3> a schema1:HowToStep ;
    schema1:text "Se agrega el litro y medio de agua caliente para no detener la cocción."@es .

<http://example.org/recipes/sopa/57/step/34fda4fd979d4b428c10279cf2392385> a schema1:HowToStep ;
    schema1:text "Añadir el tomate licuado, el ajo picadito, el condimento sabora, una cucharadita de comino y una pizca de pimienta negra. Remover todo muy bien y se deja sofreír por unos 3 minutos."@es .

<http://example.org/recipes/sopa/57/step/8177bc2958c94122ac32ac356ed44f2b> a schema1:HowToStep ;
    schema1:text "Sirva acompañado de canguil."@es .

<http://example.org/recipes/sopa/57/step/8cd976b453bc46efaef3df6e03e0b8c3> a schema1:HowToStep ;
    schema1:text "Se añadan las papas, un punto de sal y el agua caliente. Dejar cocinar."@es .

<http://example.org/recipes/sopa/57/step/a1e25cd3f4f34855ab49bb645511d851> a schema1:HowToStep ;
    schema1:text "Deshacer las papas dentro la sopa y en ese punto se agrega la leche. Deje que hierva unos 5 minutos y agregue el queso fresco."@es .

<http://example.org/recipes/sopa/57/step/bf5a98cea16c4e49aa452945abc66bf9> a schema1:HowToStep ;
    schema1:text "Aparte colocar una sartén al fuego con un poco de aceite y se agrega la avena. Remover y dejar que la avena adquiera un dolor dorado. Reserve."@es .

<http://example.org/recipes/sopa/57/step/cc242707afcc461a9cf0d4eb22685f09> a schema1:HowToStep ;
    schema1:text "Llevar al fuego una olla y agregar el aceite de achiote. Sofreír la cebolla por unos minutos."@es .

<http://example.org/recipes/sopa/57/step/e42bf271eaf8469e978ed0c8329ceb12> a schema1:HowToStep ;
    schema1:text "Se incorpora la avena a la sopa y se deja hervir por unos 20 minutos."@es .

<http://example.org/recipes/sopa/58/step/3ae16fd92d104eafaa7924ff70d0952e> a schema1:HowToStep ;
    schema1:text "Agregar media taza de leche y servir."@es .

<http://example.org/recipes/sopa/58/step/730980fa38cf4b73adc34cf44545686e> a schema1:HowToStep ;
    schema1:text "Poner sobre la harina un poco de caldo hirviendo, la mantequilla, mezclar y añadir la yema de huevo y la sal"@es .

<http://example.org/recipes/sopa/58/step/b0b001999a7b4666a5a5c8505c90d762> a schema1:HowToStep ;
    schema1:text "Mantener en el fuego sin tapar la olla, hasta que las papas y las bolas estén cocidas"@es .

<http://example.org/recipes/sopa/58/step/ef40b869dd9342fd93380899c8d7ca86> a schema1:HowToStep ;
    schema1:text "Pelar las papas y cortarlas en cuaditos, luego ponerlasa en el caldo junto con la col y la zanahoria."@es .

<http://example.org/recipes/sopa/58/step/f2550a79ea814081a9c99d79c6084c6c> a schema1:HowToStep ;
    schema1:text "Hacer las bolas de tamaño de una bola de pingpong, poner en el centro de cada una un pedazo de queso y saltarlas en la sopa cuando las papas estén en la mitad de su cocción."@es .

<http://example.org/recipes/sopa/59/step/17906ef86de24798b8a4a94a86775b68> a schema1:HowToStep ;
    schema1:text "Mezclar la harina, el huevo una pizca de sal y el aceite, amasar y formar las bolitas pequeñas."@es .

<http://example.org/recipes/sopa/59/step/3d3facd840a8475283418fe3aecb1c1c> a schema1:HowToStep ;
    schema1:text "Agregar un poco de leche dejar hervir unos minutos."@es .

<http://example.org/recipes/sopa/59/step/5d305ab798b8453da73993665694557f> a schema1:HowToStep ;
    schema1:text "Realizar un refrito con la cebolla, pimiento y el aceite de achiote."@es .

<http://example.org/recipes/sopa/59/step/7570f6ac4518419798bcb21b0657df73> a schema1:HowToStep ;
    schema1:text "Añadir agua al refrito hasta que hierva."@es .

<http://example.org/recipes/sopa/59/step/bc7b230e82864ed5a0376d8160a5fc4a> a schema1:HowToStep ;
    schema1:text "Lanzar el queso antes de apagar luego retirar para servir caliente."@es .

<http://example.org/recipes/sopa/59/step/fa0e55a436a645e3897448b95bc08f98> a schema1:HowToStep ;
    schema1:text "Ubicar aceite en un sartén y freír las bolitas hasta que estén doradas."@es .

<http://example.org/recipes/sopa/59/step/fce73015756648caa1d3d2b54c6a6b7f> a schema1:HowToStep ;
    schema1:text "Agregar las bolitas fritas al agua hirviendo"@es .

<http://example.org/recipes/sopa/6/step/110d66e5b21a474783a085b93b38fba3> a schema1:HowToStep ;
    schema1:text "Cocinar los cuadritos de la zanahoria hasta que estén blandos."@es .

<http://example.org/recipes/sopa/6/step/118846a8b5e14a4e97d0946be3145c33> a schema1:HowToStep ;
    schema1:text "Retirar las cebollas y el pimiento cuando ya estén cocidos."@es .

<http://example.org/recipes/sopa/6/step/6d169d8941b14252a5d35d024b668392> a schema1:HowToStep ;
    schema1:text "Agregar los trozos de choclo luego de unos 30 minutos que haya hervido el caldo."@es .

<http://example.org/recipes/sopa/6/step/6efeae8f8068403ca24b85cb574ede20> a schema1:HowToStep ;
    schema1:text "Refreír la carne picada en cuadritos, la cebolla picada, la zanahoria y el huevo con un poco de achiote."@es .

<http://example.org/recipes/sopa/6/step/7f1b40329fce43e8855aeb68c69de11e> a schema1:HowToStep ;
    schema1:text "Ubicar en una olla las costillas y poner a hervir, ir retirando la espuma que se va formando."@es .

<http://example.org/recipes/sopa/6/step/833b35105cf34762aacee5978cd1dc29> a schema1:HowToStep ;
    schema1:text "Verificar que el choclo y las albóndigas estén completamente cocidos, agregar el cilantro y los trozos de col, dejar cocinar unos minutos y retirar del fuego."@es .

<http://example.org/recipes/sopa/6/step/a727ecf228d945d09d74c5e00c2fd30c> a schema1:HowToStep ;
    schema1:text "Lanzar las albóndigas rellenas al caldo cuidadosamente para que no se desbaraten y a su vez lo que sobró del refrito también lanzarlo, esperar hasta que las bolitas floten en el caldo."@es .

<http://example.org/recipes/sopa/6/step/b4fb126427b645f48aa9f205803429c6> a schema1:HowToStep ;
    schema1:text "Lanzar la rama de cebolla blanca, el diente de ajo, la mitad de la cebolla paiteña, el pimiento, la sal, la pimienta y el comino."@es .

<http://example.org/recipes/sopa/6/step/fe4250aa4de94899aab38732556f18f1> a schema1:HowToStep ;
    schema1:text "Rayar el plátano verde, echarle un poco de achiote y amasarlo hasta que esté consistente, formar bolitas y rellenarlas con el refrito realizado en el paso anterior."@es .

<http://example.org/recipes/sopa/60/step/0f470280f9d84093a54fa8c621c9f4d2> a schema1:HowToStep ;
    schema1:text "Si se quiere mas cremosa se puede agregar leche. (Es opcional)."@es .

<http://example.org/recipes/sopa/60/step/74b081833d7a439eac1be7e02fa49203> a schema1:HowToStep ;
    schema1:text "Listo, se sirve con queso rayado por encima y un trocito de brócoli."@es .

<http://example.org/recipes/sopa/60/step/84264db1eee64d0db58f9fb198a86c64> a schema1:HowToStep ;
    schema1:text "En una olla colocar la mantequilla y calentar, cuando este derretida agregar la sopa licuada y cocinarla,."@es .

<http://example.org/recipes/sopa/60/step/8a23e0879ade4b54933fdb824791c471> a schema1:HowToStep ;
    schema1:text "En una olla se pone a hervir las papas con agua . Cuando estén las papas se agregan los brócoli por 5 minutos. Una vez listos se coloca el sazonador de pollo. Luego se licua con el agua."@es .

<http://example.org/recipes/sopa/60/step/c12943db3f324a5da32fa0f5b7a1a1d0> a schema1:HowToStep ;
    schema1:text "Al hervir colocar sal y pimienta."@es .

<http://example.org/recipes/sopa/61/step/11b68b60df18421093b9c7affbf71d9b> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, añadir el cilantro y servir."@es .

<http://example.org/recipes/sopa/61/step/5c35cf7ff2f0471995028ce518573bee> a schema1:HowToStep ;
    schema1:text "Retirar la cebolla y el pimiento cuando ya estén cocidos, agregar la zanahoria y las papas."@es .

<http://example.org/recipes/sopa/61/step/a2d60eaee51b45268ce7c4f8a5cfb5c6> a schema1:HowToStep ;
    schema1:text "Hervir con 1 taza de agua las cáscara del camarón por 5 minutos, dejar enfriar y licuar. Luego cernir el resultado del licuado."@es .

<http://example.org/recipes/sopa/61/step/b069099098684d1a9bf345151a44ffe7> a schema1:HowToStep ;
    schema1:text "Agregar 3 tazas de aguas con lo obtenido del licuado y poner al fuego en una olla, agregar la rama de cebolla blanca, el pimiento, el ajo y el achiote."@es .

<http://example.org/recipes/sopa/61/step/ee45aa981c8f49759359c778bc3cd534> a schema1:HowToStep ;
    schema1:text "Agregar la leche y el fideo cuando las papas y zanahorias estén suaves, verificar que el fideo esté en su punto y lanzamos los camarones, dejar cocinar 5 minutos, echar sal y pimienta al gusto."@es .

<http://example.org/recipes/sopa/62/step/0cca3063d50b411abdcada4d8e1e89ca> a schema1:HowToStep ;
    schema1:text "Retirar del fuego y listo para servir."@es .

<http://example.org/recipes/sopa/62/step/1b1381db171c4d52a0c9fb2cf65c029b> a schema1:HowToStep ;
    schema1:text "Agregar los cangrejos en una olla conjuntamente con el refrito, añadir agua hasta cubrir completamente los cangrejos."@es .

<http://example.org/recipes/sopa/62/step/2637b162569a4c439bd3f1c49c327f97> a schema1:HowToStep ;
    schema1:text "Disolver la pasta de maní con un poco agua y agregar a la sopa, dejar cocinar por 10 minutos más y remover lentamente."@es .

<http://example.org/recipes/sopa/62/step/65fd2556586b415fa0ba0ddcb5361d5f> a schema1:HowToStep ;
    schema1:text "Añadir los maduros a la sopa, dejar cocinar por 30 minutos."@es .

<http://example.org/recipes/sopa/62/step/8fb2db8bba3f4d3d8c26e9aacec6ea3d> a schema1:HowToStep ;
    schema1:text "Realizar el refrito con la cebolla blanca, colorada, el pimiento y el achiote."@es .

<http://example.org/recipes/sopa/63/step/41e0eb3c331447e391a01d0bb0c49f97> a schema1:HowToStep ;
    schema1:text "Cortar los verdes en rodajas finas."@es .

<http://example.org/recipes/sopa/63/step/549aa89473bd43c2ab0812bf156b6ed1> a schema1:HowToStep ;
    schema1:text "Agregar el huevo lentamente y revolver el caldo."@es .

<http://example.org/recipes/sopa/63/step/8311792297394b7d8eaeefc36ae33030> a schema1:HowToStep ;
    schema1:text "Calentar abundante aceite y freír las rodajas de verde con abundante aceite."@es .

<http://example.org/recipes/sopa/63/step/bb5f23e5e91b4a3c8be75ccaa32c0e31> a schema1:HowToStep ;
    schema1:text "Sazonar con sal y pimienta al gusto, sirva caliente."@es .

<http://example.org/recipes/sopa/63/step/bff4ca88c47443409afc9d42eb65a820> a schema1:HowToStep ;
    schema1:text "Retirar los chifles y extraer con servilletas de cocinas el exceso de aceite."@es .

<http://example.org/recipes/sopa/63/step/c6f0b6f5dfb04b6eb7729c52a2f7ab3a> a schema1:HowToStep ;
    schema1:text "Agregar agua al refrito y dejar hervir, echar la leche y continuar la cocción por 5 minutos."@es .

<http://example.org/recipes/sopa/63/step/cfeac51886d843fab33408b3673e8f45> a schema1:HowToStep ;
    schema1:text "Realizar un refrito con achiote y cebolla."@es .

<http://example.org/recipes/sopa/63/step/f27b1dd449b34e9e897aca8c9080d402> a schema1:HowToStep ;
    schema1:text "Lanzar los chifles y trocee en pedazos pequeñas con la mano y agregar al caldo junto con el queso rallado cocinar unos minutos más (3 minutos)."@es .

<http://example.org/recipes/sopa/64/step/1563843448154044aa5137b4b052062e> a schema1:HowToStep ;
    schema1:text "Preparar una mezcla con leche, harina y huevos. Pase las gajos de coliflor por la mezcla y fría en una sartén aceite bien caliente."@es .

<http://example.org/recipes/sopa/64/step/3f93e77f61f440809ed340f3661f81f1> a schema1:HowToStep ;
    schema1:text "En una cacerola colocar el caldo de verduras con la pechuga de pollo. Agregar cebolla picada, y condimentar con sal, pimienta y comino. Cocinar hasta que el pollo ablande."@es .

<http://example.org/recipes/sopa/64/step/600e5a9411f24dc8bfa49e5225f3ae80> a schema1:HowToStep ;
    schema1:text "Lavar bien la coliflor y separarle los gajos."@es .

<http://example.org/recipes/sopa/64/step/6e32b19671714cb7a07e8bda5de322cd> a schema1:HowToStep ;
    schema1:text "Cocinar el coliflor en agua con un poco de sal hasta que esté blando. Retire y reserve los gajos del coliflor cocidos."@es .

<http://example.org/recipes/sopa/64/step/f842460dab814187940e7859df963bab> a schema1:HowToStep ;
    schema1:text "Limpiar bien la pechuga de pollo y cortar en trozos."@es .

<http://example.org/recipes/sopa/65/step/214d519f4a9c4abab339464a5eb0513f> a schema1:HowToStep ;
    schema1:text "Agregar el fideo y cocinar hasta que estén cocidos."@es .

<http://example.org/recipes/sopa/65/step/2babb4b3c520435ba659ce6261dc4eda> a schema1:HowToStep ;
    schema1:text "Agregar agua y las papas y dejar hervir unos minutos."@es .

<http://example.org/recipes/sopa/65/step/6f03158749404f47af0b68a54897d008> a schema1:HowToStep ;
    schema1:text "Añadir la leche y el queso cuando las papas y el fideo estén blandos."@es .

<http://example.org/recipes/sopa/65/step/7e8e890bd10d4a37b8721342de3b44f3> a schema1:HowToStep ;
    schema1:text "Realizar un refrito con el aceite de achiote y la cebolla blanca."@es .

<http://example.org/recipes/sopa/65/step/cbe2138fb9694dcd8c2a9b652939c439> a schema1:HowToStep ;
    schema1:text "Echar el perejil picado finamente y servir"@es .

<http://example.org/recipes/sopa/65/step/f2824db239bf45b695e187b0ff1fe421> a schema1:HowToStep ;
    schema1:text "Agregar la sal y mantequilla y retirar del fuego."@es .

<http://example.org/recipes/sopa/66/step/149a33f3771a449e9637e0ebb5b897c3> a schema1:HowToStep ;
    schema1:text "Cocinar hasta que las papas y las habichuelas estén blanda y el caldo un poco espeso."@es .

<http://example.org/recipes/sopa/66/step/168df9b51cab4802ba46a5c0d16b1ecf> a schema1:HowToStep ;
    schema1:text "Agregar las papas y habichuelas, en el caso de que se vaya consumiendo el líquido agregar más agua caliente."@es .

<http://example.org/recipes/sopa/66/step/210d23da7969490c9088b8087ee1c195> a schema1:HowToStep ;
    schema1:text "Agregar la sal, el achiote, los dientes de ajo, el comino en polvo, la cebolla y el perejil."@es .

<http://example.org/recipes/sopa/66/step/659fae03ccc24f9aaf5155caa02abb29> a schema1:HowToStep ;
    schema1:text "Comprobar el nivel de sal y sirva caliente la sopa."@es .

<http://example.org/recipes/sopa/66/step/98c83e11045546f1a970d28bcd7309cb> a schema1:HowToStep ;
    schema1:text "Ubicar en una olla las costillas dejar hervir e ir retirando la espuma que se va formando."@es .

<http://example.org/recipes/sopa/66/step/df08d2c9303449c8a07c421ec94ffec5> a schema1:HowToStep ;
    schema1:text "Cubrir bien con agua y cocinar hasta que la carne esté suave."@es .

<http://example.org/recipes/sopa/67/step/2fa71324be2e49df84fd08a101bd6512> a schema1:HowToStep ;
    schema1:text "En licuadora batir el pimiento, el ajo y la cebolla con un poco de agua. Incorporarlo a la olla con las lentejas y añadir el achiote y las papas. Cocinar hasta que ablanden."@es .

<http://example.org/recipes/sopa/67/step/3b7b530387184d399a6f6208702d3cc2> a schema1:HowToStep ;
    schema1:text "Se agregan los fideos con unas dos tazas de agua y la albahaca fresca. Cocinar hasta que los fideos se ablanden y se rectifica el sabor. Por último se añade el orégano, la mantequilla, la leche y el queso, y se espera unos 5 minutos para retirar del fuego."@es .

<http://example.org/recipes/sopa/67/step/4683d099cfff4a4684a6189e75854f43> a schema1:HowToStep ;
    schema1:text "Remojar la lenteja en agua por una hora."@es .

<http://example.org/recipes/sopa/67/step/97301912fa9a437f8e2412e8c7aba588> a schema1:HowToStep ;
    schema1:text "Llevar al fuego una olla con las lentejas y el agua donde se remojaron."@es .

<http://example.org/recipes/sopa/67/step/b18cd6e7e6954ac0b58f6e4e282c20bc> a schema1:HowToStep ;
    schema1:text "Servir bien caliente y disfrutar."@es .

<http://example.org/recipes/sopa/68/step/1e5ca727d7f54cb5873e2288ebb4f727> a schema1:HowToStep ;
    schema1:text "Lanzar agua caliente y las lentejas sobre el refrito, dejar que ablanden un poco las lentejas."@es .

<http://example.org/recipes/sopa/68/step/71c7c7fc76f84c3c95c54fa573026dac> a schema1:HowToStep ;
    schema1:text "Lanzar el queso y apagar la sopa, lista para servir."@es .

<http://example.org/recipes/sopa/68/step/7d54da06977b4d3a98d79bf145572188> a schema1:HowToStep ;
    schema1:text "Lavar las lentejas, realizar el refrito con el aceite con achiote, la cebolla y los dientes de ajo picados."@es .

<http://example.org/recipes/sopa/68/step/dbb164f4dbdd4d2eb5d4a2785a1e1a23> a schema1:HowToStep ;
    schema1:text "Echar la leche, sal y las papas, esperar hasta que todo esté suave."@es .

<http://example.org/recipes/sopa/69/step/221e67f4f19c495eb6e643947a2f84f7> a schema1:HowToStep ;
    schema1:text "Servir caliente en cazuelas individuales."@es .

<http://example.org/recipes/sopa/69/step/2747941f51284105a9ce92a1ee957ced> a schema1:HowToStep ;
    schema1:text "Dorar los huesos de chancho en aceite sazonado. Reservar."@es .

<http://example.org/recipes/sopa/69/step/4ade247c51ac4ffa869a6811541b10a7> a schema1:HowToStep ;
    schema1:text "Agregar a la cacerola el agua, el refrito y las tazas de morocho y cocinar por 15 minutos."@es .

<http://example.org/recipes/sopa/69/step/cc5cb11114a44e7e8f0bfaeb149509f4> a schema1:HowToStep ;
    schema1:text "A la preparación de la cacerola incorporar las papas y cocinar hasta que se encuentren blandas."@es .

<http://example.org/recipes/sopa/69/step/d403086b361342c1840aa25524aaeeb4> a schema1:HowToStep ;
    schema1:text "Comenzar realizando un sofrito con la cebolla, el tomate y el ajo, hasta que estén dorados."@es .

<http://example.org/recipes/sopa/7/step/02537ef558f04f04aa2ac1c5e7c77191> a schema1:HowToStep ;
    schema1:text "Añadir la carne y un litro y medio de agua caliente. Dejar hervir por unos 15 minutos."@es .

<http://example.org/recipes/sopa/7/step/50ffd9927ee245fbab05e5fcadeaea5f> a schema1:HowToStep ;
    schema1:text "Con la masa de verde hacer bolas y rellenar la preparación de la sartén."@es .

<http://example.org/recipes/sopa/7/step/7421e5fefcc94ffa9a47c5b81e87c895> a schema1:HowToStep ;
    schema1:text "Agregar a la cacerola las papas, zanahoria, el choclo, las arvejas y los porotos y cocinar a fuego lento unos 15 minutos más."@es .

<http://example.org/recipes/sopa/7/step/94b278f9a80a451e8105b6860e0c420d> a schema1:HowToStep ;
    schema1:text "En otra cacerola cocinar los verdes hasta que estén tiernos y salar."@es .

<http://example.org/recipes/sopa/7/step/a4efbbcd2b4a4b25ae5f48dbac455aeb> a schema1:HowToStep ;
    schema1:text "Colocar en una cacerola una cebolla y el morrón rojo picados, condimentar y sofreír."@es .

<http://example.org/recipes/sopa/7/step/f0d512faf99e4a95a7ab6f3ee74a40a7> a schema1:HowToStep ;
    schema1:text "En una sartén colocar la otra cebolla con paprika y ajo y añadir la mitad de la carne que se cocinó en el caldo."@es .

<http://example.org/recipes/sopa/7/step/fc86d458b47349488a5cac9787218751> a schema1:HowToStep ;
    schema1:text "Colocar las bolas dentro del caldo y servir caliente."@es .

<http://example.org/recipes/sopa/70/step/1ce32bd2fa884003be80744f043fd29d> a schema1:HowToStep ;
    schema1:text "Agregue los huesos de cerdo y remueva todos los ingredientes. Cubra con agua y cocine por unos 30 minutos hasta que la carne esté bien cocida."@es .

<http://example.org/recipes/sopa/70/step/63396e7d192742939d6a2293b89a6a73> a schema1:HowToStep ;
    schema1:text "Incorpore las papas y se deja cocinar por otros 10 minutos"@es .

<http://example.org/recipes/sopa/70/step/92a19a659fef45bfb69cb7f73dea8c9f> a schema1:HowToStep ;
    schema1:text "Sirva caliente con un poco de cilantro y acompañe de rodajas de aguacate."@es .

<http://example.org/recipes/sopa/70/step/d9aa7935bc04490fbd18531d22c5c8ec> a schema1:HowToStep ;
    schema1:text "Luego se añade más agua y se deja hervir por 15 minutos."@es .

<http://example.org/recipes/sopa/71/step/53a611ec09be49df9a1be6fc77119e4b> a schema1:HowToStep ;
    schema1:text "Hacer un refrito con el tomate, la cebolla y el ajo, agregue 8 tazas de agua, el refrito y el morocho."@es .

<http://example.org/recipes/sopa/71/step/86b5e352fcff4edfada5c79b974b2d20> a schema1:HowToStep ;
    schema1:text "Incorporar la papa y cocinar hasta que la papa esté suave, incorporar la col y cocine durante 3 minutos más, rectifique sabores con sal, pimienta y comino."@es .

<http://example.org/recipes/sopa/71/step/ac28ed755ed249b58c3fac9508255f7a> a schema1:HowToStep ;
    schema1:text "Decorar con carne de cerdo desmenuzada y ají."@es .

<http://example.org/recipes/sopa/71/step/b0ff2952289b4449bb7fd1f21f270a31> a schema1:HowToStep ;
    schema1:text "​​​Dorar los huesos de chancho en aceite de achiote con sal y pimienta."@es .

<http://example.org/recipes/sopa/71/step/b4c8496867ea45bebfa6073fef7f57c4> a schema1:HowToStep ;
    schema1:text "Vocinar durante 15 minutos."@es .

<http://example.org/recipes/sopa/72/step/3ea515d9c79c45b3b5aa8e406ae336e9> a schema1:HowToStep ;
    schema1:text "En una olla coloque aceite de achiote y sofría cebolla blanca con el ajo por unos 2 minutos."@es .

<http://example.org/recipes/sopa/72/step/42dad604f9d14c019d734cf3007dad0b> a schema1:HowToStep ;
    schema1:text "Sirva y coloque el queso ecuatoriano por encima."@es .

<http://example.org/recipes/sopa/72/step/4b58e5a6f37542b4b81518e9c45488bf> a schema1:HowToStep ;
    schema1:text "Añada una pizca de comino, sal y pimienta. Asimismo incorpore las papas, el perejil, el cilantro y sofría por 3 minutos."@es .

<http://example.org/recipes/sopa/72/step/a23d3ddc99d4461abf92a9eb62656b95> a schema1:HowToStep ;
    schema1:text "Luego añada la leche y se deja hervir. Luego agregue la crema de leche."@es .

<http://example.org/recipes/sopa/72/step/c0a0d43628524d8fa412852bba521206> a schema1:HowToStep ;
    schema1:text "Incorpore el morocho junto con el agua de cocción, remueva constantemente para que la sopa se cocine adecuadamente y estará lista cuando las papas estén blandas."@es .

<http://example.org/recipes/sopa/73/step/1323dfb353d841d194f025d394f66e41> a schema1:HowToStep ;
    schema1:text "Añadir el orégano y se retira del fuego."@es .

<http://example.org/recipes/sopa/73/step/71ecc2b4c7384148ab2d9f424d9920e6> a schema1:HowToStep ;
    schema1:text "Añadir el agua caliente, las papas, zapallo, choclo y las habas. Tapar y cocinar por unos 20 minutos."@es .

<http://example.org/recipes/sopa/73/step/a2365bab5bb64812bf2161e4afa629b0> a schema1:HowToStep ;
    schema1:text "Agregar el nabo cortado. Se sazona con un punto de sal y se deja cocinar por 3 minutos más."@es .

<http://example.org/recipes/sopa/73/step/f04c2059bd4c43f785df055e14073566> a schema1:HowToStep ;
    schema1:text "En una olla colocar el aceite de achiote y sofreír la cebolla hasta que quede transparente."@es .

<http://example.org/recipes/sopa/73/step/f0d0c6fafa7944cb94c8a849bcf666df> a schema1:HowToStep ;
    schema1:text "Luego se incorpora la leche, el queso y se deja que hierva por 5 minutos."@es .

<http://example.org/recipes/sopa/74/step/53ce6c3ea17441f29b473198bf17b0f5> a schema1:HowToStep ;
    schema1:text "Luego agregamos la zanahoria, la ramita de cilantro, arveja y papa picada. Dejamos al fuego."@es .

<http://example.org/recipes/sopa/74/step/54cb573e9b7848acb9074f52bda430bd> a schema1:HowToStep ;
    schema1:text "Luego en otro envase hacemos un picadito de cilantro y cebolla colorada para decorar el plato."@es .

<http://example.org/recipes/sopa/74/step/ae5a2cd274d641de9fefba93a62cb055> a schema1:HowToStep ;
    schema1:text "Aparte picamos la cebolla larga y se la agregamos a la olla. Se le agrega color, sal, oregano y tapamos. Dejamos cocinar."@es .

<http://example.org/recipes/sopa/74/step/bf1df5b009d543aca8dffa6c3867ac77> a schema1:HowToStep ;
    schema1:text "Tomamos cada rodaja de platano verde, lo aplastamos con un rodillo hasta aplastarlos todos y los agregamos a la olla para que se terminen de cocinar. Aproximadamente 10 minutos."@es .

<http://example.org/recipes/sopa/74/step/cf896cb1bb504bde825b45f7a9c95484> a schema1:HowToStep ;
    schema1:text "Procedemos a cortar los platanos verdes y los freimos al termino de patacon. Los colocamos en papel absorvente."@es .

<http://example.org/recipes/sopa/74/step/d9a871b0b0de4c45b5a891426d7ecb58> a schema1:HowToStep ;
    schema1:text "Para servir colocamos en cada plato, carne, patacon y cilantro picado. Adicionamos la ensaladita picada, arroz blanco y aguacate."@es .

<http://example.org/recipes/sopa/74/step/ea51360a85514c4085eccef185ddc704> a schema1:HowToStep ;
    schema1:text "Una vez que la carne este blanda lo apagamos y dejamos reposar."@es .

<http://example.org/recipes/sopa/74/step/ee87caa391754dd09d6ae42c8fd04fd9> a schema1:HowToStep ;
    schema1:text "En una olla agregamos 2 litros de agua y se lleva al fuego. Cuando este hirviendo se le agrega la costilla de cerdo. Dejamos cocinar por 15 minutos."@es .

<http://example.org/recipes/sopa/75/step/c2a1c909697f46fcba984c2aa636d3ce> a schema1:HowToStep ;
    schema1:text "Luego que esten las papas se agrega el fideo partido a la olla, la media taza de crema de leche y la leche. Revolvemos bien."@es .

<http://example.org/recipes/sopa/75/step/c7b1f60b252742c3a79bed0585e77b52> a schema1:HowToStep ;
    schema1:text "Dejamos espesar de 15 a 20 minutos. Por ultimo agregamos el ajo y cilantro picadito."@es .

<http://example.org/recipes/sopa/75/step/cfb53df1cca648de923d7767b15c901f> a schema1:HowToStep ;
    schema1:text "Seguido de esto agregamos el guiso, el acento y revolvemos bien. Luego vamos agregando los huevo por toda la olla."@es .

<http://example.org/recipes/sopa/75/step/e897fbbab7c64bd3af50d0306f876871> a schema1:HowToStep ;
    schema1:text "En una olla con agua agregamos cilantro, cimarron, sal al gusto, las papas y auyama. Una vez que este hirviendo agregamos un poquito de achiote."@es .

<http://example.org/recipes/sopa/75/step/f09da54e92314e6782c72fbaf94a58b4> a schema1:HowToStep ;
    schema1:text "En un sarten aparte agregamos 2 cucharaditas de aceite, 2 cebollas largas o de cabeza, 1/2 taza de tomate, caldo de gallina y revolvemos bien. Luego agregamos color. Dejamos cocinar por 5 minutos."@es .

<http://example.org/recipes/sopa/76/step/32d04c17a8a94d049767eb58808fc84e> a schema1:HowToStep ;
    schema1:text "Agregar la carne de cerdo y mezclar bien. Cocinar durante 5 minutos."@es .

<http://example.org/recipes/sopa/76/step/39f28b53d14e401fb4cf9092fbaf390a> a schema1:HowToStep ;
    schema1:text "Añadir el agua y hervir, reducir la temperatura y cocine a fuego durante 30 minutos."@es .

<http://example.org/recipes/sopa/76/step/b484770a4d4848418df93ef9de3e9e7e> a schema1:HowToStep ;
    schema1:text "Calentar en una olla el aceite a fuego medio y agregar la cebolla, sal y comino. Cocinar durante unos 5 minutos, revolviendo de vez en cuando."@es .

<http://example.org/recipes/sopa/76/step/e45aec4c7bb24aa7bc5a113bdfae91fe> a schema1:HowToStep ;
    schema1:text "Reducir la temperatura y cocinar a fuego lento durante 20 minutos o hasta que las papas se ablanden."@es .

<http://example.org/recipes/sopa/76/step/e6c40a534b5940d1838d3800833ec4e3> a schema1:HowToStep ;
    schema1:text "Agregar la quinua cocida, las papas, el maní y la leche, aumentar la temperatura y hervir nuevamente."@es .

<http://example.org/recipes/sopa/76/step/fb1bfe70fee0444aa08cc2a1d2efa119> a schema1:HowToStep ;
    schema1:text "Añadir el perejil y sal al gusto. Servir la sopa de quinua con aguacate, cebollas encurtidas y ají."@es .

<http://example.org/recipes/sopa/77/step/4bd04089c1614d8bb9c1602609ab32be> a schema1:HowToStep ;
    schema1:text "Picar la cebolla, el pimiento rojo y los dientes de ajo en trozos pequeños, luego sofreir en en un cacerola añadiendo aceite de oliva."@es .

<http://example.org/recipes/sopa/77/step/98aa3af9a4c647c8b4a3932d38ef59fb> a schema1:HowToStep ;
    schema1:text "Dejar cocer a fuego moderado durante 30 minutos. Cuando haya adquirido un color rojizo, apagar y dejar que entibie. Batir hasta conseguir una textura cremosa y lisa."@es .

<http://example.org/recipes/sopa/77/step/ad3851dd20774b6aae31ac4c805ef47f> a schema1:HowToStep ;
    schema1:text "Retirar los tomates, dejarlos que se enfrien un poco y quitarles la piel y las semillas."@es .

<http://example.org/recipes/sopa/77/step/ad65b97539e8487e8c751a47caa3d643> a schema1:HowToStep ;
    schema1:text "Picar los tomates en trozos pequeños y luego triturarlos."@es .

<http://example.org/recipes/sopa/77/step/ce44180f8a814c58bf1ffce234f1e588> a schema1:HowToStep ;
    schema1:text "Colocar una hoja de laure, de perejil o de menta en el centro o un lado del plato."@es .

<http://example.org/recipes/sopa/77/step/cf1410692d8144b7933ad26a7899a076> a schema1:HowToStep ;
    schema1:text "Incorporar los tomates y el pollo al sofrito y añadir 1 cucharada de azúcar para quitar la acidez. y luego cubra con 1 litro de agua."@es .

<http://example.org/recipes/sopa/77/step/e43f8b634d594091b8d523d01a65545b> a schema1:HowToStep ;
    schema1:text "Colocar una olla llena de agua a hervir. Luego incorporar los tomates por 1 minuto aproximadamente."@es .

<http://example.org/recipes/sopa/77/step/ed0209f7146e4e558bb15a7211a0ad05> a schema1:HowToStep ;
    schema1:text "Cocinar el pollo y desmenuzarlo."@es .

<http://example.org/recipes/sopa/78/step/6acb9e6bd32f44ceb79fd77adea05f1c> a schema1:HowToStep ;
    schema1:text "Agregar en una olla agua el hueso de res, retirar la espuma que se va formando."@es .

<http://example.org/recipes/sopa/78/step/78d6296ea5a149efab409c7ce62f9c45> a schema1:HowToStep ;
    schema1:text "Retirar el fuego y servir con cilantro y la cebolla blanca picada."@es .

<http://example.org/recipes/sopa/78/step/8897d2ac005a40d981cc7cbca1c45aeb> a schema1:HowToStep ;
    schema1:text "Agregar el choclo y el hueso carnudo, cocinar unos minutos hasta que estén blandos, añadir los trozos de col, la sal y pimienta."@es .

<http://example.org/recipes/sopa/78/step/a0661115049542bea5664fa3bc886f4f> a schema1:HowToStep ;
    schema1:text "Refreír con el aceite de oliva la cebolla perla, la zanahoria y pimiento rojo, añadir al caldo."@es .

<http://example.org/recipes/sopa/78/step/a355bfdd0f444977a25be5a53fe739c2> a schema1:HowToStep ;
    schema1:text "Retirar del fuego, cernir el caldo en otra olla y ubicar al fuego el caldo nuevamente, reservar el hueso carnudo y el choclo."@es .

<http://example.org/recipes/sopa/78/step/fe0a702e6b7444fe9fdd4cef3b96d031> a schema1:HowToStep ;
    schema1:text "Añadir las 2 cebollas de rama y los dientes de ajo, añadir el choclo y tapar, dejar hervir hasta que estén cocidos."@es .

<http://example.org/recipes/sopa/79/step/0510e693b69d4ee5933f729c602aacc7> a schema1:HowToStep ;
    schema1:text "Colocar en un sarten el aceite para freír la masa, la cual pondremos en forma de pequeñas tortitas del tamaño de una cuchara para sopa. Dorar ligeramente."@es .

<http://example.org/recipes/sopa/79/step/6db6d16c786e4db281942fce30f56bc6> a schema1:HowToStep ;
    schema1:text "Colocar en un recipiente los huevos junto con la harina y un poco de sal y mezclar hasta formar una masa."@es .

<http://example.org/recipes/sopa/79/step/749d338cdf1c4e8c9b10820a82df294c> a schema1:HowToStep ;
    schema1:text "Agregar los ingredientes que picamos a la olla donde hirvió la pechuga de pollo"@es .

<http://example.org/recipes/sopa/79/step/755b6b7ba84349049515eabf715ed776> a schema1:HowToStep ;
    schema1:text "Agregar agua de a poco para que la masa no quede ni muy gruesa, ni muy fluída. Una vez realizada la mezcla colocar el perejil picadito y mezclar de nuevo."@es .

<http://example.org/recipes/sopa/79/step/a1c217575e1442e4816f4ff4dba7f876> a schema1:HowToStep ;
    schema1:text "Colocar en una olla el agua, la pechuga de pollo, la hoja de laurel, el comino y la sal. Colocar al fuego medio, para cocinar la pechuga por 40 minutos."@es .

<http://example.org/recipes/sopa/79/step/a9ca6a8bafed4d1da174677d787c359f> a schema1:HowToStep ;
    schema1:text "Sacar y trocear la pechuga para dividirla para los comensales junto a a los vegetales. Agregar a las sopas las tortitas fritas."@es .

<http://example.org/recipes/sopa/79/step/bc8a12845b644fc4a80a4abd91bfee3b> a schema1:HowToStep ;
    schema1:text "Pelar y picar la zanahoria en trozos, el ajo, la cebolla blanca, la cebolla colorada y las papas."@es .

<http://example.org/recipes/sopa/8/step/3b81d81d552f47eeb706965a0cf60bf8> a schema1:HowToStep ;
    schema1:text "Agarramos un poco de carne hacemos una abertura en el centro y agregamos el queso, luego cerramos y damos forma de bolita o albóndiga y agregamos al caldo."@es .

<http://example.org/recipes/sopa/8/step/a2554e5e802c46bfb0512185ecd47ca3> a schema1:HowToStep ;
    schema1:text "Sofreímos cebolla, ajo partido, pure de tomate y tomate en cuadritos. Revolvemos bien."@es .

<http://example.org/recipes/sopa/8/step/a40bb2bd37654a08b1efe74d4646960c> a schema1:HowToStep ;
    schema1:text "Aproximadamente una hora después esta listo para servir."@es .

<http://example.org/recipes/sopa/8/step/c3024d53f6124c3d9a137a58ad5d9b70> a schema1:HowToStep ;
    schema1:text "Preparamos la carne o albondigas. Le colocamos pan, sal pimienta leche y un huevo."@es .

<http://example.org/recipes/sopa/8/step/d77094e4b9b34882933b9a296e58cd38> a schema1:HowToStep ;
    schema1:text "Agregamos el agua, mas de 2 litros y revolvemos bien. Una vez que hierva agregamos las albóndigas."@es .

<http://example.org/recipes/sopa/8/step/f0571eb988874d8eb88e54bcabb35801> a schema1:HowToStep ;
    schema1:text "Revolvemos bien y verifiquemos que esten blandas las verduras."@es .

<http://example.org/recipes/sopa/8/step/ffe46ac2fa4f4948a8bdab304e3629ea> a schema1:HowToStep ;
    schema1:text "Luego agregamos las verduras."@es .

<http://example.org/recipes/sopa/80/step/16adef12a5424a8d8d15e795bee0d7d9> a schema1:HowToStep ;
    schema1:text "Agregar las verduras a la cacerola y continuar la cocción."@es .

<http://example.org/recipes/sopa/80/step/474a4905d5aa4932a12827fc7e2007e6> a schema1:HowToStep ;
    schema1:text "Comenzar cocinando a fuego medio el pollo con las especias en 2 litros de agua, por unos 30 minutos."@es .

<http://example.org/recipes/sopa/80/step/4fa1eeb337174cfcadd2098ce4dc1a5f> a schema1:HowToStep ;
    schema1:text "Por ultimo agregar las tortitas calientes a la sopa."@es .

<http://example.org/recipes/sopa/80/step/5802c88598684aa5a634afbce558affb> a schema1:HowToStep ;
    schema1:text "En un bol mezclar los huevos con la harina y un poco de sal hasta formar una masa, agregarle perejil fresco picado."@es .

<http://example.org/recipes/sopa/80/step/59cef3fa28b8440bb3829f9cb0a38755> a schema1:HowToStep ;
    schema1:text "Pelar y trozar las verduras en pequeños cubos."@es .

<http://example.org/recipes/sopa/80/step/657afc8c7dad4d8eb5b2e93f689222cd> a schema1:HowToStep ;
    schema1:text "Servir en pequeñas cazuelas."@es .

<http://example.org/recipes/sopa/80/step/b0375724424f4e8fa1b072ccea0e451b> a schema1:HowToStep ;
    schema1:text "En un sartén calentar aceite y freír la masa en forma de pequeñas tortitas hasta dorar de ambos lados."@es .

<http://example.org/recipes/sopa/81/step/0294ecd7d9994cb681813e198195d459> a schema1:HowToStep ;
    schema1:text "Cubir con el caldo, dejándolo cocer despacio hasta que las verduras estén casi cocidas"@es .

<http://example.org/recipes/sopa/81/step/7f6d6c57356e419d8d2307811b6a5092> a schema1:HowToStep ;
    schema1:text "Añadir la papa cortada en tiritas, Deja en el fuego unos veinte minutos más."@es .

<http://example.org/recipes/sopa/81/step/9fb709e7565b40a3a07427c80ff9f951> a schema1:HowToStep ;
    schema1:text "Freír con mantequilla la cebolla finamente picadal, as zanahorias y el nabo cortados en juliana, el repollo cortado finamente, los guisantes y una cucharada de perejil picado"@es .

<http://example.org/recipes/sopa/81/step/b3f9ea1115284181ba37fc91c4e2111c> a schema1:HowToStep ;
    schema1:text "Añadir sal al gusto y servir caliente"@es .

<http://example.org/recipes/sopa/82/step/3311883569c2494e9337350e80cfe0d7> a schema1:HowToStep ;
    schema1:text "Luego agregamos el ajo y revolvemos bien. Despues que este bien sofrito agregamos las papas previamente peladas y cortadas. Mezclamos bien para que tomen color."@es .

<http://example.org/recipes/sopa/82/step/644ab2aae654421c824ab99ca1fd56e4> a schema1:HowToStep ;
    schema1:text "Pasada media hora revisamos y revolvemos. Agregamos la leche y la crema de leche hasta que las papas se deshagan."@es .

<http://example.org/recipes/sopa/82/step/74cc5dd3375841e2b375b125b7b7b61e> a schema1:HowToStep ;
    schema1:text "Seguido de esto agregamos agua hasta cubrir las papas."@es .

<http://example.org/recipes/sopa/82/step/acb7741909e84816aa5e5ef757793404> a schema1:HowToStep ;
    schema1:text "Ya que este espeso apagamos y acompañamos con aguacate y queso."@es .

<http://example.org/recipes/sopa/82/step/b6bd1793759146be9fd320d553b108ad> a schema1:HowToStep ;
    schema1:text "En una olla colocamos el achiote en conjunto con la mantequilla. Revolvemos bien y agregamos la cebolla. Una vez sofrito agregamos el comino, la pimienta y la sal."@es .

<http://example.org/recipes/sopa/82/step/ba6b7e71d81a4043bffc7f63d1f84efd> a schema1:HowToStep ;
    schema1:text "Una vez desintegradas las papas rectificamos la sal y revolvemos."@es .

<http://example.org/recipes/sopa/83/step/115c1a3cdcd64f0b8fa224e908425581> a schema1:HowToStep ;
    schema1:text "Cocinar por 1 hora aproximadamente."@es .

<http://example.org/recipes/sopa/83/step/47cdc8832e1a4e99b02c715eb98b8aff> a schema1:HowToStep ;
    schema1:text "Sazonar con sal pimienta y comino al gusto"@es .

<http://example.org/recipes/sopa/83/step/7af22f1793404ef7a5b69c809e917c62> a schema1:HowToStep ;
    schema1:text "Preparar en una olla el refrito con la cebolla blanca, la cebolla colorada, el tomate, el cilantro, el perejil y el aceite de color."@es .

<http://example.org/recipes/sopa/83/step/a5266cd54773469f98838bb3bc8cb543> a schema1:HowToStep ;
    schema1:text "Servir inmediatamente con patacones o arroz."@es .

<http://example.org/recipes/sopa/83/step/a7ae6839d2804552a056c72385f58f41> a schema1:HowToStep ;
    schema1:text "Mezclar y agregar tres litros de agua hirviendo; tape y deje cocinar por 10 minutos a fuego lento."@es .

<http://example.org/recipes/sopa/83/step/c1f76aa2177b4a05bc62f0053518a3fc> a schema1:HowToStep ;
    schema1:text "Lavar los mariscos y agregar las almejas, las conchas y las patas de cangrejo."@es .

<http://example.org/recipes/sopa/83/step/f67293afd664458c97e90e892ee554dc> a schema1:HowToStep ;
    schema1:text "Agregar el maní, el pescado y los camarones, dejar cocinar por 15 minutos a fuego lento."@es .

<http://example.org/recipes/sopa/84/step/08f058d2527549a2a46ae4003334c817> a schema1:HowToStep ;
    schema1:text "Introducir en la cacerola el plátano cortado en rodajas y rociado con limón."@es .

<http://example.org/recipes/sopa/84/step/13394f58cc604b2db3beebaf53521f2c> a schema1:HowToStep ;
    schema1:text "Servir caliente y espolvoreado con perejil."@es .

<http://example.org/recipes/sopa/84/step/4119b149365a42d5933eefaceae04083> a schema1:HowToStep ;
    schema1:text "Agregar la cebolla y el tomate en cubos, los choclos cortados en rodajas y cocinar por media hora más."@es .

<http://example.org/recipes/sopa/84/step/58e24ac6f35743979f4fbfc70845b655> a schema1:HowToStep ;
    schema1:text "Cuando el choclo este tierno agregar la yuca y cocinar hasta que quede suave, salpimentar."@es .

<http://example.org/recipes/sopa/84/step/f5c44e5def2845559b40173356ba605d> a schema1:HowToStep ;
    schema1:text "Comenzar por hervir el hueso en agua con sal por media hora."@es .

<http://example.org/recipes/sopa/85/step/2ff20c10d71d4e7db1c0111e5e852161> a schema1:HowToStep ;
    schema1:text "Licuar el maní con la mitad de la leche. Reserve."@es .

<http://example.org/recipes/sopa/85/step/a2e1896a83be4c5c91cc017fb5448bf0> a schema1:HowToStep ;
    schema1:text "En una cacerola, agregue el caldo con las costillas, las papas, las hojas de col y las ramas de cebolla picaditas. Sazone con sal y pimienta y cocine hasta que ablanden las papas."@es .

<http://example.org/recipes/sopa/85/step/a33145ae2d7d41e284b8fedbcee4e937> a schema1:HowToStep ;
    schema1:text "Cocinar las costillas de res en una olla de presión con suficiente agua por unos 35 minutos aproximadamente."@es .

<http://example.org/recipes/sopa/85/step/b3bb7a064c5f4856be97a76fc3d6dbf4> a schema1:HowToStep ;
    schema1:text "En una sartén, coloque el aceite a calentar y sofría la cebolla y el ajo. Añada el licuado de maní y un poco de caldo de res. Añada el mote, el resto de la leche, el huevo duro picado. Rectifique el sabor."@es .

<http://example.org/recipes/sopa/86/step/0fbe2cb537c74a9c9a73b42f511cd974> a schema1:HowToStep ;
    schema1:text "Calentar 2 cucharadas de aceite en una olla grande y agregar el achiote, una cebolla cortada, el cilantro, el comino, pimienta y ajo. Cocinar durante 5 minutos."@es .

<http://example.org/recipes/sopa/86/step/1411e83c32de41b0a68023ca0fdc3349> a schema1:HowToStep ;
    schema1:text "Dejarlo reposar durante unos minutos y lavarlo nuevamente con agua fría."@es .

<http://example.org/recipes/sopa/86/step/5688318a7745429a88b3e0a163c26021> a schema1:HowToStep ;
    schema1:text "Colocar la sangre cocida en una fuente plana y desmenuzarla con los dedos cuidando extraer todas las impurezas."@es .

<http://example.org/recipes/sopa/86/step/59cdef608ce84f9abc4b60356350f5f9> a schema1:HowToStep ;
    schema1:text "Colocar el menudo en una olla de presión, agregar suficiente agua y cocinar hasta que se ponga suave. Retirar el menudo del caldo y cortarlo finamente."@es .

<http://example.org/recipes/sopa/86/step/6c229b7f0209498e8b518f59d2a093ae> a schema1:HowToStep ;
    schema1:text "Calentar en una sartén el aceite y agregar la sangre, la pimienta, el perejil, una cebolla cortada. Sofreír bien hasta que la sangre quede frita."@es .

<http://example.org/recipes/sopa/86/step/aecc32f9777f42d996965a8dfcb31696> a schema1:HowToStep ;
    schema1:text "Servir el yahuarlocro bien caliente con la sangre encima acompañada de una rodaja de aguacate, una rodaja de tomate y cebolla encurtida."@es .

<http://example.org/recipes/sopa/86/step/c7a44ba9fc764a209436014d43a260b8> a schema1:HowToStep ;
    schema1:text "Lavar el menudo con abundante agua, después agregar 2 cucharadas de sal, el jugo de los limones y las hojas de hierba buena. Estrujar todo el menudo hasta que salga la película amarillenta que lo recubre."@es .

<http://example.org/recipes/sopa/86/step/d83e93e7633e4f11a5fe0086ae7ab976> a schema1:HowToStep ;
    schema1:text "Agregue las papas y el maní disuelto en la leche, tapar y hervir durante 15 minutos. Añadir el caldo del menudo y dejar que se cocinen bien las papas. Antes de retirar la olla del fuego agregar el menudo picado."@es .

<http://example.org/recipes/sopa/86/step/f13de5c175304835bfac75531056f15e> a schema1:HowToStep ;
    schema1:text "Aparte, colocar la sangre en una olla con 2 litros de agua hirviendo y sal. Cocinar durante 30 minutos. Retirar del fuego y colar el agua."@es .

<http://example.org/recipes/sopa/9/step/112271c263924b1390eb7d6ff29710bd> a schema1:HowToStep ;
    schema1:text "Colar el caldo y ponerlo nuevamente al fuego. Agregar la yuca y cocinar durante unos 30 minutos hasta que esté suave."@es .

<http://example.org/recipes/sopa/9/step/1b2b2ca1ea7545f9ad5f307f114273f1> a schema1:HowToStep ;
    schema1:text "Agregar la cabeza de bagre y cocinar durante 5 minutos adicionales. Añadir el agua y cocinar a fuego lento durante 40 minutos."@es .

<http://example.org/recipes/sopa/9/step/2bef2a2300bd44af8aea94b5afb1bb7d> a schema1:HowToStep ;
    schema1:text "Añadir las rodajas de bagre y cocinar a fuego lento durante unos 15 minutos."@es .

<http://example.org/recipes/sopa/9/step/3a4e99248e804f149c007da3214c5b27> a schema1:HowToStep ;
    schema1:text "Calentar en una olla el aceite y agregar el ajo, la cebolla, los tomates, el cilantro, el comino, sal y pimienta. Cocinar durante 5 minutos."@es .

<http://example.org/recipes/sopa/9/step/8112b977d86e418ca2ef393d7bcef2d0> a schema1:HowToStep ;
    schema1:text "Servir el caldo de bagre bien caliente con cebolleta finamente cortada encima y limón."@es .
