<http://example.org/recipes/bebida/47> a schema1:Recipe ;
    schema1:description "El jugo o batido de guayaba se consume en todo el Ecuador, incluso en las islas galápagos es muy apetecido."@es ;
    schema1:name "Jugo de guayaba"@es ;
    schema1:recipeCategory "Bebida"@es ;
