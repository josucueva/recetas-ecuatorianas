        <http://example.org/recipes/postre/4/step/f86d7655a22b477c91e661c8798b8d2e> ;
    schema1:recipeYield 10 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/40> a schema1:Recipe ;
    schema1:description "La piña es una de las frutas exóticas muy común de Ecuador, con la cual se prepara un gran número de postres como la mermelada de piña. Para preparar este dulce, además de la piña, se utiliza otros ingredientes como azúcar o panela rallada, canela, clavos de olor, cardamomo, cedrón y zumo de limón."@es ;
    schema1:name "Mermelada de Piña"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 piña madura entera"@es,
        "1 rajita de canela"@es,
        "3 clavos de olor"@es,
        "Jugo de un limón"@es,
        "½ taza de agua"@es,
        "½ taza de azúcar (o panela rallada)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/40/step/56598d9b9ca24652b811f1016570e3fe>,
        <http://example.org/recipes/postre/40/step/86663c75571a4f928666eaa49d095dda>,
        <http://example.org/recipes/postre/40/step/88020bc95cfe448f94d73d6c822ac2be>,
