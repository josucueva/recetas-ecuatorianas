<http://example.org/recipes/entrada/60> a schema1:Recipe ;
    schema1:description "Las humitas son un plato típico de la región andina de Ecuador y se suelen servir con café en la tarde o para el desayuno, aunque son deliciosas a cualquier hora. Las humitas son pastelitos envueltos que se preparan con choclos o maíz tierno y queso."@es ;
    schema1:name "Humitas"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cucharadita de sal"@es,
        "1 cucharadita de semillas de cilantro en polvo"@es,
        "1 taza de cebolla picada finamente"@es,
        "2 dientes de ajo machacados"@es,
        "2 huevos"@es,
        "3 tazas de queso rallado o desmenuzado"@es,
        "6 o 7 mazorcas de choclos o maíz tierno con las hojas"@es,
        "¼ taza de crema líquida (o nata líquida)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/60/step/2e0f26293491452d823d286792a17840>,
        <http://example.org/recipes/entrada/60/step/3b08007e04b941c582083d3a5088cb74>,
