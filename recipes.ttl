<http://example.org/recipes/postre/57> a schema1:Recipe ;
    schema1:description "Los tradicionales quimbolitos son pasteles dulces autoctonos del Ecuador con la particularidad de ser cocidos al vapor envueltos en hojas de la planta de achira."@es ;
