        <http://example.org/recipes/postre/20/step/fe09a210d5234b4c9fe75617648ae093> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/21> a schema1:Recipe ;
    schema1:description "El sambo es un fruto que en el país se desarrolla de forma silvestre en laderas y quebradas, principalmente de las provincias la sierra, en dónde se elaboran sopas, coladas y dulces."@es ;
    schema1:name "Dulce de sambo"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 lb de azúcar morena"@es,
        "1 sambo maduro de 2 kg"@es,
        "Canela"@es,
        "Clavos de olor"@es,
        "Ralladura de naranja"@es,
        "½ lb de nueces o almendras partidas y peladas"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/21/step/67b31924c44c4b63b7dc335a820f277e>,
