        <http://example.org/recipes/plato-principal/17/step/e50421e4d22b440eb100cdbc5c20a09f> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/18> a schema1:Recipe ;
    schema1:description "Para la preparación de los carapachos de cangrejo rellenos se utilizan las caparazones de los cangrejos, crustáceos que abundan en las costas ecuatorianas"@es ;
    schema1:name "Carapachos de cangrejo rellenos"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharadita de esencia de vainilla"@es,
        "1 cucharadita de mantequilla"@es,
        "2 maduros"@es,
        "4 aceitunas"@es,
        "4 carapachos de cangrejo"@es,
