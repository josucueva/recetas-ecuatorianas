<http://example.org/recipes/plato-principal/76> a schema1:Recipe ;
    schema1:description "La menestra de lentejas es un plato típico ecuatoriano que se prepara cocinando las lentejas con cebolla, pimiento, tomate, ajo, comino y cilantro. Las menestras son algo típico de la Costa en Ecuador, pero se puede encontrar en la casi todas las ciudades del país. El nombre completo de este plato es arroz con menestra de lentejas y carne asada"@es ;
    schema1:name "Menestra de Lentejas"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada cortada en cubos pequeños"@es,
        "1 cucharadita de achiote molido"@es,
        "1 pimiento verde cortado en cubos pequeños"@es,
        "2 cucharaditas de comino molido"@es,
        "3 cucharadas de aceite"@es,
        "3 tomates cortados en cubos pequeños"@es,
        "4 cucharadas de cilantro finamente cortado"@es,
        "6 dientes de ajo machacados"@es,
        "7 tazas de agua"@es,
        "Sal al gusto"@es,
        "½ kilo de lentejas lavadas"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/76/step/245d8509e45c4e27a2808a6b8397c4cc>,
        <http://example.org/recipes/plato-principal/76/step/4f220c225af84c799077cc965580f400>,
        <http://example.org/recipes/plato-principal/76/step/e42209ba4ee94a5888ca18750c0503da> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/77> a schema1:Recipe ;
    schema1:description "Rica mezcla de sabores al probar un bocado de moro con papas chauchas. Compuesto de arroz, vegetales y lentejas."@es ;
    schema1:name "Moro con papas chauchas"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de achiote"@es,
        "1 pimiento verde"@es,
        "1 taza de cebolla picada"@es,
        "1 taza de lentejas remojadas por 2 horas"@es,
        "2 cucharadas de hiervita"@es,
        "2 cucharadas de mantequilla"@es,
        "2 tazas de arroz"@es,
        "3 dientes de ajo"@es,
        "Sal pimienta y comino al gusto"@es ;
