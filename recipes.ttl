<http://example.org/recipes/postre/48> a schema1:Recipe ;
    schema1:description "El postre \"Negro en camisa\" es un Mousse de chocolate que está ganando popularidad en Ecuador gracias a los migrantes venezolanos que han llegado al territorio."@es ;
    schema1:name "Negro en camisa"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 litro de leche"@es,
        "10 yemas de huevo"@es,
        "2 ramas de canela o vainilla"@es,
        "2 tazas de agua"@es,
        "5 claras de huevo"@es,
        "½ lb de azúcar"@es,
        "½ lb de chocolate en polvo (semi amargo)"@es,
        "½ lb de mantequilla"@es,
        "½ taza de harina para repostería"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/48/step/1a6a032b9cbd489d8270b27fab5694d7>,
        <http://example.org/recipes/postre/48/step/2d7bb13888514e8eaf97b8d1280f0a3b>,
