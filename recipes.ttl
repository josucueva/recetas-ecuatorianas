<http://example.org/recipes/sopa/15> a schema1:Recipe ;
    schema1:description "Ecuador es un país con una gran diversidad de sopas dentro de su inventario gastronómico y uno de sus platos representativos es sin duda el caldo de pata, una deliciosa mezcla de texturas y sabores acompañados del tradicional mote."@es ;
    schema1:name "Caldo de Pata"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cucharadita de achiote molido"@es,
        "1 cucharadita de comino molido"@es,
        "1 cucharadita de orégano seco"@es,
        "1 manojo de cebolletas finamente cortadas"@es,
        "1 taza de leche"@es,
        "14 tazas de agua"@es,
        "2 cucharadas de aceite"@es,
        "2 dientes de ajo machacados"@es,
        "2 kilos de patas de res cortadas en trozos grandes"@es,
        "20 onzas de yuca pelada"@es,
        "4 cucharadas de mantequilla de maní"@es,
        "4 dientes de ajo enteros"@es,
        "4 tazas de mote cocido"@es,
        "5 ramitas de cilantro entero"@es,
        "5 ramitas de perejil entero"@es,
        "Sal y pimienta al gusto"@es,
        "½ cebolla blanca cortada en cubos"@es,
        "½ cebolla colorada cortada en cubos"@es,
        "½ manojo de cilantro finamente cortado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/15/step/0858c29571a34d37add68b09ebfaa221>,
        <http://example.org/recipes/sopa/15/step/20c7e326593349049dc04a8a2ead684a>,
        <http://example.org/recipes/sopa/15/step/42dfef05aac94db69b02a7c7ca2227b0>,
