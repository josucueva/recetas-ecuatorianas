<http://example.org/recipes/plato-principal/39> a schema1:Recipe ;
    schema1:description "El cuy es una especie de roedor que pesa cerca de 1 kg y que se puede encontrar en la región andina de Sudamérica, especialmente en Ecuador. Existen diversos platos en el cual el cuy es el ingrediente estrella, pero el más popular es el de cuy asado acompañado de papas."@es ;
    schema1:name "Cuy Asado con Papas"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla colorada finamente picada"@es,
        "1 cucharada de cilantro"@es,
        "1 cucharada de comino"@es,
        "1 cuy pelado"@es,
        "1 kilo de papas peladas"@es,
        "1 pizca de orégano"@es,
        "1 pizca de pimienta molida"@es,
        "2 ramitas de cebolletas finamente cortadas"@es,
        "8 cucharadas de aceite"@es,
        "8 dientes de ajo machacados"@es,
        "Sal a gusto"@es,
        "½ cucharadita de achiote"@es ;
