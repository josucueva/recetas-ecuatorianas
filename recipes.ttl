<http://example.org/recipes/entrada/45> a schema1:Recipe ;
    schema1:description "Las empanadas de mejido son tradicionales de la Sierra del Ecuador, estas jugosas empanadas fritas tiene un delicioso relleno de dulce mejido para saborear en familia."@es ;
