<http://example.org/recipes/plato-principal/110> a schema1:Recipe ;
    schema1:description "Los tallarines con cangrejo, es una receta deliciosa y muy sencilla de preparar. El cangrejo tiene el protagonismo en este caso, y es que la suavidad de su sabor, hacen de este plato una delicia al paladar. Anímate a aprender como prepararlo y sorprenderás a todos."@es ;
    schema1:name "Tallarines de cangrejo"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de aceite de achiote"@es,
        "1 cucharada de orégano"@es,
        "2 cebollas coloradas"@es,
        "2 cucharada de cilantro"@es,
        "2 cucharadas de pasta de tomate"@es,
        "2 hojas de laurel"@es,
        "3 cucharadas de margarina"@es,
        "3 tomates"@es,
        "300 gr de pulpa de cangrejo"@es,
        "4 dientes de ajo triturados"@es,
        "4 ramas de cebolla blanca"@es,
        "500 gr de fideo tallarín"@es,
        "Sal y comino al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/110/step/4352693bd0d542bdb88977a9cad7dcbb>,
        <http://example.org/recipes/plato-principal/110/step/51e464c85fe14670a0592466b0986a1e>,
