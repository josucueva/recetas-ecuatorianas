<http://example.org/recipes/postre/20> a schema1:Recipe ;
    schema1:description "El espectacular dulce de leche o manjar de leche, como es típicamente conocido en Ecuador, es un postre muy tradicional en latinoamérica. Es un postre que le encanta a todos y se consume como parte de otras delicias o simplemente solo. Anímate a prepararlo."@es ;
    schema1:name "Dulce de leche"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 litro de leche entera"@es,
        "100 gr de mantequilla"@es,
        "2 cucharadas de esencia de vainilla"@es,
        "3 tazas	de azúcar o panela molida"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/20/step/13cb8141cecc444aae26cdddbfe551b1>,
        <http://example.org/recipes/postre/20/step/5d4eb419a191431e9d41dd069339fda3>,
