<http://example.org/recipes/postre/1> a schema1:Recipe ;
    schema1:description "Los alfajores de manjar es uno de los dulces favoritos de las familias ecuatorianas, puedes encontrar los mejores alfajores en la provincia de Manabi."@es ;
