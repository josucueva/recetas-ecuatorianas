<http://example.org/recipes/entrada/64> a schema1:Recipe ;
    schema1:description "Los llapingachos ecuatorianos son un plato típico de la gastronomía del país, realizados con puré de papas y queso tienen la particularidad de prepararse con una papa que posee mucho almidón, dejandole una textura única."@es ;
    schema1:name "Llapingacho"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla blanca picada"@es,
        "2 cucharadas de aceite"@es,
        "300 gr de queso rallado"@es,
        "6 papas cholas"@es,
        "Sal"@es,
        "Una pizca de achiote"@es ;
    schema1:recipeInstructions <http://example.org/recipes/entrada/64/step/1687d3de10ed4ef7a0f173dfc48a2333>,
        <http://example.org/recipes/entrada/64/step/4bd9e2c444ae4f6dbb56a0b5ef811b39>,
        <http://example.org/recipes/entrada/64/step/6a0cc774a82e40a58d758d62d4ec4394>,
        <http://example.org/recipes/entrada/64/step/f1644814abd04aca83ff5d48edbb0cd7>,
        <http://example.org/recipes/entrada/64/step/fc48d94f0bfc48f2b9af3c1c3a5fb9df> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/entrada/65> a schema1:Recipe ;
    schema1:description "Los llapingachos son un plato típico ecuatoriano que consiste de tortillas de puré de papa rellenas con queso. Se sirven para el desayuno, como entrada o como acompañantes para muchos otros platos ecuatorianos. Los llapingachos se preparan con la papa chola, que es una variedad de papa con mucho almidón, para lograr la textura necesaria para que los llapingachos queden esponjosos."@es ;
    schema1:name "Llapingachos"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 taza de rallado o desmenuzado"@es,
        "2 cucharadas de aceite"@es,
        "2 cucharaditas de achiote molido"@es,
        "6 papas grandes peladas y cortadas en trozos medianos"@es,
        "Sal al gusto"@es,
        "½ taza de cebolla blanca picada finamente"@es ;
