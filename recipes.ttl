<http://example.org/recipes/bebida/35> a schema1:Recipe ;
    schema1:description "Es una bebida muy refrescante en los meses de calor. Preparada a base de almendras. Se sirve bien frio."@es ;
    schema1:name "Horchata de almendra"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 limón rayadura"@es,
        "1 vaso de azúcar"@es,
        "200 gr de almendras peladas"@es,
        "Canela"@es,
        "Un litro de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/35/step/1798599b7466431ab2934f5919e890b9>,
        <http://example.org/recipes/bebida/35/step/56105c042fe6412099305b965afcc821>,
