    schema1:recipeYield 10 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/56> a schema1:Recipe ;
    schema1:description "Refrescante bebida a base de naranjilas. Con un ligero toque de vainilla. Se sirve bien fria."@es ;
    schema1:name "Naranjilla ecuatoriana"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1/½ litro y medio de agua"@es,
        "4 naranjilla medianas"@es,
        "Esencia de vainilla"@es,
        "½ taza de azúcar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/56/step/056b4713909544cfadbcc155c3e7cf68>,
        <http://example.org/recipes/bebida/56/step/ab9eb6b729794983ad1228f3304c9e74>,
