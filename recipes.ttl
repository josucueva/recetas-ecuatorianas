<http://example.org/recipes/postre/44> a schema1:Recipe ;
    schema1:description "El mousse de dulce de leche es un postre que podrás realizar en poco tiempo y le va a encantar a los más pequeños de la casa. En Ecuador al dulce de leche se lo conoce también como manjar de leche"@es ;
    schema1:name "Mousse de dulce de leche"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 taza de crema de leche (250 ml)"@es,
        "1 taza de dulce de leche (250 ml)"@es,
        "4 claras de huevo"@es,
        "Galletas de vainilla, frutos secos tostados o praliné"@es,
        "½ lb de azúcar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/44/step/21a3db8c058946edba6f08e34ca8c6e9>,
        <http://example.org/recipes/postre/44/step/3edad540863b4db5ae30f75dd95380b5>,
        <http://example.org/recipes/postre/44/step/828d6d3ab22546b3888c8e3783f3adac>,
