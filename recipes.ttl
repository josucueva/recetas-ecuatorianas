    schema1:recipeYield 12 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/67> a schema1:Recipe ;
    schema1:description "El turrón es sin duda uno de los más característicos postres de la Navidad, en Ecuador puedes encontrarlos durante todo el año en pueblos de la costa y en la sierra ecuatoriana."@es ;
    schema1:name "Turrón dulce"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharadita de canela en polvo (opcional)"@es,
        "1 taza de almendras o avellanas tostadas y sin piel"@es,
        "1 ½ tazas de azúcar impalpable"@es,
        "2 claras de huevo"@es,
        "2 obleas"@es,
        "½ taza de azúcar"@es,
        "½ taza de miel de abeja"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/67/step/12ca0f1fe9f34c77b81decad610bc909>,
        <http://example.org/recipes/postre/67/step/15be3a15a87d48599681b942661a5913>,
