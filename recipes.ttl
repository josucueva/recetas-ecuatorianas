        <http://example.org/recipes/postre/37/step/965f66f5865544c488045bcc9aea3451>,
        <http://example.org/recipes/postre/37/step/c7f0cfefe884419e974435b4308d674f> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/postre/38> a schema1:Recipe ;
    schema1:description "Delicioso dulce característico de Ecuador. Muy suave compuesto por leche y azúcar. Con un toque de canela."@es ;
    schema1:name "Manjar blanco ecuatoriano"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 lts de leche"@es,
        "1 taza de azúcar"@es,
        "Canela al gusto"@es ;
