    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/bebida/40> a schema1:Recipe ;
    schema1:description "El Jucho es una bebida tradicional de la sierra ecuatoriana, considerada sagrada ya que se elaborada para agradecer la fertilidad de la Tierra. Se prepara a base de frutas exóticas como los capulíes y duraznos cocidos en almíbar. Su sabor es delicioso, ya que combina lo dulce de las frutas con lo aromático de las especias."@es ;
    schema1:name "Jucho"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 ½ litros de agua"@es,
        "10 duraznos pelados sin la semilla"@es,
        "100 gr de almidón de camote"@es,
        "100 gr de panela"@es,
        "2 tazas de azúcar"@es,
        "2 tazas de capulíes"@es,
        "5 astillas de canela"@es,
        "8 clavos de olor"@es,
        "8 granos de pimienta dulce"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/40/step/03bc1315830c4b20b89634e5745c844d>,
        <http://example.org/recipes/bebida/40/step/0ba54408f494486d9274fcacb0269253>,
        <http://example.org/recipes/bebida/40/step/8c13f836fca0453881282f09e3d66593>,
        <http://example.org/recipes/bebida/40/step/8d34c92305254a7895e3baebe1eb1f73>,
        <http://example.org/recipes/bebida/40/step/f4d6e1e5c0b9422dbf031d75dfd7653f> ;
    schema1:recipeYield 12 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/bebida/41> a schema1:Recipe ;
    schema1:description "El jugo de naranjillas con alfalfa, es una bebida natural muy saludable y nutritiva, que es del agrado de muchos ecuatorianos. Algunas variantes de jugo incluyen huevos de codorniz y otros se acompañan con “hielo del chimborazo”. Si deseas cuidar tu salud, no puedes dejar de probarlo."@es ;
    schema1:name "Jugo de alfalfa y naranjilla"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de agua"@es,
        "1 manojo de hojas de alfalfa"@es,
        "9 naranjillas maduras"@es,
        "Azúcar al gusto"@es,
        "Hielo"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/41/step/13d59946e28f4af6afc6fefd61afa118>,
        <http://example.org/recipes/bebida/41/step/2dcf71aa14ed467c8ec23163af0b1478>,
        <http://example.org/recipes/bebida/41/step/4ec61f9fd0194ad0b87903bd07b25993> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/42> a schema1:Recipe ;
    schema1:description "El jugo o batido de borojó es muy requerido por la población ecuatoriana ya que se le conoce como un afrodisíaco y se puede encontrar en casi todos los puestos de batidos o sorbetazos"@es ;
    schema1:name "Jugo de borojó"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 cucharada de vainilla"@es,
        "1 cucharita de nuez moscada"@es,
        "1 litro de leche"@es,
        "2 huevos batidos"@es,
        "2 litros de agua"@es,
        "2 tazas de azúcar"@es,
        "Hielo picado"@es,
        "½ lb de pulpa de borojó"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/42/step/2f86071491d742cc93b189cffb525908>,
        <http://example.org/recipes/bebida/42/step/5d4c0c14705242b8bdaffcc7db9896cb>,
        <http://example.org/recipes/bebida/42/step/7153c55c55aa4eafa9a9fdaf1a635481>,
        <http://example.org/recipes/bebida/42/step/7b21d843238f41f8a5d907b506d7ed9e>,
        <http://example.org/recipes/bebida/42/step/d1cfee129ffc43b38e9e0d567469d489> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT15M"^^xsd:duration .

<http://example.org/recipes/bebida/43> a schema1:Recipe ;
    schema1:description "La caña de azúcar es uno de los cultivos más antiguos del mundo y en el Ecuador existen grandes plantaciones especialmente en la provincia del Guayas, en las calles de casi todas las ciudades y pueblos podemos encontrar vendedores ambulantes de jugo de caña."@es ;
    schema1:name "Jugo de caña"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "2 cañas de azúcar medianas (80 cm aproximadamente)"@es,
        "Hielo"@es,
        "Jugo de limón, mandarina o agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/43/step/3a74b11eae3c42ee8b500cbc111729a9>,
        <http://example.org/recipes/bebida/43/step/4092646df6ae4358b926db18d3d7163e>,
