<http://example.org/recipes/sopa/32> a schema1:Recipe ;
    schema1:description "Este plato es popular en Ecuador en época de pascuas, las familias reciben a sus familiares en semana santa con una gastronomía típica de esa celebración. Deliciosa y alta en calorías."@es ;
    schema1:name "Fanesca"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla"@es,
        "1 lata de arvejas"@es,
        "1 lata de choclo"@es,
        "1 litro de leche"@es,
        "1 taza de queso rallado"@es,
        "2 latas de porotos blancos"@es,
        "2 tazas de arroz cocido"@es,
        "200 cc de crema de leche"@es,
        "50 gr de manteca"@es,
        "500 gr de bacalao seco remojado"@es,
        "500 gr de sambo"@es,
        "500 gr de zapallo"@es,
        "Achiote, comino, orégano seco, pimienta, cilantro"@es,
        "Sal"@es,
        "Una taza de maní tostado"@es ;
