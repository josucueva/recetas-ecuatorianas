<http://example.org/recipes/plato-principal/60> a schema1:Recipe ;
    schema1:description "El guiso de tatabra es un plato típico que forma parte de la culinaria esmeraldeña. Este es un platillo tradicional y exquisito que se elabora con carne de animales silvestres. Su sabor es delicioso y deleitará hasta los paladares más exigentes."@es ;
    schema1:name "Guiso de tatabra"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 kg de carne de tatabra ahumada"@es,
        "1 tableta de caldo de carne"@es,
        "1 taza de leche de coco"@es,
        "3 cebollas coloradas"@es,
        "3 dientes de ajo"@es,
        "6 ramas de cebolla blanca"@es,
        "Aceite de achiote"@es,
        "Sal y pimienta al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/60/step/16faa90a1e884b2492d09d72360e6ccc>,
        <http://example.org/recipes/plato-principal/60/step/40affe8aaa534e298efbe5f2dfeb8cf1>,
        <http://example.org/recipes/plato-principal/60/step/9c4fe73e61fa497eae042ad461b1ae04> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/plato-principal/61> a schema1:Recipe ;
    schema1:description "El guiso de venado es un estofado delicioso elaborado con carne de venado. La cultura gastronómica ecuatoriana incluye dentro de sus opciones el uso de carnes de caza, que en este caso poseen menos grasa y tienen un sabor muy especial. No deje de disfrutar de tan suculento plato."@es ;
    schema1:name "Guiso de venado"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de aceite de achiote"@es,
        "1 cucharada de perejil picadito"@es,
        "1 kg de carne de venado cortada en trozos"@es,
        "1 taza de yuca cocida"@es,
        "2 cebollas colorada cortada en cubos"@es,
        "2 tazas de tomate cortado en cubos"@es,
        "3 tazas de agua"@es,
        "4 dientes de ajo"@es,
        "Sal, pimienta y comino c/n"@es,
        "½ taza de salsa de tomate"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/61/step/8933d56f0fa54df0aab432e177ad88d1>,
        <http://example.org/recipes/plato-principal/61/step/bd72c6356fd748e7827e8b20a6cb545b>,
        <http://example.org/recipes/plato-principal/61/step/c00ade4bac374bea844ec43c37968e68>,
        <http://example.org/recipes/plato-principal/61/step/c020bec032ba4242aa7677a5b9f0dd8f>,
        <http://example.org/recipes/plato-principal/61/step/db1e5e9afe31487cacce5cbe3df6db60> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/62> a schema1:Recipe ;
    schema1:description "El hornado de chancho o cerdo es un plato típico de Ecuador. Se trata de un plato que contiene carne de cerdo principalmente cocinado en leña, acompañado de guarniciones ecuatorianas como el choclo, plátanos maduros fritos, aguacate, curtido de cebolla, lechuga, tomate y otros ingredientes dependiendo la región donde se prepare."@es ;
    schema1:name "Hornado de Chancho"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de pimienta molida"@es,
        "1 litro de chicha (o 10 tazas de cerveza)"@es,
        "10 papas medianas peladas y cortadas a la mitad"@es,
        "3 cucharadas de achiote molido"@es,
        "3 cucharadas de comino molido"@es,
        "3 cucharadas de sal"@es,
        "40 dientes de ajo machacados"@es,
        "8 onzas de mantequilla (o manteca)"@es,
        "Jugo de 3 limones"@es,
        "Una pierna entera de chancho (10 kilos)"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/62/step/1f7127f636b24b64ba8f577340f5d733>,
        <http://example.org/recipes/plato-principal/62/step/28e9182f09b5473dbd6beb3b4f1ff448>,
