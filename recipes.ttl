<http://example.org/recipes/plato-principal/113> a schema1:Recipe ;
    schema1:description "El tapao arrecho es un plato clásico de la gastronomía ecuatoriana, originario de Esmeraldas que se realiza con carne y verduras y el toque característico de los verdes de Ecuador."@es ;
    schema1:name "Tapao de arrecho"@es ;
