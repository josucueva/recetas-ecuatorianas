        "2 cucharadas de mantequilla"@es,
        "200 gr de almejas"@es,
        "200 gr de camarones"@es,
        "200 gr de mejillones"@es,
        "3 dientes de ajo triturados"@es,
        "6 filetes de corvina"@es,
        "Sal y pimienta c/n"@es,
        "½ taza de crema de leche"@es,
        "½ taza de vino blanco"@es ;
