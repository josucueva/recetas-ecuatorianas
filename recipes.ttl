        <http://example.org/recipes/plato-principal/41/step/c7a28714365845ddab74d4887a4fb040>,
        <http://example.org/recipes/plato-principal/41/step/e8b48fcd20984db693bd759be3376be8> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/42> a schema1:Recipe ;
    schema1:description "El encocado o encocada es un plato típico de todo Ecuador, consiste en carne de res, pescado, cerdo o pollo cocido en una deliciosa salsa de coco. En esta receta la variante sera con pescado."@es ;
    schema1:name "Encocada de pescado"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla blanca"@es,
        "1 coco fresco con su pulpa y agua"@es,
        "1 pizca de achiote"@es,
        "1 pizca de cilantro"@es,
        "1 pizca de comino"@es,
        "2 cucharadas de aceite"@es,
        "2 kg de corvina"@es,
        "2 pimientos rojos"@es,
        "3 cucharadas de cilantro fresco"@es,
        "4 dientes de ajo"@es,
        "4 tomates"@es,
        "Jugo de 2 limones"@es,
        "Jugo de 2 naranjas"@es,
        "Sal al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/42/step/0faf0d3d9aa94042aefa46f793e21419>,
        <http://example.org/recipes/plato-principal/42/step/4229c5356f9d4d61905ae29865efd0ad>,
        <http://example.org/recipes/plato-principal/42/step/a87ae98d73df4331a1d604355a01db53>,
        <http://example.org/recipes/plato-principal/42/step/ba3a556ddecc44c388b1d8abbbd39bec> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/43> a schema1:Recipe ;
    schema1:description "El encocado es uno de los platos típicos de Ecuador, se hacen encocados de pollo, de pescado, de camarón o langostinos, de concha. Pero una de las recetas más deliciosas que se pueden hacer con encocados es el encocado de cangrejo."@es ;
    schema1:name "Encocado de cangrejo"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 litro de agua"@es,
        "1 litro de crema de leche"@es,
        "1 sarta de 12 cangrejos"@es,
        "2 cocos rallados"@es,
        "4 cucharadas de harina"@es,
        "4 cucharadas de mantequilla"@es,
        "4 plátanos maduros"@es,
        "Sal al gusto"@es,
        "½ lb de azúcar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/43/step/1fe620ff5185414d8a10499f3007af86>,
        <http://example.org/recipes/plato-principal/43/step/20b3c28faf804eda870134f4f53912a4>,
        <http://example.org/recipes/plato-principal/43/step/2cee7a4f8dec4a94b9f2f782e6608b7d>,
