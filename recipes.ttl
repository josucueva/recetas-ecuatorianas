<http://example.org/recipes/plato-principal/41> a schema1:Recipe ;
    schema1:description "Este es uno de los platos típicos de Ecuador, se hacen de langostinos, pescado, pollo o como en este caso, de cangrejo. Una delicia!"@es ;
    schema1:name "Encocada de cangrejo"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 litro de agua"@es,
        "1 litro de crema de leche"@es,
        "12 cangrejos surtidos frescos"@es,
        "2 cocos rallados"@es,
        "200 gr de azúcar"@es,
        "25 gr de mantequilla"@es,
        "4 cucharadas de harina"@es,
        "4 plátanos maduros"@es,
        "Sal al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/41/step/1cfc284043224a3e9790618b44d362bc>,
        <http://example.org/recipes/plato-principal/41/step/3a28cc8bc89c40b78b8e825ee6fccaf3>,
