<http://example.org/recipes/sopa/35> a schema1:Recipe ;
    schema1:description "El locro de acelga es una sopa muy tradicional en los hogares ecuatorianos. Es recomendada para las personas que tienen baja cantidad de hierro en el organismo, ya que la acelga proporciona un alto contenido del mismo."@es ;
    schema1:name "Locro de Acelga"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cucharada de aceite"@es,
        "1 cucharada de cilantro cortado"@es,
        "1 diente de ajo machacado"@es,
        "1 kilo de papas peladas y cortada en trozos"@es,
        "1 ramita de cilantro entero"@es,
        "5 hojas de acelga bien lavadas y cortada"@es,
        "6 tazas de agua"@es,
        "Sal al gusto"@es,
        "¼ taza de leche"@es,
        "½ cebolla finamente cortada"@es,
        "½ kilo de costilla de res"@es,
        "½ zanahoria"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/35/step/4799cf0137a3494cb409075431f540af>,
