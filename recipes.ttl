<http://example.org/recipes/plato-principal/66> a schema1:Recipe ;
    schema1:description "En las fiestas navideñas y de fin de año de Ecuador el lechón es incluso más popular que el pavo, su excelente sabor y bajo costo hacen que sea infaltable para las celebraciones."@es ;
    schema1:name "Lechón navideño"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
