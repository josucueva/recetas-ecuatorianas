<http://example.org/recipes/plato-principal/90> a schema1:Recipe ;
    schema1:description "El delicioso pollo en salsa de maní es un plato bastante tradicional, con mucho sabor y es ideal para disfrutarlo en familia. Así que anímate a sorprender a todos con tan especial receta."@es ;
    schema1:name "Pollo en salsa de maní"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla perla picada en cubos"@es,
        "1 cucharada de ajo molido"@es,
        "1 cucharada de ají molido"@es,
        "1 ½ taza de agua"@es,
        "2 cucharadas de aceite de achiote"@es,
        "4 muslos de pollo"@es,
        "Pimienta"@es,
        "Sal"@es,
