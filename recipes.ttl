<http://example.org/recipes/postre/3> a schema1:Recipe ;
    schema1:description "El aplanchado es un postre clásico de la Sierra, en el Ecuador. Este dulce tradicional se realiza con hojaldre y azúcar glasé."@es ;
    schema1:name "Aplanchado"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 huevo"@es,
        "2 cucharaditas de polvo de hornear"@es,
