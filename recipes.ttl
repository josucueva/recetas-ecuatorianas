    schema1:recipeYield 5 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/entrada/32> a schema1:Recipe ;
    schema1:description "Los platanitos o chifles ecuatorianos son chips fritos de plátano verde. Son un snack que acompaña muy bien una cerveza fría."@es ;
