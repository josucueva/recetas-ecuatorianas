    schema1:recipeYield 10 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/26> a schema1:Recipe ;
    schema1:description "Las espumillas, también conocido como suspiritos o suspiros son un dulce muy popular en Ecuador. Se trata de una especie de espuma cremosa tipo merengue preparada con pulpa de guayaba, claras de huevo y azúcar. Se puede colorear, de manera que se encuentra en diversos colores."@es ;
    schema1:name "Espumillas"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1½ tazas de azúcar"@es,
        "2 claras de huevo"@es,
        "8 guayabas maduras"@es,
        "Arrope o salsa de mora"@es,
        "Grajeas y/o coco rallado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/26/step/2308ee5baa4642a6a095e1074e58fbee>,
        <http://example.org/recipes/postre/26/step/6272ad9c3394457a9d97c4c07ad2cff2>,
        <http://example.org/recipes/postre/26/step/dcced127c9044604a9d16f1eabee4a54> ;
    schema1:recipeYield 8 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/postre/27> a schema1:Recipe ;
    schema1:description "El flan de coco es un postre muy popular en Ecuador que se prepara con coco rallado, leche condensada, leche, huevos y azúcar. Este flan es un postre fácil de preparar que todos disfrutan."@es ;
    schema1:name "Flan de Coco"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 taza de coco rallado"@es,
        "1¼ taza de azúcar"@es,
        "2 tazas de leche"@es,
        "2 tazas de leche condensada"@es,
        "4 huevos"@es,
        "¼ taza de agua"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/27/step/071bfa2ea9074aefbed1a67c7db88fd8>,
        <http://example.org/recipes/postre/27/step/39d071fececc4866b6e4bd13fb9d8aea>,
