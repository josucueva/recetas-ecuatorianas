    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "1 cebolla blanca"@es,
        "1 cebolla paiteña"@es,
        "1 cucharada de cilantro picadito"@es,
        "1 rama de hierbabuena"@es,
        "100 gr de pasta de maní"@es,
        "2 cucharadas de aceite de achiote"@es,
        "2 cucharadas de harina de trigo"@es,
        "2 limones"@es,
        "200 gr de papas cholas"@es,
        "3 dientes de ajo"@es,
        "300 gr de tripa de res"@es,
        "320 ml de leche"@es,
        "50 ml de agua"@es,
