    schema1:recipeYield 20 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/sopa/1> a schema1:Recipe ;
    schema1:description "El aguado es una sopa tradicional muy antigua de Ecuador que se prepara con gallina o pollo y arroz. Es un plato nutritivo y delicioso, especialmente cuando se consume a mitad de la noche."@es ;
    schema1:name "Aguado de Gallina"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla colorada cortada en cubos"@es,
        "1 cucharadita de achiote molido"@es,
        "1 cucharadita de comino molido"@es,
        "1 cucharadita de orégano seco"@es,
        "1 kilo de presas de gallina"@es,
        "1 pimiento cortado en cubos"@es,
        "1 taza de zanahorias cortadas en cubos"@es,
        "2 cucharadas de aceite o mantequilla"@es,
        "2 cucharadas de cilantro finamente cortado"@es,
        "2 cucharadas de perejil finamente cortado"@es,
        "2 papas peladas y cortadas en trozos"@es,
        "6 dientes de ajo machacados"@es,
        "8 tazas de agua"@es,
        "Sal y pimienta al gusto"@es,
        "¾ de taza de arroz sin cocer"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/1/step/287aee8d4d6549ea80458624b9038dd2>,
        <http://example.org/recipes/sopa/1/step/3f42508a663f4891b6c2bacb2efda8f4>,
        <http://example.org/recipes/sopa/1/step/4538d01a0bca453797bfab831f7ad0a3>,
        <http://example.org/recipes/sopa/1/step/bbb4a978a8a24d83bf406ca105ddc8b0>,
        <http://example.org/recipes/sopa/1/step/d237a868fdd042bebabe5a69060d124c>,
        <http://example.org/recipes/sopa/1/step/f9b90f2257af412da6decd84b18f3f1c> ;
    schema1:recipeYield 6 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/sopa/10> a schema1:Recipe ;
    schema1:description "El caldo de bolas de verde es una sopa típica de la costa ecuatoriana que consiste de bolas o albóndigas de plátano verde rellenas con carne en un delicioso caldo con choclo y yuca. El caldo de bolas de verde también se puede encontrar en algunos restaurantes de la Sierra."@es ;
    schema1:name "Caldo de Bolas de Verde"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla blanca cortada en cubos"@es,
        "1 pimiento verde cortado en cubos"@es,
        "1 yuca pelada y cortada en trozos grandes"@es,
        "10 tazas de agua"@es,
        "2 cucharaditas de achiote molido"@es,
        "2 cucharaditas de ají en polvo"@es,
        "2 huevos"@es,
        "2 plátanos verdes pelados y rallados"@es,
        "2 zanahorias peladas"@es,
        "3 choclos pelados y cortados por la mitad"@es,
        "3 cucharaditas de comino molido"@es,
        "4 cucharadas de aceite"@es,
        "4 cucharadas de cilantro cortado"@es,
        "4 hojas de col cortada en trozos"@es,
        "4 plátanos verdes pelados y cortados por la mitad"@es,
        "4 tomates pelados y cortados en cubos"@es,
        "8 dientes de ajo machacados"@es,
        "Sal y pimienta al gusto"@es,
        "½ cebolla colorada finamente cortada"@es,
        "½ cucharada de orégano seco"@es,
        "½ kilo de carne de guiso cortado en trozos"@es,
        "½ kilo de huesos de res"@es,
        "½ pimiento rojo cortado en cubos"@es,
        "½ taza de arvejas cocidas"@es,
        "½ taza de maní tostado licuado con ¼ de taza de agua"@es ;
