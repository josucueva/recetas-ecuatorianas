<http://example.org/recipes/postre/37> a schema1:Recipe ;
    schema1:description "Los deliciosos quimbolitos, son pequeños bizcochos elaborados con una masa dulce de harina de maíz blanco, el toque salado de queso y unas riquísimas pasas. Este exquisito manjar se cocina al vapor en hojas de achira y pueden consumirse acompañadas de una deliciosa taza de café."@es ;
    schema1:name "Kimbolitos"@es ;
    schema1:recipeCategory "Postre"@es ;
    schema1:recipeIngredient "1 cucharada de esencia de vainilla"@es,
        "1 taza de azúcar"@es,
        "2 cucharadas de ron anisado"@es,
        "20 hojas de achira"@es,
        "200 gr de mantequilla sin sal"@es,
        "250 gr.	de harina de maíz blanco"@es,
        "250 gr.	manteca de chancho"@es,
        "500 gr de queso fresco rallado"@es,
        "9 huevos"@es,
        "½ cucharadita de ralladura de limón"@es,
        "½ tazas de pasas"@es ;
    schema1:recipeInstructions <http://example.org/recipes/postre/37/step/1c6e782258914bc7a3bab917c3060617>,
        <http://example.org/recipes/postre/37/step/1eaef12cae1d4939aab7b26887a40ef1>,
        <http://example.org/recipes/postre/37/step/407268d2249043b9955d206b6d4387ae>,
