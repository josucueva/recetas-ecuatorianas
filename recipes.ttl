    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/bebida/39> a schema1:Recipe ;
    schema1:description "El javishca es una bebida tradicional de San José de Minas, Ecuador. Es un jugo a base de zapallo maduro con leche, que se toma en la época de cosecha."@es ;
    schema1:name "Javishca"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro leche"@es,
        "2 tazas de panela rayada"@es,
        "2 tazas de zapallo tierno cortado en cubos"@es,
        "4 palitos de canela"@es,
        "5 unidades anís estrellado"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/39/step/4aefca7cb7dc4fb78145a7775749d09a>,
        <http://example.org/recipes/bebida/39/step/bf5754e688504537a88f6e538669a51e>,
