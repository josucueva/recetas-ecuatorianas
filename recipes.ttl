        <http://example.org/recipes/plato-principal/55/step/b0d93064bfb840e8be0763eeba677f23>,
        <http://example.org/recipes/plato-principal/55/step/d4fd874af6cd4add824edfee11143449> ;
    schema1:recipeYield 4 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/56> a schema1:Recipe ;
    schema1:description "La gallina cuyana es un plato típico lojano muy rico que surgió como una variante del cuy asado. Básicamente es un pollo asado condimentado con el marinado utilizado para el cuy, de allí sus sabores tan similares."@es ;
    schema1:name "Gallina cuyana"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cucharada de achiote en pasta"@es,
        "100 ml de cerveza"@es,
        "2 cucharadas de ajo en pasta"@es,
        "500 gr de cuy"@es,
        "500 gr de gallina cortada en cuartos"@es,
        "Comino"@es,
        "Pimienta"@es,
        "Sal"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/56/step/48ebb6ee801d48b187f74459db0cc10f>,
        <http://example.org/recipes/plato-principal/56/step/83759343664b41129140d8bb1c68dbda>,
        <http://example.org/recipes/plato-principal/56/step/bb5c322eadd64cb6bd20216428385b97> ;
    schema1:recipeYield 2 ;
    schema1:totalTime "PT2H"^^xsd:duration .

<http://example.org/recipes/plato-principal/57> a schema1:Recipe ;
    schema1:description "En la zona costera ecuatoriana la langosta es muy consumida debido a su exquisito sabor, en esta receta se prepara gratinada, una delicia."@es ;
    schema1:name "Gratinado de langosta"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 cebolla"@es,
        "1 cucharadita de páprika"@es,
        "1 cucharadita de tomillo"@es,
        "1 lata de leche condensada"@es,
        "1 taza de vino blanco"@es,
        "1 zanahoria amarilla troceada"@es,
        "100 ml de crema de leche"@es,
        "2 dientes de ajo"@es,
        "2 langostas"@es,
        "2 litros de agua"@es,
        "2 tallos de apio"@es,
        "2 yemas de huevo"@es,
        "25 gr de mantequilla"@es,
        "3 cucharadas de harina"@es,
        "Sal y pimienta a gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/57/step/4a00620faefa4e73bc754560f7d84739>,
