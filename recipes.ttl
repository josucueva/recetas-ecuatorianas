<http://example.org/recipes/plato-principal/14> a schema1:Recipe ;
    schema1:description "Los deliciosos camarones reventados, es un plato delicioso y tradicional en la cultura ecuatoriana. Los camarones con esa textura suave pero envueltos en una corteza crujiente, llenarán de ricos sabores su paladar. Anímate a preparar esta sencilla receta."@es ;
    schema1:name "Camarones reventados"@es ;
    schema1:recipeCategory "Plato Principal"@es ;
    schema1:recipeIngredient "1 ½ kg de camarón frescos y limpios"@es,
        "2 cucharadas de ajo molido"@es,
        "3 huevos batidos"@es,
        "300 gr de harina de trigo"@es,
        "45 ml de jugo de limón"@es,
        "Aceite para freír"@es,
        "Pimienta"@es,
        "Sal"@es ;
    schema1:recipeInstructions <http://example.org/recipes/plato-principal/14/step/13f2ba9e722b4517a6d289df61530522>,
