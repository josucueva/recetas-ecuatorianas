<http://example.org/recipes/bebida/61> a schema1:Recipe ;
    schema1:description "El rompope es una bebida ecuatoriana preparada con yemas de huevo, vainilla, canela, almendra molida, leche, azúcar y licor. Se sirve tradicionalmente en las festividades navideñas."@es ;
    schema1:name "Rompope"@es ;
    schema1:recipeCategory "Bebida"@es ;
