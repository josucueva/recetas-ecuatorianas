<http://example.org/recipes/sopa/40> a schema1:Recipe ;
    schema1:description "El locro es un plato clásico de Ecuador que consiste en una sopa cremosa hecha a base de papas y queso. Es típico de la Sierra ecuatoriana y especialmente popular en el norte del país y Quito, donde también se conoce como locro quiteño."@es ;
    schema1:name "Locro Ecuatoriano"@es ;
    schema1:recipeCategory "Sopa"@es ;
    schema1:recipeIngredient "1 cebolla cortada en cubos"@es,
        "1 o 2 cucharaditas de achiote molido"@es,
        "1 taza de leche"@es,
        "1 taza de queso rallado o desmenuzado"@es,
        "10 papas peladas y cortadas en trozos grandes"@es,
        "2 cucharadas de aceite o mantequilla"@es,
        "2 cucharaditas de comino"@es,
        "2 dientes de ajo cortados finamente"@es,
        "4 cucharadas de cilantro cortado finamente"@es,
        "7 tazas de agua"@es,
        "Sal al gusto"@es ;
    schema1:recipeInstructions <http://example.org/recipes/sopa/40/step/36f0805126ca4626a1b3d33e245f4bdd>,
