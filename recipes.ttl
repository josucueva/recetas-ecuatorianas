<http://example.org/recipes/plato-principal/116> a schema1:Recipe ;
    schema1:description "La tilapia es un pescado que se consume cada vez mas en Ecuador y se utiliza para diversas preparaciones, en este caso la tilapia apanada es fácil de preparar y deliciosa."@es ;
    schema1:name "Tilapia empanada"@es ;
