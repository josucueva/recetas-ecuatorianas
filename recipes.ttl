    schema1:recipeYield 4 ;
    schema1:totalTime "PT30M"^^xsd:duration .

<http://example.org/recipes/bebida/52> a schema1:Recipe ;
    schema1:description "La limonada es un refresco muy popular en Ecuador para atenuar el calor y la sed predominantes en distintas épocas del año. Esta receta es rápida y efectiva porque todos los ingredientes van a la licuadora."@es ;
    schema1:name "Limonada"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 taza de azúcar"@es,
        "2 limones cortados en cubos y sin semillas"@es,
        "8 tazas de agua fría"@es,
        "Hielo al gusto"@es,
        "Hojas de menta o hierba buena"@es,
        "Rodajas de limón"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/52/step/2ab0e4c9dbf54bf6acc5d4f79bd95028>,
        <http://example.org/recipes/bebida/52/step/2b0e7600a0804fca995560a30317e706>,
        <http://example.org/recipes/bebida/52/step/80d33641a1d04a6ca30d218ba1bf7849>,
        <http://example.org/recipes/bebida/52/step/cfa17617179542bab7a6786d0fe1d6af> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT15M"^^xsd:duration .

<http://example.org/recipes/bebida/53> a schema1:Recipe ;
    schema1:description "La limonada de mango es un delicioso refresco que se prepara con una de las frutas tropicales más populares en Ecuador, el mango, junto con limón, azúcar y agua."@es ;
    schema1:name "Limonada de Mango"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 taza de jugo de limón"@es,
        "3 mangos medianos cortados en trozos"@es,
        "4 tazas de agua fría"@es,
        "Hielo al gusto"@es,
        "Hojas de menta o hierba buena"@es,
        "Rodajas de limón"@es,
        "½ taza de azúcar o miel de abeja"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/53/step/bc95af733f8d4775a776defb6b0bec03>,
        <http://example.org/recipes/bebida/53/step/cc55ae6adfd3464cb2763a08b972607b>,
        <http://example.org/recipes/bebida/53/step/e1c3c00fe7be42b6a482fae8cba6053c> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT15M"^^xsd:duration .

<http://example.org/recipes/bebida/54> a schema1:Recipe ;
    schema1:description "El morocho es una bebida típica de Guayaquil de singular aroma y exquisito sabor que se ha popularizado en todo Ecuador. Se elabora con maíz morocho, leche, panela y canela y se suele servir con pan de yuca."@es ;
    schema1:name "Morocho"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "2 tazas granos de maíz morocho partido"@es,
        "4 palitos de canela"@es,
        "6 tazas de agua"@es,
        "8 tazas de leche"@es,
        "Canela molida"@es,
        "½ taza de azúcar o panela rallada"@es,
        "½ taza de pasas"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/54/step/a64c0bb7bdce4e32bf36d1d7132c455e>,
        <http://example.org/recipes/bebida/54/step/ad0f50fe0f3640b7a3f1eb9dfefd1cf6>,
        <http://example.org/recipes/bebida/54/step/d303384eee8444378381098a383edf13>,
        <http://example.org/recipes/bebida/54/step/de3faff6aa6b470da4f1601c03ae9a5d> ;
    schema1:recipeYield 5 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/bebida/55> a schema1:Recipe ;
    schema1:description "Esta es la bebida clásica por excelencia de Guayaquil, de sabor exquisito y elaborada con maíz morocho se ha vuelvo famosa en todo el país."@es ;
    schema1:name "Morocho de maiz"@es ;
    schema1:recipeCategory "Bebida"@es ;
    schema1:recipeIngredient "1 litro de agua"@es,
        "1 taza de azúcar morena"@es,
        "1 ½ litro de leche"@es,
        "2 tazas granos de maíz morocho partido"@es,
        "3 ramas de canela"@es,
        "8 tazas de leche"@es,
        "Canela molida para decorar"@es ;
    schema1:recipeInstructions <http://example.org/recipes/bebida/55/step/25f4d678acf14282a54ac9a1f0d36b9f>,
        <http://example.org/recipes/bebida/55/step/ab04e2878c3b40d08366dffe4a71d8c5>,
