    schema1:recipeYield 8 ;
    schema1:totalTime "PT1H"^^xsd:duration .

<http://example.org/recipes/entrada/74> a schema1:Recipe ;
    schema1:description "Los patacones, también llamados tostones o plátanos verdes fritos son uno de los alimentos estrella en la cocina ecuatoriana. Son fáciles de hacer y se preparan con uno de los principales productos autóctonos del Ecuador, el plátano. Se ideales como entrada o acompañamiento de diferentes platos."@es ;
    schema1:name "Patacones"@es ;
    schema1:recipeCategory "Entrada"@es ;
    schema1:recipeIngredient "4 plátanos verdes"@es,
